<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Admin | ATLAS Career Platform</title>
  <link href="/css/output.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    :root { --primary: 228 100% 11%; --accent: 80 89% 40%; --background: 0 0% 100%; }
    .dark { --background: 228 100% 5%; }
    body { font-family: 'Inter', sans-serif; }
  </style>
  <script>
    if (localStorage.getItem('theme') === 'dark') document.documentElement.classList.add('dark');
  </script>
</head>
<body class="bg-gray-50 dark:bg-gray-950 text-gray-900 dark:text-gray-100 min-h-screen">
  <div class="flex min-h-screen">
    <%- include('../partials/admin-sidebar') %>
    <div class="flex-1 w-full min-w-0 admin-content" style="margin-left:0;transition:margin-left 0.3s ease">
      <%- include('../partials/admin-nav') %>
      <%- include('../partials/flash') %>
      <main class="p-3 sm:p-4 lg:p-6">
        <%- body %>
      </main>
    </div>
  </div>
  <script src="/js/main.js"></script>
</body>
</html>

<div class="space-y-6">
  <h1 class="text-2xl font-bold">Skill Gap Analyzer</h1>
  <p class="text-gray-500">Identify missing skills and get a personalized learning roadmap</p>

  <div class="grid lg:grid-cols-2 gap-6">
    <div class="card">
      <h3 class="font-semibold mb-4"><i class="fas fa-search mr-2"></i>Analyze Your Skills</h3>
      <div class="space-y-4">
        <div>
          <label class="label-field">Your Resume / Current Skills</label>

          <!-- Source selection tabs -->
          <div class="flex gap-2 mb-3">
            <button type="button" onclick="switchInputMode('paste')" id="tab-paste" class="px-3 py-1.5 text-xs font-medium rounded-lg bg-blue-600 text-white transition-colors">
              <i class="fas fa-keyboard mr-1"></i>Paste Text
            </button>
            <button type="button" onclick="switchInputMode('upload')" id="tab-upload" class="px-3 py-1.5 text-xs font-medium rounded-lg bg-gray-200 dark:bg-gray-700 text-gray-600 dark:text-gray-300 transition-colors">
              <i class="fas fa-upload mr-1"></i>Upload Resume
            </button>
            <% if (resumes && resumes.length > 0) { %>
            <button type="button" onclick="switchInputMode('select')" id="tab-select" class="px-3 py-1.5 text-xs font-medium rounded-lg bg-gray-200 dark:bg-gray-700 text-gray-600 dark:text-gray-300 transition-colors">
              <i class="fas fa-file-alt mr-1"></i>My Resumes
            </button>
            <% } %>
          </div>

          <!-- Mode 1: Paste text (default) -->
          <div id="mode-paste">
            <textarea id="sk-resume" rows="6" class="input-field" placeholder="Paste your resume or list your current skills..."></textarea>
          </div>

          <!-- Mode 2: Upload file -->
          <div id="mode-upload" class="hidden">
            <div id="upload-dropzone" class="border-2 border-dashed border-gray-300 dark:border-gray-600 rounded-lg p-6 text-center cursor-pointer hover:border-blue-400 dark:hover:border-blue-500 transition-colors">
              <input type="file" id="sk-file" accept=".pdf,.doc,.docx" class="hidden">
              <i class="fas fa-cloud-upload-alt text-3xl text-gray-400 mb-2"></i>
              <p class="text-sm text-gray-500">Click or drag & drop your resume here</p>
              <p class="text-xs text-gray-400 mt-1">PDF, DOC, DOCX (max 10MB)</p>
            </div>
            <div id="upload-status" class="hidden mt-3 p-3 bg-gray-50 dark:bg-gray-800 rounded-lg">
              <div class="flex items-center gap-2">
                <i id="upload-icon" class="fas fa-spinner fa-spin text-blue-500"></i>
                <span id="upload-filename" class="text-sm font-medium truncate"></span>
              </div>
              <p id="upload-msg" class="text-xs text-gray-500 mt-1"></p>
            </div>
          </div>

          <!-- Mode 3: Select saved resume -->
          <% if (resumes && resumes.length > 0) { %>
          <div id="mode-select" class="hidden">
            <div class="space-y-2 max-h-64 overflow-y-auto">
              <% resumes.forEach(r => { %>
                <label class="flex items-center gap-3 p-3 bg-gray-50 dark:bg-gray-800 rounded-lg cursor-pointer hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                  <input type="radio" name="saved-resume" value="<%= r.id %>" class="text-blue-600">
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium truncate"><%= r.title || 'Untitled Resume' %></p>
                    <div class="flex items-center gap-2 text-xs text-gray-500">
                      <% if (r.is_primary) { %><span class="text-blue-600 font-medium">Primary</span><% } %>
                      <% if (r.ats_score) { %><span>ATS: <%= r.ats_score %>%</span><% } %>
                      <span><%= new Date(r.updated_at || r.created_at).toLocaleDateString() %></span>
                    </div>
                  </div>
                  <i class="fas fa-chevron-right text-gray-400"></i>
                </label>
              <% }); %>
            </div>
          </div>
          <% } %>
        </div>
        <div>
          <label class="label-field">Target Job Role</label>
          <input type="text" id="sk-role" class="input-field" placeholder="e.g., Full Stack Developer, Data Scientist">
        </div>
        <button onclick="analyzeSkills()" id="sk-btn" class="btn-primary w-full"><i class="fas fa-chart-line mr-2"></i>Analyze Skills</button>
      </div>
    </div>

    <div class="card">
      <h3 class="font-semibold mb-4"><i class="fas fa-chart-pie mr-2"></i>Analysis Results</h3>
      <div id="sk-results" class="text-center py-12 text-gray-400">
        <i class="fas fa-chart-line text-5xl mb-4"></i>
        <p>Enter your skills and target role to see the analysis</p>
      </div>
    </div>
  </div>

  <!-- History -->
  <% if (analyses.length > 0) { %>
    <div class="card">
      <h3 class="font-semibold mb-4"><i class="fas fa-history mr-2"></i>Previous Analyses</h3>
      <div class="space-y-4">
        <% analyses.forEach(a => { %>
          <% const missing = typeof a.missing_skills === 'string' ? JSON.parse(a.missing_skills) : (a.missing_skills || []); %>
          <% const roadmap = typeof a.learning_roadmap === 'string' ? JSON.parse(a.learning_roadmap) : (a.learning_roadmap || []); %>
          <% const courses = typeof a.recommended_courses === 'string' ? JSON.parse(a.recommended_courses) : (a.recommended_courses || []); %>
          <div class="p-4 bg-gray-50 dark:bg-gray-800 rounded-lg">
            <div class="flex items-center justify-between mb-3">
              <div>
                <h4 class="font-medium"><%= a.target_role %></h4>
                <p class="text-xs text-gray-500"><%= new Date(a.created_at).toLocaleDateString() %></p>
              </div>
              <div class="text-right">
                <span class="text-2xl font-bold <%= a.match_percentage >= 70 ? 'text-green-600' : a.match_percentage >= 40 ? 'text-yellow-600' : 'text-red-600' %>"><%= a.match_percentage %>%</span>
                <p class="text-xs text-gray-500">Match</p>
              </div>
            </div>
            <% if (missing.length > 0) { %>
              <div class="mb-2"><span class="text-xs font-medium text-red-600">Missing Skills:</span>
                <div class="flex flex-wrap gap-1 mt-1"><% missing.forEach(s => { %><span class="badge-danger"><%= s %></span><% }); %></div>
              </div>
            <% } %>
            <% if (roadmap.length > 0) { %>
              <div><span class="text-xs font-medium text-blue-600">Learning Roadmap:</span>
                <div class="mt-1 space-y-1">
                  <% roadmap.slice(0, 3).forEach(r => { %>
                    <div class="flex items-center gap-2 text-xs">
                      <span class="<%= r.priority === 'high' ? 'badge-danger' : r.priority === 'medium' ? 'badge-warning' : 'badge-info' %>"><%= r.priority %></span>
                      <span><%= r.skill %></span>
                      <span class="text-gray-400"><%= r.timeEstimate %></span>
                    </div>
                  <% }); %>
                </div>
              </div>
            <% } %>
          </div>
        <% }); %>
      </div>
    </div>
  <% } %>
</div>

<script>
let currentMode = 'paste';
let uploadedText = '';

function switchInputMode(mode) {
  currentMode = mode;
  // Update tab styles
  ['paste', 'upload', 'select'].forEach(m => {
    const tab = document.getElementById('tab-' + m);
    const panel = document.getElementById('mode-' + m);
    if (!tab || !panel) return;
    if (m === mode) {
      tab.className = 'px-3 py-1.5 text-xs font-medium rounded-lg bg-blue-600 text-white transition-colors';
      panel.classList.remove('hidden');
    } else {
      tab.className = 'px-3 py-1.5 text-xs font-medium rounded-lg bg-gray-200 dark:bg-gray-700 text-gray-600 dark:text-gray-300 transition-colors';
      panel.classList.add('hidden');
    }
  });
}

// File upload handling
const dropzone = document.getElementById('upload-dropzone');
const fileInput = document.getElementById('sk-file');

if (dropzone) {
  dropzone.addEventListener('click', () => fileInput.click());
  dropzone.addEventListener('dragover', (e) => { e.preventDefault(); dropzone.classList.add('border-blue-400'); });
  dropzone.addEventListener('dragleave', () => dropzone.classList.remove('border-blue-400'));
  dropzone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropzone.classList.remove('border-blue-400');
    if (e.dataTransfer.files.length) handleFileUpload(e.dataTransfer.files[0]);
  });
  fileInput.addEventListener('change', () => { if (fileInput.files.length) handleFileUpload(fileInput.files[0]); });
}

async function handleFileUpload(file) {
  const statusEl = document.getElementById('upload-status');
  const iconEl = document.getElementById('upload-icon');
  const filenameEl = document.getElementById('upload-filename');
  const msgEl = document.getElementById('upload-msg');

  statusEl.classList.remove('hidden');
  iconEl.className = 'fas fa-spinner fa-spin text-blue-500';
  filenameEl.textContent = file.name;
  msgEl.textContent = 'Parsing resume...';
  uploadedText = '';

  const formData = new FormData();
  formData.append('resume', file);

  try {
    const res = await fetch('/skills/upload-parse', { method: 'POST', body: formData });
    const result = await res.json();
    if (result.success && result.text) {
      uploadedText = result.text;
      iconEl.className = 'fas fa-check-circle text-green-500';
      msgEl.textContent = 'Resume parsed successfully. Ready to analyze!';
    } else {
      throw new Error(result.error || 'Parse failed');
    }
  } catch (err) {
    iconEl.className = 'fas fa-exclamation-circle text-red-500';
    msgEl.textContent = err.message || 'Failed to parse resume';
  }
}

async function getResumeText() {
  if (currentMode === 'paste') {
    return document.getElementById('sk-resume').value;
  }
  if (currentMode === 'upload') {
    return uploadedText;
  }
  if (currentMode === 'select') {
    const selected = document.querySelector('input[name="saved-resume"]:checked');
    if (!selected) return '';
    try {
      const res = await fetch('/skills/resume-text/' + selected.value);
      const result = await res.json();
      return result.success ? result.text : '';
    } catch { return ''; }
  }
  return '';
}

async function analyzeSkills() {
  const btn = document.getElementById('sk-btn');
  const resumeText = await getResumeText();
  const targetRole = document.getElementById('sk-role').value;

  if (!resumeText || !targetRole) return showToast('Please provide your resume/skills and a target role', 'error');

  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Analyzing...';

  try {
    const res = await fetch('/skills/analyze', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ resumeText, targetRole }),
    });
    const result = await res.json();
    if (result.success) location.reload();
  } catch (err) { showToast('Analysis failed', 'error'); }
  btn.disabled = false;
  btn.innerHTML = '<i class="fas fa-chart-line mr-2"></i>Analyze Skills';
}
</script>

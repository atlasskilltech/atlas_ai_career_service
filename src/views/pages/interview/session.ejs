<style>
  /* Responsive interview layout */
  @media (max-width: 639px) {
    #interview-app .btn-bar { flex-wrap: wrap; }
    #interview-app .btn-bar > button { min-width: calc(50% - 0.25rem); }
    #interview-app .transcript-answer-grid { grid-template-columns: 1fr !important; }
  }
  @media (min-width: 640px) and (max-width: 1023px) {
    #interview-app .btn-bar > button { font-size: 0.7rem; padding: 0.5rem 0.75rem; }
  }
</style>

<div class="space-y-2 sm:space-y-3" id="interview-app">
  <!-- Header -->
  <div class="flex items-center justify-between flex-wrap gap-2">
    <div class="min-w-0">
      <h1 class="text-base sm:text-lg font-bold capitalize truncate"><%= interview.interview_type.replace('_', ' ') %> Interview</h1>
      <p class="text-[10px] sm:text-xs text-gray-500 truncate"><%= interview.job_role %><%= interview.company ? ' at ' + interview.company : '' %> | <%= interview.difficulty %></p>
    </div>
    <div class="flex items-center gap-2 sm:gap-3 flex-shrink-0">
      <span class="text-xs sm:text-sm font-mono bg-gray-100 dark:bg-gray-800 px-2 sm:px-3 py-1 rounded-lg" id="timer">00:00</span>
      <div class="flex items-center gap-1 sm:gap-1.5 px-2 py-1 rounded-full text-[10px] sm:text-xs font-medium" id="connection-badge">
        <span class="w-1.5 sm:w-2 h-1.5 sm:h-2 rounded-full bg-yellow-400 animate-pulse" id="conn-dot"></span>
        <span id="conn-text">Connecting</span>
      </div>
    </div>
  </div>

  <!-- Progress -->
  <div class="flex items-center gap-2">
    <div class="flex-1 h-1.5 sm:h-2 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden">
      <div class="h-full bg-gradient-to-r from-blue-500 to-purple-500 transition-all duration-500 rounded-full" id="progress-bar" style="width: <%= progress.total > 0 ? Math.round((progress.answered / progress.total) * 100) : 0 %>%"></div>
    </div>
    <span class="text-[10px] sm:text-xs text-gray-500 whitespace-nowrap" id="progress-text"><%= progress.answered %>/<%= progress.total %></span>
  </div>

  <!-- Main Layout: stacked on mobile, 2 columns on lg+ -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-2 sm:gap-3">

    <!-- LEFT: Big Video Camera -->
    <div class="space-y-2">
      <div class="card p-0 overflow-hidden">
        <div class="relative bg-gray-900 rounded-lg overflow-hidden" style="min-height: 220px;">
          <!-- Aspect ratio container for video -->
          <div class="w-full" style="padding-bottom: 65%; position: relative;">
            <video id="camera-feed" autoplay muted playsinline class="absolute inset-0 w-full h-full object-cover"></video>
          </div>
          <!-- Live badge -->
          <div class="absolute top-2 sm:top-3 left-2 sm:left-3 flex items-center gap-1 sm:gap-1.5 bg-black/60 backdrop-blur-sm text-white text-[10px] sm:text-xs px-2 sm:px-2.5 py-0.5 sm:py-1 rounded-full z-10">
            <span class="w-1.5 sm:w-2 h-1.5 sm:h-2 rounded-full bg-red-500 animate-pulse"></span> YOU
          </div>
          <!-- Auto-record badge -->
          <div class="absolute top-2 sm:top-3 right-2 sm:right-3 flex items-center gap-1 sm:gap-1.5 bg-black/60 backdrop-blur-sm text-white text-[10px] sm:text-xs px-2 sm:px-2.5 py-0.5 sm:py-1 rounded-full z-10" id="rec-badge">
            <span class="w-1.5 sm:w-2 h-1.5 sm:h-2 rounded-full bg-gray-400" id="rec-dot"></span>
            <span id="rec-label">Mic Off</span>
            <span class="font-mono text-[9px] sm:text-[10px] text-gray-300" id="rec-time"></span>
          </div>
          <!-- Mic level bars -->
          <div class="absolute bottom-10 sm:bottom-12 right-2 sm:right-3 flex items-end gap-0.5 h-4 sm:h-5 z-10" id="mic-levels">
            <span class="w-0.5 sm:w-1 bg-green-400 rounded-full transition-all" style="height:3px"></span>
            <span class="w-0.5 sm:w-1 bg-green-400 rounded-full transition-all" style="height:3px"></span>
            <span class="w-0.5 sm:w-1 bg-green-400 rounded-full transition-all" style="height:3px"></span>
            <span class="w-0.5 sm:w-1 bg-green-400 rounded-full transition-all" style="height:3px"></span>
            <span class="w-0.5 sm:w-1 bg-green-400 rounded-full transition-all" style="height:3px"></span>
          </div>
          <!-- Live transcription overlay at bottom -->
          <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 to-transparent p-2 sm:p-3 pt-6 sm:pt-8 z-10">
            <div class="text-white text-xs sm:text-sm leading-relaxed" id="live-caption">
              <span class="text-gray-400 italic text-[10px] sm:text-xs">Live captions will appear here...</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- RIGHT: Avatar + Question + Answer + Transcript -->
    <div class="flex flex-col gap-2">
      <!-- AI Interviewer Header with Avatar -->
      <div class="card p-2 sm:p-3">
        <div class="flex items-center gap-2 sm:gap-3">
          <!-- Professional Avatar Circle -->
          <div class="relative flex-shrink-0">
            <div class="w-10 h-10 sm:w-14 sm:h-14 rounded-full overflow-hidden" id="avatar-container">
              <svg viewBox="0 0 100 100" class="w-full h-full" id="avatar-svg">
                <defs>
                  <linearGradient id="avatarBg" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" style="stop-color:#1e3a5f"/>
                    <stop offset="100%" style="stop-color:#0d1b2a"/>
                  </linearGradient>
                  <linearGradient id="skinGrad" x1="0%" y1="0%" x2="0%" y2="100%">
                    <stop offset="0%" style="stop-color:#e8c4a0"/>
                    <stop offset="100%" style="stop-color:#d4a574"/>
                  </linearGradient>
                  <linearGradient id="suitGrad" x1="0%" y1="0%" x2="0%" y2="100%">
                    <stop offset="0%" style="stop-color:#1a1a2e"/>
                    <stop offset="100%" style="stop-color:#16213e"/>
                  </linearGradient>
                </defs>
                <circle cx="50" cy="50" r="50" fill="url(#avatarBg)"/>
                <path d="M15 95 Q20 70 50 65 Q80 70 85 95" fill="url(#suitGrad)"/>
                <path d="M40 67 L50 75 L60 67" fill="#e2e8f0" stroke="none"/>
                <path d="M47 68 L50 73 L53 68 L51 85 L50 87 L49 85 Z" fill="#3b82f6"/>
                <rect x="44" y="56" width="12" height="12" rx="2" fill="url(#skinGrad)"/>
                <ellipse cx="50" cy="42" rx="22" ry="26" fill="url(#skinGrad)"/>
                <path d="M28 38 Q28 16 50 14 Q72 16 72 38 Q72 22 50 18 Q28 22 28 38" fill="#1a1a2e"/>
                <ellipse cx="50" cy="20" rx="20" ry="8" fill="#1a1a2e"/>
                <ellipse cx="40" cy="40" rx="4" ry="2.5" fill="white"/>
                <ellipse cx="60" cy="40" rx="4" ry="2.5" fill="white"/>
                <circle cx="40" cy="40" r="2" fill="#2d1b0e"/>
                <circle cx="60" cy="40" r="2" fill="#2d1b0e"/>
                <circle cx="40" cy="40" r="1" fill="#111"/>
                <circle cx="60" cy="40" r="1" fill="#111"/>
                <path d="M35 35 Q40 32 45 34" stroke="#2d2d3e" stroke-width="1.5" fill="none" stroke-linecap="round"/>
                <path d="M55 34 Q60 32 65 35" stroke="#2d2d3e" stroke-width="1.5" fill="none" stroke-linecap="round"/>
                <path d="M49 43 Q47 49 48 50" stroke="#c49464" stroke-width="0.8" fill="none"/>
                <path d="M43 54 Q50 58 57 54" stroke="#c27a6a" stroke-width="1.5" fill="none" stroke-linecap="round" id="avatar-mouth"/>
                <ellipse cx="28" cy="42" rx="3" ry="5" fill="#d4a574"/>
                <ellipse cx="72" cy="42" rx="3" ry="5" fill="#d4a574"/>
              </svg>
            </div>
            <div class="absolute -bottom-0.5 -right-0.5 w-3 h-3 sm:w-4 sm:h-4 rounded-full border-2 border-white dark:border-gray-800" id="avatar-status-dot" style="background:#9ca3af;"></div>
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-1.5 sm:gap-2 flex-wrap">
              <span class="font-semibold text-xs sm:text-sm">AI Interviewer</span>
              <span class="px-1.5 sm:px-2 py-0.5 rounded-full text-[9px] sm:text-[10px] font-medium bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 whitespace-nowrap" id="avatar-state-badge">
                <i class="fas fa-circle-notch fa-spin mr-0.5 sm:mr-1"></i>Connecting
              </span>
            </div>
            <p class="text-[10px] sm:text-xs text-gray-400 mt-0.5 hidden sm:block">Professional AI Interviewer</p>
          </div>
          <button onclick="replayQuestion()" class="text-[10px] sm:text-xs text-gray-400 hover:text-blue-500 px-1.5 sm:px-2 py-1 rounded-lg hover:bg-blue-50 dark:hover:bg-blue-900/20 transition flex-shrink-0">
            <i class="fas fa-volume-high sm:mr-1"></i><span class="hidden sm:inline">Replay</span>
          </button>
        </div>
      </div>

      <!-- Question Card -->
      <div class="card py-2 sm:py-3 px-3 sm:px-4" id="question-card">
        <div class="flex items-center gap-1.5 sm:gap-2 mb-1 sm:mb-1.5">
          <span class="w-5 h-5 sm:w-6 sm:h-6 bg-gradient-to-br from-blue-500 to-purple-500 text-white rounded-full flex items-center justify-center text-[9px] sm:text-[10px] font-bold" id="q-number"><%= currentQuestion ? currentQuestion.question_order : '-' %></span>
          <span class="text-[9px] sm:text-[10px] text-gray-500 uppercase tracking-wider font-semibold" id="q-type"><%= currentQuestion && currentQuestion.is_follow_up ? 'Follow-up' : 'Question' %></span>
        </div>
        <p class="text-xs sm:text-sm font-medium leading-relaxed" id="q-text"><%= currentQuestion ? currentQuestion.question : 'Interview complete!' %></p>
      </div>

      <!-- Answer + Live Transcript Side by Side (stacked on mobile) -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 flex-1 transcript-answer-grid">
        <!-- Transcript Panel -->
        <div class="card py-2 px-2 sm:px-3" style="min-height:120px; max-height:180px;">
          <div class="flex items-center justify-between mb-1 sm:mb-1.5">
            <span class="text-[9px] sm:text-[10px] font-semibold text-gray-400 uppercase tracking-wider">Transcript</span>
            <span class="text-[9px] sm:text-[10px] text-gray-400" id="transcribe-status"></span>
          </div>
          <div class="overflow-y-auto space-y-1 sm:space-y-1.5 pr-1" id="transcript-area" style="max-height:130px;">
            <div class="text-[10px] text-gray-400 italic text-center py-3 sm:py-4" id="transcript-placeholder">Conversation will appear here as you speak...</div>
          </div>
        </div>

        <!-- Answer Panel -->
        <div class="card py-2 px-2 sm:px-3" style="min-height:120px; max-height:180px;">
          <div class="flex items-center justify-between mb-1 sm:mb-1.5">
            <span class="text-[9px] sm:text-[10px] font-semibold text-gray-400 uppercase tracking-wider">Your Answer</span>
            <span class="text-[9px] sm:text-[10px] text-gray-400"><span id="word-count">0</span> words | <span id="answer-time">0</span>s</span>
          </div>
          <textarea id="answer-text" class="w-full border-0 bg-transparent text-xs sm:text-sm resize-none focus:ring-0 focus:outline-none p-0" rows="4" placeholder="Auto-transcribed from your speech or type here..."></textarea>
        </div>
      </div>

      <!-- Action Buttons - responsive wrap -->
      <div class="flex items-center gap-1.5 sm:gap-2 flex-wrap btn-bar" id="controls-bar">
        <button onclick="submitAndNext()" id="submit-btn" class="flex-1 min-w-[120px] py-2 sm:py-2.5 bg-gradient-to-r from-blue-500 to-purple-600 text-white rounded-lg font-medium text-xs sm:text-sm hover:shadow-lg transition flex items-center justify-center gap-1 sm:gap-1.5">
          <i class="fas fa-paper-plane text-[10px] sm:text-xs"></i> Submit & Next
        </button>
        <button onclick="skipQuestion()" id="skip-btn" class="py-2 sm:py-2.5 px-2.5 sm:px-4 rounded-lg border-2 border-gray-300 dark:border-gray-600 text-[10px] sm:text-xs font-medium text-gray-500 hover:border-orange-400 hover:text-orange-500 transition flex items-center gap-1 sm:gap-1.5">
          <i class="fas fa-forward"></i> <span class="hidden xs:inline">Skip</span><span class="xs:hidden">Skip</span>
        </button>
        <button onclick="saveProgress()" id="save-btn" class="py-2 sm:py-2.5 px-2.5 sm:px-4 rounded-lg border-2 border-green-300 dark:border-green-700 text-[10px] sm:text-xs font-medium text-green-600 dark:text-green-400 hover:bg-green-50 dark:hover:bg-green-900/20 transition flex items-center gap-1 sm:gap-1.5">
          <i class="fas fa-save"></i> Save
        </button>
        <button onclick="endInterview()" id="end-btn" class="py-2 sm:py-2.5 px-2.5 sm:px-4 rounded-lg border-2 border-red-300 dark:border-red-700 text-[10px] sm:text-xs font-medium text-red-500 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 transition flex items-center gap-1 sm:gap-1.5">
          <i class="fas fa-sign-out-alt"></i> End
        </button>
      </div>

      <div class="flex items-center justify-between text-[9px] sm:text-[10px] text-gray-400 px-1">
        <span><span id="answered-count"><%= progress.answered %></span> of <%= progress.total %> answered</span>
        <span id="save-status"></span>
      </div>

      <!-- Complete Section -->
      <div id="complete-section" class="hidden">
        <div class="card text-center py-4 sm:py-6 bg-gradient-to-br from-green-50 to-blue-50 dark:from-green-900/20 dark:to-blue-900/20">
          <i class="fas fa-check-circle text-3xl sm:text-4xl text-green-500 mb-2"></i>
          <h3 class="text-base sm:text-lg font-bold">Interview Complete!</h3>
          <p class="text-xs sm:text-sm text-gray-500 mb-3 sm:mb-4">Generating your AI feedback report...</p>
          <button onclick="viewReport()" id="report-btn" class="px-6 sm:px-8 py-2 sm:py-2.5 bg-gradient-to-r from-blue-500 to-purple-500 text-white rounded-lg text-xs sm:text-sm font-medium hover:shadow-lg transition">
            <i class="fas fa-chart-bar mr-1"></i> View Report
          </button>
        </div>
      </div>
    </div>
  </div>

  <audio id="ai-audio" class="hidden"></audio>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
const interviewId = '<%= interview.id %>';
const userId = '<%= typeof user !== "undefined" && user ? user.id : "" %>';
let currentQuestionId = <%= currentQuestion ? currentQuestion.id : 'null' %>;
let mediaStream = null;
let mediaRecorder = null;
let audioChunks = [];
let recordedBlob = null;
let isRecording = false;
let recTimer = null;
let answerStartTime = Date.now();
let interviewStartTime = Date.now();
let interviewTimer = null;
let audioContext = null;
let analyser = null;
let autoRecordEnabled = true;

// ===================== SOCKET.IO =====================
const socket = io('/interview', { transports: ['websocket', 'polling'] });

socket.on('connect', () => { socket.emit('join', { interviewId }); setConnectionStatus('connected'); });
socket.on('disconnect', () => setConnectionStatus('disconnected'));
socket.on('connect_error', () => setConnectionStatus('error'));
socket.on('joined', () => { if (currentQuestionId) speakQuestion(currentQuestionId); });
socket.on('avatar-state', (d) => setAvatarState(d.state));
socket.on('question-audio-ready', (d) => playQuestionAudio(d.audioUrl));
socket.on('speak-error', () => { setAvatarState('idle'); });

socket.on('transcribe-result', (data) => {
  if (data.success && data.text) {
    const ta = document.getElementById('answer-text');
    const existing = ta.value.trim();
    ta.value = existing ? existing + ' ' + data.text : data.text;
    ta.dispatchEvent(new Event('input'));
    addTranscriptBubble('you', data.text);
    updateLiveCaption(data.text);
    document.getElementById('transcribe-status').textContent = '';
  } else {
    document.getElementById('transcribe-status').textContent = 'Failed';
    showToast(data.error || 'Transcription failed', 'error');
  }
});

socket.on('next-question', (d) => loadQuestion(d.question, d.progress));
socket.on('interview-complete', () => showComplete());
socket.on('answer-error', (d) => {
  showToast(d.error || 'Failed to save', 'error');
  const btn = document.getElementById('submit-btn');
  btn.disabled = false;
  btn.innerHTML = '<i class="fas fa-paper-plane text-[10px] sm:text-xs"></i> Submit & Next';
});
socket.on('interview-ended', (d) => {
  if (d.success) window.location.href = '/interview/' + interviewId + '/report';
  else { showToast(d.error || 'Failed', 'error'); document.getElementById('end-btn').disabled = false; }
});

// ===================== CONNECTION =====================
function setConnectionStatus(s) {
  const dot = document.getElementById('conn-dot'), text = document.getElementById('conn-text'), badge = document.getElementById('connection-badge');
  if (s === 'connected') {
    dot.className = 'w-1.5 sm:w-2 h-1.5 sm:h-2 rounded-full bg-green-400';
    text.textContent = 'Live';
    badge.className = 'flex items-center gap-1 sm:gap-1.5 px-2 py-1 rounded-full text-[10px] sm:text-xs font-medium bg-green-50 dark:bg-green-900/30 text-green-600 dark:text-green-400';
  } else {
    dot.className = 'w-1.5 sm:w-2 h-1.5 sm:h-2 rounded-full bg-red-400 animate-pulse';
    text.textContent = 'Reconnecting';
    badge.className = 'flex items-center gap-1 sm:gap-1.5 px-2 py-1 rounded-full text-[10px] sm:text-xs font-medium bg-red-50 dark:bg-red-900/30 text-red-600';
  }
}

// ===================== AVATAR STATE =====================
function setAvatarState(state) {
  const stateMap = {
    idle: ['Ready', 'fa-circle-check', '#9ca3af'],
    thinking: ['Thinking...', 'fa-brain', '#f59e0b'],
    speaking: ['Speaking', 'fa-volume-high', '#22c55e'],
    listening: ['Listening', 'fa-ear-listen', '#3b82f6']
  };
  const [label, icon, color] = stateMap[state] || stateMap.idle;
  document.getElementById('avatar-state-badge').innerHTML = '<i class="fas ' + icon + ' mr-0.5 sm:mr-1"></i>' + label;
  document.getElementById('avatar-status-dot').style.background = color;

  const mouth = document.getElementById('avatar-mouth');
  if (mouth) {
    if (state === 'speaking') {
      mouth.setAttribute('d', 'M43 53 Q50 60 57 53');
      mouth.style.transition = 'all 0.2s';
    } else {
      mouth.setAttribute('d', 'M43 54 Q50 58 57 54');
    }
  }

  // Auto-start recording when avatar finishes speaking
  if (state === 'listening' && autoRecordEnabled && !isRecording) {
    setTimeout(() => { if (!isRecording) startRecording(); }, 500);
  }
}

// ===================== TTS =====================
function playQuestionAudio(url) {
  if (isRecording) stopRecording(true);
  const audio = document.getElementById('ai-audio');
  audio.src = url;
  audio.onended = () => { setAvatarState('listening'); socket.emit('speak-done'); };
  audio.onerror = () => setAvatarState('idle');
  audio.play().catch(() => setAvatarState('idle'));
}
function speakQuestion(qId) { socket.emit('speak-question', { questionId: qId }); }
function replayQuestion() { if (currentQuestionId) speakQuestion(currentQuestionId); }

// ===================== CAMERA =====================
async function initMedia() {
  try {
    mediaStream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user' }, audio: true });
    document.getElementById('camera-feed').srcObject = mediaStream;
    try {
      audioContext = new (window.AudioContext || window.webkitAudioContext)();
      const src = audioContext.createMediaStreamSource(mediaStream);
      analyser = audioContext.createAnalyser();
      analyser.fftSize = 32;
      src.connect(analyser);
      updateMicLevels();
    } catch (e) {}
  } catch (e) {
    showToast('Camera/mic access required: ' + e.message, 'error');
  }
}

function updateMicLevels() {
  if (!analyser) return;
  const d = new Uint8Array(analyser.frequencyBinCount);
  analyser.getByteFrequencyData(d);
  const bars = document.getElementById('mic-levels').children;
  for (let i = 0; i < bars.length; i++) {
    bars[i].style.height = Math.max(3, (d[i * 2] || 0) / 6) + 'px';
  }
  requestAnimationFrame(updateMicLevels);
}

// ===================== RECORDING (Auto-start) =====================
function startRecording() {
  if (!mediaStream) { showToast('No microphone access', 'error'); return; }
  audioChunks = [];
  recordedBlob = null;
  const audioStream = new MediaStream(mediaStream.getAudioTracks());
  mediaRecorder = new MediaRecorder(audioStream, { mimeType: 'audio/webm;codecs=opus' });
  mediaRecorder.ondataavailable = (e) => { if (e.data.size > 0) audioChunks.push(e.data); };
  mediaRecorder.onstop = () => { recordedBlob = new Blob(audioChunks, { type: 'audio/webm' }); autoTranscribe(); };
  mediaRecorder.start(1000);
  isRecording = true;
  answerStartTime = Date.now();

  document.getElementById('rec-dot').className = 'w-1.5 sm:w-2 h-1.5 sm:h-2 rounded-full bg-red-500 animate-pulse';
  document.getElementById('rec-label').textContent = 'Recording';
  document.getElementById('rec-badge').classList.add('bg-red-600/60');
  document.getElementById('rec-badge').classList.remove('bg-black/60');

  recTimer = setInterval(() => {
    const s = Math.floor((Date.now() - answerStartTime) / 1000);
    document.getElementById('rec-time').textContent = Math.floor(s / 60) + ':' + (s % 60).toString().padStart(2, '0');
    document.getElementById('answer-time').textContent = s;
  }, 1000);
}

function stopRecording(silent) {
  if (mediaRecorder && mediaRecorder.state !== 'inactive') mediaRecorder.stop();
  isRecording = false;
  clearInterval(recTimer);

  document.getElementById('rec-dot').className = 'w-1.5 sm:w-2 h-1.5 sm:h-2 rounded-full bg-gray-400';
  document.getElementById('rec-label').textContent = 'Mic Off';
  document.getElementById('rec-badge').classList.remove('bg-red-600/60');
  document.getElementById('rec-badge').classList.add('bg-black/60');

  if (!silent) { updateLiveCaption('Processing your speech...'); }
}

// ===================== TRANSCRIBE =====================
function autoTranscribe() {
  if (!recordedBlob) return;
  document.getElementById('transcribe-status').textContent = 'Transcribing...';
  updateLiveCaption('Transcribing...');
  const r = new FileReader();
  r.onloadend = () => { socket.emit('transcribe', { audio: r.result }); };
  r.readAsArrayBuffer(recordedBlob);
}

// ===================== LIVE CAPTION =====================
function updateLiveCaption(text) {
  const el = document.getElementById('live-caption');
  el.innerHTML = '<span class="text-white/90">' + escapeHtml(text) + '</span>';
}

// ===================== TRANSCRIPT =====================
function addTranscriptBubble(who, text) {
  const area = document.getElementById('transcript-area');
  const ph = document.getElementById('transcript-placeholder');
  if (ph) ph.remove();
  const b = document.createElement('div');
  if (who === 'ai') {
    b.className = 'flex items-start gap-1';
    b.innerHTML = '<div class="w-3.5 h-3.5 sm:w-4 sm:h-4 rounded-full bg-blue-500 flex items-center justify-center flex-shrink-0 mt-0.5"><i class="fas fa-user-tie text-white" style="font-size:6px"></i></div><div class="bg-blue-50 dark:bg-blue-900/30 text-[10px] sm:text-[11px] rounded-lg px-1.5 sm:px-2 py-1 max-w-[90%]">' + escapeHtml(text) + '</div>';
  } else {
    b.className = 'flex items-start gap-1 justify-end';
    b.innerHTML = '<div class="bg-gray-100 dark:bg-gray-800 text-[10px] sm:text-[11px] rounded-lg px-1.5 sm:px-2 py-1 max-w-[90%]">' + escapeHtml(text) + '</div><div class="w-3.5 h-3.5 sm:w-4 sm:h-4 rounded-full bg-gray-400 flex items-center justify-center flex-shrink-0 mt-0.5"><i class="fas fa-user text-white" style="font-size:6px"></i></div>';
  }
  area.appendChild(b);
  area.scrollTop = area.scrollHeight;
}
function escapeHtml(s) { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

// ===================== SUBMIT & NEXT =====================
function submitAndNext() {
  if (isRecording) stopRecording(true);
  const ta = document.getElementById('answer-text');
  let txt = ta.value.trim();
  if (!txt && recordedBlob) { showToast('Still transcribing, please wait...', 'success'); return; }
  if (!txt) return showToast('Please record or type your answer', 'error');
  const dur = Math.floor((Date.now() - answerStartTime) / 1000);
  const btn = document.getElementById('submit-btn');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin text-[10px] sm:text-xs"></i> Submitting...';
  socket.emit('submit-answer', { questionId: currentQuestionId, answerText: txt, answerDuration: dur });
}

// ===================== SKIP =====================
function skipQuestion() {
  if (isRecording) stopRecording(true);
  const dur = Math.floor((Date.now() - answerStartTime) / 1000);
  const btn = document.getElementById('skip-btn');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
  socket.emit('submit-answer', { questionId: currentQuestionId, answerText: '[Skipped]', answerDuration: dur });
}

// ===================== SAVE (progress only) =====================
function saveProgress() {
  if (isRecording) stopRecording(true);
  const ta = document.getElementById('answer-text');
  const txt = ta.value.trim();
  if (!txt) {
    document.getElementById('save-status').innerHTML = '<i class="fas fa-check text-green-500 mr-1"></i>Nothing to save';
    setTimeout(() => { document.getElementById('save-status').textContent = ''; }, 2000);
    return;
  }
  const dur = Math.floor((Date.now() - answerStartTime) / 1000);
  const btn = document.getElementById('save-btn');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
  socket.emit('submit-answer', { questionId: currentQuestionId, answerText: txt, answerDuration: dur });
  document.getElementById('save-status').innerHTML = '<i class="fas fa-check text-green-500 mr-1"></i>Saved!';
  setTimeout(() => {
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-save"></i> Save';
    document.getElementById('save-status').textContent = '';
  }, 2000);
}

// ===================== END INTERVIEW =====================
function endInterview() {
  if (isRecording) stopRecording(true);
  if (!confirm('End this interview? Your progress will be saved and a report generated.')) return;
  if (mediaStream) mediaStream.getTracks().forEach(t => t.stop());
  const btn = document.getElementById('end-btn');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
  socket.emit('end-interview', { userId });
}

function viewReport() {
  if (mediaStream) mediaStream.getTracks().forEach(t => t.stop());
  const btn = document.getElementById('report-btn');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i>Loading...';
  socket.emit('end-interview', { userId });
}

// ===================== LOAD QUESTION =====================
function loadQuestion(q, progress) {
  currentQuestionId = q.id;
  recordedBlob = null;
  audioChunks = [];
  document.getElementById('q-number').textContent = q.question_order;
  document.getElementById('q-type').textContent = q.is_follow_up ? 'Follow-up' : 'Question';
  document.getElementById('q-text').textContent = q.question;
  document.getElementById('answer-text').value = '';
  document.getElementById('word-count').textContent = '0';
  document.getElementById('answer-time').textContent = '0';
  document.getElementById('rec-time').textContent = '';
  document.getElementById('transcribe-status').textContent = '';
  updateLiveCaption('<span class="text-gray-400 italic text-[10px] sm:text-xs">Listening for your answer...</span>');

  const btn = document.getElementById('submit-btn');
  btn.disabled = false;
  btn.innerHTML = '<i class="fas fa-paper-plane text-[10px] sm:text-xs"></i> Submit & Next';
  const skipBtn = document.getElementById('skip-btn');
  skipBtn.disabled = false;
  skipBtn.innerHTML = '<i class="fas fa-forward"></i> Skip';

  addTranscriptBubble('ai', q.question);

  if (progress) {
    const pct = Math.round((progress.answered / progress.total) * 100);
    document.getElementById('progress-bar').style.width = pct + '%';
    document.getElementById('progress-text').textContent = progress.answered + '/' + progress.total;
    document.getElementById('answered-count').textContent = progress.answered;
  }
  answerStartTime = Date.now();
  speakQuestion(q.id);
}

// ===================== COMPLETE =====================
function showComplete() {
  document.getElementById('question-card').classList.add('hidden');
  document.getElementById('controls-bar').classList.add('hidden');
  document.getElementById('complete-section').classList.remove('hidden');
  document.getElementById('progress-bar').style.width = '100%';
  setAvatarState('idle');
  clearInterval(interviewTimer);
  if (isRecording) stopRecording(true);
}

// ===================== INIT =====================
function initWordCount() {
  document.getElementById('answer-text').addEventListener('input', () => {
    const t = document.getElementById('answer-text').value.trim();
    document.getElementById('word-count').textContent = t ? t.split(/\s+/).length : 0;
  });
}

async function init() {
  await initMedia();
  interviewTimer = setInterval(() => {
    const s = Math.floor((Date.now() - interviewStartTime) / 1000);
    document.getElementById('timer').textContent = Math.floor(s / 60).toString().padStart(2, '0') + ':' + (s % 60).toString().padStart(2, '0');
  }, 1000);
  initWordCount();
  if (!currentQuestionId) showComplete();
  else addTranscriptBubble('ai', document.getElementById('q-text').textContent);
}

window.addEventListener('beforeunload', () => {
  if (mediaStream) mediaStream.getTracks().forEach(t => t.stop());
  if (isRecording) stopRecording(true);
  if (audioContext) audioContext.close();
});
init();
</script>

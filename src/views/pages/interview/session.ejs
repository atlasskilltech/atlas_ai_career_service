<style>
  #interview-app { height: calc(100vh - 140px); display: flex; flex-direction: column; overflow: hidden; }
  @media (max-width: 767px) { #interview-app { height: auto; overflow: visible; } }
</style>

<div id="interview-app">
  <!-- Top Bar: Title + Timer + Progress -->
  <div class="flex items-center justify-between mb-1.5 flex-shrink-0">
    <div class="min-w-0 flex-1">
      <div class="flex items-center gap-2 flex-wrap">
        <h1 class="text-sm md:text-base font-bold capitalize"><%= interview.interview_type.replace('_', ' ') %> Interview</h1>
        <span class="text-[10px] text-gray-400"><%= interview.job_role %><%= interview.company ? ' at ' + interview.company : '' %> | <%= interview.difficulty %></span>
      </div>
    </div>
    <div class="flex items-center gap-2 flex-shrink-0">
      <span class="text-xs font-mono bg-gray-100 dark:bg-gray-800 px-2 py-0.5 rounded" id="timer">00:00</span>
      <div class="flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-medium" id="connection-badge">
        <span class="w-1.5 h-1.5 rounded-full bg-yellow-400 animate-pulse" id="conn-dot"></span>
        <span id="conn-text">Connecting</span>
      </div>
      <span class="text-[10px] text-gray-500" id="progress-text"><%= progress.answered %>/<%= progress.total %></span>
    </div>
  </div>

  <!-- Progress bar -->
  <div class="h-1 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden mb-2 flex-shrink-0">
    <div class="h-full bg-gradient-to-r from-blue-500 to-purple-500 transition-all duration-500 rounded-full" id="progress-bar" style="width: <%= progress.total > 0 ? Math.round((progress.answered / progress.total) * 100) : 0 %>%"></div>
  </div>

  <!-- Main 2-col layout -->
  <div class="flex-1 grid grid-cols-1 md:grid-cols-12 gap-2 min-h-0">

    <!-- LEFT: Video Camera -->
    <div class="md:col-span-5 flex flex-col min-h-0">
      <div class="relative bg-gray-900 rounded-xl overflow-hidden flex-1 min-h-[200px]">
        <video id="camera-feed" autoplay muted playsinline class="absolute inset-0 w-full h-full object-cover"></video>
        <!-- YOU badge -->
        <div class="absolute top-2 left-2 flex items-center gap-1 bg-black/60 backdrop-blur-sm text-white text-[10px] px-2 py-0.5 rounded-full z-10">
          <span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse"></span> YOU
        </div>
        <!-- Recording badge -->
        <div class="absolute top-2 right-2 flex items-center gap-1 bg-black/60 backdrop-blur-sm text-white text-[10px] px-2 py-0.5 rounded-full z-10" id="rec-badge">
          <span class="w-1.5 h-1.5 rounded-full bg-gray-400" id="rec-dot"></span>
          <span id="rec-label">Mic Off</span>
          <span class="font-mono text-[9px] text-gray-300" id="rec-time"></span>
        </div>
        <!-- Mic levels -->
        <div class="absolute bottom-8 right-2 flex items-end gap-0.5 h-4 z-10" id="mic-levels">
          <span class="w-0.5 bg-green-400 rounded-full transition-all" style="height:3px"></span>
          <span class="w-0.5 bg-green-400 rounded-full transition-all" style="height:3px"></span>
          <span class="w-0.5 bg-green-400 rounded-full transition-all" style="height:3px"></span>
          <span class="w-0.5 bg-green-400 rounded-full transition-all" style="height:3px"></span>
          <span class="w-0.5 bg-green-400 rounded-full transition-all" style="height:3px"></span>
        </div>
        <!-- Live caption overlay -->
        <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 to-transparent px-3 pb-2 pt-6 z-10">
          <div class="text-white text-xs leading-relaxed" id="live-caption">
            <span class="text-gray-400 italic text-[10px]">Live captions appear here...</span>
          </div>
        </div>
      </div>
    </div>

    <!-- RIGHT: Question + Transcript + Answer -->
    <div class="md:col-span-7 flex flex-col gap-2 min-h-0">

      <!-- AI Interviewer bar -->
      <div class="flex items-center gap-2 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl px-3 py-2 flex-shrink-0">
        <div class="w-8 h-8 rounded-full overflow-hidden flex-shrink-0 bg-gradient-to-br from-slate-700 to-slate-900">
          <svg viewBox="0 0 100 100" class="w-full h-full">
            <defs>
              <linearGradient id="avBg" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" style="stop-color:#1e3a5f"/><stop offset="100%" style="stop-color:#0d1b2a"/></linearGradient>
              <linearGradient id="avSkin" x1="0%" y1="0%" x2="0%" y2="100%"><stop offset="0%" style="stop-color:#e8c4a0"/><stop offset="100%" style="stop-color:#d4a574"/></linearGradient>
            </defs>
            <circle cx="50" cy="50" r="50" fill="url(#avBg)"/>
            <path d="M15 95 Q20 70 50 65 Q80 70 85 95" fill="#1a1a2e"/>
            <path d="M40 67 L50 75 L60 67" fill="#e2e8f0"/>
            <path d="M47 68 L50 73 L53 68 L51 85 L50 87 L49 85Z" fill="#3b82f6"/>
            <rect x="44" y="56" width="12" height="12" rx="2" fill="url(#avSkin)"/>
            <ellipse cx="50" cy="42" rx="22" ry="26" fill="url(#avSkin)"/>
            <path d="M28 38 Q28 16 50 14 Q72 16 72 38 Q72 22 50 18 Q28 22 28 38" fill="#1a1a2e"/>
            <ellipse cx="50" cy="20" rx="20" ry="8" fill="#1a1a2e"/>
            <ellipse cx="40" cy="40" rx="4" ry="2.5" fill="white"/><ellipse cx="60" cy="40" rx="4" ry="2.5" fill="white"/>
            <circle cx="40" cy="40" r="2" fill="#2d1b0e"/><circle cx="60" cy="40" r="2" fill="#2d1b0e"/>
            <circle cx="40" cy="40" r="1" fill="#111"/><circle cx="60" cy="40" r="1" fill="#111"/>
            <path d="M35 35 Q40 32 45 34" stroke="#2d2d3e" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            <path d="M55 34 Q60 32 65 35" stroke="#2d2d3e" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            <path d="M43 54 Q50 58 57 54" stroke="#c27a6a" stroke-width="1.5" fill="none" stroke-linecap="round" id="avatar-mouth"/>
            <ellipse cx="28" cy="42" rx="3" ry="5" fill="#d4a574"/><ellipse cx="72" cy="42" rx="3" ry="5" fill="#d4a574"/>
          </svg>
        </div>
        <span class="font-semibold text-xs">AI Interviewer</span>
        <span class="px-2 py-0.5 rounded-full text-[10px] font-medium bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300" id="avatar-state-badge">
          <i class="fas fa-circle-notch fa-spin mr-1"></i>Connecting
        </span>
        <div class="flex-1"></div>
        <button onclick="replayQuestion()" class="flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-medium bg-blue-50 dark:bg-blue-900/30 text-blue-500 hover:bg-blue-100 dark:hover:bg-blue-900/50 transition" title="Replay question audio" id="replay-btn">
          <i class="fas fa-rotate-right"></i> Repeat Question
        </button>
      </div>

      <!-- Question -->
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl px-3 py-2 flex-shrink-0" id="question-card">
        <div class="flex items-center gap-1.5 mb-1">
          <span class="w-5 h-5 bg-gradient-to-br from-blue-500 to-purple-500 text-white rounded-full flex items-center justify-center text-[9px] font-bold" id="q-number"><%= currentQuestion ? currentQuestion.question_order : '-' %></span>
          <span class="text-[9px] text-gray-400 uppercase tracking-wider font-semibold" id="q-type"><%= currentQuestion && currentQuestion.is_follow_up ? 'Follow-up' : 'Question' %></span>
        </div>
        <p class="text-xs md:text-sm font-medium leading-snug" id="q-text"><%= currentQuestion ? currentQuestion.question : 'Interview complete!' %></p>
      </div>

      <!-- Transcript + Answer side-by-side -->
      <div class="flex-1 grid grid-cols-1 md:grid-cols-2 gap-2 min-h-0 overflow-hidden">
        <!-- Transcript -->
        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl px-3 py-2 flex flex-col min-h-[100px] overflow-hidden">
          <div class="flex items-center justify-between mb-1 flex-shrink-0">
            <span class="text-[9px] font-bold text-gray-400 uppercase tracking-wider">Transcript</span>
            <span class="text-[9px] text-gray-400" id="transcribe-status"></span>
          </div>
          <div class="overflow-y-auto flex-1 space-y-1 pr-1" id="transcript-area">
            <div class="text-[10px] text-gray-400 italic text-center py-2" id="transcript-placeholder">Conversation appears here...</div>
          </div>
        </div>

        <!-- Answer -->
        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl px-3 py-2 flex flex-col min-h-[100px] overflow-hidden">
          <div class="flex items-center justify-between mb-1 flex-shrink-0">
            <span class="text-[9px] font-bold text-gray-400 uppercase tracking-wider">Your Answer</span>
            <span class="text-[9px] text-gray-400"><span id="word-count">0</span> words | <span id="answer-time">0</span>s</span>
          </div>
          <textarea id="answer-text" class="flex-1 w-full border-0 bg-transparent text-xs resize-none focus:ring-0 focus:outline-none p-0" placeholder="Auto-transcribed or type here..."></textarea>
        </div>
      </div>

      <!-- Buttons row - clean, equal sizing -->
      <div class="grid grid-cols-4 gap-2 flex-shrink-0" id="controls-bar">
        <button onclick="submitAndNext()" id="submit-btn" class="py-2 bg-gradient-to-r from-blue-500 to-purple-600 text-white rounded-lg text-xs font-semibold hover:shadow-lg transition flex items-center justify-center gap-1">
          <i class="fas fa-paper-plane text-[10px]"></i> Submit
        </button>
        <button onclick="skipQuestion()" id="skip-btn" class="py-2 bg-white dark:bg-gray-800 border-2 border-gray-200 dark:border-gray-600 rounded-lg text-xs font-semibold text-gray-600 dark:text-gray-300 hover:border-orange-400 hover:text-orange-500 transition flex items-center justify-center gap-1">
          <i class="fas fa-forward text-[10px]"></i> Skip
        </button>
        <button onclick="saveProgress()" id="save-btn" class="py-2 bg-white dark:bg-gray-800 border-2 border-green-200 dark:border-green-700 rounded-lg text-xs font-semibold text-green-600 dark:text-green-400 hover:bg-green-50 dark:hover:bg-green-900/20 transition flex items-center justify-center gap-1">
          <i class="fas fa-save text-[10px]"></i> Save
        </button>
        <button onclick="endInterview()" id="end-btn" class="py-2 bg-white dark:bg-gray-800 border-2 border-red-200 dark:border-red-700 rounded-lg text-xs font-semibold text-red-500 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 transition flex items-center justify-center gap-1">
          <i class="fas fa-sign-out-alt text-[10px]"></i> End
        </button>
      </div>

      <!-- Status line -->
      <div class="flex items-center justify-between text-[9px] text-gray-400 flex-shrink-0">
        <span><span id="answered-count"><%= progress.answered %></span> of <%= progress.total %> answered</span>
        <span id="save-status"></span>
      </div>

      <!-- Complete Section (hidden) -->
      <div id="complete-section" class="hidden flex-1">
        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl text-center py-6 bg-gradient-to-br from-green-50 to-blue-50 dark:from-green-900/20 dark:to-blue-900/20 h-full flex flex-col items-center justify-center">
          <i class="fas fa-check-circle text-3xl text-green-500 mb-2"></i>
          <h3 class="text-base font-bold">Interview Complete!</h3>
          <p class="text-xs text-gray-500 mb-3">Generating your AI feedback report...</p>
          <button onclick="viewReport()" id="report-btn" class="px-6 py-2 bg-gradient-to-r from-blue-500 to-purple-500 text-white rounded-lg text-xs font-medium hover:shadow-lg transition">
            <i class="fas fa-chart-bar mr-1"></i> View Report
          </button>
        </div>
      </div>
    </div>
  </div>

  <audio id="ai-audio" class="hidden"></audio>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
const interviewId = '<%= interview.id %>';
const userId = '<%= typeof user !== "undefined" && user ? user.id : "" %>';
let currentQuestionId = <%= currentQuestion ? currentQuestion.id : 'null' %>;
let mediaStream = null;
let mediaRecorder = null;
let audioChunks = [];
let recordedBlob = null;
let isRecording = false;
let recTimer = null;
let answerStartTime = Date.now();
let interviewStartTime = Date.now();
let interviewTimer = null;
let audioContext = null;
let analyser = null;
let autoRecordEnabled = true;

// ===================== SOCKET.IO =====================
const socket = io('/interview', { transports: ['websocket', 'polling'] });

socket.on('connect', () => { socket.emit('join', { interviewId }); setConnectionStatus('connected'); });
socket.on('disconnect', () => setConnectionStatus('disconnected'));
socket.on('connect_error', () => setConnectionStatus('error'));
socket.on('joined', () => { if (currentQuestionId) speakQuestion(currentQuestionId); });
socket.on('avatar-state', (d) => setAvatarState(d.state));
socket.on('question-audio-ready', (d) => playQuestionAudio(d.audioUrl));
socket.on('speak-error', () => { setAvatarState('idle'); });

socket.on('transcribe-result', (data) => {
  if (data.success && data.text) {
    const ta = document.getElementById('answer-text');
    const existing = ta.value.trim();
    ta.value = existing ? existing + ' ' + data.text : data.text;
    ta.dispatchEvent(new Event('input'));
    addTranscriptBubble('you', data.text);
    updateLiveCaption(data.text);
    document.getElementById('transcribe-status').textContent = '';
  } else {
    document.getElementById('transcribe-status').textContent = 'Failed';
    showToast(data.error || 'Transcription failed', 'error');
  }
});

socket.on('next-question', (d) => loadQuestion(d.question, d.progress));
socket.on('interview-complete', () => showComplete());
socket.on('answer-error', (d) => {
  showToast(d.error || 'Failed to save', 'error');
  const btn = document.getElementById('submit-btn');
  btn.disabled = false;
  btn.innerHTML = '<i class="fas fa-paper-plane text-[10px]"></i> Submit';
});
socket.on('interview-ended', (d) => {
  if (d.success) window.location.href = '/interview/' + interviewId + '/report';
  else { showToast(d.error || 'Failed', 'error'); document.getElementById('end-btn').disabled = false; }
});

// ===================== CONNECTION =====================
function setConnectionStatus(s) {
  const dot = document.getElementById('conn-dot'), text = document.getElementById('conn-text'), badge = document.getElementById('connection-badge');
  if (s === 'connected') {
    dot.className = 'w-1.5 h-1.5 rounded-full bg-green-400';
    text.textContent = 'Live';
    badge.className = 'flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-medium bg-green-50 dark:bg-green-900/30 text-green-600 dark:text-green-400';
  } else {
    dot.className = 'w-1.5 h-1.5 rounded-full bg-red-400 animate-pulse';
    text.textContent = 'Reconnecting';
    badge.className = 'flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-medium bg-red-50 dark:bg-red-900/30 text-red-600';
  }
}

// ===================== AVATAR STATE =====================
function setAvatarState(state) {
  const stateMap = {
    idle: ['Ready', 'fa-circle-check'],
    thinking: ['Thinking...', 'fa-brain'],
    speaking: ['Speaking', 'fa-volume-high'],
    listening: ['Listening', 'fa-ear-listen']
  };
  const [label, icon] = stateMap[state] || stateMap.idle;
  document.getElementById('avatar-state-badge').innerHTML = '<i class="fas ' + icon + ' mr-1"></i>' + label;

  const mouth = document.getElementById('avatar-mouth');
  if (mouth) {
    mouth.setAttribute('d', state === 'speaking' ? 'M43 53 Q50 60 57 53' : 'M43 54 Q50 58 57 54');
  }

  // Auto-start recording when AI done speaking
  if (state === 'listening' && autoRecordEnabled && !isRecording) {
    setTimeout(() => { if (!isRecording) startRecording(); }, 500);
  }
}

// ===================== TTS =====================
let audioUnlocked = false;
let pendingAudioUrl = null;

function playQuestionAudio(url) {
  if (isRecording) stopRecording(true);
  const audio = document.getElementById('ai-audio');
  audio.src = url;
  audio.onended = () => { setAvatarState('listening'); socket.emit('speak-done'); };
  audio.onerror = () => { setAvatarState('idle'); showAutoplayHint(); };
  const playPromise = audio.play();
  if (playPromise !== undefined) {
    playPromise.then(() => { audioUnlocked = true; hideAutoplayHint(); }).catch(() => {
      // Browser blocked autoplay - show hint to user
      pendingAudioUrl = url;
      showAutoplayHint();
      setAvatarState('idle');
    });
  }
}

function showAutoplayHint() {
  const btn = document.getElementById('replay-btn');
  btn.classList.add('animate-pulse', 'bg-orange-100', 'dark:bg-orange-900/30', 'text-orange-600');
  btn.classList.remove('bg-blue-50', 'dark:bg-blue-900/30', 'text-blue-500');
  btn.innerHTML = '<i class="fas fa-volume-high"></i> Click to hear question';
}

function hideAutoplayHint() {
  const btn = document.getElementById('replay-btn');
  btn.classList.remove('animate-pulse', 'bg-orange-100', 'dark:bg-orange-900/30', 'text-orange-600');
  btn.classList.add('bg-blue-50', 'dark:bg-blue-900/30', 'text-blue-500');
  btn.innerHTML = '<i class="fas fa-rotate-right"></i> Repeat Question';
}

function speakQuestion(qId) { socket.emit('speak-question', { questionId: qId }); }

function replayQuestion() {
  if (pendingAudioUrl) {
    // User clicked after autoplay was blocked - play the pending audio
    const audio = document.getElementById('ai-audio');
    audio.src = pendingAudioUrl;
    audio.onended = () => { setAvatarState('listening'); socket.emit('speak-done'); };
    audio.onerror = () => setAvatarState('idle');
    setAvatarState('speaking');
    audio.play().then(() => { audioUnlocked = true; pendingAudioUrl = null; hideAutoplayHint(); }).catch(() => {});
  } else if (currentQuestionId) {
    speakQuestion(currentQuestionId);
  }
}

// ===================== CAMERA =====================
async function initMedia() {
  try {
    mediaStream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user' }, audio: true });
    document.getElementById('camera-feed').srcObject = mediaStream;
    try {
      audioContext = new (window.AudioContext || window.webkitAudioContext)();
      const src = audioContext.createMediaStreamSource(mediaStream);
      analyser = audioContext.createAnalyser(); analyser.fftSize = 32;
      src.connect(analyser); updateMicLevels();
    } catch (e) {}
  } catch (e) { showToast('Camera/mic access needed: ' + e.message, 'error'); }
}

function updateMicLevels() {
  if (!analyser) return;
  const d = new Uint8Array(analyser.frequencyBinCount); analyser.getByteFrequencyData(d);
  const bars = document.getElementById('mic-levels').children;
  for (let i = 0; i < bars.length; i++) bars[i].style.height = Math.max(3, (d[i * 2] || 0) / 6) + 'px';
  requestAnimationFrame(updateMicLevels);
}

// ===================== RECORDING =====================
function startRecording() {
  if (!mediaStream) { showToast('No microphone', 'error'); return; }
  audioChunks = []; recordedBlob = null;
  const as = new MediaStream(mediaStream.getAudioTracks());
  mediaRecorder = new MediaRecorder(as, { mimeType: 'audio/webm;codecs=opus' });
  mediaRecorder.ondataavailable = (e) => { if (e.data.size > 0) audioChunks.push(e.data); };
  mediaRecorder.onstop = () => { recordedBlob = new Blob(audioChunks, { type: 'audio/webm' }); autoTranscribe(); };
  mediaRecorder.start(1000); isRecording = true; answerStartTime = Date.now();

  document.getElementById('rec-dot').className = 'w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse';
  document.getElementById('rec-label').textContent = 'Rec';
  document.getElementById('rec-badge').classList.add('bg-red-600/60');
  document.getElementById('rec-badge').classList.remove('bg-black/60');
  recTimer = setInterval(() => {
    const s = Math.floor((Date.now() - answerStartTime) / 1000);
    document.getElementById('rec-time').textContent = Math.floor(s / 60) + ':' + (s % 60).toString().padStart(2, '0');
    document.getElementById('answer-time').textContent = s;
  }, 1000);
}

function stopRecording(silent) {
  if (mediaRecorder && mediaRecorder.state !== 'inactive') mediaRecorder.stop();
  isRecording = false; clearInterval(recTimer);
  document.getElementById('rec-dot').className = 'w-1.5 h-1.5 rounded-full bg-gray-400';
  document.getElementById('rec-label').textContent = 'Mic Off';
  document.getElementById('rec-badge').classList.remove('bg-red-600/60');
  document.getElementById('rec-badge').classList.add('bg-black/60');
  if (!silent) updateLiveCaption('Processing...');
}

// ===================== TRANSCRIBE =====================
function autoTranscribe() {
  if (!recordedBlob) return;
  document.getElementById('transcribe-status').textContent = 'Transcribing...';
  updateLiveCaption('Transcribing...');
  const r = new FileReader();
  r.onloadend = () => { socket.emit('transcribe', { audio: r.result }); };
  r.readAsArrayBuffer(recordedBlob);
}

// ===================== LIVE CAPTION =====================
function updateLiveCaption(text) {
  document.getElementById('live-caption').innerHTML = '<span class="text-white/90">' + escapeHtml(text) + '</span>';
}

// ===================== TRANSCRIPT =====================
function addTranscriptBubble(who, text) {
  const area = document.getElementById('transcript-area');
  const ph = document.getElementById('transcript-placeholder'); if (ph) ph.remove();
  const b = document.createElement('div');
  if (who === 'ai') {
    b.className = 'flex items-start gap-1';
    b.innerHTML = '<div class="w-4 h-4 rounded-full bg-blue-500 flex items-center justify-center flex-shrink-0 mt-0.5"><i class="fas fa-user-tie text-white" style="font-size:6px"></i></div><div class="bg-blue-50 dark:bg-blue-900/30 text-[10px] rounded-lg px-2 py-1 max-w-[85%]">' + escapeHtml(text) + '</div>';
  } else {
    b.className = 'flex items-start gap-1 justify-end';
    b.innerHTML = '<div class="bg-gray-100 dark:bg-gray-800 text-[10px] rounded-lg px-2 py-1 max-w-[85%]">' + escapeHtml(text) + '</div><div class="w-4 h-4 rounded-full bg-gray-400 flex items-center justify-center flex-shrink-0 mt-0.5"><i class="fas fa-user text-white" style="font-size:6px"></i></div>';
  }
  area.appendChild(b); area.scrollTop = area.scrollHeight;
}
function escapeHtml(s) { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

// ===================== SUBMIT =====================
function submitAndNext() {
  if (isRecording) stopRecording(true);
  const ta = document.getElementById('answer-text'); let txt = ta.value.trim();
  if (!txt && recordedBlob) { showToast('Still transcribing...', 'success'); return; }
  if (!txt) return showToast('Please record or type your answer', 'error');
  const dur = Math.floor((Date.now() - answerStartTime) / 1000);
  const btn = document.getElementById('submit-btn');
  btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin text-[10px]"></i> Saving...';
  socket.emit('submit-answer', { questionId: currentQuestionId, answerText: txt, answerDuration: dur });
}

// ===================== SKIP =====================
function skipQuestion() {
  if (isRecording) stopRecording(true);
  const dur = Math.floor((Date.now() - answerStartTime) / 1000);
  const btn = document.getElementById('skip-btn');
  btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin text-[10px]"></i>';
  socket.emit('submit-answer', { questionId: currentQuestionId, answerText: '[Skipped]', answerDuration: dur });
}

// ===================== SAVE =====================
function saveProgress() {
  if (isRecording) stopRecording(true);
  const txt = document.getElementById('answer-text').value.trim();
  if (!txt) {
    document.getElementById('save-status').innerHTML = '<i class="fas fa-info-circle text-blue-400 mr-1"></i>Nothing to save';
    setTimeout(() => { document.getElementById('save-status').textContent = ''; }, 2000);
    return;
  }
  const dur = Math.floor((Date.now() - answerStartTime) / 1000);
  const btn = document.getElementById('save-btn');
  btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin text-[10px]"></i>';
  socket.emit('submit-answer', { questionId: currentQuestionId, answerText: txt, answerDuration: dur });
  document.getElementById('save-status').innerHTML = '<i class="fas fa-check text-green-500 mr-1"></i>Saved!';
  setTimeout(() => { btn.disabled = false; btn.innerHTML = '<i class="fas fa-save text-[10px]"></i> Save'; document.getElementById('save-status').textContent = ''; }, 2000);
}

// ===================== END =====================
function endInterview() {
  if (isRecording) stopRecording(true);
  if (!confirm('End this interview? A report will be generated.')) return;
  if (mediaStream) mediaStream.getTracks().forEach(t => t.stop());
  const btn = document.getElementById('end-btn');
  btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin text-[10px]"></i>';
  socket.emit('end-interview', { userId });
}

function viewReport() {
  if (mediaStream) mediaStream.getTracks().forEach(t => t.stop());
  const btn = document.getElementById('report-btn');
  btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i>Loading...';
  socket.emit('end-interview', { userId });
}

// ===================== LOAD QUESTION =====================
function loadQuestion(q, progress) {
  currentQuestionId = q.id; recordedBlob = null; audioChunks = [];
  document.getElementById('q-number').textContent = q.question_order;
  document.getElementById('q-type').textContent = q.is_follow_up ? 'Follow-up' : 'Question';
  document.getElementById('q-text').textContent = q.question;
  document.getElementById('answer-text').value = '';
  document.getElementById('word-count').textContent = '0';
  document.getElementById('answer-time').textContent = '0';
  document.getElementById('rec-time').textContent = '';
  document.getElementById('transcribe-status').textContent = '';
  updateLiveCaption('<span class="text-gray-400 italic text-[10px]">Listening...</span>');
  const btn = document.getElementById('submit-btn');
  btn.disabled = false; btn.innerHTML = '<i class="fas fa-paper-plane text-[10px]"></i> Submit';
  const skipBtn = document.getElementById('skip-btn');
  skipBtn.disabled = false; skipBtn.innerHTML = '<i class="fas fa-forward text-[10px]"></i> Skip';
  addTranscriptBubble('ai', q.question);
  if (progress) {
    document.getElementById('progress-bar').style.width = Math.round((progress.answered / progress.total) * 100) + '%';
    document.getElementById('progress-text').textContent = progress.answered + '/' + progress.total;
    document.getElementById('answered-count').textContent = progress.answered;
  }
  answerStartTime = Date.now(); speakQuestion(q.id);
}

// ===================== COMPLETE =====================
function showComplete() {
  document.getElementById('question-card').classList.add('hidden');
  document.getElementById('controls-bar').classList.add('hidden');
  document.getElementById('complete-section').classList.remove('hidden');
  document.getElementById('progress-bar').style.width = '100%';
  setAvatarState('idle'); clearInterval(interviewTimer);
  if (isRecording) stopRecording(true);
}

// ===================== INIT =====================
function initWordCount() {
  document.getElementById('answer-text').addEventListener('input', () => {
    const t = document.getElementById('answer-text').value.trim();
    document.getElementById('word-count').textContent = t ? t.split(/\s+/).length : 0;
  });
}

// Unlock audio on first user interaction so subsequent questions can auto-play
function unlockAudio() {
  if (audioUnlocked) return;
  const audio = document.getElementById('ai-audio');
  audio.play().then(() => { audio.pause(); audio.currentTime = 0; audioUnlocked = true; }).catch(() => {});
}
['click', 'touchstart', 'keydown'].forEach(evt => document.addEventListener(evt, unlockAudio, { once: false }));

async function init() {
  await initMedia();
  interviewTimer = setInterval(() => {
    const s = Math.floor((Date.now() - interviewStartTime) / 1000);
    document.getElementById('timer').textContent = Math.floor(s / 60).toString().padStart(2, '0') + ':' + (s % 60).toString().padStart(2, '0');
  }, 1000);
  initWordCount();
  if (!currentQuestionId) showComplete();
  else addTranscriptBubble('ai', document.getElementById('q-text').textContent);
}

window.addEventListener('beforeunload', () => {
  if (mediaStream) mediaStream.getTracks().forEach(t => t.stop());
  if (isRecording) stopRecording(true);
  if (audioContext) audioContext.close();
});
init();
</script>

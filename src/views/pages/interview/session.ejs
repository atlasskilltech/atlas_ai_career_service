<% const questions = typeof interview.questions === 'string' ? JSON.parse(interview.questions) : (interview.questions || []); %>
<% const answers = typeof interview.answers === 'string' ? JSON.parse(interview.answers) : (interview.answers || []); %>
<% const mode = interview.mode || 'text'; %>

<div class="max-w-3xl mx-auto space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold capitalize"><%= interview.interview_type.replace('_', ' ') %> Interview</h1>
      <p class="text-gray-500"><%= interview.job_role || 'General' %> | <i class="fas <%= mode === 'video' ? 'fa-video' : mode === 'audio' ? 'fa-headphones' : 'fa-keyboard' %> mr-1"></i><%= mode %> mode</p>
    </div>
    <span class="badge-warning">In Progress</span>
  </div>

  <% if (mode === 'video') { %>
  <div class="card">
    <div class="flex items-center justify-between mb-3">
      <h3 class="font-semibold"><i class="fas fa-video mr-2"></i>Camera Preview</h3>
      <span id="camera-status" class="text-xs text-yellow-600">Initializing...</span>
    </div>
    <div class="relative rounded-lg overflow-hidden bg-gray-900 aspect-video">
      <video id="camera-preview" autoplay muted playsinline class="w-full h-full object-cover"></video>
    </div>
  </div>
  <% } %>

  <% if (mode === 'audio' || mode === 'video') { %>
  <div class="card p-4">
    <div class="flex items-center gap-3">
      <i class="fas fa-microphone text-accent"></i>
      <span class="text-sm font-medium">Speech-to-text enabled</span>
      <span class="text-xs text-gray-500">- Click "Start Recording" on each question to answer by voice</span>
    </div>
  </div>
  <% } %>

  <div class="card">
    <div class="flex items-center justify-between mb-6">
      <h3 class="font-semibold">Questions</h3>
      <span class="text-sm text-gray-500" id="progress-text">0 / <%= questions.length %> answered</span>
    </div>

    <div class="space-y-6" id="questions-container">
      <% questions.forEach((q, i) => { %>
        <div class="p-4 bg-gray-50 dark:bg-gray-800 rounded-lg" id="q-<%= i %>">
          <div class="flex items-start gap-3 mb-3">
            <span class="w-7 h-7 bg-primary text-white rounded-full flex items-center justify-center text-sm flex-shrink-0"><%= i + 1 %></span>
            <p class="font-medium"><%= q %></p>
          </div>

          <% if (mode === 'audio' || mode === 'video') { %>
          <div class="mb-2">
            <button onclick="toggleRecording(<%= i %>)" id="rec-btn-<%= i %>" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border-2 border-gray-300 text-sm font-medium hover:border-red-400 transition">
              <span class="w-3 h-3 rounded-full bg-gray-400" id="rec-dot-<%= i %>"></span>
              <span id="rec-label-<%= i %>">Start Recording</span>
            </button>
            <span id="rec-time-<%= i %>" class="text-xs text-gray-500 ml-2"></span>
          </div>
          <% } %>

          <textarea class="input-field answer-input" rows="4" placeholder="<%= (mode === 'audio' || mode === 'video') ? 'Your speech will appear here, or type manually...' : 'Type your answer here...' %>" data-index="<%= i %>"><%= answers[i] || '' %></textarea>
          <div class="flex items-center gap-2 mt-2">
            <button onclick="submitAnswer(<%= i %>)" class="btn-accent text-sm">Save Answer</button>
            <span id="save-status-<%= i %>" class="text-xs text-green-600 hidden"><i class="fas fa-check"></i> Saved</span>
          </div>
        </div>
      <% }); %>
    </div>

    <div class="mt-6 pt-6 border-t dark:border-gray-700 flex justify-end">
      <button onclick="completeInterview()" id="complete-btn" class="btn-primary text-lg px-8"><i class="fas fa-check-circle mr-2"></i>Complete & Get Feedback</button>
    </div>
  </div>
</div>

<script>
const interviewMode = '<%= mode %>';
const interviewId = '<%= interview.id %>';
const recordings = {};
let mediaStream = null;

// Initialize camera for video mode
async function initCamera() {
  if (interviewMode !== 'video') return;
  const statusEl = document.getElementById('camera-status');
  try {
    mediaStream = await navigator.mediaDevices.getUserMedia({ video: true, audio: true });
    const video = document.getElementById('camera-preview');
    video.srcObject = mediaStream;
    statusEl.textContent = 'Camera active';
    statusEl.classList.remove('text-yellow-600');
    statusEl.classList.add('text-green-600');
  } catch (err) {
    statusEl.textContent = 'Camera unavailable: ' + err.message;
    statusEl.classList.remove('text-yellow-600');
    statusEl.classList.add('text-red-600');
  }
}

// Speech recognition setup
function createRecognition() {
  const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SpeechRecognition) return null;
  const recognition = new SpeechRecognition();
  recognition.continuous = true;
  recognition.interimResults = true;
  recognition.lang = 'en-US';
  return recognition;
}

function toggleRecording(index) {
  if (recordings[index] && recordings[index].active) {
    stopRecording(index);
  } else {
    startRecording(index);
  }
}

async function startRecording(index) {
  // Request mic permission if not already granted via camera
  if (interviewMode === 'audio' && !mediaStream) {
    try {
      mediaStream = await navigator.mediaDevices.getUserMedia({ audio: true });
    } catch (err) {
      showToast('Microphone access denied', 'error');
      return;
    }
  }

  const recognition = createRecognition();
  if (!recognition) {
    showToast('Speech recognition not supported in this browser. Please use Chrome.', 'error');
    return;
  }

  const textarea = document.querySelector(`textarea[data-index="${index}"]`);
  const btn = document.getElementById('rec-btn-' + index);
  const dot = document.getElementById('rec-dot-' + index);
  const label = document.getElementById('rec-label-' + index);
  const timeEl = document.getElementById('rec-time-' + index);

  const existingText = textarea.value;
  let finalTranscript = existingText;

  recognition.onresult = (event) => {
    let interim = '';
    for (let i = event.resultIndex; i < event.results.length; i++) {
      if (event.results[i].isFinal) {
        finalTranscript += (finalTranscript ? ' ' : '') + event.results[i][0].transcript;
      } else {
        interim += event.results[i][0].transcript;
      }
    }
    textarea.value = finalTranscript + (interim ? ' ' + interim : '');
  };

  recognition.onerror = (event) => {
    if (event.error !== 'no-speech') {
      showToast('Speech error: ' + event.error, 'error');
    }
  };

  recognition.onend = () => {
    // Auto-restart if still recording
    if (recordings[index] && recordings[index].active) {
      try { recognition.start(); } catch (e) {}
    }
  };

  recognition.start();

  // Timer
  const startTime = Date.now();
  const timer = setInterval(() => {
    const elapsed = Math.floor((Date.now() - startTime) / 1000);
    const mins = Math.floor(elapsed / 60);
    const secs = elapsed % 60;
    timeEl.textContent = `${mins}:${secs.toString().padStart(2, '0')}`;
  }, 1000);

  recordings[index] = { recognition, active: true, timer };

  // Update UI
  btn.classList.add('border-red-500', 'text-red-600');
  btn.classList.remove('border-gray-300');
  dot.classList.remove('bg-gray-400');
  dot.classList.add('bg-red-500', 'animate-pulse');
  label.textContent = 'Stop Recording';
}

function stopRecording(index) {
  const rec = recordings[index];
  if (!rec) return;

  rec.active = false;
  rec.recognition.stop();
  clearInterval(rec.timer);

  const btn = document.getElementById('rec-btn-' + index);
  const dot = document.getElementById('rec-dot-' + index);
  const label = document.getElementById('rec-label-' + index);

  btn.classList.remove('border-red-500', 'text-red-600');
  btn.classList.add('border-gray-300');
  dot.classList.add('bg-gray-400');
  dot.classList.remove('bg-red-500', 'animate-pulse');
  label.textContent = 'Start Recording';

  recordings[index] = null;
}

async function submitAnswer(index) {
  // Stop recording if active
  if (recordings[index] && recordings[index].active) stopRecording(index);

  const textarea = document.querySelector(`textarea[data-index="${index}"]`);
  const answer = textarea.value;
  if (!answer.trim()) return showToast('Please provide an answer', 'error');

  try {
    await fetch('/interview/' + interviewId + '/answer', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ questionIndex: index, answer }),
    });
    const statusEl = document.getElementById('save-status-' + index);
    statusEl.classList.remove('hidden');
    setTimeout(() => statusEl.classList.add('hidden'), 3000);
    showToast('Answer saved', 'success');
    updateProgress();
  } catch (err) { showToast('Failed to save', 'error'); }
}

function updateProgress() {
  const total = document.querySelectorAll('.answer-input').length;
  const filled = Array.from(document.querySelectorAll('.answer-input')).filter(t => t.value.trim()).length;
  document.getElementById('progress-text').textContent = filled + ' / ' + total + ' answered';
}

async function completeInterview() {
  // Stop all active recordings
  Object.keys(recordings).forEach(i => { if (recordings[i] && recordings[i].active) stopRecording(i); });

  // Stop camera stream
  if (mediaStream) { mediaStream.getTracks().forEach(t => t.stop()); }

  const btn = document.getElementById('complete-btn');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Generating Feedback...';
  try {
    const res = await fetch('/interview/' + interviewId + '/complete', { method: 'POST' });
    const data = await res.json();
    if (data.success) window.location.href = '/interview/' + interviewId + '/feedback';
    else showToast(data.error || 'Failed to complete', 'error');
  } catch (err) { showToast('Failed', 'error'); }
  btn.disabled = false;
  btn.innerHTML = '<i class="fas fa-check-circle mr-2"></i>Complete & Get Feedback';
}

// Cleanup on page leave
window.addEventListener('beforeunload', () => {
  if (mediaStream) mediaStream.getTracks().forEach(t => t.stop());
});

updateProgress();
initCamera();
</script>

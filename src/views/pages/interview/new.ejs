<div class="max-w-2xl mx-auto space-y-6">
  <h1 class="text-2xl font-bold text-center">Start Mock Interview</h1>
  <p class="text-gray-500 text-center">Choose your interview type and get started</p>

  <div class="card">
    <div class="space-y-4">
      <div>
        <label class="label-field">Interview Type</label>
        <div class="grid grid-cols-2 gap-3" id="type-options">
          <% ['technical', 'behavioral', 'hr', 'case_study'].forEach(type => { %>
            <div class="mode-card flex items-center gap-3 p-4 border-2 rounded-lg cursor-pointer hover:border-accent transition border-gray-200" data-name="interviewType" data-value="<%= type %>">
              <div class="w-4 h-4 rounded-full border-2 border-gray-400 flex items-center justify-center flex-shrink-0 radio-dot">
                <div class="w-2 h-2 rounded-full"></div>
              </div>
              <div>
                <p class="font-medium capitalize"><%= type.replace('_', ' ') %></p>
                <p class="text-xs text-gray-500">
                  <%= type === 'technical' ? 'Coding & system design' : type === 'behavioral' ? 'Situational questions' : type === 'hr' ? 'Culture & personality' : 'Problem solving' %>
                </p>
              </div>
            </div>
          <% }); %>
        </div>
      </div>

      <div>
        <label class="label-field">Mode</label>
        <div class="grid grid-cols-3 gap-3" id="mode-options">
          <% [{val:'text',icon:'fa-keyboard',label:'Text'}, {val:'audio',icon:'fa-headphones',label:'Audio'}, {val:'video',icon:'fa-video',label:'Video'}].forEach(m => { %>
            <div class="mode-card flex flex-col items-center gap-2 p-4 border-2 rounded-lg cursor-pointer hover:border-accent transition border-gray-200" data-name="mode" data-value="<%= m.val %>">
              <i class="fas <%= m.icon %> text-xl text-gray-500 mode-icon"></i>
              <span class="text-sm font-medium"><%= m.label %></span>
            </div>
          <% }); %>
        </div>
        <p id="permission-status" class="text-xs mt-2 hidden"></p>
      </div>

      <div>
        <label class="label-field">Target Job Role</label>
        <input type="text" id="int-role" class="input-field" placeholder="e.g., Software Engineer, Product Manager">
      </div>

      <button onclick="startInterview()" id="start-btn" class="btn-primary w-full text-lg py-3"><i class="fas fa-play mr-2"></i>Start Interview</button>
    </div>
  </div>
</div>

<script>
const selected = { interviewType: 'behavioral', mode: 'text' };

function initSelection() {
  document.querySelectorAll('.mode-card').forEach(card => {
    card.addEventListener('click', () => selectCard(card));
  });
  // Set defaults
  selectCardByValue('interviewType', 'behavioral');
  selectCardByValue('mode', 'text');
}

function selectCardByValue(name, value) {
  const card = document.querySelector(`.mode-card[data-name="${name}"][data-value="${value}"]`);
  if (card) selectCard(card);
}

function selectCard(card) {
  const name = card.dataset.name;
  const value = card.dataset.value;
  selected[name] = value;

  // Reset all cards in same group
  document.querySelectorAll(`.mode-card[data-name="${name}"]`).forEach(c => {
    c.classList.remove('border-accent', 'bg-green-50');
    c.classList.add('border-gray-200');
    const icon = c.querySelector('.mode-icon');
    if (icon) { icon.classList.remove('text-accent'); icon.classList.add('text-gray-500'); }
    const dot = c.querySelector('.radio-dot');
    if (dot) { dot.classList.remove('border-accent'); dot.classList.add('border-gray-400'); dot.querySelector('div').classList.remove('bg-accent'); }
  });

  // Highlight selected
  card.classList.remove('border-gray-200');
  card.classList.add('border-accent', 'bg-green-50');
  const icon = card.querySelector('.mode-icon');
  if (icon) { icon.classList.remove('text-gray-500'); icon.classList.add('text-accent'); }
  const dot = card.querySelector('.radio-dot');
  if (dot) { dot.classList.remove('border-gray-400'); dot.classList.add('border-accent'); dot.querySelector('div').classList.add('bg-accent'); }

  // Check permissions for audio/video
  if (name === 'mode') checkPermissions(value);
}

async function checkPermissions(mode) {
  const status = document.getElementById('permission-status');
  status.classList.remove('hidden', 'text-green-600', 'text-red-600', 'text-yellow-600');

  if (mode === 'text') {
    status.classList.add('hidden');
    return true;
  }

  const constraints = mode === 'video' ? { audio: true, video: true } : { audio: true };
  const label = mode === 'video' ? 'Camera & Microphone' : 'Microphone';

  try {
    const stream = await navigator.mediaDevices.getUserMedia(constraints);
    stream.getTracks().forEach(t => t.stop());
    status.textContent = label + ' access granted';
    status.classList.add('text-green-600');
    return true;
  } catch (err) {
    if (err.name === 'NotAllowedError' || err.name === 'PermissionDeniedError') {
      status.textContent = label + ' access denied. Please allow in browser settings to use this mode.';
      status.classList.add('text-red-600');
    } else if (err.name === 'NotFoundError') {
      status.textContent = 'No ' + label.toLowerCase() + ' found on this device.';
      status.classList.add('text-red-600');
    } else {
      status.textContent = 'Could not access ' + label.toLowerCase() + ': ' + err.message;
      status.classList.add('text-yellow-600');
    }
    return false;
  }
}

async function startInterview() {
  const btn = document.getElementById('start-btn');
  if (!selected.interviewType || !selected.mode) {
    showToast('Please select interview type and mode', 'error');
    return;
  }

  // Verify permissions for audio/video before starting
  if (selected.mode !== 'text') {
    const hasPermission = await checkPermissions(selected.mode);
    if (!hasPermission) {
      const label = selected.mode === 'video' ? 'camera and microphone' : 'microphone';
      showToast('Please grant ' + label + ' access to use ' + selected.mode + ' mode', 'error');
      return;
    }
  }

  const data = {
    interviewType: selected.interviewType,
    mode: selected.mode,
    jobRole: document.getElementById('int-role').value,
  };
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Generating Questions...';
  try {
    const res = await fetch('/interview/start', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
    const result = await res.json();
    if (result.success) window.location.href = '/interview/' + result.interview.id + '/session';
    else showToast(result.error || 'Failed to start interview', 'error');
  } catch (err) { showToast('Failed to start', 'error'); }
  btn.disabled = false;
  btn.innerHTML = '<i class="fas fa-play mr-2"></i>Start Interview';
}

initSelection();
</script>

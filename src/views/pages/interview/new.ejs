<div class="max-w-2xl mx-auto space-y-6">
  <div class="text-center">
    <h1 class="text-2xl font-bold">AI Avatar Mock Interview</h1>
    <p class="text-gray-500 mt-1">Face a real-time AI interviewer avatar with voice interaction and live feedback</p>
  </div>

  <div class="card space-y-5">
    <!-- Job Role -->
    <div>
      <label class="label-field">Target Job Role <span class="text-red-500">*</span></label>
      <input type="text" id="job-role" class="input-field" placeholder="e.g., Software Engineer, Product Manager, Data Analyst" required>
    </div>

    <!-- Company (optional) -->
    <div>
      <label class="label-field">Company <span class="text-xs text-gray-400">(optional)</span></label>
      <input type="text" id="company" class="input-field" placeholder="e.g., Google, TCS, Infosys">
    </div>

    <!-- Interview Type -->
    <div>
      <label class="label-field">Interview Type</label>
      <div class="grid grid-cols-2 gap-3" id="type-options">
        <% [
          {val:'technical', icon:'fa-code', label:'Technical', desc:'Coding, system design & concepts'},
          {val:'behavioral', icon:'fa-users', label:'Behavioral', desc:'STAR method & situational questions'},
          {val:'hr', icon:'fa-handshake', label:'HR', desc:'Culture fit & motivation'},
          {val:'case_study', icon:'fa-lightbulb', label:'Case Study', desc:'Analytical & problem solving'},
        ].forEach(t => { %>
          <div class="sel-card border-gray-200" data-group="interviewType" data-value="<%= t.val %>">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-lg bg-gray-100 flex items-center justify-center flex-shrink-0">
                <i class="fas <%= t.icon %> text-gray-500 sel-icon"></i>
              </div>
              <div>
                <p class="font-medium text-sm"><%= t.label %></p>
                <p class="text-xs text-gray-400"><%= t.desc %></p>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
    </div>

    <!-- Difficulty -->
    <div>
      <label class="label-field">Difficulty Level</label>
      <div class="grid grid-cols-3 gap-3" id="diff-options">
        <% [
          {val:'easy', icon:'fa-seedling', label:'Easy', desc:'8 questions'},
          {val:'medium', icon:'fa-fire', label:'Medium', desc:'10 questions'},
          {val:'hard', icon:'fa-bolt', label:'Hard', desc:'12 questions'},
        ].forEach(d => { %>
          <div class="sel-card border-gray-200" data-group="difficulty" data-value="<%= d.val %>">
            <div class="flex flex-col items-center gap-1 text-center">
              <i class="fas <%= d.icon %> text-lg text-gray-500 sel-icon"></i>
              <span class="text-sm font-medium"><%= d.label %></span>
              <span class="text-xs text-gray-400"><%= d.desc %></span>
            </div>
          </div>
        <% }); %>
      </div>
    </div>

    <!-- Camera Check -->
    <div class="p-4 bg-gray-50 dark:bg-gray-800 rounded-lg">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-3">
          <i class="fas fa-video text-lg text-gray-500" id="cam-icon"></i>
          <div>
            <p class="text-sm font-medium">Video Interview Mode</p>
            <p class="text-xs text-gray-400" id="cam-status">Click "Check Camera" to verify access</p>
          </div>
        </div>
        <button onclick="checkCamera()" id="cam-btn" class="btn-outline text-xs px-3 py-1.5">Check Camera</button>
      </div>
      <div id="cam-preview-wrap" class="hidden mt-3">
        <video id="cam-preview" autoplay muted playsinline class="w-full max-h-40 rounded-lg bg-black object-cover"></video>
      </div>
    </div>

    <!-- Start Button -->
    <button onclick="startInterview()" id="start-btn" class="btn-primary w-full text-lg py-3" disabled>
      <i class="fas fa-video mr-2"></i>Start Video Interview
    </button>
  </div>

  <!-- How It Works Guide -->
  <div class="card">
    <h2 class="text-lg font-bold mb-4 flex items-center gap-2">
      <i class="fas fa-book-open text-blue-500"></i> How the Interview Works
    </h2>
    <div class="space-y-4">
      <!-- Step 1 -->
      <div class="flex gap-3">
        <div class="w-7 h-7 rounded-full bg-blue-500 text-white flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5">1</div>
        <div>
          <p class="font-semibold text-sm">Allow Camera & Microphone</p>
          <p class="text-xs text-gray-500">Click "Check Camera" above to grant access. The AI needs your mic to hear your answers and camera for the video interview experience.</p>
        </div>
      </div>
      <!-- Step 2 -->
      <div class="flex gap-3">
        <div class="w-7 h-7 rounded-full bg-blue-500 text-white flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5">2</div>
        <div>
          <p class="font-semibold text-sm">Listen to the AI Question</p>
          <p class="text-xs text-gray-500">The AI interviewer will read each question aloud. If you didn't hear it, click <strong>"Repeat Question"</strong> to replay the audio. The question text is also shown on screen.</p>
        </div>
      </div>
      <!-- Step 3 -->
      <div class="flex gap-3">
        <div class="w-7 h-7 rounded-full bg-blue-500 text-white flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5">3</div>
        <div>
          <p class="font-semibold text-sm">Speak Your Answer</p>
          <p class="text-xs text-gray-500">After the AI finishes speaking, recording starts automatically. Speak clearly near your microphone. Your speech is auto-transcribed to text. You can also type or edit your answer manually.</p>
        </div>
      </div>
      <!-- Step 4 -->
      <div class="flex gap-3">
        <div class="w-7 h-7 rounded-full bg-blue-500 text-white flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5">4</div>
        <div>
          <p class="font-semibold text-sm">Use the Action Buttons</p>
          <p class="text-xs text-gray-500 mt-1">
          </p>
          <div class="mt-2 space-y-1.5">
            <div class="flex items-center gap-2 text-xs">
              <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-blue-500 text-white rounded font-medium"><i class="fas fa-paper-plane" style="font-size:8px"></i> Submit</span>
              <span class="text-gray-500">Submit your answer and move to the next question</span>
            </div>
            <div class="flex items-center gap-2 text-xs">
              <span class="inline-flex items-center gap-1 px-2 py-0.5 border border-gray-300 rounded font-medium text-gray-600"><i class="fas fa-forward" style="font-size:8px"></i> Skip</span>
              <span class="text-gray-500">Skip a question you don't want to answer</span>
            </div>
            <div class="flex items-center gap-2 text-xs">
              <span class="inline-flex items-center gap-1 px-2 py-0.5 border border-green-300 text-green-600 rounded font-medium"><i class="fas fa-save" style="font-size:8px"></i> Save</span>
              <span class="text-gray-500">Save your progress and come back later</span>
            </div>
            <div class="flex items-center gap-2 text-xs">
              <span class="inline-flex items-center gap-1 px-2 py-0.5 border border-red-300 text-red-500 rounded font-medium"><i class="fas fa-sign-out-alt" style="font-size:8px"></i> End</span>
              <span class="text-gray-500">End the interview early and generate your AI feedback report</span>
            </div>
          </div>
        </div>
      </div>
      <!-- Step 5 -->
      <div class="flex gap-3">
        <div class="w-7 h-7 rounded-full bg-green-500 text-white flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5">5</div>
        <div>
          <p class="font-semibold text-sm">Get Your AI Report</p>
          <p class="text-xs text-gray-500">After answering all questions or clicking "End", an AI-powered report is generated with scores for technical skills, communication, confidence, and personalized improvement tips.</p>
        </div>
      </div>
    </div>

    <!-- Tips -->
    <div class="mt-5 p-3 bg-amber-50 dark:bg-amber-900/20 rounded-lg border border-amber-200 dark:border-amber-800">
      <p class="text-xs font-semibold text-amber-700 dark:text-amber-400 mb-2"><i class="fas fa-lightbulb mr-1"></i> Tips for Best Results</p>
      <ul class="text-xs text-amber-600 dark:text-amber-300 space-y-1">
        <li><i class="fas fa-check mr-1"></i> Use a quiet environment with minimal background noise</li>
        <li><i class="fas fa-check mr-1"></i> Speak clearly and at a normal pace</li>
        <li><i class="fas fa-check mr-1"></i> If transcription fails, you can always type your answer manually</li>
        <li><i class="fas fa-check mr-1"></i> Use "Save" if you need a break - you can resume later from the dashboard</li>
      </ul>
    </div>
  </div>
</div>

<script>
const selected = { interviewType: 'behavioral', difficulty: 'medium' };
let cameraReady = false;
let previewStream = null;

// Selection logic
document.querySelectorAll('.sel-card').forEach(card => {
  card.addEventListener('click', () => {
    const group = card.dataset.group;
    selected[group] = card.dataset.value;
    document.querySelectorAll(`.sel-card[data-group="${group}"]`).forEach(c => {
      c.classList.remove('border-accent', 'bg-green-50', 'dark:bg-green-950');
      c.classList.add('border-gray-200');
      const icon = c.querySelector('.sel-icon');
      if (icon) { icon.classList.remove('text-accent'); icon.classList.add('text-gray-500'); }
      const bg = c.querySelector('.w-10');
      if (bg) { bg.classList.remove('bg-green-100'); bg.classList.add('bg-gray-100'); }
    });
    card.classList.remove('border-gray-200');
    card.classList.add('border-accent', 'bg-green-50', 'dark:bg-green-950');
    const icon = card.querySelector('.sel-icon');
    if (icon) { icon.classList.remove('text-gray-500'); icon.classList.add('text-accent'); }
    const bg = card.querySelector('.w-10');
    if (bg) { bg.classList.remove('bg-gray-100'); bg.classList.add('bg-green-100'); }
  });
});

// Set defaults
document.querySelector('.sel-card[data-value="behavioral"]').click();
document.querySelector('.sel-card[data-value="medium"]').click();

async function checkCamera() {
  const statusEl = document.getElementById('cam-status');
  const iconEl = document.getElementById('cam-icon');
  const btnEl = document.getElementById('cam-btn');
  const wrapEl = document.getElementById('cam-preview-wrap');
  const videoEl = document.getElementById('cam-preview');

  btnEl.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
  try {
    previewStream = await navigator.mediaDevices.getUserMedia({ video: true, audio: true });
    videoEl.srcObject = previewStream;
    wrapEl.classList.remove('hidden');
    statusEl.textContent = 'Camera & microphone ready';
    statusEl.classList.add('text-green-600');
    iconEl.classList.remove('text-gray-500');
    iconEl.classList.add('text-green-600');
    btnEl.textContent = 'Ready';
    btnEl.disabled = true;
    btnEl.classList.add('opacity-50');
    cameraReady = true;
    document.getElementById('start-btn').disabled = false;
  } catch (err) {
    statusEl.textContent = err.name === 'NotAllowedError'
      ? 'Permission denied. Allow camera & microphone in browser settings.'
      : 'Camera not available: ' + err.message;
    statusEl.classList.add('text-red-600');
    iconEl.classList.add('text-red-600');
    btnEl.textContent = 'Retry';
    cameraReady = false;
  }
}

async function startInterview() {
  const jobRole = document.getElementById('job-role').value.trim();
  if (!jobRole) return showToast('Please enter a job role', 'error');
  if (!cameraReady) return showToast('Please check camera access first', 'error');

  // Stop preview stream
  if (previewStream) { previewStream.getTracks().forEach(t => t.stop()); }

  const btn = document.getElementById('start-btn');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Generating interview questions...';

  try {
    const res = await fetch('/interview/start', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        jobRole,
        company: document.getElementById('company').value.trim(),
        interviewType: selected.interviewType,
        difficulty: selected.difficulty,
      }),
    });
    const data = await res.json();
    if (data.success) window.location.href = '/interview/' + data.interviewId + '/session';
    else showToast(data.error || 'Failed to start', 'error');
  } catch (err) { showToast('Failed to start interview', 'error'); }
  btn.disabled = false;
  btn.innerHTML = '<i class="fas fa-video mr-2"></i>Start Video Interview';
}
</script>

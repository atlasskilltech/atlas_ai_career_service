<% const r = result || {}; %>
<% const parseJSON = (v) => { try { return typeof v === 'string' ? JSON.parse(v) : (v || []); } catch { return []; } }; %>
<% const strengths = parseJSON(r.strengths); %>
<% const weaknesses = parseJSON(r.weaknesses); %>
<% const suggestions = parseJSON(r.suggestions); %>
<% const qFeedback = parseJSON(r.question_feedback); %>

<div class="max-w-5xl mx-auto space-y-6">
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
    <div>
      <a href="/interview" class="text-sm text-gray-500 hover:text-gray-700"><i class="fas fa-arrow-left mr-1"></i>Back to Interviews</a>
      <h1 class="text-xl sm:text-2xl font-bold mt-1">Interview Performance Report</h1>
      <p class="text-gray-500 capitalize text-sm"><%= interview.interview_type.replace('_', ' ') %> | <%= interview.job_role %><%= interview.company ? ' at ' + interview.company : '' %> | <%= interview.difficulty %></p>
    </div>
    <div class="text-left sm:text-right text-sm text-gray-500 flex-shrink-0">
      <p><%= interview.total_questions %> questions | <%= Math.floor((interview.duration_seconds || 0) / 60) %> min</p>
      <p><%= interview.completed_at ? new Date(interview.completed_at).toLocaleDateString() : '' %></p>
    </div>
  </div>

  <% if (r.id) { %>
  <!-- Overall Score -->
  <div class="card text-center py-6">
    <div class="text-4xl sm:text-6xl font-bold <%= r.overall_score >= 70 ? 'text-green-600' : r.overall_score >= 50 ? 'text-yellow-600' : 'text-red-600' %>"><%= r.overall_score %>%</div>
    <p class="text-lg text-gray-500 mt-1">Overall Interview Score</p>
    <div class="mt-3">
      <span class="<%= r.overall_score >= 80 ? 'badge-success' : r.overall_score >= 60 ? 'badge-warning' : 'badge-danger' %> text-sm px-4 py-1">
        <%= r.overall_score >= 80 ? 'Excellent' : r.overall_score >= 60 ? 'Good' : r.overall_score >= 40 ? 'Needs Improvement' : 'Needs Practice' %>
      </span>
    </div>
  </div>

  <!-- Score Breakdown + Radar Chart -->
  <div class="grid lg:grid-cols-2 gap-4">
    <!-- Scores -->
    <div class="card">
      <h3 class="font-semibold mb-4"><i class="fas fa-chart-bar mr-2"></i>Skill Breakdown</h3>
      <div class="space-y-4">
        <% [
          {label: 'Technical Knowledge', score: r.technical_score, color: 'blue'},
          {label: 'Communication Skills', score: r.communication_score, color: 'green'},
          {label: 'Confidence Level', score: r.confidence_score, color: 'purple'},
          {label: 'Problem Solving', score: r.problem_solving_score, color: 'orange'},
        ].forEach(s => { %>
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="font-medium"><%= s.label %></span>
              <span class="font-bold <%= s.score >= 70 ? 'text-green-600' : s.score >= 50 ? 'text-yellow-600' : 'text-red-600' %>"><%= s.score %>%</span>
            </div>
            <div class="progress-bar"><div class="progress-fill bg-<%= s.color %>-500" style="width: <%= s.score %>%"></div></div>
          </div>
        <% }); %>
      </div>
    </div>

    <!-- Radar Chart -->
    <div class="card">
      <h3 class="font-semibold mb-4"><i class="fas fa-chart-pie mr-2"></i>Skills Radar</h3>
      <canvas id="radarChart" height="250"></canvas>
    </div>
  </div>

  <!-- Strengths & Weaknesses -->
  <div class="grid lg:grid-cols-2 gap-4">
    <div class="card">
      <h3 class="font-semibold mb-3 text-green-600"><i class="fas fa-trophy mr-2"></i>Strengths</h3>
      <ul class="space-y-2">
        <% strengths.forEach(s => { %>
          <li class="flex items-start gap-2 text-sm"><i class="fas fa-check-circle text-green-500 mt-0.5"></i><span><%= s %></span></li>
        <% }); %>
        <% if (strengths.length === 0) { %><li class="text-sm text-gray-400">No data available</li><% } %>
      </ul>
    </div>
    <div class="card">
      <h3 class="font-semibold mb-3 text-red-600"><i class="fas fa-exclamation-triangle mr-2"></i>Areas to Improve</h3>
      <ul class="space-y-2">
        <% weaknesses.forEach(w => { %>
          <li class="flex items-start gap-2 text-sm"><i class="fas fa-arrow-up text-red-500 mt-0.5"></i><span><%= w %></span></li>
        <% }); %>
        <% if (weaknesses.length === 0) { %><li class="text-sm text-gray-400">No data available</li><% } %>
      </ul>
    </div>
  </div>

  <!-- Detailed Feedback -->
  <div class="card">
    <h3 class="font-semibold mb-3"><i class="fas fa-comment-dots mr-2"></i>Detailed Feedback</h3>
    <p class="text-sm text-gray-600 dark:text-gray-400 whitespace-pre-wrap leading-relaxed"><%= r.detailed_feedback || 'No detailed feedback available.' %></p>
  </div>

  <!-- Improvement Suggestions -->
  <% if (suggestions.length > 0) { %>
  <div class="card">
    <h3 class="font-semibold mb-3"><i class="fas fa-lightbulb text-yellow-500 mr-2"></i>Improvement Suggestions</h3>
    <div class="grid md:grid-cols-2 gap-3">
      <% suggestions.forEach((s, i) => { %>
        <div class="flex items-start gap-2 p-3 bg-yellow-50 dark:bg-yellow-900/20 rounded-lg">
          <span class="w-6 h-6 rounded-full bg-yellow-200 dark:bg-yellow-800 text-yellow-800 dark:text-yellow-200 flex items-center justify-center text-xs font-bold flex-shrink-0"><%= i + 1 %></span>
          <span class="text-sm"><%= s %></span>
        </div>
      <% }); %>
    </div>
  </div>
  <% } %>

  <!-- Question-by-Question Feedback -->
  <% if (answers && answers.length > 0) { %>
  <div class="card">
    <h3 class="font-semibold mb-4"><i class="fas fa-list-ol mr-2"></i>Question-by-Question Review</h3>
    <div class="space-y-4">
      <% answers.forEach((a, i) => {
        const qf = qFeedback.find(f => f.questionIndex === (i + 1)) || {};
        const ratingColor = qf.rating === 'good' ? 'green' : qf.rating === 'needs_improvement' ? 'red' : 'yellow';
      %>
        <div class="p-4 bg-gray-50 dark:bg-gray-800 rounded-lg">
          <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-2 mb-2">
            <div class="flex items-start gap-2 min-w-0">
              <span class="w-6 h-6 bg-primary text-white rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0"><%= i + 1 %></span>
              <p class="font-medium text-sm"><%= a.question %></p>
            </div>
            <% if (qf.rating) { %>
              <span class="badge-<%= ratingColor === 'green' ? 'success' : ratingColor === 'red' ? 'danger' : 'warning' %> text-xs flex-shrink-0 self-start"><%= (qf.rating || '').replace('_', ' ') %></span>
            <% } %>
          </div>
          <p class="text-xs text-gray-500 ml-8 mb-1"><%= a.word_count %> words | <%= a.answer_duration_seconds %>s | <%= a.filler_words_count %> filler words</p>
          <p class="text-sm text-gray-600 dark:text-gray-400 ml-8 truncate"><%= a.answer_text %></p>
          <% if (qf.comment) { %>
            <p class="text-xs text-<%= ratingColor %>-600 ml-8 mt-1"><i class="fas fa-comment mr-1"></i><%= qf.comment %></p>
          <% } %>
        </div>
      <% }); %>
    </div>
  </div>
  <% } %>

  <!-- Actions -->
  <div class="flex flex-col sm:flex-row justify-center gap-3">
    <a href="/interview/new" class="btn-primary text-center"><i class="fas fa-redo mr-2"></i>Practice Again</a>
    <a href="/interview/feedback/all" class="btn-outline text-center"><i class="fas fa-history mr-2"></i>View All History</a>
  </div>

  <% } else { %>
  <div class="card text-center py-12 text-gray-400">
    <i class="fas fa-clock text-4xl mb-3"></i>
    <p>Report is being generated. Please wait or check back later.</p>
  </div>
  <% } %>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
const ctx = document.getElementById('radarChart');
if (ctx) {
  new Chart(ctx, {
    type: 'radar',
    data: {
      labels: ['Technical', 'Communication', 'Confidence', 'Problem Solving'],
      datasets: [{
        label: 'Your Score',
        data: [<%= r.technical_score || 0 %>, <%= r.communication_score || 0 %>, <%= r.confidence_score || 0 %>, <%= r.problem_solving_score || 0 %>],
        backgroundColor: 'rgba(99, 150, 0, 0.15)',
        borderColor: 'hsl(80, 89%, 40%)',
        borderWidth: 2,
        pointBackgroundColor: 'hsl(80, 89%, 40%)',
        pointRadius: 4,
      }]
    },
    options: {
      responsive: true,
      scales: {
        r: {
          beginAtZero: true,
          max: 100,
          ticks: { stepSize: 20, display: false },
          grid: { color: 'rgba(0,0,0,0.05)' },
          pointLabels: { font: { size: 12, weight: '600' } },
        }
      },
      plugins: { legend: { display: false } }
    }
  });
}
</script>

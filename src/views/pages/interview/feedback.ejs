<div class="max-w-3xl mx-auto space-y-6">
  <a href="/interview" class="text-gray-500 hover:text-gray-700 text-sm"><i class="fas fa-arrow-left mr-1"></i>Back</a>

  <h1 class="text-2xl font-bold">Interview Feedback</h1>
  <p class="text-gray-500 capitalize"><%= interview.interview_type %> Interview | <%= interview.job_role || 'General' %></p>

  <% if (feedback) { %>
    <!-- Scores -->
    <div class="grid grid-cols-5 gap-4">
      <% [
        {label: 'Confidence', score: feedback.confidence_score, color: 'blue'},
        {label: 'Communication', score: feedback.communication_score, color: 'green'},
        {label: 'Technical', score: feedback.technical_score, color: 'purple'},
        {label: 'STAR Method', score: feedback.star_score, color: 'orange'},
        {label: 'Overall', score: feedback.overall_score, color: 'primary'},
      ].forEach(s => { %>
        <div class="card text-center">
          <div class="text-3xl font-bold"><%= s.score %>%</div>
          <p class="text-xs text-gray-500 mt-1"><%= s.label %></p>
          <div class="progress-bar mt-2"><div class="progress-fill bg-<%= s.color %>-500" style="width: <%= s.score %>%"></div></div>
        </div>
      <% }); %>
    </div>

    <!-- Detailed Feedback -->
    <div class="card">
      <h3 class="font-semibold mb-3"><i class="fas fa-comment-dots mr-2"></i>Detailed Feedback</h3>
      <p class="text-sm text-gray-600 whitespace-pre-wrap"><%= feedback.feedback_text %></p>
    </div>

    <!-- Suggestions -->
    <% const suggestions = typeof feedback.suggestions === 'string' ? JSON.parse(feedback.suggestions) : (feedback.suggestions || []); %>
    <% if (suggestions.length > 0) { %>
      <div class="card">
        <h3 class="font-semibold mb-3"><i class="fas fa-lightbulb text-yellow-500 mr-2"></i>Improvement Suggestions</h3>
        <ul class="space-y-2">
          <% suggestions.forEach(s => { %>
            <li class="flex items-start gap-2 text-sm"><i class="fas fa-arrow-right text-accent mt-1"></i><span><%= s %></span></li>
          <% }); %>
        </ul>
      </div>
    <% } %>
  <% } else { %>
    <div class="card text-center py-12 text-gray-400">
      <p>No feedback available yet. Complete the interview first.</p>
    </div>
  <% } %>
</div>

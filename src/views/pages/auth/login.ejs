<div class="card">
  <h2 class="text-2xl font-bold text-center mb-6">Welcome Back</h2>
  <form action="/auth/login" method="POST" class="space-y-4">
    <div>
      <label class="label-field">Email</label>
      <input type="email" name="email" required class="input-field" placeholder="your@atlas.edu.in">
    </div>
    <div>
      <label class="label-field">Password</label>
      <input type="password" name="password" required class="input-field" placeholder="Enter your password">
    </div>
    <div class="flex items-center justify-between text-sm">
      <label class="flex items-center gap-2 cursor-pointer">
        <input type="checkbox" name="remember" class="rounded">
        <span class="text-gray-600">Remember me</span>
      </label>
      <a href="/auth/forgot-password" class="text-accent hover:underline">Forgot Password?</a>
    </div>
    <button type="submit" class="btn-primary w-full">Sign In</button>
  </form>
  <div class="relative my-6">
    <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-gray-200 dark:border-gray-700"></div></div>
    <div class="relative flex justify-center text-sm"><span class="px-4 bg-white dark:bg-gray-900 text-gray-500">or</span></div>
  </div>
  <a href="/auth/google" class="flex items-center justify-center gap-3 w-full px-4 py-2.5 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800 transition text-sm font-medium">
    <svg width="18" height="18" viewBox="0 0 48 48"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59a14.5 14.5 0 0 1 0-9.18l-7.98-6.19a24.01 24.01 0 0 0 0 21.56l7.98-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/></svg>
    Sign in with Google
  </a>
  <p class="text-center text-sm text-gray-500 mt-6">
    Don't have an account? <a href="/auth/register" class="text-accent hover:underline font-medium">Register</a>
  </p>
</div>

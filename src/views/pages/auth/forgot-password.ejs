<div class="card">
  <h2 class="text-2xl font-bold text-center mb-2">Forgot Password</h2>
  <p class="text-gray-500 text-center text-sm mb-6">Enter your email to receive a reset link</p>
  <form action="/auth/forgot-password" method="POST" class="space-y-4">
    <div>
      <label class="label-field">Email</label>
      <input type="email" name="email" required class="input-field" placeholder="your@atlas.edu.in">
    </div>
    <button type="submit" class="btn-primary w-full">Send Reset Link</button>
  </form>
  <p class="text-center text-sm text-gray-500 mt-6">
    <a href="/auth/login" class="text-accent hover:underline"><i class="fas fa-arrow-left mr-1"></i> Back to Login</a>
  </p>
</div>

<div class="space-y-6">
  <!-- Welcome -->
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
    <div>
      <h1 class="text-xl sm:text-2xl font-bold">Welcome back, <%= user.name %>!</h1>
      <p class="text-gray-500 mt-1 text-sm sm:text-base">Here's your career progress overview</p>
    </div>
    <a href="/resume/new" class="btn-primary text-sm flex-shrink-0 self-start sm:self-auto"><i class="fas fa-plus mr-2"></i> New Resume</a>
  </div>

  <!-- Stats Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
    <div class="stat-card">
      <div class="flex items-center justify-between w-full mb-3">
        <span class="text-sm text-gray-500">Resume Score</span>
        <div class="w-10 h-10 bg-blue-100 dark:bg-blue-900 rounded-lg flex items-center justify-center">
          <i class="fas fa-file-alt text-blue-600"></i>
        </div>
      </div>
      <div class="text-3xl font-bold"><%= resumeScore %>%</div>
      <div class="progress-bar w-full mt-2">
        <div class="progress-fill bg-blue-500" style="width: <%= resumeScore %>%"></div>
      </div>
    </div>

    <div class="stat-card">
      <div class="flex items-center justify-between w-full mb-3">
        <span class="text-sm text-gray-500">Applications</span>
        <div class="w-10 h-10 bg-green-100 dark:bg-green-900 rounded-lg flex items-center justify-center">
          <i class="fas fa-paper-plane text-green-600"></i>
        </div>
      </div>
      <div class="text-3xl font-bold"><%= totalApplications %></div>
      <p class="text-sm text-gray-500 mt-1">Total submitted</p>
    </div>

    <div class="stat-card">
      <div class="flex items-center justify-between w-full mb-3">
        <span class="text-sm text-gray-500">Interviews</span>
        <div class="w-10 h-10 bg-purple-100 dark:bg-purple-900 rounded-lg flex items-center justify-center">
          <i class="fas fa-calendar-check text-purple-600"></i>
        </div>
      </div>
      <div class="text-3xl font-bold"><%= interviewInvitations %></div>
      <p class="text-sm text-gray-500 mt-1">Invitations received</p>
    </div>

    <div class="stat-card">
      <div class="flex items-center justify-between w-full mb-3">
        <span class="text-sm text-gray-500">Interview Readiness</span>
        <div class="w-10 h-10 bg-orange-100 dark:bg-orange-900 rounded-lg flex items-center justify-center">
          <i class="fas fa-bolt text-orange-600"></i>
        </div>
      </div>
      <div class="text-3xl font-bold"><%= interviewReadiness %>%</div>
      <div class="progress-bar w-full mt-2">
        <div class="progress-fill bg-orange-500" style="width: <%= interviewReadiness %>%"></div>
      </div>
    </div>
  </div>

  <!-- Quick Actions & Skill Gaps -->
  <div class="grid lg:grid-cols-2 gap-6">
    <div class="card">
      <h3 class="text-lg font-semibold mb-4"><i class="fas fa-bolt text-accent mr-2"></i>Quick Actions</h3>
      <div class="grid grid-cols-2 gap-3">
        <a href="/resume/new" class="flex items-center gap-3 p-3 rounded-lg bg-gray-50 dark:bg-gray-800 hover:bg-gray-100 dark:hover:bg-gray-700 transition">
          <i class="fas fa-file-alt text-blue-500"></i>
          <span class="text-sm font-medium">Build Resume</span>
        </a>
        <a href="/resume/ats" class="flex items-center gap-3 p-3 rounded-lg bg-gray-50 dark:bg-gray-800 hover:bg-gray-100 dark:hover:bg-gray-700 transition">
          <i class="fas fa-search-plus text-green-500"></i>
          <span class="text-sm font-medium">ATS Check</span>
        </a>
        <a href="/interview/new" class="flex items-center gap-3 p-3 rounded-lg bg-gray-50 dark:bg-gray-800 hover:bg-gray-100 dark:hover:bg-gray-700 transition">
          <i class="fas fa-microphone text-purple-500"></i>
          <span class="text-sm font-medium">Mock Interview</span>
        </a>
        <a href="/cover-letter/new" class="flex items-center gap-3 p-3 rounded-lg bg-gray-50 dark:bg-gray-800 hover:bg-gray-100 dark:hover:bg-gray-700 transition">
          <i class="fas fa-envelope text-orange-500"></i>
          <span class="text-sm font-medium">Cover Letter</span>
        </a>
        <a href="/jobs" class="flex items-center gap-3 p-3 rounded-lg bg-gray-50 dark:bg-gray-800 hover:bg-gray-100 dark:hover:bg-gray-700 transition">
          <i class="fas fa-briefcase text-red-500"></i>
          <span class="text-sm font-medium">Track Jobs</span>
        </a>
        <a href="/skills" class="flex items-center gap-3 p-3 rounded-lg bg-gray-50 dark:bg-gray-800 hover:bg-gray-100 dark:hover:bg-gray-700 transition">
          <i class="fas fa-chart-line text-teal-500"></i>
          <span class="text-sm font-medium">Skill Analysis</span>
        </a>
      </div>
    </div>

    <div class="card">
      <h3 class="text-lg font-semibold mb-4"><i class="fas fa-exclamation-triangle text-yellow-500 mr-2"></i>Skill Gaps</h3>
      <% if (skillGaps.length > 0) { %>
        <div class="space-y-3">
          <% skillGaps.forEach(skill => { %>
            <div class="flex items-center justify-between p-3 rounded-lg bg-yellow-50 dark:bg-yellow-900/20">
              <span class="text-sm font-medium"><%= skill %></span>
              <a href="/skills" class="text-xs text-accent hover:underline">Learn</a>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <div class="text-center py-8 text-gray-400">
          <i class="fas fa-check-circle text-4xl mb-3"></i>
          <p>No skill gaps analyzed yet</p>
          <a href="/skills" class="text-accent text-sm hover:underline mt-2 inline-block">Run Analysis</a>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Career Flow -->
  <div class="card">
    <h3 class="text-lg font-semibold mb-6"><i class="fas fa-road text-primary mr-2"></i>Your Career Journey</h3>
    <div class="flex items-center justify-between overflow-x-auto pb-4">
      <% const steps = [
        { icon: 'fa-user-plus', label: 'Sign Up', path: '/dashboard', done: true },
        { icon: 'fa-file-alt', label: 'Create Resume', path: '/resume', done: totalResumes > 0 },
        { icon: 'fa-search-plus', label: 'ATS Analysis', path: '/resume/ats', done: resumeScore > 0 },
        { icon: 'fa-linkedin', label: 'Optimize LinkedIn', path: '/linkedin', done: false },
        { icon: 'fa-briefcase', label: 'Track Jobs', path: '/jobs', done: totalApplications > 0 },
        { icon: 'fa-microphone', label: 'Mock Interview', path: '/interview', done: interviewReadiness > 0 },
        { icon: 'fa-comments', label: 'Get Feedback', path: '/interview/feedback/all', done: false },
        { icon: 'fa-graduation-cap', label: 'Placement Ready', path: '/dashboard', done: false },
      ]; %>
      <% steps.forEach((step, i) => { %>
        <div class="flex flex-col items-center min-w-[100px]">
          <a href="<%= step.path %>" class="w-12 h-12 rounded-full flex items-center justify-center mb-2 transition
            <%= step.done ? 'bg-accent text-white' : 'bg-gray-100 dark:bg-gray-800 text-gray-400' %>">
            <i class="fas <%= step.icon %>"></i>
          </a>
          <span class="text-xs text-center font-medium"><%= step.label %></span>
        </div>
        <% if (i < steps.length - 1) { %>
          <div class="flex-1 h-0.5 mx-2 <%= step.done ? 'bg-accent' : 'bg-gray-200 dark:bg-gray-700' %>"></div>
        <% } %>
      <% }); %>
    </div>
  </div>
</div>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold">All Students</h1>
    <span class="badge-info"><%= students.length %> students</span>
  </div>

  <div class="card">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead><tr class="border-b dark:border-gray-700 text-left">
          <th class="py-3 px-3">#</th><th class="py-3 px-3">Name</th><th class="py-3 px-3">Email</th><th class="py-3 px-3">Department</th><th class="py-3 px-3">Year</th><th class="py-3 px-3">Joined</th>
        </tr></thead>
        <tbody>
          <% students.forEach((s, i) => { %>
            <tr class="border-b dark:border-gray-800 hover:bg-gray-50 dark:hover:bg-gray-800">
              <td class="py-3 px-3 text-gray-500"><%= i + 1 %></td>
              <td class="py-3 px-3 font-medium"><%= s.name %></td>
              <td class="py-3 px-3 text-gray-500"><%= s.email %></td>
              <td class="py-3 px-3"><%= s.department || '-' %></td>
              <td class="py-3 px-3"><%= s.year_of_study || '-' %></td>
              <td class="py-3 px-3 text-gray-500"><%= new Date(s.created_at).toLocaleDateString() %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js"></script>

<style>
  .fc { font-family: 'Inter', sans-serif !important; }
  .fc .fc-toolbar-title { font-size: 1.1rem !important; font-weight: 700 !important; }
  .fc .fc-button { border-radius: 10px !important; font-size: 12px !important; font-weight: 600 !important; padding: 6px 14px !important; text-transform: capitalize !important; }
  .fc .fc-button-primary { background: hsl(var(--accent)) !important; border-color: hsl(var(--accent)) !important; }
  .fc .fc-button-primary:not(.fc-button-active):not(:disabled):hover { background: hsl(80 89% 35%) !important; }
  .fc .fc-button-primary:disabled { opacity: 0.5 !important; }
  .fc .fc-button-primary.fc-button-active { background: hsl(var(--primary)) !important; border-color: hsl(var(--primary)) !important; }
  .fc .fc-daygrid-day-number { font-size: 13px !important; font-weight: 600 !important; padding: 6px 10px !important; }
  .fc .fc-event { border-radius: 6px !important; border: none !important; padding: 3px 6px !important; font-size: 11px !important; font-weight: 500 !important; cursor: pointer !important; }
  .fc .fc-col-header-cell-cushion { font-size: 11px !important; font-weight: 700 !important; text-transform: uppercase !important; letter-spacing: 0.05em !important; color: #6b7280 !important; }
  .fc td, .fc th { border-color: #f3f4f6 !important; }
  .dark .fc td, .dark .fc th { border-color: #1f2937 !important; }
  .dark .fc .fc-col-header-cell-cushion { color: #9ca3af !important; }
  .dark .fc .fc-daygrid-day-number { color: #d1d5db !important; }
  .fc .fc-daygrid-day.fc-day-today { background: hsla(80, 89%, 40%, 0.05) !important; }
  .fc .fc-toolbar { flex-wrap: wrap !important; gap: 8px !important; }
</style>

<div class="space-y-5">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
    <div>
      <h1 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white tracking-tight">Interview Calendar</h1>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5">Visual schedule of all interviews</p>
    </div>
    <div class="flex items-center gap-2 flex-wrap">
      <a href="/admin/interviews"
         class="inline-flex items-center gap-2 px-4 py-2.5 border border-gray-200 dark:border-gray-700 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-800/80 text-sm font-medium text-gray-600 dark:text-gray-300 transition-all active:scale-[0.97]">
        <i class="fas fa-list text-xs"></i> List View
      </a>
      <button onclick="openScheduleModalCal()"
         class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-white text-sm font-semibold transition-all shadow-sm hover:shadow-md active:scale-[0.97]"
         style="background:hsl(var(--accent))">
        <i class="fas fa-plus text-xs"></i> Schedule Interview
      </button>
    </div>
  </div>

  <!-- Stats Row -->
  <div class="grid grid-cols-3 sm:grid-cols-5 gap-3">
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-100 dark:border-gray-800 p-3 text-center">
      <div class="text-lg font-bold text-blue-600"><%= stats.scheduled || 0 %></div>
      <p class="text-[10px] text-gray-400 font-medium">Scheduled</p>
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-100 dark:border-gray-800 p-3 text-center">
      <div class="text-lg font-bold text-green-600"><%= stats.completed || 0 %></div>
      <p class="text-[10px] text-gray-400 font-medium">Completed</p>
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-100 dark:border-gray-800 p-3 text-center">
      <div class="text-lg font-bold text-purple-600"><%= stats.today || 0 %></div>
      <p class="text-[10px] text-gray-400 font-medium">Today</p>
    </div>
    <div class="hidden sm:block bg-white dark:bg-gray-900 rounded-xl border border-gray-100 dark:border-gray-800 p-3 text-center">
      <div class="text-lg font-bold text-yellow-600"><%= stats.this_week || 0 %></div>
      <p class="text-[10px] text-gray-400 font-medium">This Week</p>
    </div>
    <div class="hidden sm:block bg-white dark:bg-gray-900 rounded-xl border border-gray-100 dark:border-gray-800 p-3 text-center">
      <div class="text-lg font-bold text-red-600"><%= stats.cancelled || 0 %></div>
      <p class="text-[10px] text-gray-400 font-medium">Cancelled</p>
    </div>
  </div>

  <!-- Legend -->
  <div class="flex flex-wrap gap-3 text-[11px] font-medium text-gray-500 dark:text-gray-400">
    <span class="inline-flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full" style="background:#3b82f6"></span> Scheduled</span>
    <span class="inline-flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full" style="background:#6366f1"></span> Confirmed</span>
    <span class="inline-flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full" style="background:#10b981"></span> Completed</span>
    <span class="inline-flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full" style="background:#ef4444"></span> Cancelled</span>
    <span class="inline-flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full" style="background:#f97316"></span> Rescheduled</span>
    <span class="inline-flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full" style="background:#6b7280"></span> No Show</span>
  </div>

  <!-- Calendar Container -->
  <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-100 dark:border-gray-800 p-4 sm:p-6 shadow-sm">
    <div id="calendar"></div>
  </div>
</div>

<!-- Event Detail Modal -->
<div id="cal-detail-modal" class="fixed inset-0 z-[100]" style="display:none" onclick="if(event.target===this)this.style.display='none'">
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
  <div class="absolute top-1/2 left-1/2 w-[95%] max-w-md bg-white dark:bg-gray-900 rounded-2xl shadow-2xl border border-gray-200 dark:border-gray-700 max-h-[80vh] overflow-y-auto" style="transform:translate(-50%,-50%)">
    <div class="sticky top-0 bg-white dark:bg-gray-900 px-6 py-4 border-b border-gray-100 dark:border-gray-800 flex items-center justify-between z-10">
      <h3 class="font-bold text-gray-900 dark:text-white text-sm">Interview Details</h3>
      <button onclick="document.getElementById('cal-detail-modal').style.display='none'" class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-400 transition"><i class="fas fa-times"></i></button>
    </div>
    <div id="cal-detail-content" class="p-6"></div>
  </div>
</div>

<!-- Schedule Modal (simplified for calendar) -->
<div id="cal-schedule-modal" class="fixed inset-0 z-[100]" style="display:none" onclick="if(event.target===this)this.style.display='none'">
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
  <div class="absolute top-1/2 left-1/2 w-[95%] max-w-2xl bg-white dark:bg-gray-900 rounded-2xl shadow-2xl border border-gray-200 dark:border-gray-700 max-h-[90vh] overflow-y-auto" style="transform:translate(-50%,-50%)">
    <div class="sticky top-0 bg-white dark:bg-gray-900 px-6 py-4 border-b border-gray-100 dark:border-gray-800 flex items-center justify-between z-10">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background:hsla(80,89%,40%,0.1)">
          <i class="fas fa-calendar-plus text-sm" style="color:hsl(var(--accent))"></i>
        </div>
        <h3 class="font-bold text-gray-900 dark:text-white">Schedule Interview</h3>
      </div>
      <button onclick="document.getElementById('cal-schedule-modal').style.display='none'" class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-400 transition"><i class="fas fa-times"></i></button>
    </div>
    <form id="cal-schedule-form" class="p-6 space-y-5">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="sm:col-span-2">
          <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1.5 uppercase tracking-wider">Select Job <span class="text-red-400">*</span></label>
          <select name="job_id" id="cal-sched-job" required onchange="calLoadStudents(this.value)"
            class="w-full text-sm border border-gray-200 dark:border-gray-700 rounded-xl px-3.5 py-2.5 bg-white dark:bg-gray-800 transition">
            <option value="">Choose a job...</option>
            <% jobs.forEach(function(j){ %>
              <option value="<%= j.id %>"><%= j.role_title %> - <%= j.company_name %></option>
            <% }); %>
          </select>
        </div>
        <div class="sm:col-span-2">
          <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1.5 uppercase tracking-wider">Students <span class="text-red-400">*</span></label>
          <div id="cal-student-area" class="border border-gray-200 dark:border-gray-700 rounded-xl p-3 min-h-[60px] bg-gray-50 dark:bg-gray-800/50">
            <p class="text-xs text-gray-400" id="cal-student-ph">Select a job first</p>
            <div id="cal-student-list" class="space-y-2 hidden"></div>
          </div>
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1.5 uppercase tracking-wider">Type</label>
          <select name="interview_type" class="w-full text-sm border border-gray-200 dark:border-gray-700 rounded-xl px-3.5 py-2.5 bg-white dark:bg-gray-800 transition">
            <% ['technical','hr','behavioral','case_study','group_discussion','aptitude','coding','panel'].forEach(function(t){ %>
              <option value="<%= t %>"><%= t.replace(/_/g,' ') %></option>
            <% }); %>
          </select>
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1.5 uppercase tracking-wider">Mode</label>
          <select name="mode" id="cal-mode" onchange="document.getElementById('cal-link').style.display=this.value==='online'?'block':'none';document.getElementById('cal-venue').style.display=this.value==='onsite'?'block':'none'"
            class="w-full text-sm border border-gray-200 dark:border-gray-700 rounded-xl px-3.5 py-2.5 bg-white dark:bg-gray-800 transition">
            <option value="online">Online</option><option value="onsite">Onsite</option><option value="phone">Phone</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1.5 uppercase tracking-wider">Date</label>
          <input type="date" name="scheduled_date" id="cal-sched-date" required class="w-full text-sm border border-gray-200 dark:border-gray-700 rounded-xl px-3.5 py-2.5 bg-white dark:bg-gray-800 transition">
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1.5 uppercase tracking-wider">Time</label>
          <input type="time" name="scheduled_time" required class="w-full text-sm border border-gray-200 dark:border-gray-700 rounded-xl px-3.5 py-2.5 bg-white dark:bg-gray-800 transition">
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1.5 uppercase tracking-wider">Duration</label>
          <select name="duration_minutes" class="w-full text-sm border border-gray-200 dark:border-gray-700 rounded-xl px-3.5 py-2.5 bg-white dark:bg-gray-800 transition">
            <% [30,45,60,90].forEach(function(d){ %><option value="<%= d %>" <%= d===60?'selected':'' %>><%= d %> min</option><% }); %>
          </select>
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1.5 uppercase tracking-wider">Round</label>
          <input type="number" name="round_number" value="1" min="1" class="w-full text-sm border border-gray-200 dark:border-gray-700 rounded-xl px-3.5 py-2.5 bg-white dark:bg-gray-800 transition">
        </div>
        <div id="cal-link" class="sm:col-span-2">
          <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1.5 uppercase tracking-wider">Meeting Link</label>
          <input type="url" name="meet_link" placeholder="https://..." class="w-full text-sm border border-gray-200 dark:border-gray-700 rounded-xl px-3.5 py-2.5 bg-white dark:bg-gray-800 transition">
        </div>
        <div id="cal-venue" class="sm:col-span-2" style="display:none">
          <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1.5 uppercase tracking-wider">Venue</label>
          <input type="text" name="venue" class="w-full text-sm border border-gray-200 dark:border-gray-700 rounded-xl px-3.5 py-2.5 bg-white dark:bg-gray-800 transition">
        </div>
      </div>
      <div class="flex justify-end gap-3 pt-3 border-t border-gray-100 dark:border-gray-800">
        <button type="button" onclick="document.getElementById('cal-schedule-modal').style.display='none'" class="px-4 py-2.5 text-sm font-medium border border-gray-200 dark:border-gray-700 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-800 transition-all">Cancel</button>
        <button type="submit" class="px-5 py-2.5 text-sm text-white rounded-xl font-semibold transition-all" style="background:hsl(var(--accent))">
          <i class="fas fa-calendar-check mr-1 text-xs"></i> Schedule
        </button>
      </div>
    </form>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function(){
  var calEl = document.getElementById('calendar');
  var calendar = new FullCalendar.Calendar(calEl, {
    initialView: window.innerWidth < 768 ? 'listWeek' : 'dayGridMonth',
    headerToolbar: {
      left: 'prev,next today',
      center: 'title',
      right: 'dayGridMonth,timeGridWeek,timeGridDay,listWeek'
    },
    events: {
      url: '/admin/interviews/api/calendar',
      failure: function(){ showToast('Failed to load calendar events', 'error'); }
    },
    eventClick: function(info){
      info.jsEvent.preventDefault();
      showCalDetail(info.event);
    },
    dateClick: function(info){
      document.getElementById('cal-sched-date').value = info.dateStr;
      openScheduleModalCal();
    },
    height: 'auto',
    dayMaxEvents: 3,
    nowIndicator: true,
    eventDisplay: 'block',
    buttonText: { today: 'Today', month: 'Month', week: 'Week', day: 'Day', list: 'List' },
  });
  calendar.render();
});

function showCalDetail(event) {
  var modal = document.getElementById('cal-detail-modal');
  var content = document.getElementById('cal-detail-content');
  var p = event.extendedProps;
  var statusColors = { scheduled:'#3b82f6', confirmed:'#4f46e5', completed:'#10b981', cancelled:'#ef4444', rescheduled:'#f97316', no_show:'#6b7280', in_progress:'#ca8a04' };

  var startDate = event.start ? event.start.toLocaleDateString('en-IN', { weekday:'short', day:'numeric', month:'short', year:'numeric' }) : '';
  var startTime = event.start ? event.start.toLocaleTimeString('en-IN', { hour:'2-digit', minute:'2-digit' }) : '';

  content.innerHTML = '<div class="space-y-4">'
    + '<div class="flex items-center gap-3 mb-2">'
    + '<div class="w-10 h-10 rounded-xl flex items-center justify-center text-white font-bold text-sm" style="background:' + (event.backgroundColor || '#3b82f6') + '">' + (p.student_name ? p.student_name.charAt(0) : '?') + '</div>'
    + '<div><p class="font-bold text-gray-900 dark:text-white text-sm">' + (p.student_name || '') + '</p>'
    + '<p class="text-xs text-gray-400">' + (p.company_name || '') + ' - ' + (p.role_title || '') + '</p></div></div>'
    + '<div class="grid grid-cols-2 gap-3">'
    + '<div class="bg-gray-50 dark:bg-gray-800/50 rounded-xl p-3"><p class="text-[10px] text-gray-400 font-medium uppercase mb-0.5">Date</p><p class="text-sm font-medium text-gray-900 dark:text-white">' + startDate + '</p></div>'
    + '<div class="bg-gray-50 dark:bg-gray-800/50 rounded-xl p-3"><p class="text-[10px] text-gray-400 font-medium uppercase mb-0.5">Time</p><p class="text-sm font-medium text-gray-900 dark:text-white">' + startTime + '</p></div>'
    + '<div class="bg-gray-50 dark:bg-gray-800/50 rounded-xl p-3"><p class="text-[10px] text-gray-400 font-medium uppercase mb-0.5">Type</p><p class="text-sm text-gray-900 dark:text-white capitalize">' + (p.interview_type || '').replace(/_/g,' ') + '</p></div>'
    + '<div class="bg-gray-50 dark:bg-gray-800/50 rounded-xl p-3"><p class="text-[10px] text-gray-400 font-medium uppercase mb-0.5">Mode</p><p class="text-sm text-gray-900 dark:text-white capitalize">' + (p.mode || '') + '</p></div>'
    + '<div class="bg-gray-50 dark:bg-gray-800/50 rounded-xl p-3"><p class="text-[10px] text-gray-400 font-medium uppercase mb-0.5">Round</p><p class="text-sm text-gray-900 dark:text-white">' + (p.round_number || 1) + '</p></div>'
    + '<div class="bg-gray-50 dark:bg-gray-800/50 rounded-xl p-3"><p class="text-[10px] text-gray-400 font-medium uppercase mb-0.5">Status</p><p class="text-sm font-semibold capitalize" style="color:' + (statusColors[p.status] || '#6b7280') + '">' + (p.status || '').replace(/_/g,' ') + '</p></div>'
    + '</div>'
    + '<div class="flex gap-2 pt-2"><a href="/admin/interviews?search=' + encodeURIComponent(p.student_name || '') + '" class="flex-1 text-center px-4 py-2.5 text-sm font-medium border border-gray-200 dark:border-gray-700 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-800 transition">View in List</a></div>'
    + '</div>';
  modal.style.display = 'block';
}

function openScheduleModalCal(){ document.getElementById('cal-schedule-modal').style.display = 'block'; }

function calLoadStudents(jobId){
  var area = document.getElementById('cal-student-list');
  var ph = document.getElementById('cal-student-ph');
  if (!jobId){ area.classList.add('hidden'); ph.classList.remove('hidden'); ph.textContent = 'Select a job first'; return; }
  ph.textContent = 'Loading...';
  fetch('/admin/interviews/api/students/' + jobId)
    .then(function(r){ return r.json(); })
    .then(function(res){
      if (!res.students || !res.students.length){ ph.textContent = 'No shortlisted students'; return; }
      var html = '';
      res.students.forEach(function(s){
        html += '<label class="flex items-center gap-2 p-2 rounded-lg hover:bg-white dark:hover:bg-gray-800 cursor-pointer">'
          + '<input type="checkbox" name="student_ids" value="' + s.user_id + '" class="rounded border-gray-300">'
          + '<span class="text-sm text-gray-900 dark:text-white">' + s.name + '</span>'
          + '<span class="text-[10px] text-gray-400">' + (s.program || '') + '</span></label>';
      });
      area.innerHTML = html;
      area.classList.remove('hidden');
      ph.classList.add('hidden');
    });
}

document.getElementById('cal-schedule-form').addEventListener('submit', function(e){
  e.preventDefault();
  var fd = new FormData(this);
  var data = {};
  fd.forEach(function(val, key){
    if (key === 'student_ids') { if (!data.student_ids) data.student_ids = []; data.student_ids.push(val); }
    else data[key] = val;
  });
  if (!data.student_ids || !data.student_ids.length){ showToast('Select students', 'error'); return; }
  fetch('/admin/interviews/api/schedule', {
    method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data)
  }).then(function(r){ return r.json(); }).then(function(res){
    if (res.success){ showToast('Scheduled!', 'success'); setTimeout(function(){ window.location.reload(); }, 1000); }
    else showToast(res.error || 'Failed', 'error');
  });
});
</script>

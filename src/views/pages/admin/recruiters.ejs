<div class="space-y-6">
  <h1 class="text-2xl font-bold">Recruiters</h1>

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
    <% if (recruiters.length) { %>
      <% recruiters.forEach(function(r) { %>
        <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-5">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 bg-blue-100 dark:bg-blue-900/30 rounded-lg flex items-center justify-center flex-shrink-0">
              <i class="fas fa-building text-blue-600 dark:text-blue-400"></i>
            </div>
            <div class="min-w-0">
              <p class="font-semibold truncate"><%= r.name %></p>
              <p class="text-xs text-gray-500 dark:text-gray-400"><%= r.industry || 'Industry N/A' %></p>
            </div>
          </div>
          <div class="flex items-center justify-between text-sm">
            <span class="text-gray-500"><%= r.job_count %> active job<%= r.job_count !== 1 ? 's' : '' %></span>
            <% if (r.is_verified) { %>
              <span class="text-xs text-green-600 dark:text-green-400 font-medium"><i class="fas fa-check-circle"></i> Verified</span>
            <% } else { %>
              <span class="text-xs text-gray-400">Unverified</span>
            <% } %>
          </div>
        </div>
      <% }); %>
    <% } else { %>
      <div class="col-span-full text-center py-8 text-gray-400">No recruiters found</div>
    <% } %>
  </div>
</div>

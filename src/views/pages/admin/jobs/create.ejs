<div class="max-w-4xl mx-auto space-y-5">
  <!-- Header -->
  <div class="flex items-center gap-3">
    <a href="/admin/jobs" class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-500"><i class="fas fa-arrow-left"></i></a>
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white"><%= job ? 'Edit Job' : 'Create New Job' %></h1>
      <p class="text-sm text-gray-500 mt-0.5">Fill in the details below</p>
    </div>
  </div>

  <!-- Step Indicator -->
  <div class="flex items-center justify-center gap-2">
    <% for (var si = 1; si <= 3; si++) { %>
      <div class="flex items-center gap-2">
        <div id="step-dot-<%= si %>" class="w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold transition"
             style="<%= si === 1 ? 'background:hsl(var(--accent));color:white' : 'background:#f3f4f6;color:#9ca3af' %>"><%= si %></div>
        <span id="step-label-<%= si %>" class="text-sm font-medium" style="color:<%= si === 1 ? 'hsl(var(--accent))' : '#9ca3af' %>">
          <%= si === 1 ? 'Basic Info' : si === 2 ? 'Details' : 'Process' %>
        </span>
        <% if (si < 3) { %>
          <div class="w-12 h-0.5" style="background:#e5e7eb"></div>
        <% } %>
      </div>
    <% } %>
  </div>

  <!-- Form -->
  <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6">

    <!-- Step 1: Basic Info -->
    <div id="step-1" class="space-y-5">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Basic Information</h2>

      <div class="grid sm:grid-cols-2 gap-4">
        <div class="sm:col-span-2">
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Company Name *</label>
          <input type="text" id="f-company-name" value="<%= job ? job.company_name : '' %>" required
            class="w-full border border-gray-300 dark:border-gray-700 rounded-lg px-4 py-2.5 bg-white dark:bg-gray-800 text-sm">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Company Logo URL</label>
          <input type="text" id="f-company-logo" value="<%= job ? (job.company_logo || '') : '' %>" placeholder="https://..."
            class="w-full border border-gray-300 dark:border-gray-700 rounded-lg px-4 py-2.5 bg-white dark:bg-gray-800 text-sm">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Role / Title *</label>
          <input type="text" id="f-role-title" value="<%= job ? job.role_title : '' %>" required
            class="w-full border border-gray-300 dark:border-gray-700 rounded-lg px-4 py-2.5 bg-white dark:bg-gray-800 text-sm">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Job Type</label>
          <select id="f-job-type" class="w-full border border-gray-300 dark:border-gray-700 rounded-lg px-4 py-2.5 bg-white dark:bg-gray-800 text-sm">
            <% ['full_time','part_time','internship','contract','freelance'].forEach(function(t){ %>
              <option value="<%= t %>" <%= (job && job.job_type === t) ? 'selected' : '' %>><%= t.replace(/_/g,' ') %></option>
            <% }); %>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">CTC Min (LPA)</label>
          <input type="number" id="f-ctc-min" step="0.5" value="<%= job ? (job.ctc_min || '') : '' %>"
            class="w-full border border-gray-300 dark:border-gray-700 rounded-lg px-4 py-2.5 bg-white dark:bg-gray-800 text-sm">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">CTC Max (LPA)</label>
          <input type="number" id="f-ctc-max" step="0.5" value="<%= job ? (job.ctc_max || '') : '' %>"
            class="w-full border border-gray-300 dark:border-gray-700 rounded-lg px-4 py-2.5 bg-white dark:bg-gray-800 text-sm">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Location</label>
          <input type="text" id="f-location" value="<%= job ? (job.location || '') : '' %>" placeholder="e.g. Mumbai, Bangalore"
            class="w-full border border-gray-300 dark:border-gray-700 rounded-lg px-4 py-2.5 bg-white dark:bg-gray-800 text-sm">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Work Mode</label>
          <select id="f-work-mode" class="w-full border border-gray-300 dark:border-gray-700 rounded-lg px-4 py-2.5 bg-white dark:bg-gray-800 text-sm">
            <% ['onsite','remote','hybrid'].forEach(function(w){ %>
              <option value="<%= w %>" <%= (job && job.work_mode === w) ? 'selected' : '' %>><%= w.charAt(0).toUpperCase() + w.slice(1) %></option>
            <% }); %>
          </select>
        </div>
      </div>

      <div class="flex justify-end pt-4">
        <button onclick="goToStep(2)" class="px-6 py-2.5 rounded-lg text-white text-sm font-medium" style="background:hsl(var(--accent))">
          Next: Details <i class="fas fa-arrow-right ml-1"></i>
        </button>
      </div>
    </div>

    <!-- Step 2: Details -->
    <div id="step-2" style="display:none" class="space-y-5">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Job Details</h2>

      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Job Description *</label>
        <div id="quill-editor" style="height:250px;border:1px solid #d1d5db;border-radius:0.5rem;"></div>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Required Skills (press Enter to add)</label>
        <div class="flex flex-wrap gap-2 p-3 border border-gray-300 dark:border-gray-700 rounded-lg bg-white dark:bg-gray-800 min-h-[44px]" id="skills-container">
          <input type="text" id="skill-input" placeholder="Type a skill and press Enter"
            class="flex-1 min-w-[150px] border-none outline-none bg-transparent text-sm" style="border:none">
        </div>
      </div>

      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">CGPA Cutoff</label>
          <input type="number" id="f-cgpa-cutoff" step="0.1" min="0" max="10" value="<%= job ? (job.cgpa_cutoff || '') : '' %>"
            class="w-full border border-gray-300 dark:border-gray-700 rounded-lg px-4 py-2.5 bg-white dark:bg-gray-800 text-sm">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Application Deadline</label>
          <input type="date" id="f-deadline" value="<%= job && job.application_deadline ? new Date(job.application_deadline).toISOString().split('T')[0] : '' %>"
            class="w-full border border-gray-300 dark:border-gray-700 rounded-lg px-4 py-2.5 bg-white dark:bg-gray-800 text-sm">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Joining Date</label>
          <input type="date" id="f-joining" value="<%= job && job.joining_date ? new Date(job.joining_date).toISOString().split('T')[0] : '' %>"
            class="w-full border border-gray-300 dark:border-gray-700 rounded-lg px-4 py-2.5 bg-white dark:bg-gray-800 text-sm">
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Eligible Programs (comma separated)</label>
        <input type="text" id="f-programs" value="<%= job && job.eligible_programs ? job.eligible_programs.join(', ') : '' %>" placeholder="B.Tech, M.Tech, MBA"
          class="w-full border border-gray-300 dark:border-gray-700 rounded-lg px-4 py-2.5 bg-white dark:bg-gray-800 text-sm">
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Eligible Branches (comma separated)</label>
          <input type="text" id="f-branches" value="<%= job && job.eligible_branches ? job.eligible_branches.join(', ') : '' %>" placeholder="CSE, IT, ECE"
            class="w-full border border-gray-300 dark:border-gray-700 rounded-lg px-4 py-2.5 bg-white dark:bg-gray-800 text-sm">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Eligible Years (comma separated)</label>
          <input type="text" id="f-years" value="<%= job && job.eligible_years ? job.eligible_years.join(', ') : '' %>" placeholder="2025, 2026"
            class="w-full border border-gray-300 dark:border-gray-700 rounded-lg px-4 py-2.5 bg-white dark:bg-gray-800 text-sm">
        </div>
      </div>

      <div class="flex justify-between pt-4">
        <button onclick="goToStep(1)" class="px-6 py-2.5 rounded-lg text-sm font-medium border border-gray-300 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-800 transition">
          <i class="fas fa-arrow-left mr-1"></i> Back
        </button>
        <button onclick="goToStep(3)" class="px-6 py-2.5 rounded-lg text-white text-sm font-medium" style="background:hsl(var(--accent))">
          Next: Process <i class="fas fa-arrow-right ml-1"></i>
        </button>
      </div>
    </div>

    <!-- Step 3: Process -->
    <div id="step-3" style="display:none" class="space-y-5">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Interview Process & Status</h2>

      <!-- Interview Rounds -->
      <div>
        <div class="flex items-center justify-between mb-3">
          <label class="text-sm font-medium text-gray-700 dark:text-gray-300">Interview Rounds</label>
          <button type="button" onclick="addRound()" class="text-sm font-medium" style="color:hsl(var(--accent))"><i class="fas fa-plus mr-1"></i> Add Round</button>
        </div>
        <div id="rounds-container" class="space-y-3"></div>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Selection Notes</label>
        <textarea id="f-selection-notes" rows="3" class="w-full border border-gray-300 dark:border-gray-700 rounded-lg px-4 py-2.5 bg-white dark:bg-gray-800 text-sm"><%= job ? (job.selection_notes || '') : '' %></textarea>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Status</label>
        <select id="f-status" class="w-full border border-gray-300 dark:border-gray-700 rounded-lg px-4 py-2.5 bg-white dark:bg-gray-800 text-sm">
          <% ['draft','active','closed','on_hold'].forEach(function(s){ %>
            <option value="<%= s %>" <%= (job && job.status === s) ? 'selected' : '' %>><%= s.replace(/_/g,' ').replace(/^\w/,function(c){return c.toUpperCase()}) %></option>
          <% }); %>
        </select>
      </div>

      <div class="flex justify-between pt-4 border-t border-gray-100 dark:border-gray-800">
        <button onclick="goToStep(2)" class="px-6 py-2.5 rounded-lg text-sm font-medium border border-gray-300 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-800 transition">
          <i class="fas fa-arrow-left mr-1"></i> Back
        </button>
        <button onclick="submitJob()" id="submit-btn" class="px-8 py-2.5 rounded-lg text-white text-sm font-medium" style="background:hsl(var(--accent))">
          <i class="fas fa-check mr-1"></i> <%= job ? 'Update Job' : 'Create Job' %>
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Quill.js CDN -->
<link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
<script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>

<script>
var currentStep = 1;
var skills = [];
var rounds = [];
var isEdit = <%= job ? 'true' : 'false' %>;
var editJobId = <%= job ? job.id : 'null' %>;

// ─── Quill Editor ────────────────────────────────────────
var quill = new Quill('#quill-editor', {
  theme: 'snow',
  placeholder: 'Describe the role, responsibilities, requirements...',
  modules: {
    toolbar: [
      [{ header: [1, 2, 3, false] }],
      ['bold', 'italic', 'underline'],
      [{ list: 'ordered' }, { list: 'bullet' }],
      ['link'],
      ['clean']
    ]
  }
});

<% if (job && job.description) { %>
  quill.root.innerHTML = <%- JSON.stringify(job.description) %>;
<% } %>

// ─── Step Navigation ─────────────────────────────────────
function goToStep(n) {
  // Validate step 1
  if (n > 1 && currentStep === 1) {
    if (!document.getElementById('f-company-name').value.trim()) { alert('Company name is required'); return; }
    if (!document.getElementById('f-role-title').value.trim()) { alert('Role title is required'); return; }
  }

  document.getElementById('step-' + currentStep).style.display = 'none';
  document.getElementById('step-' + n).style.display = 'block';
  currentStep = n;

  for (var i = 1; i <= 3; i++) {
    var dot = document.getElementById('step-dot-' + i);
    var label = document.getElementById('step-label-' + i);
    if (i <= n) {
      dot.style.background = 'hsl(var(--accent))';
      dot.style.color = 'white';
      label.style.color = 'hsl(var(--accent))';
    } else {
      dot.style.background = '#f3f4f6';
      dot.style.color = '#9ca3af';
      label.style.color = '#9ca3af';
    }
  }
}

// ─── Skills Tag Input ────────────────────────────────────
<% if (job && job.skills && job.skills.length) { %>
  skills = <%- JSON.stringify(job.skills.map(function(s){ return s.skill_name || s.name || s; })) %>;
<% } %>

function renderSkillTags() {
  var container = document.getElementById('skills-container');
  var input = document.getElementById('skill-input');
  var tags = container.querySelectorAll('.skill-tag');
  tags.forEach(function(t){ t.remove(); });
  skills.forEach(function(sk, idx) {
    var tag = document.createElement('span');
    tag.className = 'skill-tag inline-flex items-center gap-1 text-xs px-2 py-1 rounded-full';
    tag.style.cssText = 'background:#eff6ff;color:#2563eb;';
    tag.innerHTML = sk + ' <button type="button" onclick="removeSkill(' + idx + ')" style="cursor:pointer;color:#93c5fd">&times;</button>';
    container.insertBefore(tag, input);
  });
}
function removeSkill(idx) { skills.splice(idx, 1); renderSkillTags(); }
renderSkillTags();

document.getElementById('skill-input').addEventListener('keydown', function(e) {
  if (e.key === 'Enter' || e.key === ',') {
    e.preventDefault();
    var val = this.value.trim().replace(/,$/,'');
    if (val && !skills.includes(val)) { skills.push(val); renderSkillTags(); }
    this.value = '';
  }
});

// ─── Interview Rounds ────────────────────────────────────
<% if (job && job.rounds && job.rounds.length) { %>
  rounds = <%- JSON.stringify(job.rounds.map(function(r){ return { round_name: r.round_name, round_type: r.round_type, description: r.description || '', duration_minutes: r.duration_minutes || '' }; })) %>;
<% } %>

function renderRounds() {
  var c = document.getElementById('rounds-container');
  c.innerHTML = '';
  if (!rounds.length) {
    c.innerHTML = '<p class="text-sm text-gray-400 text-center py-4">No interview rounds added yet</p>';
    return;
  }
  rounds.forEach(function(r, idx) {
    var types = ['aptitude','technical','hr','group_discussion','coding','other'];
    var opts = types.map(function(t){ return '<option value="'+t+'" '+(r.round_type===t?'selected':'')+'>'+t.replace(/_/g,' ')+'</option>'; }).join('');
    c.innerHTML +=
      '<div class="flex items-start gap-3 p-3 bg-gray-50 dark:bg-gray-800/50 rounded-lg border border-gray-200 dark:border-gray-700">' +
        '<span class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold text-white" style="background:hsl(var(--accent));flex-shrink:0">' + (idx+1) + '</span>' +
        '<div class="flex-1 grid sm:grid-cols-3 gap-2">' +
          '<input type="text" value="' + (r.round_name || '') + '" placeholder="Round name" class="text-sm border border-gray-300 dark:border-gray-700 rounded-lg px-3 py-1.5 bg-white dark:bg-gray-800" onchange="rounds['+idx+'].round_name=this.value">' +
          '<select class="text-sm border border-gray-300 dark:border-gray-700 rounded-lg px-3 py-1.5 bg-white dark:bg-gray-800" onchange="rounds['+idx+'].round_type=this.value">' + opts + '</select>' +
          '<input type="number" value="' + (r.duration_minutes || '') + '" placeholder="Minutes" class="text-sm border border-gray-300 dark:border-gray-700 rounded-lg px-3 py-1.5 bg-white dark:bg-gray-800" onchange="rounds['+idx+'].duration_minutes=parseInt(this.value)||null">' +
        '</div>' +
        '<button type="button" onclick="removeRound('+idx+')" class="p-1.5 text-red-400 hover:text-red-600"><i class="fas fa-trash text-xs"></i></button>' +
      '</div>';
  });
}
function addRound() {
  rounds.push({ round_name: '', round_type: 'technical', description: '', duration_minutes: null });
  renderRounds();
}
function removeRound(idx) { rounds.splice(idx, 1); renderRounds(); }
renderRounds();

// ─── Submit ──────────────────────────────────────────────
function submitJob() {
  var btn = document.getElementById('submit-btn');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i> Saving...';

  var body = {
    company_name: document.getElementById('f-company-name').value.trim(),
    company_logo: document.getElementById('f-company-logo').value.trim() || null,
    role_title: document.getElementById('f-role-title').value.trim(),
    job_type: document.getElementById('f-job-type').value,
    ctc_min: parseFloat(document.getElementById('f-ctc-min').value) || null,
    ctc_max: parseFloat(document.getElementById('f-ctc-max').value) || null,
    location: document.getElementById('f-location').value.trim() || null,
    work_mode: document.getElementById('f-work-mode').value,
    description: quill.root.innerHTML,
    cgpa_cutoff: parseFloat(document.getElementById('f-cgpa-cutoff').value) || null,
    application_deadline: document.getElementById('f-deadline').value || null,
    joining_date: document.getElementById('f-joining').value || null,
    eligible_programs: document.getElementById('f-programs').value.split(',').map(function(s){return s.trim()}).filter(Boolean).join(','),
    eligible_branches: document.getElementById('f-branches').value.split(',').map(function(s){return s.trim()}).filter(Boolean).join(','),
    eligible_years: document.getElementById('f-years').value.split(',').map(function(s){return s.trim()}).filter(Boolean).join(','),
    skills: skills.join(','),
    rounds: JSON.stringify(rounds.filter(function(r){ return r.round_name; })),
    selection_notes: document.getElementById('f-selection-notes').value.trim() || null,
    status: document.getElementById('f-status').value,
  };

  var url = isEdit ? '/admin/jobs/api/' + editJobId : '/admin/jobs/api/create';
  var method = isEdit ? 'PUT' : 'POST';

  fetch(url, {
    method: method,
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(body),
  })
  .then(function(r){ return r.json(); })
  .then(function(res){
    if (res.success) {
      window.location.href = isEdit ? '/admin/jobs/' + editJobId : '/admin/jobs/' + res.jobId;
    } else {
      alert(res.error || 'Failed to save');
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-check mr-1"></i> ' + (isEdit ? 'Update Job' : 'Create Job');
    }
  })
  .catch(function(err){
    alert('Error: ' + err.message);
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-check mr-1"></i> ' + (isEdit ? 'Update Job' : 'Create Job');
  });
}
</script>

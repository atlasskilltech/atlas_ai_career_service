<div class="max-w-4xl mx-auto space-y-5">
  <!-- Header -->
  <div class="flex items-center gap-3">
    <a href="/admin/jobs" class="p-2.5 rounded-xl hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-400 hover:text-gray-600 transition-all active:scale-95"><i class="fas fa-arrow-left text-sm"></i></a>
    <div>
      <h1 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white tracking-tight"><%= job ? 'Edit Job' : 'Create New Job' %></h1>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5">Fill in the details below</p>
    </div>
  </div>

  <!-- Step Indicator -->
  <div class="flex items-center justify-center gap-0 bg-white dark:bg-gray-900 rounded-xl border border-gray-100 dark:border-gray-800 p-4">
    <% for (var si = 1; si <= 3; si++) { %>
      <div class="flex items-center gap-2.5">
        <div id="step-dot-<%= si %>" class="w-9 h-9 rounded-xl flex items-center justify-center text-sm font-bold transition-all"
             style="<%= si === 1 ? 'background:hsl(var(--accent));color:white;box-shadow:0 2px 8px hsla(80,89%,40%,0.3)' : 'background:#f3f4f6;color:#9ca3af' %>"><%= si %></div>
        <span id="step-label-<%= si %>" class="text-sm font-semibold hidden sm:inline transition" style="color:<%= si === 1 ? 'hsl(var(--accent))' : '#9ca3af' %>">
          <%= si === 1 ? 'Basic Info' : si === 2 ? 'Details' : 'Process' %>
        </span>
        <% if (si < 3) { %>
          <div class="w-8 sm:w-16 h-0.5 rounded-full mx-2" style="background:#e5e7eb"></div>
        <% } %>
      </div>
    <% } %>
  </div>

  <!-- Form -->
  <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-100 dark:border-gray-800 p-6 sm:p-8 shadow-sm">

    <!-- Step 1: Basic Info -->
    <div id="step-1" class="space-y-6">
      <div class="flex items-center gap-2 mb-1">
        <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background:hsla(80,89%,40%,0.1)"><i class="fas fa-building text-xs" style="color:hsl(var(--accent))"></i></div>
        <h2 class="text-base font-bold text-gray-900 dark:text-white">Basic Information</h2>
      </div>

      <div class="grid sm:grid-cols-2 gap-5">
        <div class="sm:col-span-2">
          <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1.5 uppercase tracking-wider">Company Name <span class="text-red-400">*</span></label>
          <input type="text" id="f-company-name" value="<%= job ? job.company_name : '' %>" required placeholder="e.g. Google, TCS, Infosys"
            class="w-full border border-gray-200 dark:border-gray-700 rounded-xl px-4 py-3 bg-white dark:bg-gray-800 text-sm hover:border-gray-300 dark:hover:border-gray-600 transition placeholder:text-gray-400">
        </div>
        <div class="sm:col-span-2">
          <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1.5 uppercase tracking-wider">Company Logo</label>
          <div class="flex items-start gap-4">
            <div id="logo-preview" class="w-16 h-16 rounded-xl border-2 border-dashed border-gray-200 dark:border-gray-600 flex items-center justify-center overflow-hidden flex-shrink-0 bg-gray-50 dark:bg-gray-800">
              <% if (job && job.company_logo) { %>
                <img src="<%= job.company_logo %>" alt="" class="w-full h-full object-contain">
              <% } else { %>
                <i class="fas fa-image text-gray-300 dark:text-gray-600 text-xl"></i>
              <% } %>
            </div>
            <div class="flex-1 space-y-2.5">
              <div>
                <label class="inline-flex items-center gap-2 px-4 py-2.5 border border-gray-200 dark:border-gray-700 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-800 cursor-pointer text-sm font-medium transition-all active:scale-[0.97]">
                  <i class="fas fa-upload text-xs text-gray-400"></i> Upload Image
                  <input type="file" id="f-company-logo-file" accept="image/*" style="display:none" onchange="previewLogo(this)">
                </label>
                <span id="logo-file-name" class="text-xs text-gray-400 ml-2"></span>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-[10px] text-gray-400 font-medium uppercase tracking-wider">or paste URL</span>
                <input type="text" id="f-company-logo" value="<%= job ? (job.company_logo || '') : '' %>" placeholder="https://logo.clearbit.com/company.com"
                  class="flex-1 border border-gray-200 dark:border-gray-700 rounded-xl px-3 py-2 bg-white dark:bg-gray-800 text-sm hover:border-gray-300 dark:hover:border-gray-600 transition placeholder:text-gray-400" oninput="previewLogoUrl(this.value)">
              </div>
            </div>
          </div>
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1.5 uppercase tracking-wider">Role / Title <span class="text-red-400">*</span></label>
          <input type="text" id="f-role-title" value="<%= job ? job.role_title : '' %>" required placeholder="e.g. SDE, Data Analyst"
            class="w-full border border-gray-200 dark:border-gray-700 rounded-xl px-4 py-3 bg-white dark:bg-gray-800 text-sm hover:border-gray-300 dark:hover:border-gray-600 transition placeholder:text-gray-400">
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1.5 uppercase tracking-wider">Job Type</label>
          <select id="f-job-type" class="w-full border border-gray-200 dark:border-gray-700 rounded-xl px-4 py-3 bg-white dark:bg-gray-800 text-sm hover:border-gray-300 dark:hover:border-gray-600 transition">
            <% ['full_time','part_time','internship','contract','freelance'].forEach(function(t){ %>
              <option value="<%= t %>" <%= (job && job.job_type === t) ? 'selected' : '' %>><%= t.replace(/_/g,' ') %></option>
            <% }); %>
          </select>
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1.5 uppercase tracking-wider">CTC Min (LPA)</label>
          <input type="number" id="f-ctc-min" step="0.5" value="<%= job ? (job.ctc_min || '') : '' %>" placeholder="e.g. 4"
            class="w-full border border-gray-200 dark:border-gray-700 rounded-xl px-4 py-3 bg-white dark:bg-gray-800 text-sm hover:border-gray-300 dark:hover:border-gray-600 transition placeholder:text-gray-400">
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1.5 uppercase tracking-wider">CTC Max (LPA)</label>
          <input type="number" id="f-ctc-max" step="0.5" value="<%= job ? (job.ctc_max || '') : '' %>" placeholder="e.g. 12"
            class="w-full border border-gray-200 dark:border-gray-700 rounded-xl px-4 py-3 bg-white dark:bg-gray-800 text-sm hover:border-gray-300 dark:hover:border-gray-600 transition placeholder:text-gray-400">
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1.5 uppercase tracking-wider">Location</label>
          <input type="text" id="f-location" value="<%= job ? (job.location || '') : '' %>" placeholder="e.g. Mumbai, Bangalore"
            class="w-full border border-gray-200 dark:border-gray-700 rounded-xl px-4 py-3 bg-white dark:bg-gray-800 text-sm hover:border-gray-300 dark:hover:border-gray-600 transition placeholder:text-gray-400">
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1.5 uppercase tracking-wider">Work Mode</label>
          <select id="f-work-mode" class="w-full border border-gray-200 dark:border-gray-700 rounded-xl px-4 py-3 bg-white dark:bg-gray-800 text-sm hover:border-gray-300 dark:hover:border-gray-600 transition">
            <% ['onsite','remote','hybrid'].forEach(function(w){ %>
              <option value="<%= w %>" <%= (job && job.work_mode === w) ? 'selected' : '' %>><%= w.charAt(0).toUpperCase() + w.slice(1) %></option>
            <% }); %>
          </select>
        </div>
      </div>

      <div class="flex justify-end pt-3">
        <button onclick="goToStep(2)" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl text-white text-sm font-semibold transition-all shadow-sm hover:shadow active:scale-[0.97]" style="background:hsl(var(--accent))">
          Next: Details <i class="fas fa-arrow-right text-xs"></i>
        </button>
      </div>
    </div>

    <!-- Step 2: Details -->
    <div id="step-2" style="display:none" class="space-y-6">
      <div class="flex items-center gap-2 mb-1">
        <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background:hsla(228,100%,11%,0.06)"><i class="fas fa-file-alt text-xs" style="color:hsl(var(--primary))"></i></div>
        <h2 class="text-base font-bold text-gray-900 dark:text-white">Job Details</h2>
      </div>

      <div>
        <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1.5 uppercase tracking-wider">Job Description <span class="text-red-400">*</span></label>
        <div id="quill-editor" style="height:250px;border:1px solid #e5e7eb;border-radius:12px"></div>
      </div>

      <div>
        <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1.5 uppercase tracking-wider">Required Skills <span class="text-gray-400 normal-case font-normal">(press Enter to add)</span></label>
        <div class="flex flex-wrap gap-2 p-3.5 border border-gray-200 dark:border-gray-700 rounded-xl bg-white dark:bg-gray-800 min-h-[48px] hover:border-gray-300 dark:hover:border-gray-600 transition" id="skills-container">
          <input type="text" id="skill-input" placeholder="Type a skill and press Enter"
            class="flex-1 min-w-[150px] border-none outline-none bg-transparent text-sm" style="border:none">
        </div>
      </div>

      <div class="grid sm:grid-cols-2 gap-5">
        <div>
          <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1.5 uppercase tracking-wider">CGPA Cutoff</label>
          <input type="number" id="f-cgpa-cutoff" step="0.1" min="0" max="10" value="<%= job ? (job.cgpa_cutoff || '') : '' %>" placeholder="e.g. 7.0"
            class="w-full border border-gray-200 dark:border-gray-700 rounded-xl px-4 py-3 bg-white dark:bg-gray-800 text-sm hover:border-gray-300 dark:hover:border-gray-600 transition placeholder:text-gray-400">
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1.5 uppercase tracking-wider">Application Deadline</label>
          <input type="date" id="f-deadline" value="<%= job && job.application_deadline ? new Date(job.application_deadline).toISOString().split('T')[0] : '' %>"
            class="w-full border border-gray-200 dark:border-gray-700 rounded-xl px-4 py-3 bg-white dark:bg-gray-800 text-sm hover:border-gray-300 dark:hover:border-gray-600 transition">
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1.5 uppercase tracking-wider">Joining Date</label>
          <input type="date" id="f-joining" value="<%= job && job.joining_date ? new Date(job.joining_date).toISOString().split('T')[0] : '' %>"
            class="w-full border border-gray-200 dark:border-gray-700 rounded-xl px-4 py-3 bg-white dark:bg-gray-800 text-sm hover:border-gray-300 dark:hover:border-gray-600 transition">
        </div>
      </div>

      <div>
        <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1.5 uppercase tracking-wider">Eligible Programs <span class="text-gray-400 normal-case font-normal">(comma separated)</span></label>
        <input type="text" id="f-programs" value="<%= job && job.eligible_programs ? job.eligible_programs.join(', ') : '' %>" placeholder="B.Tech, M.Tech, MBA"
          class="w-full border border-gray-200 dark:border-gray-700 rounded-xl px-4 py-3 bg-white dark:bg-gray-800 text-sm hover:border-gray-300 dark:hover:border-gray-600 transition placeholder:text-gray-400">
      </div>
      <div class="grid sm:grid-cols-2 gap-5">
        <div>
          <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1.5 uppercase tracking-wider">Eligible Branches</label>
          <input type="text" id="f-branches" value="<%= job && job.eligible_branches ? job.eligible_branches.join(', ') : '' %>" placeholder="CSE, IT, ECE"
            class="w-full border border-gray-200 dark:border-gray-700 rounded-xl px-4 py-3 bg-white dark:bg-gray-800 text-sm hover:border-gray-300 dark:hover:border-gray-600 transition placeholder:text-gray-400">
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1.5 uppercase tracking-wider">Eligible Years</label>
          <input type="text" id="f-years" value="<%= job && job.eligible_years ? job.eligible_years.join(', ') : '' %>" placeholder="2025, 2026"
            class="w-full border border-gray-200 dark:border-gray-700 rounded-xl px-4 py-3 bg-white dark:bg-gray-800 text-sm hover:border-gray-300 dark:hover:border-gray-600 transition placeholder:text-gray-400">
        </div>
      </div>

      <div class="flex justify-between pt-3">
        <button onclick="goToStep(1)" class="inline-flex items-center gap-2 px-5 py-3 rounded-xl text-sm font-medium border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all active:scale-[0.97]">
          <i class="fas fa-arrow-left text-xs"></i> Back
        </button>
        <button onclick="goToStep(3)" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl text-white text-sm font-semibold transition-all shadow-sm hover:shadow active:scale-[0.97]" style="background:hsl(var(--accent))">
          Next: Process <i class="fas fa-arrow-right text-xs"></i>
        </button>
      </div>
    </div>

    <!-- Step 3: Process -->
    <div id="step-3" style="display:none" class="space-y-6">
      <div class="flex items-center gap-2 mb-1">
        <div class="w-8 h-8 rounded-lg flex items-center justify-center bg-purple-50 dark:bg-purple-900/20"><i class="fas fa-cogs text-xs text-purple-600"></i></div>
        <h2 class="text-base font-bold text-gray-900 dark:text-white">Interview Process & Status</h2>
      </div>

      <!-- Interview Rounds -->
      <div>
        <div class="flex items-center justify-between mb-3">
          <label class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Interview Rounds</label>
          <button type="button" onclick="addRound()" class="inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5 rounded-lg transition-all active:scale-[0.97]" style="color:hsl(var(--accent));background:hsla(80,89%,40%,0.08)">
            <i class="fas fa-plus text-[10px]"></i> Add Round
          </button>
        </div>
        <div id="rounds-container" class="space-y-3"></div>
      </div>

      <div>
        <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1.5 uppercase tracking-wider">Selection Notes</label>
        <textarea id="f-selection-notes" rows="3" placeholder="Additional notes about the selection process..."
          class="w-full border border-gray-200 dark:border-gray-700 rounded-xl px-4 py-3 bg-white dark:bg-gray-800 text-sm hover:border-gray-300 dark:hover:border-gray-600 transition placeholder:text-gray-400 resize-none"><%= job ? (job.selection_notes || '') : '' %></textarea>
      </div>

      <div>
        <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1.5 uppercase tracking-wider">Status</label>
        <select id="f-status" class="w-full border border-gray-200 dark:border-gray-700 rounded-xl px-4 py-3 bg-white dark:bg-gray-800 text-sm hover:border-gray-300 dark:hover:border-gray-600 transition">
          <% ['draft','active','closed','on_hold'].forEach(function(s){ %>
            <option value="<%= s %>" <%= (job && job.status === s) ? 'selected' : '' %>><%= s.replace(/_/g,' ').replace(/^\w/,function(c){return c.toUpperCase()}) %></option>
          <% }); %>
        </select>
      </div>

      <div class="flex justify-between pt-4 border-t border-gray-100 dark:border-gray-800">
        <button onclick="goToStep(2)" class="inline-flex items-center gap-2 px-5 py-3 rounded-xl text-sm font-medium border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all active:scale-[0.97]">
          <i class="fas fa-arrow-left text-xs"></i> Back
        </button>
        <button onclick="submitJob()" id="submit-btn" class="inline-flex items-center gap-2 px-8 py-3 rounded-xl text-white text-sm font-semibold transition-all shadow-sm hover:shadow-md active:scale-[0.97]" style="background:hsl(var(--accent))">
          <i class="fas fa-check text-xs"></i> <%= job ? 'Update Job' : 'Create Job' %>
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Quill.js CDN -->
<link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
<script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>

<script>
var currentStep = 1;
var skills = [];
var rounds = [];
var isEdit = <%= job ? 'true' : 'false' %>;
var editJobId = <%= job ? job.id : 'null' %>;

// ─── Quill Editor ────────────────────────────────────────
var quill = new Quill('#quill-editor', {
  theme: 'snow',
  placeholder: 'Describe the role, responsibilities, requirements...',
  modules: {
    toolbar: [
      [{ header: [1, 2, 3, false] }],
      ['bold', 'italic', 'underline'],
      [{ list: 'ordered' }, { list: 'bullet' }],
      ['link'],
      ['clean']
    ]
  }
});

<% if (job && job.description) { %>
  quill.root.innerHTML = <%- JSON.stringify(job.description) %>;
<% } %>

// ─── Step Navigation ─────────────────────────────────────
function goToStep(n) {
  if (n > 1 && currentStep === 1) {
    if (!document.getElementById('f-company-name').value.trim()) { showToast('Company name is required', 'error'); return; }
    if (!document.getElementById('f-role-title').value.trim()) { showToast('Role title is required', 'error'); return; }
  }

  document.getElementById('step-' + currentStep).style.display = 'none';
  document.getElementById('step-' + n).style.display = 'block';
  currentStep = n;

  for (var i = 1; i <= 3; i++) {
    var dot = document.getElementById('step-dot-' + i);
    var label = document.getElementById('step-label-' + i);
    if (i <= n) {
      dot.style.background = 'hsl(var(--accent))';
      dot.style.color = 'white';
      dot.style.boxShadow = '0 2px 8px hsla(80,89%,40%,0.3)';
      label.style.color = 'hsl(var(--accent))';
    } else {
      dot.style.background = '#f3f4f6';
      dot.style.color = '#9ca3af';
      dot.style.boxShadow = 'none';
      label.style.color = '#9ca3af';
    }
  }
}

// ─── Skills Tag Input ────────────────────────────────────
<% if (job && job.skills && job.skills.length) { %>
  skills = <%- JSON.stringify(job.skills.map(function(s){ return s.skill_name || s.name || s; })) %>;
<% } %>

function renderSkillTags() {
  var container = document.getElementById('skills-container');
  var input = document.getElementById('skill-input');
  var tags = container.querySelectorAll('.skill-tag');
  tags.forEach(function(t){ t.remove(); });
  skills.forEach(function(sk, idx) {
    var tag = document.createElement('span');
    tag.className = 'skill-tag inline-flex items-center gap-1.5 text-xs font-medium px-2.5 py-1.5 rounded-lg';
    tag.style.cssText = 'background:hsla(228,100%,11%,0.06);color:hsl(228,100%,25%)';
    tag.innerHTML = sk + ' <button type="button" onclick="removeSkill(' + idx + ')" style="cursor:pointer;color:#93c5fd;font-size:14px;line-height:1">&times;</button>';
    container.insertBefore(tag, input);
  });
}
function removeSkill(idx) { skills.splice(idx, 1); renderSkillTags(); }
renderSkillTags();

document.getElementById('skill-input').addEventListener('keydown', function(e) {
  if (e.key === 'Enter' || e.key === ',') {
    e.preventDefault();
    var val = this.value.trim().replace(/,$/,'');
    if (val && !skills.includes(val)) { skills.push(val); renderSkillTags(); }
    this.value = '';
  }
});

// ─── Interview Rounds ────────────────────────────────────
<% if (job && job.rounds && job.rounds.length) { %>
  rounds = <%- JSON.stringify(job.rounds.map(function(r){ return { round_name: r.round_name, round_type: r.round_type, description: r.description || '', duration_minutes: r.duration_minutes || '' }; })) %>;
<% } %>

function renderRounds() {
  var c = document.getElementById('rounds-container');
  c.innerHTML = '';
  if (!rounds.length) {
    c.innerHTML = '<div class="text-center py-8 text-gray-400"><div class="w-12 h-12 rounded-xl mx-auto mb-3 flex items-center justify-center bg-gray-50 dark:bg-gray-800"><i class="fas fa-layer-group text-gray-300"></i></div><p class="text-sm">No interview rounds added yet</p></div>';
    return;
  }
  rounds.forEach(function(r, idx) {
    var types = ['aptitude','technical','hr','group_discussion','coding','other'];
    var opts = types.map(function(t){ return '<option value="'+t+'" '+(r.round_type===t?'selected':'')+'>'+t.replace(/_/g,' ')+'</option>'; }).join('');
    c.innerHTML +=
      '<div class="flex items-start gap-3 p-4 bg-gray-50 dark:bg-gray-800/50 rounded-xl border border-gray-100 dark:border-gray-700 hover:border-gray-200 dark:hover:border-gray-600 transition">' +
        '<span class="w-8 h-8 rounded-lg flex items-center justify-center text-xs font-bold text-white flex-shrink-0 mt-0.5" style="background:hsl(var(--accent))">' + (idx+1) + '</span>' +
        '<div class="flex-1 grid sm:grid-cols-3 gap-2.5">' +
          '<input type="text" value="' + (r.round_name || '') + '" placeholder="Round name" class="text-sm border border-gray-200 dark:border-gray-700 rounded-xl px-3 py-2.5 bg-white dark:bg-gray-800 hover:border-gray-300 dark:hover:border-gray-600 transition" onchange="rounds['+idx+'].round_name=this.value">' +
          '<select class="text-sm border border-gray-200 dark:border-gray-700 rounded-xl px-3 py-2.5 bg-white dark:bg-gray-800 hover:border-gray-300 dark:hover:border-gray-600 transition" onchange="rounds['+idx+'].round_type=this.value">' + opts + '</select>' +
          '<input type="number" value="' + (r.duration_minutes || '') + '" placeholder="Minutes" class="text-sm border border-gray-200 dark:border-gray-700 rounded-xl px-3 py-2.5 bg-white dark:bg-gray-800 hover:border-gray-300 dark:hover:border-gray-600 transition" onchange="rounds['+idx+'].duration_minutes=parseInt(this.value)||null">' +
        '</div>' +
        '<button type="button" onclick="removeRound('+idx+')" class="p-2 rounded-lg text-gray-400 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 transition"><i class="fas fa-trash text-xs"></i></button>' +
      '</div>';
  });
}
function addRound() {
  rounds.push({ round_name: '', round_type: 'technical', description: '', duration_minutes: null });
  renderRounds();
}
function removeRound(idx) { rounds.splice(idx, 1); renderRounds(); }
renderRounds();

// ─── Logo Preview ────────────────────────────────────────
function previewLogo(input) {
  if (input.files && input.files[0]) {
    var reader = new FileReader();
    reader.onload = function(e) {
      document.getElementById('logo-preview').innerHTML = '<img src="' + e.target.result + '" class="w-full h-full object-contain">';
      document.getElementById('f-company-logo').value = '';
    };
    reader.readAsDataURL(input.files[0]);
    document.getElementById('logo-file-name').textContent = input.files[0].name;
  }
}
function previewLogoUrl(url) {
  if (!url) return;
  var preview = document.getElementById('logo-preview');
  var img = new Image();
  img.onload = function() { preview.innerHTML = '<img src="' + url + '" class="w-full h-full object-contain">'; };
  img.onerror = function() { preview.innerHTML = '<i class="fas fa-image text-gray-300 dark:text-gray-600 text-xl"></i>'; };
  img.src = url;
  document.getElementById('f-company-logo-file').value = '';
  document.getElementById('logo-file-name').textContent = '';
}

// ─── Submit ──────────────────────────────────────────────
function submitJob() {
  var btn = document.getElementById('submit-btn');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i> Saving...';

  var fd = new FormData();
  fd.append('company_name', document.getElementById('f-company-name').value.trim());
  fd.append('role_title', document.getElementById('f-role-title').value.trim());
  fd.append('job_type', document.getElementById('f-job-type').value);
  fd.append('work_mode', document.getElementById('f-work-mode').value);
  fd.append('status', document.getElementById('f-status').value);
  fd.append('description', quill.root.innerHTML);
  fd.append('skills', skills.join(','));
  fd.append('rounds', JSON.stringify(rounds.filter(function(r){ return r.round_name; })));

  var logoFile = document.getElementById('f-company-logo-file').files[0];
  var logoUrl = document.getElementById('f-company-logo').value.trim();
  if (logoFile) { fd.append('company_logo_file', logoFile); }
  else if (logoUrl) { fd.append('company_logo', logoUrl); }

  var ctcMin = document.getElementById('f-ctc-min').value;
  var ctcMax = document.getElementById('f-ctc-max').value;
  if (ctcMin) fd.append('ctc_min', ctcMin);
  if (ctcMax) fd.append('ctc_max', ctcMax);
  var loc = document.getElementById('f-location').value.trim();
  if (loc) fd.append('location', loc);
  var cgpa = document.getElementById('f-cgpa-cutoff').value;
  if (cgpa) fd.append('cgpa_cutoff', cgpa);
  var deadline = document.getElementById('f-deadline').value;
  if (deadline) fd.append('application_deadline', deadline);
  var joining = document.getElementById('f-joining').value;
  if (joining) fd.append('joining_date', joining);
  var programs = document.getElementById('f-programs').value.split(',').map(function(s){return s.trim()}).filter(Boolean).join(',');
  if (programs) fd.append('eligible_programs', programs);
  var branches = document.getElementById('f-branches').value.split(',').map(function(s){return s.trim()}).filter(Boolean).join(',');
  if (branches) fd.append('eligible_branches', branches);
  var years = document.getElementById('f-years').value.split(',').map(function(s){return s.trim()}).filter(Boolean).join(',');
  if (years) fd.append('eligible_years', years);
  var notes = document.getElementById('f-selection-notes').value.trim();
  if (notes) fd.append('selection_notes', notes);

  var url = isEdit ? '/admin/jobs/api/' + editJobId : '/admin/jobs/api/create';
  var method = isEdit ? 'PUT' : 'POST';

  fetch(url, { method: method, body: fd })
  .then(function(r){ return r.json(); })
  .then(function(res){
    if (res.success) {
      showToast(isEdit ? 'Job updated' : 'Job created', 'success');
      setTimeout(function() { window.location.href = isEdit ? '/admin/jobs/' + editJobId : '/admin/jobs/' + res.jobId; }, 800);
    } else {
      showToast(res.error || 'Failed to save', 'error');
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-check mr-1 text-xs"></i> ' + (isEdit ? 'Update Job' : 'Create Job');
    }
  })
  .catch(function(err){
    showToast('Error: ' + err.message, 'error');
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-check mr-1 text-xs"></i> ' + (isEdit ? 'Update Job' : 'Create Job');
  });
}
</script>

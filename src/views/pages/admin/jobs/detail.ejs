<div class="space-y-5">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">
    <div class="flex items-start gap-4">
      <a href="/admin/jobs" class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-500 mt-1"><i class="fas fa-arrow-left"></i></a>
      <% if (job.company_logo) { %>
        <img src="<%= job.company_logo %>" alt="" class="w-14 h-14 rounded-xl object-contain border border-gray-200 dark:border-gray-700" style="flex-shrink:0">
      <% } else { %>
        <div class="w-14 h-14 rounded-xl flex items-center justify-center text-white text-lg font-bold" style="flex-shrink:0;background:hsl(var(--primary))"><%= job.company_name ? job.company_name.charAt(0) : '?' %></div>
      <% } %>
      <div>
        <h1 class="text-xl font-bold text-gray-900 dark:text-white"><%= job.role_title %></h1>
        <p class="text-sm text-gray-500"><%= job.company_name %></p>
        <div class="flex flex-wrap gap-2 mt-2">
          <%
            var stColors = { draft:'background:#f3f4f6;color:#6b7280', active:'background:#dcfce7;color:#16a34a', closed:'background:#fee2e2;color:#dc2626', on_hold:'background:#fef9c3;color:#ca8a04' };
            var typeLabels = { full_time:'Full Time', part_time:'Part Time', internship:'Internship', contract:'Contract', freelance:'Freelance' };
          %>
          <span class="text-xs font-medium px-2.5 py-1 rounded-full" style="<%= stColors[job.status] || stColors.draft %>"><%= job.status.replace(/_/g,' ') %></span>
          <span class="text-xs px-2 py-1 rounded font-medium" style="background:#eff6ff;color:#2563eb"><%= typeLabels[job.job_type] || job.job_type %></span>
          <% if (job.work_mode) { %>
            <span class="text-xs px-2 py-1 rounded font-medium" style="background:#f0fdf4;color:#16a34a"><%= job.work_mode %></span>
          <% } %>
        </div>
      </div>
    </div>
    <div class="flex items-center gap-2">
      <!-- Status Quick Actions -->
      <select id="status-select" onchange="changeStatus(this.value)" class="text-sm border border-gray-300 dark:border-gray-700 rounded-lg px-3 py-2 bg-white dark:bg-gray-800">
        <% ['draft','active','closed','on_hold'].forEach(function(s){ %>
          <option value="<%= s %>" <%= job.status === s ? 'selected' : '' %>><%= s.replace(/_/g,' ') %></option>
        <% }); %>
      </select>
      <a href="/admin/jobs/<%= job.id %>/edit" class="inline-flex items-center gap-2 px-4 py-2 border border-gray-300 dark:border-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800 text-sm transition">
        <i class="fas fa-pen"></i> Edit
      </a>
    </div>
  </div>

  <!-- Info Grid -->
  <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3">
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4">
      <p class="text-xs text-gray-500 mb-1"><i class="fas fa-rupee-sign w-4"></i> CTC Range</p>
      <p class="font-semibold text-gray-900 dark:text-white"><%= job.ctc_min || job.ctc_max ? (job.ctc_min || 0) + ' – ' + (job.ctc_max || '?') + ' LPA' : 'Not specified' %></p>
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4">
      <p class="text-xs text-gray-500 mb-1"><i class="fas fa-map-marker-alt w-4"></i> Location</p>
      <p class="font-semibold text-gray-900 dark:text-white"><%= job.location || 'Not specified' %></p>
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4">
      <p class="text-xs text-gray-500 mb-1"><i class="fas fa-calendar w-4"></i> Deadline</p>
      <p class="font-semibold text-gray-900 dark:text-white"><%= job.application_deadline ? new Date(job.application_deadline).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) : 'None' %></p>
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4">
      <p class="text-xs text-gray-500 mb-1"><i class="fas fa-user-check w-4"></i> CGPA Cutoff</p>
      <p class="font-semibold text-gray-900 dark:text-white"><%= job.cgpa_cutoff || 'None' %></p>
    </div>
  </div>

  <!-- Pipeline Summary -->
  <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-5">
    <h3 class="font-semibold text-gray-900 dark:text-white mb-4">Applicant Pipeline</h3>
    <div class="grid grid-cols-3 sm:grid-cols-6 gap-3">
      <%
        var stageColors = {
          applied: '#6b7280', shortlisted: '#2563eb', interview: '#ca8a04',
          offered: '#16a34a', rejected: '#dc2626', withdrawn: '#9ca3af'
        };
        var pipeline = job.pipeline || {};
      %>
      <% ['applied','shortlisted','interview','offered','rejected','withdrawn'].forEach(function(s){ %>
        <div class="text-center p-3 rounded-lg cursor-pointer hover:opacity-80 transition" style="background:<%= stageColors[s] %>15" onclick="filterApplicants('<%= s %>')">
          <div class="text-xl font-bold" style="color:<%= stageColors[s] %>"><%= pipeline[s] || 0 %></div>
          <div class="text-[10px] font-medium" style="color:<%= stageColors[s] %>"><%= s.charAt(0).toUpperCase() + s.slice(1) %></div>
        </div>
      <% }); %>
    </div>
  </div>

  <!-- Tabs: JD | Skills | Eligibility | Rounds -->
  <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden">
    <div class="border-b border-gray-200 dark:border-gray-800 flex overflow-x-auto" style="gap:0">
      <button onclick="showTab('jd')" class="tab-btn px-5 py-3 text-sm font-medium border-b-2 transition" style="border-color:hsl(var(--accent));color:hsl(var(--accent))" data-tab="jd">Description</button>
      <button onclick="showTab('skills')" class="tab-btn px-5 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 transition" data-tab="skills">Skills (<%= (job.skills || []).length %>)</button>
      <button onclick="showTab('eligibility')" class="tab-btn px-5 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 transition" data-tab="eligibility">Eligibility</button>
      <button onclick="showTab('rounds')" class="tab-btn px-5 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 transition" data-tab="rounds">Rounds (<%= (job.rounds || []).length %>)</button>
    </div>

    <div id="tab-jd" class="p-5">
      <div class="prose prose-sm dark:prose-invert max-w-none"><%= job.description ? job.description : '<p class="text-gray-400">No description provided</p>' %></div>
      <% if (job.selection_notes) { %>
        <div class="mt-4 pt-4 border-t border-gray-100 dark:border-gray-800">
          <h4 class="text-xs font-semibold uppercase text-gray-500 mb-2">Selection Notes</h4>
          <p class="text-sm text-gray-600 dark:text-gray-400"><%= job.selection_notes %></p>
        </div>
      <% } %>
    </div>
    <div id="tab-skills" class="p-5" style="display:none">
      <div class="flex flex-wrap gap-2">
        <% (job.skills || []).forEach(function(sk) { %>
          <span class="inline-flex items-center gap-1 text-sm px-3 py-1.5 rounded-full" style="background:#eff6ff;color:#2563eb">
            <%= sk.skill_name %>
            <% if (sk.is_required) { %><i class="fas fa-asterisk text-[8px] text-red-400" title="Required"></i><% } %>
          </span>
        <% }); %>
        <% if (!(job.skills || []).length) { %><p class="text-sm text-gray-400">No skills specified</p><% } %>
      </div>
    </div>
    <div id="tab-eligibility" class="p-5" style="display:none">
      <div class="grid sm:grid-cols-3 gap-4 text-sm">
        <div>
          <h4 class="text-xs font-semibold uppercase text-gray-500 mb-2">Programs</h4>
          <% if (job.eligible_programs && job.eligible_programs.length) { %>
            <% job.eligible_programs.forEach(function(p){ %><span class="inline-block text-xs px-2 py-1 rounded mr-1 mb-1" style="background:#f3f4f6"><%= p %></span><% }); %>
          <% } else { %><p class="text-gray-400">All programs</p><% } %>
        </div>
        <div>
          <h4 class="text-xs font-semibold uppercase text-gray-500 mb-2">Branches</h4>
          <% if (job.eligible_branches && job.eligible_branches.length) { %>
            <% job.eligible_branches.forEach(function(b){ %><span class="inline-block text-xs px-2 py-1 rounded mr-1 mb-1" style="background:#f3f4f6"><%= b %></span><% }); %>
          <% } else { %><p class="text-gray-400">All branches</p><% } %>
        </div>
        <div>
          <h4 class="text-xs font-semibold uppercase text-gray-500 mb-2">Graduation Years</h4>
          <% if (job.eligible_years && job.eligible_years.length) { %>
            <% job.eligible_years.forEach(function(y){ %><span class="inline-block text-xs px-2 py-1 rounded mr-1 mb-1" style="background:#f3f4f6"><%= y %></span><% }); %>
          <% } else { %><p class="text-gray-400">All years</p><% } %>
        </div>
      </div>
    </div>
    <div id="tab-rounds" class="p-5" style="display:none">
      <% if ((job.rounds || []).length) { %>
        <div class="space-y-3">
          <% job.rounds.forEach(function(r, idx) { %>
            <div class="flex items-start gap-3 p-3 bg-gray-50 dark:bg-gray-800/50 rounded-lg">
              <span class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold text-white" style="background:hsl(var(--accent));flex-shrink:0"><%= idx + 1 %></span>
              <div>
                <p class="font-medium text-sm text-gray-900 dark:text-white"><%= r.round_name %></p>
                <p class="text-xs text-gray-500"><%= r.round_type.replace(/_/g,' ') %><%= r.duration_minutes ? ' · ' + r.duration_minutes + ' min' : '' %></p>
                <% if (r.description) { %><p class="text-xs text-gray-400 mt-1"><%= r.description %></p><% } %>
              </div>
            </div>
          <% }); %>
        </div>
      <% } else { %><p class="text-sm text-gray-400">No interview rounds defined</p><% } %>
    </div>
  </div>

  <!-- Applicants Section -->
  <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800">
    <div class="p-5 border-b border-gray-200 dark:border-gray-800 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <h3 class="font-semibold text-gray-900 dark:text-white">Applicants (<%= applicants.length %>)</h3>
      <div class="flex items-center gap-2">
        <input type="text" id="applicant-search" placeholder="Search applicants..." class="text-sm border border-gray-300 dark:border-gray-700 rounded-lg px-3 py-2 bg-white dark:bg-gray-800">
        <select id="stage-filter" onchange="filterApplicants(this.value)" class="text-sm border border-gray-300 dark:border-gray-700 rounded-lg px-3 py-2 bg-white dark:bg-gray-800">
          <option value="">All Stages</option>
          <% ['applied','shortlisted','interview','offered','rejected','withdrawn'].forEach(function(s){ %>
            <option value="<%= s %>" <%= query.stage === s ? 'selected' : '' %>><%= s.charAt(0).toUpperCase() + s.slice(1) %></option>
          <% }); %>
        </select>
        <button onclick="bulkShortlist()" id="bulk-shortlist-btn" style="display:none" class="px-4 py-2 rounded-lg text-white text-sm font-medium" style="background:hsl(var(--accent))">
          Shortlist Selected
        </button>
      </div>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-gray-50 dark:bg-gray-800 text-left">
            <th class="py-3 px-4 w-10"><input type="checkbox" id="select-all-apps" onchange="toggleAllApplicants(this)" class="rounded border-gray-300 dark:border-gray-600"></th>
            <th class="py-3 px-4 font-medium">Student</th>
            <th class="py-3 px-4 font-medium">Program</th>
            <th class="py-3 px-4 font-medium">CGPA</th>
            <th class="py-3 px-4 font-medium">ATS Match</th>
            <th class="py-3 px-4 font-medium">Resume</th>
            <th class="py-3 px-4 font-medium">Stage</th>
            <th class="py-3 px-4 font-medium w-32">Actions</th>
          </tr>
        </thead>
        <tbody id="applicants-tbody">
          <% if (applicants.length) { %>
            <% applicants.forEach(function(a) { %>
              <%
                var stageBg = { applied:'#f3f4f6', shortlisted:'#dbeafe', interview:'#fef9c3', offered:'#dcfce7', rejected:'#fee2e2', withdrawn:'#f3f4f6' };
                var stageFg = { applied:'#6b7280', shortlisted:'#2563eb', interview:'#ca8a04', offered:'#16a34a', rejected:'#dc2626', withdrawn:'#9ca3af' };
              %>
              <tr class="border-t border-gray-100 dark:border-gray-800 hover:bg-gray-50 dark:hover:bg-gray-800/50 applicant-row" data-id="<%= a.id %>" data-stage="<%= a.stage %>">
                <td class="py-3 px-4"><input type="checkbox" class="app-checkbox rounded border-gray-300 dark:border-gray-600" value="<%= a.id %>" onchange="updateBulkBtn()"></td>
                <td class="py-3 px-4">
                  <div class="flex items-center gap-2">
                    <div class="w-8 h-8 rounded-full flex items-center justify-center text-white text-xs font-bold" style="background:hsl(var(--primary));flex-shrink:0"><%= a.name ? a.name.charAt(0).toUpperCase() : '?' %></div>
                    <div>
                      <p class="font-medium text-gray-900 dark:text-white"><%= a.name %></p>
                      <p class="text-[10px] text-gray-500"><%= a.email %></p>
                    </div>
                  </div>
                </td>
                <td class="py-3 px-4 text-gray-600 dark:text-gray-400"><%= a.program || '-' %> <% if (a.branch) { %><span class="text-xs text-gray-400">(<%= a.branch %>)</span><% } %></td>
                <td class="py-3 px-4 font-medium"><%= a.cgpa || '-' %></td>
                <td class="py-3 px-4">
                  <% if (a.ats_match_score !== null && a.ats_match_score !== undefined) { %>
                    <span class="font-bold" style="color:<%= a.ats_match_score >= 70 ? '#16a34a' : a.ats_match_score >= 50 ? '#ca8a04' : '#dc2626' %>"><%= a.ats_match_score %>%</span>
                  <% } else { %>
                    <span class="text-gray-400">-</span>
                  <% } %>
                </td>
                <td class="py-3 px-4">
                  <% if (a.resume_path) { %>
                    <a href="<%= a.resume_path %>" target="_blank" class="text-xs font-medium" style="color:hsl(var(--accent))"><i class="fas fa-file-alt mr-1"></i>View</a>
                  <% } else { %>
                    <span class="text-xs text-gray-400">No resume</span>
                  <% } %>
                </td>
                <td class="py-3 px-4">
                  <span class="text-[10px] font-medium px-2 py-0.5 rounded-full" style="background:<%= stageBg[a.stage] || '#f3f4f6' %>;color:<%= stageFg[a.stage] || '#6b7280' %>"><%= a.stage %></span>
                </td>
                <td class="py-3 px-4">
                  <div class="flex items-center gap-1">
                    <select onchange="moveApplicant(<%= a.id %>, this.value)" class="text-[10px] border border-gray-300 dark:border-gray-700 rounded px-1.5 py-1 bg-white dark:bg-gray-800">
                      <option value="">Move to...</option>
                      <% ['shortlisted','interview','offered','rejected','withdrawn'].forEach(function(s){ %>
                        <% if (s !== a.stage) { %>
                          <option value="<%= s %>"><%= s.charAt(0).toUpperCase() + s.slice(1) %></option>
                        <% } %>
                      <% }); %>
                    </select>
                    <button onclick="openNoteModal(<%= a.id %>, '<%= (a.notes || '').replace(/'/g, "\\'") %>')" class="p-1 rounded hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-400" title="Add Note">
                      <i class="fas fa-sticky-note text-xs"></i>
                    </button>
                  </div>
                </td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr><td colspan="8" class="py-12 text-center text-gray-400">
              <i class="fas fa-users text-3xl mb-3 block"></i>No applicants yet
            </td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Note Modal -->
<div id="note-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:100;display:none" onclick="if(event.target===this)closeNoteModal()">
  <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:90%;max-width:450px" class="bg-white dark:bg-gray-900 rounded-xl p-5 shadow-2xl">
    <h3 class="font-semibold text-gray-900 dark:text-white mb-3">Applicant Note</h3>
    <textarea id="note-text" rows="4" class="w-full border border-gray-300 dark:border-gray-700 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-800 mb-3"></textarea>
    <input type="hidden" id="note-app-id">
    <div class="flex justify-end gap-2">
      <button onclick="closeNoteModal()" class="px-4 py-2 text-sm border border-gray-300 dark:border-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800">Cancel</button>
      <button onclick="saveNote()" class="px-4 py-2 text-sm text-white rounded-lg font-medium" style="background:hsl(var(--accent))">Save</button>
    </div>
  </div>
</div>

<script>
var jobId = <%= job.id %>;

// ─── Tabs ────────────────────────────────────────────────
function showTab(tab) {
  ['jd','skills','eligibility','rounds'].forEach(function(t) {
    document.getElementById('tab-' + t).style.display = t === tab ? 'block' : 'none';
  });
  document.querySelectorAll('.tab-btn').forEach(function(btn) {
    if (btn.dataset.tab === tab) {
      btn.style.borderColor = 'hsl(var(--accent))';
      btn.style.color = 'hsl(var(--accent))';
    } else {
      btn.style.borderColor = 'transparent';
      btn.style.color = '#6b7280';
    }
  });
}

// ─── Status Change ───────────────────────────────────────
function changeStatus(status) {
  fetch('/admin/jobs/api/' + jobId + '/status', {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ status: status })
  }).then(function(r){ return r.json(); }).then(function(res){
    if (res.success) window.location.reload();
    else alert(res.error || 'Failed');
  });
}

// ─── Filter Applicants ───────────────────────────────────
function filterApplicants(stage) {
  document.getElementById('stage-filter').value = stage;
  var rows = document.querySelectorAll('.applicant-row');
  rows.forEach(function(row) {
    row.style.display = (!stage || row.dataset.stage === stage) ? '' : 'none';
  });
}

// ─── Move Applicant ──────────────────────────────────────
function moveApplicant(appId, stage) {
  if (!stage) return;
  fetch('/admin/jobs/api/applicants/' + appId + '/stage', {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ stage: stage })
  }).then(function(r){ return r.json(); }).then(function(res){
    if (res.success) window.location.reload();
    else alert(res.error || 'Failed');
  });
}

// ─── Bulk Shortlist ──────────────────────────────────────
function toggleAllApplicants(el) {
  document.querySelectorAll('.app-checkbox').forEach(function(cb){ cb.checked = el.checked; });
  updateBulkBtn();
}
function updateBulkBtn() {
  var checked = document.querySelectorAll('.app-checkbox:checked');
  var btn = document.getElementById('bulk-shortlist-btn');
  btn.style.display = checked.length > 0 ? 'inline-flex' : 'none';
  btn.style.background = 'hsl(var(--accent))';
}
function bulkShortlist() {
  var ids = Array.from(document.querySelectorAll('.app-checkbox:checked')).map(function(c){ return parseInt(c.value); });
  if (!ids.length) return;
  fetch('/admin/jobs/api/' + jobId + '/shortlist', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ application_ids: ids })
  }).then(function(r){ return r.json(); }).then(function(res){
    if (res.success) window.location.reload();
    else alert(res.error || 'Failed');
  });
}

// ─── Note Modal ──────────────────────────────────────────
function openNoteModal(appId, note) {
  document.getElementById('note-app-id').value = appId;
  document.getElementById('note-text').value = note || '';
  document.getElementById('note-modal').style.display = 'block';
}
function closeNoteModal() { document.getElementById('note-modal').style.display = 'none'; }
function saveNote() {
  var appId = document.getElementById('note-app-id').value;
  var note = document.getElementById('note-text').value;
  fetch('/admin/jobs/api/applicants/' + appId + '/note', {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ note: note })
  }).then(function(r){ return r.json(); }).then(function(res){
    if (res.success) { closeNoteModal(); alert('Note saved'); }
    else alert(res.error || 'Failed');
  });
}

// ─── Search Applicants ───────────────────────────────────
document.getElementById('applicant-search').addEventListener('input', function() {
  var q = this.value.toLowerCase();
  document.querySelectorAll('.applicant-row').forEach(function(row) {
    var text = row.textContent.toLowerCase();
    row.style.display = text.includes(q) ? '' : 'none';
  });
});
</script>

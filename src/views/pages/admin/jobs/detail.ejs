<div class="space-y-5">
  <!-- Header -->
  <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4">
    <div class="flex items-start gap-4">
      <a href="/admin/jobs" class="p-2.5 rounded-xl hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-400 hover:text-gray-600 transition-all active:scale-95 mt-1 flex-shrink-0"><i class="fas fa-arrow-left text-sm"></i></a>
      <% if (job.company_logo) { %>
        <img src="<%= job.company_logo %>" alt="" class="w-14 h-14 rounded-xl object-contain flex-shrink-0 border border-gray-100 dark:border-gray-700 bg-white dark:bg-gray-800 p-1" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
        <div class="w-14 h-14 rounded-xl items-center justify-center text-white text-lg font-bold flex-shrink-0 hidden" style="background:hsl(var(--primary))"><%= job.company_name ? job.company_name.charAt(0) : '?' %></div>
      <% } else { %>
        <div class="w-14 h-14 rounded-xl flex items-center justify-center text-white text-lg font-bold flex-shrink-0" style="background:hsl(var(--primary))"><%= job.company_name ? job.company_name.charAt(0) : '?' %></div>
      <% } %>
      <div>
        <h1 class="text-lg sm:text-xl font-bold text-gray-900 dark:text-white tracking-tight"><%= job.role_title %></h1>
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5"><%= job.company_name %></p>
        <div class="flex flex-wrap gap-2 mt-2.5">
          <%
            var stColors = { draft:'background:#f3f4f6;color:#6b7280', active:'background:#dcfce7;color:#16a34a', closed:'background:#fee2e2;color:#dc2626', on_hold:'background:#fef9c3;color:#ca8a04' };
            var typeLabels = { full_time:'Full Time', part_time:'Part Time', internship:'Internship', contract:'Contract', freelance:'Freelance' };
          %>
          <span class="text-[10px] font-semibold px-2.5 py-1 rounded-lg uppercase tracking-wider" style="<%= stColors[job.status] || stColors.draft %>"><%= job.status.replace(/_/g,' ') %></span>
          <span class="text-[10px] font-semibold px-2.5 py-1 rounded-lg uppercase tracking-wider" style="background:hsla(228,100%,11%,0.06);color:hsl(228,100%,30%)"><%= typeLabels[job.job_type] || job.job_type %></span>
          <% if (job.work_mode) { %>
            <span class="text-[10px] font-semibold px-2.5 py-1 rounded-lg uppercase tracking-wider" style="background:#f0fdf4;color:#16a34a"><%= job.work_mode %></span>
          <% } %>
        </div>
      </div>
    </div>
    <div class="flex items-center gap-2 flex-shrink-0 flex-wrap">
      <select id="status-select" onchange="changeStatus(this.value)" class="text-sm border border-gray-200 dark:border-gray-700 rounded-xl bg-white dark:bg-gray-800 px-3 py-2.5 hover:border-gray-300 dark:hover:border-gray-600 transition">
        <% ['draft','active','closed','on_hold'].forEach(function(s){ %>
          <option value="<%= s %>" <%= job.status === s ? 'selected' : '' %>><%= s.replace(/_/g,' ') %></option>
        <% }); %>
      </select>
      <% if (typeof isPublished !== 'undefined' && isPublished) { %>
        <button onclick="unpublishJob()" id="publish-btn" class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl text-xs font-semibold transition-all active:scale-[0.97]" style="background:#fee2e2;color:#dc2626">
          <i class="fas fa-globe-americas"></i> Unpublish
        </button>
      <% } else { %>
        <button onclick="publishJob()" id="publish-btn" class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl text-xs font-semibold transition-all active:scale-[0.97]" style="background:#dcfce7;color:#16a34a">
          <i class="fas fa-globe-americas"></i> Publish
        </button>
      <% } %>
      <a href="/admin/jobs/<%= job.id %>/edit" class="inline-flex items-center gap-2 px-4 py-2.5 border border-gray-200 dark:border-gray-700 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-800 text-sm font-medium transition-all active:scale-[0.97]">
        <i class="fas fa-pen text-xs"></i> Edit
      </a>
    </div>
  </div>

  <!-- Info Grid -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-100 dark:border-gray-800 p-4 hover:shadow-sm transition-shadow">
      <div class="flex items-center gap-2.5">
        <div class="w-9 h-9 rounded-lg flex items-center justify-center bg-purple-50 dark:bg-purple-900/20"><i class="fas fa-rupee-sign text-xs text-purple-600"></i></div>
        <div>
          <p class="text-[10px] text-gray-400 font-medium uppercase tracking-wider">CTC Range</p>
          <p class="font-bold text-sm text-gray-900 dark:text-white mt-0.5"><%= job.ctc_min || job.ctc_max ? (job.ctc_min || 0) + ' - ' + (job.ctc_max || '?') + ' LPA' : 'Not specified' %></p>
        </div>
      </div>
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-100 dark:border-gray-800 p-4 hover:shadow-sm transition-shadow">
      <div class="flex items-center gap-2.5">
        <div class="w-9 h-9 rounded-lg flex items-center justify-center bg-blue-50 dark:bg-blue-900/20"><i class="fas fa-map-marker-alt text-xs text-blue-600"></i></div>
        <div>
          <p class="text-[10px] text-gray-400 font-medium uppercase tracking-wider">Location</p>
          <p class="font-bold text-sm text-gray-900 dark:text-white mt-0.5"><%= job.location || 'Not specified' %></p>
        </div>
      </div>
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-100 dark:border-gray-800 p-4 hover:shadow-sm transition-shadow">
      <div class="flex items-center gap-2.5">
        <div class="w-9 h-9 rounded-lg flex items-center justify-center bg-orange-50 dark:bg-orange-900/20"><i class="fas fa-calendar text-xs text-orange-600"></i></div>
        <div>
          <p class="text-[10px] text-gray-400 font-medium uppercase tracking-wider">Deadline</p>
          <p class="font-bold text-sm text-gray-900 dark:text-white mt-0.5"><%= job.application_deadline ? new Date(job.application_deadline).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) : 'None' %></p>
        </div>
      </div>
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-100 dark:border-gray-800 p-4 hover:shadow-sm transition-shadow">
      <div class="flex items-center gap-2.5">
        <div class="w-9 h-9 rounded-lg flex items-center justify-center bg-green-50 dark:bg-green-900/20"><i class="fas fa-user-check text-xs text-green-600"></i></div>
        <div>
          <p class="text-[10px] text-gray-400 font-medium uppercase tracking-wider">CGPA Cutoff</p>
          <p class="font-bold text-sm text-gray-900 dark:text-white mt-0.5"><%= job.cgpa_cutoff || 'None' %></p>
        </div>
      </div>
    </div>
  </div>

  <!-- Pipeline Summary -->
  <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-100 dark:border-gray-800 p-5">
    <h3 class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-4">Applicant Pipeline</h3>
    <div class="grid grid-cols-3 lg:grid-cols-6 gap-3">
      <%
        var stageColors = {
          applied: { bg:'#f3f4f6', fg:'#6b7280' }, shortlisted: { bg:'#dbeafe', fg:'#2563eb' },
          interview: { bg:'#fef9c3', fg:'#ca8a04' }, offered: { bg:'#dcfce7', fg:'#16a34a' },
          rejected: { bg:'#fee2e2', fg:'#dc2626' }, withdrawn: { bg:'#f3f4f6', fg:'#9ca3af' }
        };
        var pipeline = job.pipeline || {};
      %>
      <% ['applied','shortlisted','interview','offered','rejected','withdrawn'].forEach(function(s){ %>
        <div class="text-center p-3.5 rounded-xl cursor-pointer hover:scale-[1.02] transition-all active:scale-[0.98]" style="background:<%= stageColors[s].bg %>" onclick="filterApplicants('<%= s %>')">
          <div class="text-xl font-bold" style="color:<%= stageColors[s].fg %>"><%= pipeline[s] || 0 %></div>
          <div class="text-[10px] font-semibold uppercase tracking-wider mt-0.5" style="color:<%= stageColors[s].fg %>"><%= s %></div>
        </div>
      <% }); %>
    </div>
  </div>

  <!-- Tabs -->
  <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-100 dark:border-gray-800 overflow-hidden shadow-sm">
    <div class="border-b border-gray-100 dark:border-gray-800 flex overflow-x-auto px-1 pt-1" style="gap:0">
      <button onclick="showTab('jd')" class="tab-btn px-5 py-3 text-sm font-semibold border-b-2 transition-all rounded-t-lg" style="border-color:hsl(var(--accent));color:hsl(var(--accent))" data-tab="jd">Description</button>
      <button onclick="showTab('skills')" class="tab-btn px-5 py-3 text-sm font-medium border-b-2 border-transparent text-gray-400 hover:text-gray-600 transition-all rounded-t-lg" data-tab="skills">Skills (<%= (job.skills || []).length %>)</button>
      <button onclick="showTab('eligibility')" class="tab-btn px-5 py-3 text-sm font-medium border-b-2 border-transparent text-gray-400 hover:text-gray-600 transition-all rounded-t-lg" data-tab="eligibility">Eligibility</button>
      <button onclick="showTab('rounds')" class="tab-btn px-5 py-3 text-sm font-medium border-b-2 border-transparent text-gray-400 hover:text-gray-600 transition-all rounded-t-lg" data-tab="rounds">Rounds (<%= (job.rounds || []).length %>)</button>
    </div>

    <div id="tab-jd" class="p-5 sm:p-6">
      <div class="prose prose-sm dark:prose-invert max-w-none"><%= job.description ? job.description : '<p class="text-gray-400">No description provided</p>' %></div>
      <% if (job.selection_notes) { %>
        <div class="mt-5 pt-5 border-t border-gray-100 dark:border-gray-800">
          <h4 class="text-[10px] font-semibold uppercase tracking-wider text-gray-400 mb-2">Selection Notes</h4>
          <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed"><%= job.selection_notes %></p>
        </div>
      <% } %>
    </div>
    <div id="tab-skills" class="p-5 sm:p-6" style="display:none">
      <div class="flex flex-wrap gap-2">
        <% (job.skills || []).forEach(function(sk) { %>
          <span class="inline-flex items-center gap-1.5 text-sm font-medium px-3 py-1.5 rounded-xl" style="background:hsla(228,100%,11%,0.06);color:hsl(228,100%,25%)">
            <%= sk.skill_name %>
            <% if (sk.is_required) { %><span class="w-1.5 h-1.5 rounded-full bg-red-400 flex-shrink-0" title="Required"></span><% } %>
          </span>
        <% }); %>
        <% if (!(job.skills || []).length) { %><p class="text-sm text-gray-400">No skills specified</p><% } %>
      </div>
    </div>
    <div id="tab-eligibility" class="p-5 sm:p-6" style="display:none">
      <div class="grid sm:grid-cols-3 gap-6 text-sm">
        <div>
          <h4 class="text-[10px] font-semibold uppercase tracking-wider text-gray-400 mb-3">Programs</h4>
          <% if (job.eligible_programs && job.eligible_programs.length) { %>
            <div class="flex flex-wrap gap-1.5"><% job.eligible_programs.forEach(function(p){ %><span class="inline-block text-xs font-medium px-2.5 py-1 rounded-lg bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-300"><%= p %></span><% }); %></div>
          <% } else { %><p class="text-gray-400">All programs</p><% } %>
        </div>
        <div>
          <h4 class="text-[10px] font-semibold uppercase tracking-wider text-gray-400 mb-3">Branches</h4>
          <% if (job.eligible_branches && job.eligible_branches.length) { %>
            <div class="flex flex-wrap gap-1.5"><% job.eligible_branches.forEach(function(b){ %><span class="inline-block text-xs font-medium px-2.5 py-1 rounded-lg bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-300"><%= b %></span><% }); %></div>
          <% } else { %><p class="text-gray-400">All branches</p><% } %>
        </div>
        <div>
          <h4 class="text-[10px] font-semibold uppercase tracking-wider text-gray-400 mb-3">Graduation Years</h4>
          <% if (job.eligible_years && job.eligible_years.length) { %>
            <div class="flex flex-wrap gap-1.5"><% job.eligible_years.forEach(function(y){ %><span class="inline-block text-xs font-medium px-2.5 py-1 rounded-lg bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-300"><%= y %></span><% }); %></div>
          <% } else { %><p class="text-gray-400">All years</p><% } %>
        </div>
      </div>
    </div>
    <div id="tab-rounds" class="p-5 sm:p-6" style="display:none">
      <% if ((job.rounds || []).length) { %>
        <div class="space-y-3">
          <% job.rounds.forEach(function(r, idx) { %>
            <div class="flex items-start gap-3 p-4 bg-gray-50 dark:bg-gray-800/50 rounded-xl border border-gray-100 dark:border-gray-700">
              <span class="w-8 h-8 rounded-lg flex items-center justify-center text-xs font-bold text-white flex-shrink-0" style="background:hsl(var(--accent))"><%= idx + 1 %></span>
              <div>
                <p class="font-semibold text-sm text-gray-900 dark:text-white"><%= r.round_name %></p>
                <p class="text-xs text-gray-500 mt-0.5"><%= r.round_type.replace(/_/g,' ') %><%= r.duration_minutes ? ' &middot; ' + r.duration_minutes + ' min' : '' %></p>
                <% if (r.description) { %><p class="text-xs text-gray-400 mt-1"><%= r.description %></p><% } %>
              </div>
            </div>
          <% }); %>
        </div>
      <% } else { %><p class="text-sm text-gray-400">No interview rounds defined</p><% } %>
    </div>
  </div>

  <!-- Applicants Section -->
  <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-100 dark:border-gray-800 shadow-sm">
    <div class="p-5 border-b border-gray-100 dark:border-gray-800 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <div class="flex items-center gap-2">
        <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background:hsla(228,100%,11%,0.06)"><i class="fas fa-users text-xs" style="color:hsl(var(--primary))"></i></div>
        <h3 class="font-bold text-gray-900 dark:text-white text-sm">Applicants <span class="text-gray-400 font-normal">(<%= applicants.length %>)</span></h3>
      </div>
      <div class="flex items-center gap-2">
        <div class="relative">
          <i class="fas fa-search absolute left-3 top-1/2 text-gray-400 text-[10px]" style="transform:translateY(-50%)"></i>
          <input type="text" id="applicant-search" placeholder="Search..." class="text-sm border border-gray-200 dark:border-gray-700 rounded-xl pl-8 pr-3 py-2 bg-white dark:bg-gray-800 w-40 hover:border-gray-300 dark:hover:border-gray-600 transition">
        </div>
        <select id="stage-filter" onchange="filterApplicants(this.value)" class="text-sm border border-gray-200 dark:border-gray-700 rounded-xl px-3 py-2 bg-white dark:bg-gray-800 hover:border-gray-300 dark:hover:border-gray-600 transition">
          <option value="">All Stages</option>
          <% ['applied','shortlisted','interview','offered','rejected','withdrawn'].forEach(function(s){ %>
            <option value="<%= s %>" <%= query.stage === s ? 'selected' : '' %>><%= s.charAt(0).toUpperCase() + s.slice(1) %></option>
          <% }); %>
        </select>
        <button onclick="bulkShortlist()" id="bulk-shortlist-btn" class="px-4 py-2 rounded-xl text-white text-xs font-semibold transition-all active:scale-[0.97]" style="display:none;background:hsl(var(--accent))">
          Shortlist Selected
        </button>
      </div>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-gray-50/80 dark:bg-gray-800/50 text-left">
            <th class="py-3 px-4 w-10"><input type="checkbox" id="select-all-apps" onchange="toggleAllApplicants(this)" class="rounded border-gray-300 dark:border-gray-600"></th>
            <th class="py-3 px-4 font-semibold text-[10px] text-gray-400 uppercase tracking-wider">Student</th>
            <th class="py-3 px-4 font-semibold text-[10px] text-gray-400 uppercase tracking-wider">Program</th>
            <th class="py-3 px-4 font-semibold text-[10px] text-gray-400 uppercase tracking-wider">CGPA</th>
            <th class="py-3 px-4 font-semibold text-[10px] text-gray-400 uppercase tracking-wider">ATS</th>
            <th class="py-3 px-4 font-semibold text-[10px] text-gray-400 uppercase tracking-wider">Resume</th>
            <th class="py-3 px-4 font-semibold text-[10px] text-gray-400 uppercase tracking-wider">Stage</th>
            <th class="py-3 px-4 font-semibold text-[10px] text-gray-400 uppercase tracking-wider w-36">Actions</th>
          </tr>
        </thead>
        <tbody id="applicants-tbody">
          <% if (applicants.length) { %>
            <% applicants.forEach(function(a) { %>
              <%
                var stageBg = { applied:'#f3f4f6', shortlisted:'#dbeafe', interview:'#fef9c3', offered:'#dcfce7', rejected:'#fee2e2', withdrawn:'#f3f4f6' };
                var stageFg = { applied:'#6b7280', shortlisted:'#2563eb', interview:'#ca8a04', offered:'#16a34a', rejected:'#dc2626', withdrawn:'#9ca3af' };
              %>
              <tr class="border-t border-gray-50 dark:border-gray-800 hover:bg-gray-50/50 dark:hover:bg-gray-800/20 transition applicant-row" data-id="<%= a.id %>" data-stage="<%= a.stage %>">
                <td class="py-3.5 px-4"><input type="checkbox" class="app-checkbox rounded border-gray-300 dark:border-gray-600" value="<%= a.id %>" onchange="updateBulkBtn()"></td>
                <td class="py-3.5 px-4">
                  <div class="flex items-center gap-2.5">
                    <div class="w-8 h-8 rounded-lg flex items-center justify-center text-white text-[10px] font-bold flex-shrink-0" style="background:hsl(var(--primary))"><%= a.name ? a.name.charAt(0).toUpperCase() : '?' %></div>
                    <div class="min-w-0">
                      <p class="font-semibold text-gray-900 dark:text-white text-[13px] truncate"><%= a.name %></p>
                      <p class="text-[10px] text-gray-400 truncate"><%= a.email %></p>
                    </div>
                  </div>
                </td>
                <td class="py-3.5 px-4 text-gray-600 dark:text-gray-400 text-[13px]"><%= a.program || '-' %> <% if (a.branch) { %><span class="text-[10px] text-gray-400">(<%= a.branch %>)</span><% } %></td>
                <td class="py-3.5 px-4 font-semibold text-[13px]"><%= a.cgpa || '-' %></td>
                <td class="py-3.5 px-4">
                  <% if (a.ats_match_score !== null && a.ats_match_score !== undefined) { %>
                    <span class="font-bold text-[13px]" style="color:<%= a.ats_match_score >= 70 ? '#16a34a' : a.ats_match_score >= 50 ? '#ca8a04' : '#dc2626' %>"><%= a.ats_match_score %>%</span>
                  <% } else { %>
                    <span class="text-gray-400 text-xs">-</span>
                  <% } %>
                </td>
                <td class="py-3.5 px-4">
                  <% if (a.resume_path) { %>
                    <a href="<%= a.resume_path %>" target="_blank" class="inline-flex items-center gap-1 text-xs font-semibold transition hover:opacity-80" style="color:hsl(var(--accent))"><i class="fas fa-file-alt text-[10px]"></i>View</a>
                  <% } else { %>
                    <span class="text-[10px] text-gray-400">No resume</span>
                  <% } %>
                </td>
                <td class="py-3.5 px-4">
                  <span class="text-[10px] font-semibold px-2.5 py-1 rounded-lg uppercase tracking-wider" style="background:<%= stageBg[a.stage] || '#f3f4f6' %>;color:<%= stageFg[a.stage] || '#6b7280' %>"><%= a.stage %></span>
                </td>
                <td class="py-3.5 px-4">
                  <div class="flex items-center gap-1">
                    <select onchange="moveApplicant(<%= a.id %>, this.value)" class="text-[10px] font-medium border border-gray-200 dark:border-gray-700 rounded-lg px-2 py-1.5 bg-white dark:bg-gray-800 hover:border-gray-300 transition">
                      <option value="">Move to...</option>
                      <% ['shortlisted','interview','offered','rejected','withdrawn'].forEach(function(s){ %>
                        <% if (s !== a.stage) { %>
                          <option value="<%= s %>"><%= s.charAt(0).toUpperCase() + s.slice(1) %></option>
                        <% } %>
                      <% }); %>
                    </select>
                    <button onclick="openNoteModal(<%= a.id %>, '<%= (a.notes || '').replace(/'/g, "\\'") %>')" class="p-1.5 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-400 hover:text-gray-600 transition" title="Add Note">
                      <i class="fas fa-sticky-note text-xs"></i>
                    </button>
                  </div>
                </td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr><td colspan="8" class="py-16 text-center text-gray-400">
              <div class="w-14 h-14 rounded-2xl mx-auto mb-3 flex items-center justify-center bg-gray-50 dark:bg-gray-800"><i class="fas fa-users text-lg text-gray-300"></i></div>
              <p class="font-medium mb-1">No applicants yet</p>
              <p class="text-xs text-gray-400">Applications will appear here</p>
            </td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Note Modal -->
<div id="note-modal" class="fixed inset-0 z-[100]" style="display:none" onclick="if(event.target===this)closeNoteModal()">
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
  <div class="absolute top-1/2 left-1/2 w-[90%] max-w-md bg-white dark:bg-gray-900 rounded-2xl p-6 shadow-2xl border border-gray-200 dark:border-gray-700" style="transform:translate(-50%,-50%)">
    <div class="flex items-center gap-2 mb-4">
      <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background:hsla(80,89%,40%,0.1)"><i class="fas fa-sticky-note text-xs" style="color:hsl(var(--accent))"></i></div>
      <h3 class="font-bold text-gray-900 dark:text-white text-sm">Applicant Note</h3>
    </div>
    <textarea id="note-text" rows="4" placeholder="Write your note here..." class="w-full border border-gray-200 dark:border-gray-700 rounded-xl px-4 py-3 text-sm bg-white dark:bg-gray-800 mb-4 hover:border-gray-300 dark:hover:border-gray-600 transition resize-none placeholder:text-gray-400"></textarea>
    <input type="hidden" id="note-app-id">
    <div class="flex justify-end gap-2">
      <button onclick="closeNoteModal()" class="px-4 py-2.5 text-sm font-medium border border-gray-200 dark:border-gray-700 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-800 transition-all active:scale-[0.97]">Cancel</button>
      <button onclick="saveNote()" class="px-5 py-2.5 text-sm text-white rounded-xl font-semibold transition-all active:scale-[0.97]" style="background:hsl(var(--accent))">Save Note</button>
    </div>
  </div>
</div>

<script>
var jobId = <%= job.id %>;

// ─── Tabs ────────────────────────────────────────────────
function showTab(tab) {
  ['jd','skills','eligibility','rounds'].forEach(function(t) {
    document.getElementById('tab-' + t).style.display = t === tab ? 'block' : 'none';
  });
  document.querySelectorAll('.tab-btn').forEach(function(btn) {
    if (btn.dataset.tab === tab) {
      btn.style.borderColor = 'hsl(var(--accent))';
      btn.style.color = 'hsl(var(--accent))';
      btn.className = btn.className.replace('font-medium', 'font-semibold');
    } else {
      btn.style.borderColor = 'transparent';
      btn.style.color = '#9ca3af';
      btn.className = btn.className.replace('font-semibold', 'font-medium');
    }
  });
}

// ─── Publish / Unpublish ─────────────────────────────────
function publishJob() {
  var btn = document.getElementById('publish-btn');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Publishing...';
  fetch('/admin/jobs/api/' + jobId + '/publish', { method: 'POST' })
    .then(function(r){ return r.json(); })
    .then(function(res){
      if (res.success) { showToast('Job published', 'success'); setTimeout(function(){ window.location.reload(); }, 800); }
      else { showToast(res.error || 'Failed', 'error'); btn.disabled = false; }
    })
    .catch(function(err){ showToast('Error: ' + err.message, 'error'); btn.disabled = false; });
}
function unpublishJob() {
  if (!confirm('Remove this job from the public Job Board?')) return;
  fetch('/admin/jobs/api/' + jobId + '/unpublish', { method: 'POST' })
    .then(function(r){ return r.json(); })
    .then(function(res){
      if (res.success) { showToast('Job unpublished', 'success'); setTimeout(function(){ window.location.reload(); }, 800); }
      else showToast(res.error || 'Failed', 'error');
    });
}

// ─── Status Change ───────────────────────────────────────
function changeStatus(status) {
  fetch('/admin/jobs/api/' + jobId + '/status', {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ status: status })
  }).then(function(r){ return r.json(); }).then(function(res){
    if (res.success) { showToast('Status updated', 'success'); setTimeout(function(){ window.location.reload(); }, 800); }
    else showToast(res.error || 'Failed', 'error');
  });
}

// ─── Filter Applicants ───────────────────────────────────
function filterApplicants(stage) {
  document.getElementById('stage-filter').value = stage;
  var rows = document.querySelectorAll('.applicant-row');
  rows.forEach(function(row) {
    row.style.display = (!stage || row.dataset.stage === stage) ? '' : 'none';
  });
}

// ─── Move Applicant ──────────────────────────────────────
function moveApplicant(appId, stage) {
  if (!stage) return;
  fetch('/admin/jobs/api/applicants/' + appId + '/stage', {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ stage: stage })
  }).then(function(r){ return r.json(); }).then(function(res){
    if (res.success) { showToast('Applicant moved', 'success'); setTimeout(function(){ window.location.reload(); }, 800); }
    else showToast(res.error || 'Failed', 'error');
  });
}

// ─── Bulk Shortlist ──────────────────────────────────────
function toggleAllApplicants(el) {
  document.querySelectorAll('.app-checkbox').forEach(function(cb){ cb.checked = el.checked; });
  updateBulkBtn();
}
function updateBulkBtn() {
  var checked = document.querySelectorAll('.app-checkbox:checked');
  document.getElementById('bulk-shortlist-btn').style.display = checked.length > 0 ? 'inline-flex' : 'none';
}
function bulkShortlist() {
  var ids = Array.from(document.querySelectorAll('.app-checkbox:checked')).map(function(c){ return parseInt(c.value); });
  if (!ids.length) return;
  fetch('/admin/jobs/api/' + jobId + '/shortlist', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ application_ids: ids })
  }).then(function(r){ return r.json(); }).then(function(res){
    if (res.success) { showToast('Applicants shortlisted', 'success'); setTimeout(function(){ window.location.reload(); }, 800); }
    else showToast(res.error || 'Failed', 'error');
  });
}

// ─── Note Modal ──────────────────────────────────────────
function openNoteModal(appId, note) {
  document.getElementById('note-app-id').value = appId;
  document.getElementById('note-text').value = note || '';
  document.getElementById('note-modal').style.display = 'block';
}
function closeNoteModal() { document.getElementById('note-modal').style.display = 'none'; }
function saveNote() {
  var appId = document.getElementById('note-app-id').value;
  var note = document.getElementById('note-text').value;
  fetch('/admin/jobs/api/applicants/' + appId + '/note', {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ note: note })
  }).then(function(r){ return r.json(); }).then(function(res){
    if (res.success) { closeNoteModal(); showToast('Note saved', 'success'); }
    else showToast(res.error || 'Failed', 'error');
  });
}

// ─── Search Applicants ───────────────────────────────────
document.getElementById('applicant-search').addEventListener('input', function() {
  var q = this.value.toLowerCase();
  document.querySelectorAll('.applicant-row').forEach(function(row) {
    var text = row.textContent.toLowerCase();
    row.style.display = text.includes(q) ? '' : 'none';
  });
});
</script>

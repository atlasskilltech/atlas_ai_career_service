<div class="space-y-5">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Jobs Management</h1>
      <p class="text-sm text-gray-500 mt-1"><%= total %> job<%= total !== 1 ? 's' : '' %> found</p>
    </div>
    <div class="flex items-center gap-2">
      <a href="/admin/jobs/export?<%= Object.entries(query).map(function(e){return e[0]+'='+encodeURIComponent(e[1]);}).join('&') %>" class="inline-flex items-center gap-2 px-4 py-2 border border-gray-300 dark:border-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800 text-sm transition">
        <i class="fas fa-download"></i> Export
      </a>
      <a href="/admin/jobs/create" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-white text-sm font-medium transition" style="background:hsl(var(--accent))">
        <i class="fas fa-plus"></i> Create Job
      </a>
    </div>
  </div>

  <!-- Stats Cards -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4 text-center">
      <div class="text-2xl font-bold" style="color:hsl(var(--accent))"><%= stats.total_jobs || 0 %></div>
      <p class="text-xs text-gray-500 mt-1">Total Jobs</p>
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4 text-center">
      <div class="text-2xl font-bold text-green-600"><%= stats.active_jobs || 0 %></div>
      <p class="text-xs text-gray-500 mt-1">Active</p>
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4 text-center">
      <div class="text-2xl font-bold text-yellow-600"><%= stats.draft_jobs || 0 %></div>
      <p class="text-xs text-gray-500 mt-1">Drafts</p>
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4 text-center">
      <div class="text-2xl font-bold text-blue-600"><%= stats.total_applications || 0 %></div>
      <p class="text-xs text-gray-500 mt-1">Applications</p>
    </div>
  </div>

  <!-- Search + Filters Row -->
  <div class="flex flex-col sm:flex-row gap-3">
    <div class="relative flex-1">
      <i class="fas fa-search absolute left-3 top-1/2 text-gray-400 text-sm" style="transform:translateY(-50%)"></i>
      <input type="text" id="search-input" value="<%= query.search || '' %>" placeholder="Search by company or role..."
        class="w-full pl-10 pr-4 py-2.5 border border-gray-300 dark:border-gray-700 rounded-lg bg-white dark:bg-gray-800 text-sm">
    </div>
    <div class="flex items-center gap-2">
      <button onclick="toggleFilters()" class="inline-flex items-center gap-2 px-4 py-2.5 border border-gray-300 dark:border-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800 text-sm transition">
        <i class="fas fa-filter"></i> Filters
      </button>
      <!-- View Toggle -->
      <div class="flex border border-gray-300 dark:border-gray-700 rounded-lg overflow-hidden">
        <button onclick="setView('grid')" id="btn-grid" class="px-3 py-2 text-sm" style="background:hsl(var(--accent));color:white">
          <i class="fas fa-th"></i>
        </button>
        <button onclick="setView('list')" id="btn-list" class="px-3 py-2 text-sm bg-white dark:bg-gray-800 text-gray-500">
          <i class="fas fa-list"></i>
        </button>
      </div>
    </div>
  </div>

  <!-- Filters Panel (collapsible) -->
  <div id="filters-panel" style="display:none" class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-5">
    <div class="flex items-center justify-between mb-4">
      <h3 class="font-semibold text-gray-900 dark:text-white">Filters</h3>
      <button onclick="clearFilters()" class="text-xs text-red-500 hover:text-red-600 font-medium">Clear All</button>
    </div>
    <form id="filter-form" class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <div>
        <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Status</label>
        <select name="status" class="w-full text-sm border border-gray-300 dark:border-gray-700 rounded-lg px-3 py-2 bg-white dark:bg-gray-800">
          <option value="">All</option>
          <% ['draft','active','closed','on_hold'].forEach(function(s){ %>
            <option value="<%= s %>" <%= query.status === s ? 'selected' : '' %>><%= s.replace(/_/g,' ') %></option>
          <% }); %>
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Job Type</label>
        <select name="job_type" class="w-full text-sm border border-gray-300 dark:border-gray-700 rounded-lg px-3 py-2 bg-white dark:bg-gray-800">
          <option value="">All</option>
          <% ['full_time','part_time','internship','contract','freelance'].forEach(function(t){ %>
            <option value="<%= t %>" <%= query.job_type === t ? 'selected' : '' %>><%= t.replace(/_/g,' ') %></option>
          <% }); %>
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Work Mode</label>
        <select name="work_mode" class="w-full text-sm border border-gray-300 dark:border-gray-700 rounded-lg px-3 py-2 bg-white dark:bg-gray-800">
          <option value="">All</option>
          <% ['onsite','remote','hybrid'].forEach(function(w){ %>
            <option value="<%= w %>" <%= query.work_mode === w ? 'selected' : '' %>><%= w %></option>
          <% }); %>
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Company</label>
        <select name="company" class="w-full text-sm border border-gray-300 dark:border-gray-700 rounded-lg px-3 py-2 bg-white dark:bg-gray-800">
          <option value="">All</option>
          <% filterOptions.companies.forEach(function(c){ %>
            <option value="<%= c %>" <%= query.company === c ? 'selected' : '' %>><%= c %></option>
          <% }); %>
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Location</label>
        <select name="location" class="w-full text-sm border border-gray-300 dark:border-gray-700 rounded-lg px-3 py-2 bg-white dark:bg-gray-800">
          <option value="">All</option>
          <% filterOptions.locations.forEach(function(l){ %>
            <option value="<%= l %>" <%= query.location === l ? 'selected' : '' %>><%= l %></option>
          <% }); %>
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">CTC Range (LPA)</label>
        <div class="flex gap-2">
          <input type="number" name="ctc_min" placeholder="Min" step="0.5" value="<%= query.ctc_min || '' %>" class="w-1/2 text-sm border border-gray-300 dark:border-gray-700 rounded-lg px-3 py-2 bg-white dark:bg-gray-800">
          <input type="number" name="ctc_max" placeholder="Max" step="0.5" value="<%= query.ctc_max || '' %>" class="w-1/2 text-sm border border-gray-300 dark:border-gray-700 rounded-lg px-3 py-2 bg-white dark:bg-gray-800">
        </div>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Deadline Range</label>
        <div class="flex gap-2">
          <input type="date" name="deadline_from" value="<%= query.deadline_from || '' %>" class="w-1/2 text-sm border border-gray-300 dark:border-gray-700 rounded-lg px-3 py-2 bg-white dark:bg-gray-800">
          <input type="date" name="deadline_to" value="<%= query.deadline_to || '' %>" class="w-1/2 text-sm border border-gray-300 dark:border-gray-700 rounded-lg px-3 py-2 bg-white dark:bg-gray-800">
        </div>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Sort By</label>
        <select name="sort" class="w-full text-sm border border-gray-300 dark:border-gray-700 rounded-lg px-3 py-2 bg-white dark:bg-gray-800">
          <% ['newest','oldest','deadline','company','ctc'].forEach(function(s){ %>
            <option value="<%= s %>" <%= query.sort === s ? 'selected' : '' %>><%= s.charAt(0).toUpperCase() + s.slice(1) %></option>
          <% }); %>
        </select>
      </div>
      <div class="sm:col-span-2 lg:col-span-4 flex justify-end gap-3 pt-2">
        <button type="button" onclick="clearFilters()" class="px-4 py-2 text-sm border border-gray-300 dark:border-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800 transition">Reset</button>
        <button type="submit" class="px-6 py-2 text-sm text-white rounded-lg font-medium transition" style="background:hsl(var(--accent))">Apply</button>
      </div>
    </form>
  </div>

  <!-- Card Grid View -->
  <div id="view-grid" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
    <% if (jobs.length) { %>
      <% jobs.forEach(function(j) { %>
        <%
          var statusColors = { draft:'background:#f3f4f6;color:#6b7280', active:'background:#dcfce7;color:#16a34a', closed:'background:#fee2e2;color:#dc2626', on_hold:'background:#fef9c3;color:#ca8a04' };
          var typeLabels = { full_time:'Full Time', part_time:'Part Time', internship:'Internship', contract:'Contract', freelance:'Freelance' };
          var daysLeft = j.application_deadline ? Math.ceil((new Date(j.application_deadline) - new Date()) / 86400000) : null;
        %>
        <a href="/admin/jobs/<%= j.id %>" class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-5 hover:shadow-lg transition block">
          <div class="flex items-start gap-3 mb-3">
            <% if (j.company_logo) { %>
              <img src="<%= j.company_logo %>" alt="" class="w-10 h-10 rounded-lg object-contain border border-gray-200 dark:border-gray-700" style="flex-shrink:0">
            <% } else { %>
              <div class="w-10 h-10 rounded-lg flex items-center justify-center text-white text-sm font-bold" style="flex-shrink:0;background:hsl(var(--primary))"><%= j.company_name ? j.company_name.charAt(0) : '?' %></div>
            <% } %>
            <div class="flex-1 min-w-0">
              <h3 class="font-semibold text-gray-900 dark:text-white text-sm" style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= j.role_title %></h3>
              <p class="text-xs text-gray-500"><%= j.company_name %></p>
            </div>
            <span class="text-[10px] font-medium px-2 py-0.5 rounded-full" style="<%= statusColors[j.status] || statusColors.draft %>; flex-shrink:0"><%= j.status %></span>
          </div>

          <div class="flex flex-wrap gap-2 text-xs text-gray-500 mb-3">
            <% if (j.ctc_min || j.ctc_max) { %>
              <span><i class="fas fa-rupee-sign w-3"></i> <%= j.ctc_min || 0 %>–<%= j.ctc_max || '?' %> LPA</span>
            <% } %>
            <% if (j.location) { %>
              <span><i class="fas fa-map-marker-alt w-3"></i> <%= j.location %></span>
            <% } %>
            <span class="px-1.5 py-0.5 rounded text-[10px] font-medium" style="background:#eff6ff;color:#2563eb"><%= typeLabels[j.job_type] || j.job_type %></span>
          </div>

          <% if (daysLeft !== null) { %>
            <div class="text-[10px] mb-3 <%= daysLeft <= 3 ? 'text-red-500 font-medium' : 'text-gray-400' %>">
              <i class="fas fa-clock w-3"></i>
              <% if (daysLeft < 0) { %>Expired<% } else if (daysLeft === 0) { %>Closes today<% } else { %><%= daysLeft %> day<%= daysLeft > 1 ? 's' : '' %> left<% } %>
            </div>
          <% } %>

          <!-- Pipeline Mini Stats -->
          <div class="grid grid-cols-4 gap-1 pt-3 border-t border-gray-100 dark:border-gray-800">
            <div class="text-center">
              <div class="text-sm font-bold text-gray-700 dark:text-gray-300"><%= j.applied_count || 0 %></div>
              <div class="text-[9px] text-gray-400">Applied</div>
            </div>
            <div class="text-center">
              <div class="text-sm font-bold text-blue-600"><%= j.shortlisted_count || 0 %></div>
              <div class="text-[9px] text-gray-400">Shortlisted</div>
            </div>
            <div class="text-center">
              <div class="text-sm font-bold text-yellow-600"><%= j.interview_count || 0 %></div>
              <div class="text-[9px] text-gray-400">Interview</div>
            </div>
            <div class="text-center">
              <div class="text-sm font-bold text-green-600"><%= j.offer_count || 0 %></div>
              <div class="text-[9px] text-gray-400">Offers</div>
            </div>
          </div>
        </a>
      <% }); %>
    <% } else { %>
      <div class="sm:col-span-2 lg:col-span-3 py-12 text-center text-gray-400">
        <i class="fas fa-briefcase text-4xl mb-3 block"></i>
        <p>No jobs found</p>
        <a href="/admin/jobs/create" class="text-sm mt-2 inline-block" style="color:hsl(var(--accent))">Create your first job</a>
      </div>
    <% } %>
  </div>

  <!-- List View (hidden by default) -->
  <div id="view-list" style="display:none" class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-gray-50 dark:bg-gray-800 text-left">
            <th class="py-3 px-4 font-medium">Company / Role</th>
            <th class="py-3 px-4 font-medium">Type</th>
            <th class="py-3 px-4 font-medium">CTC</th>
            <th class="py-3 px-4 font-medium">Location</th>
            <th class="py-3 px-4 font-medium">Deadline</th>
            <th class="py-3 px-4 font-medium">Pipeline</th>
            <th class="py-3 px-4 font-medium">Status</th>
            <th class="py-3 px-4 font-medium w-20">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (jobs.length) { %>
            <% jobs.forEach(function(j) { %>
              <%
                var statusStyles = { draft:'background:#f3f4f6;color:#6b7280', active:'background:#dcfce7;color:#16a34a', closed:'background:#fee2e2;color:#dc2626', on_hold:'background:#fef9c3;color:#ca8a04' };
                var typeLabels2 = { full_time:'Full Time', part_time:'Part Time', internship:'Internship', contract:'Contract', freelance:'Freelance' };
              %>
              <tr class="border-t border-gray-100 dark:border-gray-800 hover:bg-gray-50 dark:hover:bg-gray-800/50">
                <td class="py-3 px-4">
                  <div class="flex items-center gap-3">
                    <% if (j.company_logo) { %>
                      <img src="<%= j.company_logo %>" alt="" class="w-8 h-8 rounded object-contain border border-gray-200 dark:border-gray-700">
                    <% } else { %>
                      <div class="w-8 h-8 rounded flex items-center justify-center text-white text-xs font-bold" style="background:hsl(var(--primary))"><%= j.company_name ? j.company_name.charAt(0) : '?' %></div>
                    <% } %>
                    <div>
                      <a href="/admin/jobs/<%= j.id %>" class="font-medium text-gray-900 dark:text-white hover:underline"><%= j.role_title %></a>
                      <p class="text-xs text-gray-500"><%= j.company_name %></p>
                    </div>
                  </div>
                </td>
                <td class="py-3 px-4"><span class="text-xs px-2 py-0.5 rounded font-medium" style="background:#eff6ff;color:#2563eb"><%= typeLabels2[j.job_type] || j.job_type %></span></td>
                <td class="py-3 px-4 text-gray-600 dark:text-gray-400"><%= j.ctc_min || j.ctc_max ? (j.ctc_min || 0) + '–' + (j.ctc_max || '?') + ' LPA' : '-' %></td>
                <td class="py-3 px-4 text-gray-600 dark:text-gray-400"><%= j.location || '-' %></td>
                <td class="py-3 px-4 text-gray-600 dark:text-gray-400"><%= j.application_deadline ? new Date(j.application_deadline).toLocaleDateString('en-IN',{day:'numeric',month:'short'}) : '-' %></td>
                <td class="py-3 px-4">
                  <div class="flex items-center gap-2 text-xs">
                    <span title="Applied"><%= j.applied_count || 0 %></span>
                    <i class="fas fa-chevron-right text-[8px] text-gray-300"></i>
                    <span class="text-blue-600" title="Shortlisted"><%= j.shortlisted_count || 0 %></span>
                    <i class="fas fa-chevron-right text-[8px] text-gray-300"></i>
                    <span class="text-yellow-600" title="Interview"><%= j.interview_count || 0 %></span>
                    <i class="fas fa-chevron-right text-[8px] text-gray-300"></i>
                    <span class="text-green-600 font-bold" title="Offers"><%= j.offer_count || 0 %></span>
                  </div>
                </td>
                <td class="py-3 px-4"><span class="text-[10px] font-medium px-2 py-0.5 rounded-full" style="<%= statusStyles[j.status] || statusStyles.draft %>"><%= j.status %></span></td>
                <td class="py-3 px-4">
                  <div class="flex items-center gap-1">
                    <a href="/admin/jobs/<%= j.id %>" class="p-1.5 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-500" title="View"><i class="fas fa-eye text-xs"></i></a>
                    <a href="/admin/jobs/<%= j.id %>/edit" class="p-1.5 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-500" title="Edit"><i class="fas fa-pen text-xs"></i></a>
                    <button onclick="deleteJob(<%= j.id %>)" class="p-1.5 rounded-lg hover:bg-red-50 dark:hover:bg-red-900/20 text-gray-500 hover:text-red-500" title="Delete"><i class="fas fa-trash text-xs"></i></button>
                  </div>
                </td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr><td colspan="8" class="py-12 text-center text-gray-400"><i class="fas fa-briefcase text-3xl mb-3 block"></i>No jobs found</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Pagination -->
  <% if (totalPages > 1) { %>
    <div class="flex items-center justify-between">
      <span class="text-xs text-gray-500">Page <%= page %> of <%= totalPages %> (<%= total %> total)</span>
      <div class="flex items-center gap-1">
        <% if (page > 1) { %>
          <a href="?<%= Object.entries(query).filter(function(e){return e[0]!=='page';}).map(function(e){return e[0]+'='+encodeURIComponent(e[1]);}).join('&') %>&page=<%= page-1 %>"
             class="px-3 py-1.5 text-sm border border-gray-300 dark:border-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800">Prev</a>
        <% } %>
        <% for (var p = Math.max(1, page-2); p <= Math.min(totalPages, page+2); p++) { %>
          <a href="?<%= Object.entries(query).filter(function(e){return e[0]!=='page';}).map(function(e){return e[0]+'='+encodeURIComponent(e[1]);}).join('&') %>&page=<%= p %>"
             class="px-3 py-1.5 text-sm border rounded-lg <%= p === page ? 'text-white border-transparent' : 'border-gray-300 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-800' %>"
             <% if (p === page) { %>style="background:hsl(var(--accent))"<% } %>><%= p %></a>
        <% } %>
        <% if (page < totalPages) { %>
          <a href="?<%= Object.entries(query).filter(function(e){return e[0]!=='page';}).map(function(e){return e[0]+'='+encodeURIComponent(e[1]);}).join('&') %>&page=<%= page+1 %>"
             class="px-3 py-1.5 text-sm border border-gray-300 dark:border-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800">Next</a>
        <% } %>
      </div>
    </div>
  <% } %>
</div>

<script>
// ─── Search ──────────────────────────────────────────────
(function(){
  var input = document.getElementById('search-input');
  var timer;
  input.addEventListener('input', function(){
    clearTimeout(timer);
    timer = setTimeout(function(){
      var url = new URL(window.location.href);
      if (input.value) url.searchParams.set('search', input.value);
      else url.searchParams.delete('search');
      url.searchParams.set('page','1');
      window.location.href = url.toString();
    }, 500);
  });
})();

// ─── Filters ─────────────────────────────────────────────
function toggleFilters(){
  var p = document.getElementById('filters-panel');
  p.style.display = p.style.display === 'none' ? 'block' : 'none';
}
function clearFilters(){ window.location.href = '/admin/jobs'; }

(function(){
  var form = document.getElementById('filter-form');
  if (!form) return;
  form.addEventListener('submit', function(e){
    e.preventDefault();
    var url = new URL(window.location.origin + '/admin/jobs');
    var fd = new FormData(form);
    fd.forEach(function(val, key){ if (val) url.searchParams.set(key, val); });
    var search = document.getElementById('search-input').value;
    if (search) url.searchParams.set('search', search);
    url.searchParams.set('page','1');
    window.location.href = url.toString();
  });
})();

// ─── View Toggle ─────────────────────────────────────────
var currentView = localStorage.getItem('admin-jobs-view') || 'grid';
function setView(v){
  currentView = v;
  localStorage.setItem('admin-jobs-view', v);
  document.getElementById('view-grid').style.display = v === 'grid' ? 'grid' : 'none';
  document.getElementById('view-list').style.display = v === 'list' ? 'block' : 'none';
  document.getElementById('btn-grid').style.background = v === 'grid' ? 'hsl(var(--accent))' : '';
  document.getElementById('btn-grid').style.color = v === 'grid' ? 'white' : '#6b7280';
  document.getElementById('btn-list').style.background = v === 'list' ? 'hsl(var(--accent))' : '';
  document.getElementById('btn-list').style.color = v === 'list' ? 'white' : '#6b7280';
}
setView(currentView);

// ─── Delete ──────────────────────────────────────────────
function deleteJob(id){
  if (!confirm('Are you sure you want to delete this job?')) return;
  fetch('/admin/jobs/api/' + id, { method: 'DELETE' })
    .then(function(r){ return r.json(); })
    .then(function(res){
      if (res.success) window.location.reload();
      else alert(res.error || 'Delete failed');
    })
    .catch(function(err){ alert('Error: ' + err.message); });
}
</script>

<div class="space-y-6">
  <h1 class="text-2xl font-bold">Settings</h1>

  <div class="grid lg:grid-cols-2 gap-6">
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6">
      <h3 class="font-semibold mb-4">Platform Settings</h3>
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Academic Year</label>
          <input type="text" value="2025-26" disabled class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-lg bg-gray-50 dark:bg-gray-800 text-sm">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Institution Name</label>
          <input type="text" value="Atlas SkillTech University" disabled class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-lg bg-gray-50 dark:bg-gray-800 text-sm">
        </div>
      </div>
    </div>

    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6">
      <h3 class="font-semibold mb-4">Quick Actions</h3>
      <div class="space-y-3">
        <button onclick="fetch('/admin/refresh', {method:'POST'}).then(function(){location.reload();})" class="w-full text-left px-4 py-3 rounded-lg border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-800 transition text-sm flex items-center gap-3">
          <i class="fas fa-sync-alt text-accent w-5"></i> Recalculate Dashboard Metrics
        </button>
        <a href="/job-board/admin" class="block px-4 py-3 rounded-lg border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-800 transition text-sm flex items-center gap-3">
          <i class="fas fa-cogs text-blue-500 w-5"></i> Job Board Management
        </a>
        <a href="/admin/students" class="block px-4 py-3 rounded-lg border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-800 transition text-sm flex items-center gap-3">
          <i class="fas fa-users text-purple-500 w-5"></i> View All Students
        </a>
      </div>
    </div>
  </div>
</div>

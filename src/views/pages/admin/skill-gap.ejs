<div class="space-y-6">
  <h1 class="text-2xl font-bold">Skill Gap Analysis</h1>

  <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-gray-50 dark:bg-gray-800 text-left">
            <th class="py-3 px-4 font-medium">Student</th>
            <th class="py-3 px-4 font-medium">Department</th>
            <th class="py-3 px-4 font-medium">Target Role</th>
            <th class="py-3 px-4 font-medium">Match %</th>
            <th class="py-3 px-4 font-medium">Missing Skills</th>
            <th class="py-3 px-4 font-medium">Date</th>
          </tr>
        </thead>
        <tbody>
          <% if (analyses.length) { %>
            <% analyses.forEach(function(a) { %>
              <%
                var missing = [];
                try { missing = typeof a.missing_skills === 'string' ? JSON.parse(a.missing_skills) : (a.missing_skills || []); } catch(e) {}
              %>
              <tr class="border-t border-gray-100 dark:border-gray-800 hover:bg-gray-50 dark:hover:bg-gray-800/50">
                <td class="py-3 px-4 font-medium"><%= a.student %></td>
                <td class="py-3 px-4 text-gray-500"><%= a.department || '-' %></td>
                <td class="py-3 px-4"><%= a.target_role || '-' %></td>
                <td class="py-3 px-4">
                  <span class="font-semibold <%= a.match_percentage >= 70 ? 'text-green-600' : a.match_percentage >= 40 ? 'text-yellow-600' : 'text-red-600' %>"><%= a.match_percentage %>%</span>
                </td>
                <td class="py-3 px-4 max-w-[250px]">
                  <div class="flex flex-wrap gap-1">
                    <% missing.slice(0, 3).forEach(function(s) { %>
                      <span class="text-[10px] px-1.5 py-0.5 rounded bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400"><%= typeof s === 'string' ? s : s.name || s %></span>
                    <% }); %>
                    <% if (missing.length > 3) { %>
                      <span class="text-[10px] text-gray-400">+<%= missing.length - 3 %> more</span>
                    <% } %>
                  </div>
                </td>
                <td class="py-3 px-4 text-gray-500 text-xs"><%= new Date(a.created_at).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' }) %></td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr><td colspan="6" class="py-8 text-center text-gray-400">No skill analyses found</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

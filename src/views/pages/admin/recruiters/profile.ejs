<%
  var tierConfig = {
    platinum: { style: 'background:#f3e8ff;color:#7c3aed', label: 'Platinum', icon: 'fa-gem' },
    gold: { style: 'background:#fef9c3;color:#ca8a04', label: 'Gold', icon: 'fa-crown' },
    silver: { style: 'background:#f3f4f6;color:#6b7280', label: 'Silver', icon: 'fa-medal' },
    new: { style: 'background:#eff6ff;color:#2563eb', label: 'New', icon: 'fa-star' }
  };
  var tf = tierConfig[recruiter.tier] || tierConfig.new;
  var mouStyle = {
    active: 'background:#dcfce7;color:#16a34a',
    pending: 'background:#fef9c3;color:#ca8a04',
    expired: 'background:#fee2e2;color:#dc2626',
    none: 'background:#f3f4f6;color:#9ca3af'
  };
%>

<div class="space-y-5">
  <!-- Breadcrumb -->
  <div class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400">
    <a href="/admin/recruiters" class="hover:text-gray-700 dark:hover:text-gray-200 transition"><i class="fas fa-arrow-left mr-1"></i> All Recruiters</a>
    <i class="fas fa-chevron-right text-[10px] text-gray-300"></i>
    <span class="text-gray-700 dark:text-gray-200 font-medium"><%= recruiter.company_name %></span>
  </div>

  <!-- Header Card -->
  <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden">
    <!-- Gradient Banner -->
    <div style="height:80px;background:linear-gradient(135deg, hsl(var(--primary)), hsl(228,80%,25%))"></div>
    <div class="px-6 pb-6" style="margin-top:-36px">
      <div class="flex flex-col sm:flex-row sm:items-end gap-4">
        <!-- Logo -->
        <% if (recruiter.logo) { %>
          <img src="<%= recruiter.logo %>" alt="" class="w-[72px] h-[72px] rounded-2xl object-contain border-4 border-white dark:border-gray-900 bg-white dark:bg-gray-800 shadow-lg">
        <% } else { %>
          <div class="w-[72px] h-[72px] rounded-2xl flex items-center justify-center border-4 border-white dark:border-gray-900 shadow-lg" style="background:hsl(var(--primary))">
            <span class="text-2xl font-bold" style="color:hsl(var(--accent))"><%= recruiter.company_name.charAt(0).toUpperCase() %></span>
          </div>
        <% } %>
        <div class="flex-1 min-w-0 pt-2">
          <div class="flex flex-wrap items-center gap-2 mb-1">
            <h1 class="text-xl font-bold text-gray-900 dark:text-white"><%= recruiter.company_name %></h1>
            <span class="text-[10px] font-bold px-2.5 py-1 rounded-full flex items-center gap-1" style="<%= tf.style %>">
              <i class="fas <%= tf.icon %> text-[8px]"></i> <%= tf.label %>
            </span>
            <% if (recruiter.mou_status && recruiter.mou_status !== 'none') { %>
              <span class="text-[10px] font-medium px-2.5 py-1 rounded-full" style="<%= mouStyle[recruiter.mou_status] %>">
                <i class="fas fa-file-contract mr-0.5"></i> MOU: <%= recruiter.mou_status.charAt(0).toUpperCase() + recruiter.mou_status.slice(1) %>
              </span>
            <% } %>
          </div>
          <div class="flex flex-wrap items-center gap-4 text-sm text-gray-500 dark:text-gray-400">
            <% if (recruiter.industry) { %><span><i class="fas fa-industry mr-1 text-gray-400"></i> <%= recruiter.industry %></span><% } %>
            <% if (recruiter.website) { %><a href="<%= recruiter.website %>" target="_blank" class="hover:text-blue-600 transition"><i class="fas fa-globe mr-1"></i> Website <i class="fas fa-external-link-alt text-[9px]"></i></a><% } %>
            <% if (recruiter.company_size) { %><span><i class="fas fa-users mr-1 text-gray-400"></i> <%= recruiter.company_size.charAt(0).toUpperCase() + recruiter.company_size.slice(1) %></span><% } %>
            <span class="text-xs text-gray-400">Score: <strong class="text-gray-600 dark:text-gray-300"><%= recruiter.tier_score || 0 %></strong></span>
          </div>
        </div>
        <button onclick="openEditModal()" class="self-start sm:self-end inline-flex items-center gap-2 px-4 py-2 text-sm font-medium border border-gray-300 dark:border-gray-700 rounded-lg text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 transition">
          <i class="fas fa-pen text-xs"></i> Edit
        </button>
      </div>
    </div>
  </div>

  <!-- Stats + Contact Row -->
  <div class="grid lg:grid-cols-3 gap-4">
    <!-- Contact Card -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-5">
      <h3 class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3 flex items-center gap-2">
        <i class="fas fa-address-card text-gray-400"></i> Contact Person
      </h3>
      <% if (recruiter.contact_name) { %>
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold" style="background:hsl(var(--primary));color:hsl(var(--accent))">
            <%= recruiter.contact_name.charAt(0).toUpperCase() %>
          </div>
          <div>
            <p class="font-semibold text-gray-900 dark:text-white text-sm"><%= recruiter.contact_name %></p>
            <% if (recruiter.contact_role) { %><p class="text-xs text-gray-500"><%= recruiter.contact_role %></p><% } %>
          </div>
        </div>
        <div class="space-y-2 text-sm">
          <% if (recruiter.contact_email) { %>
            <a href="mailto:<%= recruiter.contact_email %>" class="flex items-center gap-2 text-blue-600 hover:text-blue-700 hover:underline transition">
              <div class="w-7 h-7 rounded-lg bg-blue-50 dark:bg-blue-900/20 flex items-center justify-center flex-shrink-0"><i class="fas fa-envelope text-blue-500 text-[10px]"></i></div>
              <span class="truncate text-xs"><%= recruiter.contact_email %></span>
            </a>
          <% } %>
          <% if (recruiter.contact_phone) { %>
            <a href="tel:<%= recruiter.contact_phone %>" class="flex items-center gap-2 text-blue-600 hover:text-blue-700 hover:underline transition">
              <div class="w-7 h-7 rounded-lg bg-green-50 dark:bg-green-900/20 flex items-center justify-center flex-shrink-0"><i class="fas fa-phone text-green-500 text-[10px]"></i></div>
              <span class="text-xs"><%= recruiter.contact_phone %></span>
            </a>
          <% } %>
        </div>
      <% } else { %>
        <div class="text-center py-4">
          <i class="fas fa-user-slash text-gray-300 dark:text-gray-600 text-2xl mb-2"></i>
          <p class="text-xs text-gray-400">No contact info added</p>
        </div>
      <% } %>
    </div>

    <!-- Stats Grid (spans 2 cols) -->
    <div class="lg:col-span-2 grid grid-cols-4 gap-3">
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4 text-center">
        <div class="w-10 h-10 rounded-xl mx-auto mb-2 flex items-center justify-center" style="background:hsla(228,100%,11%,0.08)">
          <i class="fas fa-briefcase" style="color:hsl(var(--primary))"></i>
        </div>
        <p class="text-2xl font-bold text-gray-900 dark:text-white"><%= stats ? stats.totalJobs : 0 %></p>
        <p class="text-[10px] text-gray-500 mt-0.5 uppercase tracking-wider">Jobs Posted</p>
      </div>
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4 text-center">
        <div class="w-10 h-10 rounded-xl mx-auto mb-2 flex items-center justify-center bg-green-50 dark:bg-green-900/20">
          <i class="fas fa-user-check text-green-600"></i>
        </div>
        <p class="text-2xl font-bold text-green-600"><%= stats ? stats.totalHired : 0 %></p>
        <p class="text-[10px] text-gray-500 mt-0.5 uppercase tracking-wider">Students Hired</p>
      </div>
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4 text-center">
        <div class="w-10 h-10 rounded-xl mx-auto mb-2 flex items-center justify-center bg-purple-50 dark:bg-purple-900/20">
          <i class="fas fa-rupee-sign text-purple-600"></i>
        </div>
        <p class="text-2xl font-bold text-purple-600"><%= stats && stats.avgCtc ? (stats.avgCtc / 100000).toFixed(1) + 'L' : '—' %></p>
        <p class="text-[10px] text-gray-500 mt-0.5 uppercase tracking-wider">Avg CTC</p>
      </div>
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4 text-center">
        <div class="w-10 h-10 rounded-xl mx-auto mb-2 flex items-center justify-center bg-orange-50 dark:bg-orange-900/20">
          <i class="fas fa-chart-line text-orange-600"></i>
        </div>
        <p class="text-2xl font-bold text-orange-600"><%= stats ? stats.conversionRate : 0 %><span class="text-base">%</span></p>
        <p class="text-[10px] text-gray-500 mt-0.5 uppercase tracking-wider">Conversion</p>
      </div>
    </div>
  </div>

  <!-- Tabs Section -->
  <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden">
    <!-- Tab Bar -->
    <div class="flex border-b border-gray-200 dark:border-gray-800 overflow-x-auto" style="scrollbar-width:none">
      <button onclick="switchTab('jobs')" class="tab-btn active px-5 py-3.5 text-sm font-medium whitespace-nowrap transition-all" data-tab="jobs">
        <i class="fas fa-briefcase mr-1.5 text-xs"></i> Jobs <span class="ml-1 px-1.5 py-0.5 rounded-full text-[10px] bg-gray-100 dark:bg-gray-800 text-gray-500"><%= jobs.length %></span>
      </button>
      <button onclick="switchTab('hired')" class="tab-btn px-5 py-3.5 text-sm font-medium whitespace-nowrap transition-all" data-tab="hired">
        <i class="fas fa-user-check mr-1.5 text-xs"></i> Hired Students <span class="ml-1 px-1.5 py-0.5 rounded-full text-[10px] bg-gray-100 dark:bg-gray-800 text-gray-500"><%= hiredStudents.length %></span>
      </button>
      <button onclick="switchTab('interactions')" class="tab-btn px-5 py-3.5 text-sm font-medium whitespace-nowrap transition-all" data-tab="interactions">
        <i class="fas fa-comments mr-1.5 text-xs"></i> Interactions <span class="ml-1 px-1.5 py-0.5 rounded-full text-[10px] bg-gray-100 dark:bg-gray-800 text-gray-500"><%= interactions.length %></span>
      </button>
      <button onclick="switchTab('analytics')" class="tab-btn px-5 py-3.5 text-sm font-medium whitespace-nowrap transition-all" data-tab="analytics">
        <i class="fas fa-chart-line mr-1.5 text-xs"></i> Analytics
      </button>
      <button onclick="switchTab('notes')" class="tab-btn px-5 py-3.5 text-sm font-medium whitespace-nowrap transition-all" data-tab="notes">
        <i class="fas fa-sticky-note mr-1.5 text-xs"></i> Notes
      </button>
    </div>

    <!-- Jobs Tab -->
    <div id="tab-jobs" class="tab-content p-5">
      <% if (jobs.length) { %>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-left bg-gray-50 dark:bg-gray-800">
                <th class="py-2.5 px-3 font-medium text-gray-500 dark:text-gray-400 rounded-l-lg">Role</th>
                <th class="py-2.5 px-3 font-medium text-gray-500 dark:text-gray-400">Type</th>
                <th class="py-2.5 px-3 font-medium text-gray-500 dark:text-gray-400">Location</th>
                <th class="py-2.5 px-3 font-medium text-gray-500 dark:text-gray-400">CTC</th>
                <th class="py-2.5 px-3 font-medium text-gray-500 dark:text-gray-400">Status</th>
                <th class="py-2.5 px-3 font-medium text-gray-500 dark:text-gray-400 rounded-r-lg">Deadline</th>
              </tr>
            </thead>
            <tbody>
              <% jobs.forEach(function(j) { %>
                <%
                  var sc = { active: 'background:#dcfce7;color:#16a34a', draft: 'background:#f3f4f6;color:#6b7280', closed: 'background:#fee2e2;color:#dc2626', on_hold: 'background:#fef9c3;color:#ca8a04' };
                  var typeLabels = { full_time:'Full Time', part_time:'Part Time', internship:'Internship', contract:'Contract', freelance:'Freelance' };
                %>
                <tr class="border-t border-gray-100 dark:border-gray-800 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition">
                  <td class="py-3 px-3">
                    <a href="/admin/jobs/<%= j.id %>" class="font-medium text-gray-900 dark:text-white hover:text-blue-600 transition"><%= j.role_title %></a>
                  </td>
                  <td class="py-3 px-3"><span class="text-xs px-2 py-0.5 rounded font-medium" style="background:#eff6ff;color:#2563eb"><%= typeLabels[j.job_type] || j.job_type || '—' %></span></td>
                  <td class="py-3 px-3 text-gray-500"><%= j.location || '—' %></td>
                  <td class="py-3 px-3 text-gray-500">
                    <% if (j.ctc_max) { %><span class="font-medium"><%= (j.ctc_max / 100000).toFixed(1) %></span> LPA<% } else { %>—<% } %>
                  </td>
                  <td class="py-3 px-3">
                    <span class="text-[10px] font-medium px-2 py-0.5 rounded-full" style="<%= sc[j.status] || sc.draft %>"><%= j.status %></span>
                  </td>
                  <td class="py-3 px-3 text-xs text-gray-400"><%= j.application_deadline ? new Date(j.application_deadline).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) : '—' %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="text-center py-12">
          <div class="w-12 h-12 rounded-xl mx-auto mb-3 flex items-center justify-center bg-gray-100 dark:bg-gray-800"><i class="fas fa-briefcase text-gray-300 dark:text-gray-600"></i></div>
          <p class="text-gray-400 text-sm">No jobs posted by this recruiter</p>
        </div>
      <% } %>
    </div>

    <!-- Hired Students Tab -->
    <div id="tab-hired" class="tab-content p-5 hidden">
      <% if (hiredStudents.length) { %>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-left bg-gray-50 dark:bg-gray-800">
                <th class="py-2.5 px-3 font-medium text-gray-500 dark:text-gray-400 rounded-l-lg">Student</th>
                <th class="py-2.5 px-3 font-medium text-gray-500 dark:text-gray-400">Department</th>
                <th class="py-2.5 px-3 font-medium text-gray-500 dark:text-gray-400">Role</th>
                <th class="py-2.5 px-3 font-medium text-gray-500 dark:text-gray-400">CTC</th>
                <th class="py-2.5 px-3 font-medium text-gray-500 dark:text-gray-400 rounded-r-lg">Date</th>
              </tr>
            </thead>
            <tbody>
              <% hiredStudents.forEach(function(s) { %>
                <tr class="border-t border-gray-100 dark:border-gray-800 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition">
                  <td class="py-3 px-3">
                    <div class="flex items-center gap-2">
                      <div class="w-7 h-7 rounded-full flex items-center justify-center text-[10px] font-bold" style="background:hsl(var(--primary));color:hsl(var(--accent))"><%= s.name ? s.name.charAt(0).toUpperCase() : '?' %></div>
                      <div>
                        <p class="font-medium text-gray-900 dark:text-white text-xs"><%= s.name %></p>
                        <p class="text-[10px] text-gray-400"><%= s.email %></p>
                      </div>
                    </div>
                  </td>
                  <td class="py-3 px-3 text-gray-500 text-xs"><%= s.department || '—' %></td>
                  <td class="py-3 px-3 text-gray-700 dark:text-gray-300 text-xs font-medium"><%= s.role_title %></td>
                  <td class="py-3 px-3"><% if (s.ctc_max) { %><span class="text-xs font-medium text-green-600"><%= (s.ctc_max / 100000).toFixed(1) %> LPA</span><% } else { %><span class="text-gray-300">—</span><% } %></td>
                  <td class="py-3 px-3 text-[10px] text-gray-400"><%= new Date(s.applied_at).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="text-center py-12">
          <div class="w-12 h-12 rounded-xl mx-auto mb-3 flex items-center justify-center bg-gray-100 dark:bg-gray-800"><i class="fas fa-user-check text-gray-300 dark:text-gray-600"></i></div>
          <p class="text-gray-400 text-sm">No hired students yet</p>
        </div>
      <% } %>
    </div>

    <!-- Interactions Tab -->
    <div id="tab-interactions" class="tab-content p-5 hidden">
      <div class="flex justify-between items-center mb-4">
        <h3 class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Interaction Log</h3>
        <button onclick="openInteractionModal()" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-white rounded-lg transition" style="background:hsl(var(--accent))">
          <i class="fas fa-plus"></i> Log Interaction
        </button>
      </div>
      <% if (interactions.length) { %>
        <div class="space-y-3">
          <% interactions.forEach(function(i) { %>
            <%
              var typeConfig = {
                email: { icon: 'fa-envelope', bg: 'bg-blue-50 dark:bg-blue-900/20', color: 'text-blue-500' },
                call: { icon: 'fa-phone', bg: 'bg-green-50 dark:bg-green-900/20', color: 'text-green-500' },
                campus_visit: { icon: 'fa-university', bg: 'bg-purple-50 dark:bg-purple-900/20', color: 'text-purple-500' },
                virtual: { icon: 'fa-video', bg: 'bg-orange-50 dark:bg-orange-900/20', color: 'text-orange-500' },
                other: { icon: 'fa-ellipsis-h', bg: 'bg-gray-100 dark:bg-gray-800', color: 'text-gray-500' }
              };
              var ic = typeConfig[i.type] || typeConfig.other;
            %>
            <div class="flex gap-3 p-4 rounded-xl border border-gray-100 dark:border-gray-800 hover:border-gray-200 dark:hover:border-gray-700 transition">
              <div class="w-9 h-9 rounded-xl <%= ic.bg %> flex items-center justify-center flex-shrink-0">
                <i class="fas <%= ic.icon %> <%= ic.color %> text-xs"></i>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1 flex-wrap">
                  <span class="text-[10px] font-bold uppercase tracking-wider text-gray-500 px-2 py-0.5 rounded bg-gray-100 dark:bg-gray-800"><%= i.type.replace('_', ' ') %></span>
                  <span class="text-[10px] text-gray-400"><%= new Date(i.interaction_date).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></span>
                  <% if (i.created_by_name) { %><span class="text-[10px] text-gray-400">by <strong><%= i.created_by_name %></strong></span><% } %>
                </div>
                <p class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed"><%= i.summary %></p>
                <% if (i.follow_up_date) { %>
                  <div class="mt-2 inline-flex items-center gap-1.5 text-xs px-2.5 py-1 rounded-lg <%= i.follow_up_done ? 'bg-green-50 dark:bg-green-900/20 text-green-600' : 'bg-orange-50 dark:bg-orange-900/20 text-orange-600' %>">
                    <i class="fas <%= i.follow_up_done ? 'fa-check-circle' : 'fa-clock' %> text-[10px]"></i>
                    Follow-up: <%= new Date(i.follow_up_date).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                    <% if (!i.follow_up_done) { %>
                      <button onclick="markDone(<%= i.id %>)" class="ml-1 text-blue-600 hover:text-blue-700 font-medium underline">Mark done</button>
                    <% } %>
                  </div>
                <% } %>
              </div>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <div class="text-center py-12">
          <div class="w-12 h-12 rounded-xl mx-auto mb-3 flex items-center justify-center bg-gray-100 dark:bg-gray-800"><i class="fas fa-comments text-gray-300 dark:text-gray-600"></i></div>
          <p class="text-gray-400 text-sm mb-2">No interactions logged yet</p>
          <button onclick="openInteractionModal()" class="text-xs font-medium transition" style="color:hsl(var(--accent))">Log your first interaction</button>
        </div>
      <% } %>
    </div>

    <!-- Analytics Tab -->
    <div id="tab-analytics" class="tab-content p-5 hidden">
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-gray-50 dark:bg-gray-800/50 rounded-xl p-4">
          <h4 class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3 flex items-center gap-2">
            <i class="fas fa-chart-line text-blue-500"></i> Hiring Trend
          </h4>
          <div style="height:260px"><canvas id="hiringTrendChart"></canvas></div>
        </div>
        <div class="bg-gray-50 dark:bg-gray-800/50 rounded-xl p-4">
          <h4 class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3 flex items-center gap-2">
            <i class="fas fa-chart-bar text-green-500"></i> CTC by Year
          </h4>
          <div style="height:260px"><canvas id="ctcByYearChart"></canvas></div>
        </div>
      </div>
    </div>

    <!-- Notes Tab -->
    <div id="tab-notes" class="tab-content p-5 hidden">
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider flex items-center gap-2">
          <i class="fas fa-sticky-note text-gray-400"></i> Private Notes
        </h3>
        <button onclick="saveNotes()" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-white rounded-lg transition" style="background:hsl(var(--accent))">
          <i class="fas fa-save"></i> Save Notes
        </button>
      </div>
      <textarea id="notesEditor" rows="12" class="w-full px-4 py-3 text-sm border border-gray-300 dark:border-gray-600 rounded-xl bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white font-mono leading-relaxed focus:ring-2 focus:ring-accent focus:border-transparent transition" placeholder="Write notes about this recruiter... (Markdown supported)"><%= recruiter.notes || '' %></textarea>
    </div>
  </div>
</div>

<!-- Add Interaction Modal -->
<div id="interactionModal" class="fixed inset-0 z-50" style="display:none">
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeInteractionModal()"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-md bg-white dark:bg-gray-900 rounded-2xl shadow-2xl">
    <div class="px-6 pt-6 pb-4 border-b border-gray-100 dark:border-gray-800">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="text-lg font-bold text-gray-900 dark:text-white">Log Interaction</h2>
          <p class="text-xs text-gray-500 mt-0.5">Record a call, visit, or meeting</p>
        </div>
        <button onclick="closeInteractionModal()" class="w-8 h-8 rounded-lg flex items-center justify-center hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-400 hover:text-gray-600 transition"><i class="fas fa-times"></i></button>
      </div>
    </div>
    <form id="interactionForm" class="p-6 space-y-4">
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Type <span class="text-red-500">*</span></label>
          <select name="type" required class="w-full px-3 py-2.5 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white">
            <option value="email">Email</option>
            <option value="call">Phone Call</option>
            <option value="campus_visit">Campus Visit</option>
            <option value="virtual">Virtual Meeting</option>
            <option value="other">Other</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Date <span class="text-red-500">*</span></label>
          <input type="datetime-local" name="interaction_date" required class="w-full px-3 py-2.5 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white">
        </div>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Summary <span class="text-red-500">*</span></label>
        <textarea name="summary" rows="3" required class="w-full px-3 py-2.5 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white" placeholder="What was discussed..."></textarea>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Follow-up Date <span class="text-[10px] text-gray-400">(optional)</span></label>
        <input type="date" name="follow_up_date" class="w-full px-3 py-2.5 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white">
      </div>
      <div class="flex justify-end gap-3 pt-2">
        <button type="button" onclick="closeInteractionModal()" class="px-5 py-2.5 text-sm border border-gray-300 dark:border-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800 text-gray-700 dark:text-gray-300 transition font-medium">Cancel</button>
        <button type="submit" class="px-5 py-2.5 text-sm text-white rounded-lg font-medium transition" style="background:hsl(var(--accent))">
          <i class="fas fa-save mr-1"></i> Save
        </button>
      </div>
    </form>
  </div>
</div>

<!-- Edit Recruiter Modal -->
<div id="editModal" class="fixed inset-0 z-50" style="display:none">
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeEditModal()"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-lg bg-white dark:bg-gray-900 rounded-2xl shadow-2xl max-h-[90vh] overflow-y-auto">
    <div class="sticky top-0 bg-white dark:bg-gray-900 px-6 pt-6 pb-4 border-b border-gray-100 dark:border-gray-800 z-10 rounded-t-2xl">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="text-lg font-bold text-gray-900 dark:text-white">Edit Recruiter</h2>
          <p class="text-xs text-gray-500 mt-0.5">Update company details</p>
        </div>
        <button onclick="closeEditModal()" class="w-8 h-8 rounded-lg flex items-center justify-center hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-400 hover:text-gray-600 transition"><i class="fas fa-times"></i></button>
      </div>
    </div>
    <form id="editForm" class="p-6 space-y-4">
      <div>
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3 flex items-center gap-2"><i class="fas fa-building text-gray-400"></i> Company</p>
        <div class="grid grid-cols-2 gap-3">
          <div class="col-span-2">
            <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Name <span class="text-red-500">*</span></label>
            <input type="text" name="company_name" value="<%= recruiter.company_name %>" required class="w-full px-3 py-2.5 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-accent focus:border-transparent">
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Industry</label>
            <input type="text" name="industry" value="<%= recruiter.industry || '' %>" class="w-full px-3 py-2.5 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-accent focus:border-transparent">
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Size</label>
            <select name="company_size" class="w-full px-3 py-2.5 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white">
              <option value="">Select</option>
              <% ['startup','small','medium','large','enterprise'].forEach(function(s) { %>
                <option value="<%= s %>" <%= recruiter.company_size === s ? 'selected' : '' %>><%= s.charAt(0).toUpperCase() + s.slice(1) %></option>
              <% }); %>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Website</label>
            <input type="url" name="website" value="<%= recruiter.website || '' %>" class="w-full px-3 py-2.5 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white">
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Logo URL</label>
            <input type="url" name="logo" value="<%= recruiter.logo || '' %>" class="w-full px-3 py-2.5 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white">
          </div>
        </div>
      </div>
      <div>
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3 flex items-center gap-2"><i class="fas fa-file-contract text-gray-400"></i> MOU</p>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Status</label>
            <select name="mou_status" class="w-full px-3 py-2.5 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white">
              <% ['none','pending','active','expired'].forEach(function(s) { %>
                <option value="<%= s %>" <%= recruiter.mou_status === s ? 'selected' : '' %>><%= s.charAt(0).toUpperCase() + s.slice(1) %></option>
              <% }); %>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Expiry</label>
            <input type="date" name="mou_expiry" value="<%= recruiter.mou_expiry ? new Date(recruiter.mou_expiry).toISOString().split('T')[0] : '' %>" class="w-full px-3 py-2.5 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white">
          </div>
        </div>
      </div>
      <div>
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3 flex items-center gap-2"><i class="fas fa-user-tie text-gray-400"></i> Contact</p>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Name</label><input type="text" name="contact_name" value="<%= recruiter.contact_name || '' %>" class="w-full px-3 py-2.5 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white"></div>
          <div><label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Role</label><input type="text" name="contact_role" value="<%= recruiter.contact_role || '' %>" class="w-full px-3 py-2.5 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white"></div>
          <div><label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Email</label><input type="email" name="contact_email" value="<%= recruiter.contact_email || '' %>" class="w-full px-3 py-2.5 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white"></div>
          <div><label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Phone</label><input type="tel" name="contact_phone" value="<%= recruiter.contact_phone || '' %>" class="w-full px-3 py-2.5 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white"></div>
        </div>
      </div>
      <div class="flex justify-end gap-3 pt-2 border-t border-gray-100 dark:border-gray-800">
        <button type="button" onclick="closeEditModal()" class="px-5 py-2.5 text-sm border border-gray-300 dark:border-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800 text-gray-700 dark:text-gray-300 transition font-medium">Cancel</button>
        <button type="submit" class="px-5 py-2.5 text-sm text-white rounded-lg font-medium transition" style="background:hsl(var(--accent))"><i class="fas fa-save mr-1"></i> Save Changes</button>
      </div>
    </form>
  </div>
</div>

<style>
  .tab-btn { color: #9ca3af; border-bottom: 2px solid transparent; }
  .tab-btn:hover { color: #374151; }
  .tab-btn.active { color: hsl(228,100%,11%); border-bottom-color: hsl(var(--accent)); }
  .dark .tab-btn.active { color: #93c5fd; border-bottom-color: hsl(var(--accent)); }
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
var RECRUITER_ID = '<%= recruiter.id %>';

// ─── Tabs ────────────────────────────────────────────────
function switchTab(tab) {
  document.querySelectorAll('.tab-content').forEach(function(el) { el.classList.add('hidden'); });
  document.querySelectorAll('.tab-btn').forEach(function(el) { el.classList.remove('active'); });
  document.getElementById('tab-' + tab).classList.remove('hidden');
  document.querySelector('[data-tab="' + tab + '"]').classList.add('active');
  if (tab === 'analytics') initCharts();
}

// ─── Modals ──────────────────────────────────────────────
function openEditModal() { document.getElementById('editModal').style.display = 'block'; }
function closeEditModal() { document.getElementById('editModal').style.display = 'none'; }
function openInteractionModal() { document.getElementById('interactionModal').style.display = 'block'; }
function closeInteractionModal() { document.getElementById('interactionModal').style.display = 'none'; }

document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') { closeEditModal(); closeInteractionModal(); }
});

// ─── Edit Form ───────────────────────────────────────────
document.getElementById('editForm').addEventListener('submit', function(e) {
  e.preventDefault();
  var fd = new FormData(this);
  var body = {};
  fd.forEach(function(v, k) { body[k] = v; });

  fetch('/admin/recruiters/api/' + RECRUITER_ID, {
    method: 'PUT',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(body)
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    if (data.success) { showToast('Recruiter updated', 'success'); setTimeout(function() { location.reload(); }, 800); }
    else showToast(data.error || 'Failed', 'error');
  })
  .catch(function() { showToast('Network error', 'error'); });
});

// ─── Interaction Form ────────────────────────────────────
document.getElementById('interactionForm').addEventListener('submit', function(e) {
  e.preventDefault();
  var fd = new FormData(this);
  var body = {};
  fd.forEach(function(v, k) { if (v) body[k] = v; });

  fetch('/admin/recruiters/api/' + RECRUITER_ID + '/interactions', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(body)
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    if (data.success) { showToast('Interaction logged', 'success'); setTimeout(function() { location.reload(); }, 800); }
    else showToast(data.error || 'Failed', 'error');
  })
  .catch(function() { showToast('Network error', 'error'); });
});

// ─── Follow-up Done ──────────────────────────────────────
function markDone(id) {
  fetch('/admin/recruiters/api/interactions/' + id + '/done', { method: 'PATCH' })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    if (data.success) { showToast('Marked as done', 'success'); setTimeout(function() { location.reload(); }, 500); }
  });
}

// ─── Save Notes ──────────────────────────────────────────
function saveNotes() {
  var notes = document.getElementById('notesEditor').value;
  fetch('/admin/recruiters/api/' + RECRUITER_ID, {
    method: 'PUT',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ notes: notes })
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    if (data.success) showToast('Notes saved', 'success');
    else showToast(data.error || 'Failed', 'error');
  })
  .catch(function() { showToast('Network error', 'error'); });
}

// ─── Charts ──────────────────────────────────────────────
var chartsInit = false;
function initCharts() {
  if (chartsInit) return;
  chartsInit = true;

  var hiringData = <%- JSON.stringify(analytics.hiringTrend) %>;
  var ctcData = <%- JSON.stringify(analytics.ctcByYear) %>;
  var primaryColor = 'hsl(228,100%,11%)';
  var accentColor = 'hsl(80,89%,40%)';

  if (hiringData.length) {
    var months = ['','Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    new Chart(document.getElementById('hiringTrendChart'), {
      type: 'line',
      data: {
        labels: hiringData.map(function(d) { return months[d.mo] + ' ' + d.yr; }),
        datasets: [{
          label: 'Students Hired',
          data: hiringData.map(function(d) { return d.hired; }),
          borderColor: primaryColor,
          backgroundColor: 'hsla(228,100%,11%,0.08)',
          fill: true,
          tension: 0.4,
          pointBackgroundColor: primaryColor,
          pointRadius: 4,
          pointHoverRadius: 6
        }]
      },
      options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { precision: 0 } } } }
    });
  } else {
    document.getElementById('hiringTrendChart').parentElement.innerHTML = '<div class="flex items-center justify-center h-full text-gray-400 text-sm">No hiring data available</div>';
  }

  if (ctcData.length) {
    new Chart(document.getElementById('ctcByYearChart'), {
      type: 'bar',
      data: {
        labels: ctcData.map(function(d) { return d.yr; }),
        datasets: [{
          label: 'Avg CTC (LPA)',
          data: ctcData.map(function(d) { return Math.round(d.avg_ctc / 100000 * 10) / 10; }),
          backgroundColor: accentColor,
          borderRadius: 8,
          maxBarThickness: 40
        }]
      },
      options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } } }
    });
  } else {
    document.getElementById('ctcByYearChart').parentElement.innerHTML = '<div class="flex items-center justify-center h-full text-gray-400 text-sm">No CTC data available</div>';
  }
}
</script>

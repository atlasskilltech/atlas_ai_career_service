<%
  var tierColors = {
    platinum: { bg: 'bg-purple-100 dark:bg-purple-900/30', text: 'text-purple-700 dark:text-purple-300' },
    gold: { bg: 'bg-yellow-100 dark:bg-yellow-900/30', text: 'text-yellow-700 dark:text-yellow-300' },
    silver: { bg: 'bg-gray-100 dark:bg-gray-700', text: 'text-gray-600 dark:text-gray-300' },
    new: { bg: 'bg-blue-100 dark:bg-blue-900/30', text: 'text-blue-700 dark:text-blue-300' }
  };
  var tc = tierColors[recruiter.tier] || tierColors.new;
  var mouColors = {
    active: 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400',
    pending: 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400',
    expired: 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400',
    none: 'bg-gray-100 text-gray-500 dark:bg-gray-800 dark:text-gray-400'
  };
%>

<div class="space-y-6">
  <!-- Breadcrumb -->
  <div class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400">
    <a href="/admin/recruiters" class="hover:text-blue-600"><i class="fas fa-arrow-left mr-1"></i> All Recruiters</a>
  </div>

  <!-- Header -->
  <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6">
    <div class="flex flex-col sm:flex-row sm:items-center gap-4">
      <% if (recruiter.logo) { %>
        <img src="<%= recruiter.logo %>" alt="" class="w-16 h-16 rounded-xl object-contain bg-gray-50 dark:bg-gray-800">
      <% } else { %>
        <div class="w-16 h-16 rounded-xl flex items-center justify-center" style="background:hsl(228,100%,11%)">
          <span class="text-2xl font-bold" style="color:hsl(80,89%,40%)"><%= recruiter.company_name.charAt(0).toUpperCase() %></span>
        </div>
      <% } %>
      <div class="flex-1">
        <div class="flex flex-wrap items-center gap-2">
          <h1 class="text-2xl font-bold text-gray-900 dark:text-white"><%= recruiter.company_name %></h1>
          <span class="text-[10px] font-bold uppercase px-2 py-0.5 rounded-full <%= tc.bg %> <%= tc.text %>"><%= recruiter.tier %></span>
          <span class="text-[10px] font-medium px-2 py-0.5 rounded-full <%= mouColors[recruiter.mou_status] || mouColors.none %>">MOU: <%= recruiter.mou_status %></span>
        </div>
        <div class="flex flex-wrap items-center gap-3 mt-1 text-sm text-gray-500 dark:text-gray-400">
          <% if (recruiter.industry) { %><span><i class="fas fa-industry mr-1"></i> <%= recruiter.industry %></span><% } %>
          <% if (recruiter.website) { %><a href="<%= recruiter.website %>" target="_blank" class="hover:text-blue-600"><i class="fas fa-globe mr-1"></i> Website</a><% } %>
          <% if (recruiter.company_size) { %><span><i class="fas fa-users mr-1"></i> <%= recruiter.company_size.charAt(0).toUpperCase() + recruiter.company_size.slice(1) %></span><% } %>
        </div>
      </div>
      <button onclick="openEditModal()" class="self-start px-4 py-2 text-sm font-medium border border-gray-300 dark:border-gray-600 rounded-lg text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800">
        <i class="fas fa-edit mr-1"></i> Edit
      </button>
    </div>
  </div>

  <!-- Contact + Stats Row -->
  <div class="grid md:grid-cols-2 gap-4">
    <!-- Contact Card -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-5">
      <h3 class="font-semibold text-gray-900 dark:text-white mb-3"><i class="fas fa-address-card mr-2 text-gray-400"></i>Contact Person</h3>
      <% if (recruiter.contact_name) { %>
        <p class="font-medium text-gray-900 dark:text-white"><%= recruiter.contact_name %></p>
        <% if (recruiter.contact_role) { %><p class="text-sm text-gray-500 dark:text-gray-400"><%= recruiter.contact_role %></p><% } %>
        <div class="mt-2 space-y-1">
          <% if (recruiter.contact_email) { %>
            <a href="mailto:<%= recruiter.contact_email %>" class="block text-sm text-blue-600 hover:underline"><i class="fas fa-envelope mr-2 w-4"></i><%= recruiter.contact_email %></a>
          <% } %>
          <% if (recruiter.contact_phone) { %>
            <a href="tel:<%= recruiter.contact_phone %>" class="block text-sm text-blue-600 hover:underline"><i class="fas fa-phone mr-2 w-4"></i><%= recruiter.contact_phone %></a>
          <% } %>
        </div>
      <% } else { %>
        <p class="text-sm text-gray-400">No contact info added</p>
      <% } %>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 gap-3">
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4 text-center">
        <p class="text-2xl font-bold" style="color:hsl(228,100%,11%)"><%= stats ? stats.totalJobs : 0 %></p>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Jobs Posted</p>
      </div>
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4 text-center">
        <p class="text-2xl font-bold text-green-600"><%= stats ? stats.totalHired : 0 %></p>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Students Hired</p>
      </div>
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4 text-center">
        <p class="text-2xl font-bold text-purple-600"><%= stats && stats.avgCtc ? '₹' + (stats.avgCtc / 100000).toFixed(1) + 'L' : '—' %></p>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Avg CTC</p>
      </div>
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4 text-center">
        <p class="text-2xl font-bold text-orange-600"><%= stats ? stats.conversionRate : 0 %>%</p>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Conversion Rate</p>
      </div>
    </div>
  </div>

  <!-- Tabs -->
  <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800">
    <div class="flex border-b border-gray-200 dark:border-gray-800 overflow-x-auto">
      <button onclick="switchTab('jobs')" class="tab-btn active px-5 py-3 text-sm font-medium whitespace-nowrap" data-tab="jobs">
        <i class="fas fa-briefcase mr-1"></i> Jobs (<%= jobs.length %>)
      </button>
      <button onclick="switchTab('hired')" class="tab-btn px-5 py-3 text-sm font-medium whitespace-nowrap" data-tab="hired">
        <i class="fas fa-user-check mr-1"></i> Hired Students (<%= hiredStudents.length %>)
      </button>
      <button onclick="switchTab('interactions')" class="tab-btn px-5 py-3 text-sm font-medium whitespace-nowrap" data-tab="interactions">
        <i class="fas fa-comments mr-1"></i> Interactions (<%= interactions.length %>)
      </button>
      <button onclick="switchTab('analytics')" class="tab-btn px-5 py-3 text-sm font-medium whitespace-nowrap" data-tab="analytics">
        <i class="fas fa-chart-line mr-1"></i> Analytics
      </button>
      <button onclick="switchTab('notes')" class="tab-btn px-5 py-3 text-sm font-medium whitespace-nowrap" data-tab="notes">
        <i class="fas fa-sticky-note mr-1"></i> Notes
      </button>
    </div>

    <!-- Jobs Tab -->
    <div id="tab-jobs" class="tab-content p-5">
      <% if (jobs.length) { %>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-left text-gray-500 dark:text-gray-400 border-b border-gray-100 dark:border-gray-800">
                <th class="pb-2 font-medium">Role</th>
                <th class="pb-2 font-medium">Type</th>
                <th class="pb-2 font-medium">Location</th>
                <th class="pb-2 font-medium">CTC</th>
                <th class="pb-2 font-medium">Status</th>
                <th class="pb-2 font-medium">Deadline</th>
              </tr>
            </thead>
            <tbody>
              <% jobs.forEach(function(j) { %>
                <tr class="border-b border-gray-50 dark:border-gray-800 hover:bg-gray-50 dark:hover:bg-gray-800/50">
                  <td class="py-2.5">
                    <a href="/admin/jobs/<%= j.id %>" class="font-medium text-blue-600 hover:underline"><%= j.role_title %></a>
                  </td>
                  <td class="py-2.5 text-gray-500"><%= j.job_type ? j.job_type.replace('_', ' ') : '—' %></td>
                  <td class="py-2.5 text-gray-500"><%= j.location || '—' %></td>
                  <td class="py-2.5 text-gray-500">
                    <% if (j.ctc_max) { %>₹<%= (j.ctc_max / 100000).toFixed(1) %>L<% } else { %>—<% } %>
                  </td>
                  <td class="py-2.5">
                    <% var sc = { active: 'bg-green-100 text-green-700', draft: 'bg-gray-100 text-gray-500', closed: 'bg-red-100 text-red-600', on_hold: 'bg-yellow-100 text-yellow-700' }; %>
                    <span class="text-xs px-2 py-0.5 rounded-full <%= sc[j.status] || sc.draft %>"><%= j.status %></span>
                  </td>
                  <td class="py-2.5 text-gray-500 text-xs"><%= j.application_deadline ? new Date(j.application_deadline).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) : '—' %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <p class="text-center text-gray-400 py-8">No jobs posted by this recruiter</p>
      <% } %>
    </div>

    <!-- Hired Students Tab -->
    <div id="tab-hired" class="tab-content p-5 hidden">
      <% if (hiredStudents.length) { %>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-left text-gray-500 dark:text-gray-400 border-b border-gray-100 dark:border-gray-800">
                <th class="pb-2 font-medium">Student</th>
                <th class="pb-2 font-medium">Department</th>
                <th class="pb-2 font-medium">Role</th>
                <th class="pb-2 font-medium">CTC</th>
                <th class="pb-2 font-medium">Date</th>
              </tr>
            </thead>
            <tbody>
              <% hiredStudents.forEach(function(s) { %>
                <tr class="border-b border-gray-50 dark:border-gray-800">
                  <td class="py-2.5">
                    <p class="font-medium"><%= s.name %></p>
                    <p class="text-xs text-gray-400"><%= s.email %></p>
                  </td>
                  <td class="py-2.5 text-gray-500"><%= s.department || '—' %></td>
                  <td class="py-2.5 text-gray-500"><%= s.role_title %></td>
                  <td class="py-2.5 text-gray-500"><% if (s.ctc_max) { %>₹<%= (s.ctc_max / 100000).toFixed(1) %>L<% } else { %>—<% } %></td>
                  <td class="py-2.5 text-gray-500 text-xs"><%= new Date(s.applied_at).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <p class="text-center text-gray-400 py-8">No hired students yet</p>
      <% } %>
    </div>

    <!-- Interactions Tab -->
    <div id="tab-interactions" class="tab-content p-5 hidden">
      <div class="flex justify-between items-center mb-4">
        <h3 class="font-semibold text-gray-900 dark:text-white">Interaction Log</h3>
        <button onclick="openInteractionModal()" class="px-3 py-1.5 text-xs font-medium text-white rounded-lg" style="background:hsl(228,100%,11%)">
          <i class="fas fa-plus mr-1"></i> Add Interaction
        </button>
      </div>
      <% if (interactions.length) { %>
        <div class="space-y-3">
          <% interactions.forEach(function(i) { %>
            <%
              var typeIcons = { email: 'fa-envelope text-blue-500', call: 'fa-phone text-green-500', campus_visit: 'fa-university text-purple-500', virtual: 'fa-video text-orange-500', other: 'fa-ellipsis-h text-gray-500' };
              var icon = typeIcons[i.type] || typeIcons.other;
            %>
            <div class="flex gap-3 p-3 rounded-lg border border-gray-100 dark:border-gray-800">
              <div class="w-8 h-8 rounded-full bg-gray-100 dark:bg-gray-800 flex items-center justify-center flex-shrink-0">
                <i class="fas <%= icon %> text-xs"></i>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-xs font-semibold uppercase text-gray-500"><%= i.type.replace('_', ' ') %></span>
                  <span class="text-xs text-gray-400"><%= new Date(i.interaction_date).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></span>
                  <% if (i.created_by_name) { %><span class="text-xs text-gray-400">by <%= i.created_by_name %></span><% } %>
                </div>
                <p class="text-sm text-gray-700 dark:text-gray-300"><%= i.summary %></p>
                <% if (i.follow_up_date) { %>
                  <p class="text-xs mt-1 <%= i.follow_up_done ? 'text-green-600' : 'text-orange-600' %>">
                    <i class="fas <%= i.follow_up_done ? 'fa-check-circle' : 'fa-clock' %> mr-1"></i>
                    Follow-up: <%= new Date(i.follow_up_date).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                    <% if (!i.follow_up_done) { %>
                      <button onclick="markDone(<%= i.id %>)" class="ml-2 text-blue-600 hover:underline">Mark done</button>
                    <% } %>
                  </p>
                <% } %>
              </div>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <p class="text-center text-gray-400 py-8">No interactions logged yet</p>
      <% } %>
    </div>

    <!-- Analytics Tab -->
    <div id="tab-analytics" class="tab-content p-5 hidden">
      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <h4 class="font-semibold text-gray-900 dark:text-white mb-3">Hiring Trend</h4>
          <div style="height:260px"><canvas id="hiringTrendChart"></canvas></div>
        </div>
        <div>
          <h4 class="font-semibold text-gray-900 dark:text-white mb-3">CTC by Year</h4>
          <div style="height:260px"><canvas id="ctcByYearChart"></canvas></div>
        </div>
      </div>
    </div>

    <!-- Notes Tab -->
    <div id="tab-notes" class="tab-content p-5 hidden">
      <textarea id="notesEditor" rows="10" class="w-full px-4 py-3 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white font-mono" placeholder="Write notes about this recruiter (markdown supported)..."><%= recruiter.notes || '' %></textarea>
      <div class="flex justify-end mt-3">
        <button onclick="saveNotes()" class="px-4 py-2 text-sm font-medium text-white rounded-lg" style="background:hsl(228,100%,11%)">
          <i class="fas fa-save mr-1"></i> Save Notes
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Add Interaction Modal -->
<div id="interactionModal" class="fixed inset-0 z-50 hidden">
  <div class="absolute inset-0 bg-black/50" onclick="closeInteractionModal()"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-md bg-white dark:bg-gray-900 rounded-xl shadow-xl p-6">
    <h2 class="text-lg font-bold text-gray-900 dark:text-white mb-4">Log Interaction</h2>
    <form id="interactionForm" class="space-y-3">
      <div>
        <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Type *</label>
        <select name="type" required class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white">
          <option value="email">Email</option>
          <option value="call">Call</option>
          <option value="campus_visit">Campus Visit</option>
          <option value="virtual">Virtual Meeting</option>
          <option value="other">Other</option>
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Date *</label>
        <input type="datetime-local" name="interaction_date" required class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white">
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Summary *</label>
        <textarea name="summary" rows="3" required class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white" placeholder="What was discussed..."></textarea>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Follow-up Date</label>
        <input type="date" name="follow_up_date" class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white">
      </div>
      <div class="flex justify-end gap-2 pt-2">
        <button type="button" onclick="closeInteractionModal()" class="px-4 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg text-gray-700 dark:text-gray-300">Cancel</button>
        <button type="submit" class="px-4 py-2 text-sm font-medium text-white rounded-lg" style="background:hsl(228,100%,11%)">Save</button>
      </div>
    </form>
  </div>
</div>

<!-- Edit Recruiter Modal -->
<div id="editModal" class="fixed inset-0 z-50 hidden">
  <div class="absolute inset-0 bg-black/50" onclick="closeEditModal()"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-lg bg-white dark:bg-gray-900 rounded-xl shadow-xl p-6 max-h-[90vh] overflow-y-auto">
    <h2 class="text-lg font-bold text-gray-900 dark:text-white mb-4">Edit Recruiter</h2>
    <form id="editForm" class="space-y-3">
      <div class="grid grid-cols-2 gap-3">
        <div class="col-span-2">
          <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Company Name *</label>
          <input type="text" name="company_name" value="<%= recruiter.company_name %>" required class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white">
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Industry</label>
          <input type="text" name="industry" value="<%= recruiter.industry || '' %>" class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white">
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Company Size</label>
          <select name="company_size" class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white">
            <option value="">Select</option>
            <% ['startup','small','medium','large','enterprise'].forEach(function(s) { %>
              <option value="<%= s %>" <%= recruiter.company_size === s ? 'selected' : '' %>><%= s.charAt(0).toUpperCase() + s.slice(1) %></option>
            <% }); %>
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Website</label>
          <input type="url" name="website" value="<%= recruiter.website || '' %>" class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white">
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Logo URL</label>
          <input type="url" name="logo" value="<%= recruiter.logo || '' %>" class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white">
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">MOU Status</label>
          <select name="mou_status" class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white">
            <% ['none','pending','active','expired'].forEach(function(s) { %>
              <option value="<%= s %>" <%= recruiter.mou_status === s ? 'selected' : '' %>><%= s.charAt(0).toUpperCase() + s.slice(1) %></option>
            <% }); %>
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">MOU Expiry</label>
          <input type="date" name="mou_expiry" value="<%= recruiter.mou_expiry ? new Date(recruiter.mou_expiry).toISOString().split('T')[0] : '' %>" class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white">
        </div>
        <div class="col-span-2 border-t border-gray-100 dark:border-gray-800 pt-3 mt-1">
          <p class="text-xs font-semibold text-gray-500 uppercase mb-2">Contact Person</p>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Name</label>
          <input type="text" name="contact_name" value="<%= recruiter.contact_name || '' %>" class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white">
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Role</label>
          <input type="text" name="contact_role" value="<%= recruiter.contact_role || '' %>" class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white">
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Email</label>
          <input type="email" name="contact_email" value="<%= recruiter.contact_email || '' %>" class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white">
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Phone</label>
          <input type="tel" name="contact_phone" value="<%= recruiter.contact_phone || '' %>" class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white">
        </div>
      </div>
      <div class="flex justify-end gap-2 pt-3">
        <button type="button" onclick="closeEditModal()" class="px-4 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg text-gray-700 dark:text-gray-300">Cancel</button>
        <button type="submit" class="px-4 py-2 text-sm font-medium text-white rounded-lg" style="background:hsl(228,100%,11%)">Save</button>
      </div>
    </form>
  </div>
</div>

<style>
  .tab-btn { color: #9ca3af; border-bottom: 2px solid transparent; transition: all 0.15s; }
  .tab-btn:hover { color: #374151; }
  .tab-btn.active { color: hsl(228,100%,11%); border-bottom-color: hsl(228,100%,11%); }
  .dark .tab-btn.active { color: #93c5fd; border-bottom-color: #93c5fd; }
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
var RECRUITER_ID = '<%= recruiter.id %>';

// Tabs
function switchTab(tab) {
  document.querySelectorAll('.tab-content').forEach(function(el) { el.classList.add('hidden'); });
  document.querySelectorAll('.tab-btn').forEach(function(el) { el.classList.remove('active'); });
  document.getElementById('tab-' + tab).classList.remove('hidden');
  document.querySelector('[data-tab="' + tab + '"]').classList.add('active');
  if (tab === 'analytics') initCharts();
}

// Modals
function openEditModal() { document.getElementById('editModal').classList.remove('hidden'); }
function closeEditModal() { document.getElementById('editModal').classList.add('hidden'); }
function openInteractionModal() { document.getElementById('interactionModal').classList.remove('hidden'); }
function closeInteractionModal() { document.getElementById('interactionModal').classList.add('hidden'); }

// Edit form
document.getElementById('editForm').addEventListener('submit', function(e) {
  e.preventDefault();
  var fd = new FormData(this);
  var body = {};
  fd.forEach(function(v, k) { body[k] = v; });

  fetch('/admin/recruiters/api/' + RECRUITER_ID, {
    method: 'PUT',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(body)
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    if (data.success) {
      showToast('Recruiter updated', 'success');
      setTimeout(function() { location.reload(); }, 800);
    } else {
      showToast(data.error || 'Failed', 'error');
    }
  })
  .catch(function() { showToast('Network error', 'error'); });
});

// Interaction form
document.getElementById('interactionForm').addEventListener('submit', function(e) {
  e.preventDefault();
  var fd = new FormData(this);
  var body = {};
  fd.forEach(function(v, k) { if (v) body[k] = v; });

  fetch('/admin/recruiters/api/' + RECRUITER_ID + '/interactions', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(body)
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    if (data.success) {
      showToast('Interaction logged', 'success');
      setTimeout(function() { location.reload(); }, 800);
    } else {
      showToast(data.error || 'Failed', 'error');
    }
  })
  .catch(function() { showToast('Network error', 'error'); });
});

// Mark follow-up done
function markDone(id) {
  fetch('/admin/recruiters/api/interactions/' + id + '/done', { method: 'PATCH' })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    if (data.success) {
      showToast('Marked as done', 'success');
      setTimeout(function() { location.reload(); }, 500);
    }
  });
}

// Save notes
function saveNotes() {
  var notes = document.getElementById('notesEditor').value;
  fetch('/admin/recruiters/api/' + RECRUITER_ID, {
    method: 'PUT',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ notes: notes })
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    if (data.success) showToast('Notes saved', 'success');
    else showToast(data.error || 'Failed', 'error');
  })
  .catch(function() { showToast('Network error', 'error'); });
}

// Charts
var chartsInit = false;
function initCharts() {
  if (chartsInit) return;
  chartsInit = true;

  var hiringData = <%- JSON.stringify(analytics.hiringTrend) %>;
  var ctcData = <%- JSON.stringify(analytics.ctcByYear) %>;

  // Hiring Trend (line)
  if (hiringData.length) {
    var labels = hiringData.map(function(d) {
      return ['', 'Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][d.mo] + ' ' + d.yr;
    });
    new Chart(document.getElementById('hiringTrendChart'), {
      type: 'line',
      data: {
        labels: labels,
        datasets: [{
          label: 'Students Hired',
          data: hiringData.map(function(d) { return d.hired; }),
          borderColor: 'hsl(228,100%,11%)',
          backgroundColor: 'hsla(228,100%,11%,0.1)',
          fill: true,
          tension: 0.3
        }]
      },
      options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
    });
  }

  // CTC by Year (bar)
  if (ctcData.length) {
    new Chart(document.getElementById('ctcByYearChart'), {
      type: 'bar',
      data: {
        labels: ctcData.map(function(d) { return d.yr; }),
        datasets: [{
          label: 'Avg CTC (₹L)',
          data: ctcData.map(function(d) { return Math.round(d.avg_ctc / 100000); }),
          backgroundColor: 'hsl(80,89%,40%)',
          borderRadius: 6
        }]
      },
      options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
    });
  }
}
</script>

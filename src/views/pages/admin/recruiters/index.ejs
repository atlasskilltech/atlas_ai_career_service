<div class="space-y-5">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Recruiter Management</h1>
      <p class="text-sm text-gray-500 mt-1"><%= recruiters.length %> recruiter<%= recruiters.length !== 1 ? 's' : '' %> found</p>
    </div>
    <div class="flex items-center gap-2">
      <button onclick="recalcTiers()" class="inline-flex items-center gap-2 px-4 py-2 border border-gray-300 dark:border-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800 text-sm transition">
        <i class="fas fa-sync-alt"></i> Recalc Tiers
      </button>
      <button onclick="openAddModal()" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-white text-sm font-medium transition" style="background:hsl(var(--accent))">
        <i class="fas fa-plus"></i> Add Recruiter
      </button>
    </div>
  </div>

  <!-- Stats Cards -->
  <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:12px">
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4 text-center">
      <div class="text-2xl font-bold" style="color:hsl(var(--primary))"><%= listStats.total || 0 %></div>
      <p class="text-xs text-gray-500 mt-1">Total Recruiters</p>
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4 text-center">
      <div class="text-2xl font-bold text-purple-600"><%= listStats.platinum || 0 %></div>
      <p class="text-xs text-gray-500 mt-1">Platinum</p>
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4 text-center">
      <div class="text-2xl font-bold text-yellow-600"><%= listStats.gold || 0 %></div>
      <p class="text-xs text-gray-500 mt-1">Gold</p>
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4 text-center">
      <div class="text-2xl font-bold text-gray-500"><%= listStats.silver || 0 %></div>
      <p class="text-xs text-gray-500 mt-1">Silver</p>
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4 text-center">
      <div class="text-2xl font-bold text-green-600"><%= listStats.active_mou || 0 %></div>
      <p class="text-xs text-gray-500 mt-1">Active MOUs</p>
    </div>
  </div>

  <!-- Search + Filter Toggle -->
  <div class="flex flex-col sm:flex-row gap-3">
    <div class="relative flex-1">
      <i class="fas fa-search absolute left-3 top-1/2 text-gray-400 text-sm" style="transform:translateY(-50%)"></i>
      <input type="text" id="search-input" value="<%= query.search || '' %>" placeholder="Search by company name, contact person, or email..."
        class="w-full pl-10 pr-4 py-2.5 border border-gray-300 dark:border-gray-700 rounded-lg bg-white dark:bg-gray-800 text-sm focus:ring-2 focus:ring-accent focus:border-transparent">
    </div>
    <div class="flex items-center gap-2">
      <button onclick="toggleFilters()" id="filter-toggle-btn" class="inline-flex items-center gap-2 px-4 py-2.5 border border-gray-300 dark:border-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800 text-sm transition">
        <i class="fas fa-filter"></i> Filters
        <% var activeFilters = [query.industry, query.tier, query.mou_status, query.company_size, query.hire_min, query.hire_max].filter(Boolean).length; %>
        <% if (activeFilters) { %><span class="ml-1 w-5 h-5 rounded-full text-[10px] font-bold text-white flex items-center justify-center" style="background:hsl(var(--accent))"><%= activeFilters %></span><% } %>
      </button>
      <!-- View Toggle -->
      <div class="flex border border-gray-300 dark:border-gray-700 rounded-lg overflow-hidden">
        <button onclick="setView('grid')" id="btn-grid" class="px-3 py-2 text-sm" style="background:hsl(var(--accent));color:white">
          <i class="fas fa-th"></i>
        </button>
        <button onclick="setView('list')" id="btn-list" class="px-3 py-2 text-sm bg-white dark:bg-gray-800 text-gray-500">
          <i class="fas fa-list"></i>
        </button>
      </div>
    </div>
  </div>

  <!-- Filters Panel (collapsible) -->
  <div id="filters-panel" style="display:none" class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-5">
    <div class="flex items-center justify-between mb-4">
      <h3 class="font-semibold text-gray-900 dark:text-white"><i class="fas fa-sliders-h mr-2 text-gray-400"></i>Filter Recruiters</h3>
      <button onclick="clearFilters()" class="text-xs text-red-500 hover:text-red-600 font-medium">Clear All</button>
    </div>
    <form id="filter-form" style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px">
      <div>
        <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Industry</label>
        <select name="industry" class="w-full text-sm border border-gray-300 dark:border-gray-700 rounded-lg px-3 py-2 bg-white dark:bg-gray-800">
          <option value="">All Industries</option>
          <% filterOptions.industries.forEach(function(ind) { %>
            <option value="<%= ind %>" <%= query.industry === ind ? 'selected' : '' %>><%= ind %></option>
          <% }); %>
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Tier</label>
        <select name="tier" class="w-full text-sm border border-gray-300 dark:border-gray-700 rounded-lg px-3 py-2 bg-white dark:bg-gray-800">
          <option value="">All Tiers</option>
          <% ['platinum','gold','silver','new'].forEach(function(t) { %>
            <option value="<%= t %>" <%= query.tier === t ? 'selected' : '' %>><%= t.charAt(0).toUpperCase() + t.slice(1) %></option>
          <% }); %>
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">MOU Status</label>
        <select name="mou_status" class="w-full text-sm border border-gray-300 dark:border-gray-700 rounded-lg px-3 py-2 bg-white dark:bg-gray-800">
          <option value="">All</option>
          <% ['active','pending','expired','none'].forEach(function(s) { %>
            <option value="<%= s %>" <%= query.mou_status === s ? 'selected' : '' %>><%= s.charAt(0).toUpperCase() + s.slice(1) %></option>
          <% }); %>
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Company Size</label>
        <select name="company_size" class="w-full text-sm border border-gray-300 dark:border-gray-700 rounded-lg px-3 py-2 bg-white dark:bg-gray-800">
          <option value="">All Sizes</option>
          <% ['startup','small','medium','large','enterprise'].forEach(function(s) { %>
            <option value="<%= s %>" <%= query.company_size === s ? 'selected' : '' %>><%= s.charAt(0).toUpperCase() + s.slice(1) %></option>
          <% }); %>
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Hiring Count Range</label>
        <div class="flex gap-2">
          <input type="number" name="hire_min" placeholder="Min" value="<%= query.hire_min || '' %>" class="w-1/2 text-sm border border-gray-300 dark:border-gray-700 rounded-lg px-3 py-2 bg-white dark:bg-gray-800">
          <input type="number" name="hire_max" placeholder="Max" value="<%= query.hire_max || '' %>" class="w-1/2 text-sm border border-gray-300 dark:border-gray-700 rounded-lg px-3 py-2 bg-white dark:bg-gray-800">
        </div>
      </div>
      <div style="grid-column:2/-1;display:flex;justify-content:flex-end;gap:12px;align-items:end">
        <button type="button" onclick="clearFilters()" class="px-4 py-2 text-sm border border-gray-300 dark:border-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800 transition">Reset</button>
        <button type="submit" class="px-6 py-2 text-sm text-white rounded-lg font-medium transition" style="background:hsl(var(--accent))">Apply Filters</button>
      </div>
    </form>
  </div>

  <!-- Card Grid View -->
  <div id="view-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px">
    <% if (recruiters.length) { %>
      <% recruiters.forEach(function(r) { %>
        <%
          var tierConfig = {
            platinum: { bg: 'background:#f3e8ff;color:#7c3aed', label: 'Platinum', icon: 'fa-gem' },
            gold: { bg: 'background:#fef9c3;color:#ca8a04', label: 'Gold', icon: 'fa-crown' },
            silver: { bg: 'background:#f3f4f6;color:#6b7280', label: 'Silver', icon: 'fa-medal' },
            new: { bg: 'background:#eff6ff;color:#2563eb', label: 'New', icon: 'fa-star' }
          };
          var tf = tierConfig[r.tier] || tierConfig.new;
          var mouBadge = {
            active: 'background:#dcfce7;color:#16a34a',
            pending: 'background:#fef9c3;color:#ca8a04',
            expired: 'background:#fee2e2;color:#dc2626',
            none: ''
          };
        %>
        <a href="/admin/recruiters/<%= r.id %>" class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-5 hover:shadow-lg transition-all block group">
          <!-- Top Row: Logo + Name + Tier -->
          <div class="flex items-start gap-3 mb-3">
            <% if (r.logo) { %>
              <img src="<%= r.logo %>" alt="" class="w-12 h-12 rounded-xl object-contain border border-gray-200 dark:border-gray-700" style="flex-shrink:0" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
              <div class="w-12 h-12 rounded-xl items-center justify-center text-white text-lg font-bold" style="flex-shrink:0;background:hsl(var(--primary));display:none"><%= r.company_name.charAt(0).toUpperCase() %></div>
            <% } else { %>
              <div class="w-12 h-12 rounded-xl flex items-center justify-center text-white text-lg font-bold" style="flex-shrink:0;background:hsl(var(--primary))">
                <span style="color:hsl(var(--accent))"><%= r.company_name.charAt(0).toUpperCase() %></span>
              </div>
            <% } %>
            <div class="flex-1 min-w-0">
              <h3 class="font-semibold text-gray-900 dark:text-white text-sm group-hover:text-blue-600 dark:group-hover:text-blue-400 transition" style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= r.company_name %></h3>
              <p class="text-xs text-gray-500 dark:text-gray-400"><%= r.industry || 'Industry N/A' %></p>
            </div>
            <span class="text-[10px] font-bold px-2.5 py-1 rounded-full flex items-center gap-1" style="<%= tf.bg %>;flex-shrink:0;white-space:nowrap">
              <i class="fas <%= tf.icon %> text-[8px]"></i> <%= tf.label %>
            </span>
          </div>

          <!-- Contact Row -->
          <% if (r.contact_name) { %>
            <div class="flex items-center gap-2 mb-3 text-xs text-gray-500 dark:text-gray-400">
              <div class="w-6 h-6 rounded-full bg-gray-100 dark:bg-gray-800 flex items-center justify-center flex-shrink-0">
                <i class="fas fa-user-tie text-[9px] text-gray-400"></i>
              </div>
              <span class="truncate"><%= r.contact_name %><%= r.contact_role ? ' &middot; ' + r.contact_role : '' %></span>
            </div>
          <% } %>

          <!-- MOU Badge (if not none) -->
          <% if (r.mou_status && r.mou_status !== 'none') { %>
            <div class="mb-3">
              <span class="text-[10px] font-medium px-2 py-0.5 rounded-full" style="<%= mouBadge[r.mou_status] %>">
                <i class="fas fa-file-contract mr-1"></i>MOU: <%= r.mou_status.charAt(0).toUpperCase() + r.mou_status.slice(1) %>
              </span>
            </div>
          <% } %>

          <!-- Stats Row -->
          <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:4px;padding-top:12px;border-top:1px solid #f3f4f6" class="dark:border-gray-800">
            <div class="text-center">
              <div class="text-sm font-bold text-gray-700 dark:text-gray-300"><%= r.job_count || 0 %></div>
              <div class="text-[9px] text-gray-400 uppercase">Jobs</div>
            </div>
            <div class="text-center">
              <div class="text-sm font-bold text-green-600"><%= r.hired_count || 0 %></div>
              <div class="text-[9px] text-gray-400 uppercase">Hired</div>
            </div>
            <div class="text-center">
              <% if (r.avg_ctc && r.avg_ctc > 0) { %>
                <div class="text-sm font-bold text-purple-600"><%= (r.avg_ctc / 100000).toFixed(1) %>L</div>
              <% } else { %>
                <div class="text-sm font-bold text-gray-300 dark:text-gray-600">&mdash;</div>
              <% } %>
              <div class="text-[9px] text-gray-400 uppercase">Avg CTC</div>
            </div>
          </div>

          <!-- Last Interaction -->
          <% if (r.last_interaction_at) { %>
            <div class="mt-3 pt-2 border-t border-gray-50 dark:border-gray-800 text-[10px] text-gray-400 flex items-center gap-1">
              <i class="fas fa-clock"></i>
              Last contact: <%= new Date(r.last_interaction_at).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %>
            </div>
          <% } %>
        </a>
      <% }); %>
    <% } else { %>
      <div style="grid-column:1/-1" class="py-16 text-center">
        <div class="w-16 h-16 rounded-2xl mx-auto mb-4 flex items-center justify-center" style="background:hsl(var(--primary))">
          <i class="fas fa-building text-xl" style="color:hsl(var(--accent))"></i>
        </div>
        <p class="text-gray-500 dark:text-gray-400 font-medium mb-1">No recruiters found</p>
        <p class="text-sm text-gray-400 dark:text-gray-500 mb-4">Get started by adding your first recruiter</p>
        <button onclick="openAddModal()" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-white text-sm font-medium" style="background:hsl(var(--accent))">
          <i class="fas fa-plus"></i> Add Recruiter
        </button>
      </div>
    <% } %>
  </div>

  <!-- List View (hidden by default) -->
  <div id="view-list" style="display:none" class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-gray-50 dark:bg-gray-800 text-left">
            <th class="py-3 px-4 font-medium">Company</th>
            <th class="py-3 px-4 font-medium">Industry</th>
            <th class="py-3 px-4 font-medium">Tier</th>
            <th class="py-3 px-4 font-medium">Contact</th>
            <th class="py-3 px-4 font-medium">MOU</th>
            <th class="py-3 px-4 font-medium text-center">Jobs</th>
            <th class="py-3 px-4 font-medium text-center">Hired</th>
            <th class="py-3 px-4 font-medium text-center">Avg CTC</th>
            <th class="py-3 px-4 font-medium">Last Contact</th>
          </tr>
        </thead>
        <tbody>
          <% if (recruiters.length) { %>
            <% recruiters.forEach(function(r) { %>
              <%
                var tConf = {
                  platinum: { style: 'background:#f3e8ff;color:#7c3aed', label: 'Platinum' },
                  gold: { style: 'background:#fef9c3;color:#ca8a04', label: 'Gold' },
                  silver: { style: 'background:#f3f4f6;color:#6b7280', label: 'Silver' },
                  new: { style: 'background:#eff6ff;color:#2563eb', label: 'New' }
                };
                var tc = tConf[r.tier] || tConf.new;
                var mouStyle = {
                  active: 'background:#dcfce7;color:#16a34a',
                  pending: 'background:#fef9c3;color:#ca8a04',
                  expired: 'background:#fee2e2;color:#dc2626',
                  none: 'background:#f3f4f6;color:#9ca3af'
                };
              %>
              <tr class="border-t border-gray-100 dark:border-gray-800 hover:bg-gray-50 dark:hover:bg-gray-800/50 cursor-pointer" onclick="window.location='/admin/recruiters/<%= r.id %>'">
                <td class="py-3 px-4">
                  <div class="flex items-center gap-3">
                    <% if (r.logo) { %>
                      <img src="<%= r.logo %>" alt="" class="w-8 h-8 rounded-lg object-contain border border-gray-200 dark:border-gray-700">
                    <% } else { %>
                      <div class="w-8 h-8 rounded-lg flex items-center justify-center text-white text-xs font-bold" style="background:hsl(var(--primary))"><span style="color:hsl(var(--accent))"><%= r.company_name.charAt(0).toUpperCase() %></span></div>
                    <% } %>
                    <div>
                      <p class="font-medium text-gray-900 dark:text-white"><%= r.company_name %></p>
                      <% if (r.company_size) { %><p class="text-[10px] text-gray-400"><%= r.company_size.charAt(0).toUpperCase() + r.company_size.slice(1) %></p><% } %>
                    </div>
                  </div>
                </td>
                <td class="py-3 px-4 text-gray-500"><%= r.industry || '—' %></td>
                <td class="py-3 px-4"><span class="text-[10px] font-bold px-2 py-0.5 rounded-full" style="<%= tc.style %>"><%= tc.label %></span></td>
                <td class="py-3 px-4">
                  <% if (r.contact_name) { %>
                    <p class="text-gray-700 dark:text-gray-300 text-xs font-medium"><%= r.contact_name %></p>
                    <% if (r.contact_email) { %><p class="text-[10px] text-gray-400"><%= r.contact_email %></p><% } %>
                  <% } else { %>
                    <span class="text-gray-300">—</span>
                  <% } %>
                </td>
                <td class="py-3 px-4"><span class="text-[10px] font-medium px-2 py-0.5 rounded-full" style="<%= mouStyle[r.mou_status] || mouStyle.none %>"><%= r.mou_status %></span></td>
                <td class="py-3 px-4 text-center font-semibold text-gray-700 dark:text-gray-300"><%= r.job_count || 0 %></td>
                <td class="py-3 px-4 text-center font-semibold text-green-600"><%= r.hired_count || 0 %></td>
                <td class="py-3 px-4 text-center text-purple-600 font-semibold"><%= r.avg_ctc && r.avg_ctc > 0 ? (r.avg_ctc / 100000).toFixed(1) + 'L' : '—' %></td>
                <td class="py-3 px-4 text-xs text-gray-400"><%= r.last_interaction_at ? new Date(r.last_interaction_at).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' }) : '—' %></td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr><td colspan="9" class="py-12 text-center text-gray-400"><i class="fas fa-building text-3xl mb-3 block"></i>No recruiters found</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Add Recruiter Modal -->
<div id="addModal" class="fixed inset-0 z-50 hidden" style="display:none">
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeAddModal()"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-lg bg-white dark:bg-gray-900 rounded-2xl shadow-2xl max-h-[90vh] overflow-y-auto">
    <div class="sticky top-0 bg-white dark:bg-gray-900 px-6 pt-6 pb-4 border-b border-gray-100 dark:border-gray-800 z-10 rounded-t-2xl">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="text-lg font-bold text-gray-900 dark:text-white">Add New Recruiter</h2>
          <p class="text-xs text-gray-500 mt-0.5">Fill in company details and contact info</p>
        </div>
        <button onclick="closeAddModal()" class="w-8 h-8 rounded-lg flex items-center justify-center hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-400 hover:text-gray-600 transition">
          <i class="fas fa-times"></i>
        </button>
      </div>
    </div>
    <form id="addForm" class="p-6 space-y-4">
      <!-- Company Info -->
      <div>
        <p class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3 flex items-center gap-2">
          <i class="fas fa-building text-gray-400"></i> Company Information
        </p>
        <div class="grid grid-cols-2 gap-3">
          <div class="col-span-2">
            <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Company Name <span class="text-red-500">*</span></label>
            <input type="text" name="company_name" required class="w-full px-3 py-2.5 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-accent focus:border-transparent transition" placeholder="e.g. Infosys, TCS, Google...">
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Industry</label>
            <input type="text" name="industry" class="w-full px-3 py-2.5 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-accent focus:border-transparent transition" placeholder="e.g. IT, Finance...">
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Company Size</label>
            <select name="company_size" class="w-full px-3 py-2.5 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white">
              <option value="">Select size</option>
              <option value="startup">Startup (1-50)</option>
              <option value="small">Small (51-200)</option>
              <option value="medium">Medium (201-1000)</option>
              <option value="large">Large (1001-5000)</option>
              <option value="enterprise">Enterprise (5000+)</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Website</label>
            <input type="url" name="website" placeholder="https://example.com" class="w-full px-3 py-2.5 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-accent focus:border-transparent transition">
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Logo URL</label>
            <input type="url" name="logo" placeholder="https://logo.clearbit.com/..." class="w-full px-3 py-2.5 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-accent focus:border-transparent transition">
          </div>
        </div>
      </div>

      <!-- MOU -->
      <div>
        <p class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3 flex items-center gap-2">
          <i class="fas fa-file-contract text-gray-400"></i> MOU Details
        </p>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">MOU Status</label>
            <select name="mou_status" class="w-full px-3 py-2.5 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white">
              <option value="none">None</option>
              <option value="pending">Pending</option>
              <option value="active">Active</option>
              <option value="expired">Expired</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">MOU Expiry</label>
            <input type="date" name="mou_expiry" class="w-full px-3 py-2.5 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white">
          </div>
        </div>
      </div>

      <!-- Contact Person -->
      <div>
        <p class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3 flex items-center gap-2">
          <i class="fas fa-user-tie text-gray-400"></i> Contact Person
        </p>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Name</label>
            <input type="text" name="contact_name" class="w-full px-3 py-2.5 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-accent focus:border-transparent transition" placeholder="Full name">
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Role / Designation</label>
            <input type="text" name="contact_role" class="w-full px-3 py-2.5 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-accent focus:border-transparent transition" placeholder="e.g. HR Manager">
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Email</label>
            <input type="email" name="contact_email" class="w-full px-3 py-2.5 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-accent focus:border-transparent transition" placeholder="email@company.com">
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Phone</label>
            <input type="tel" name="contact_phone" class="w-full px-3 py-2.5 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-accent focus:border-transparent transition" placeholder="+91 98765 43210">
          </div>
        </div>
      </div>

      <!-- Actions -->
      <div class="flex justify-end gap-3 pt-2 border-t border-gray-100 dark:border-gray-800">
        <button type="button" onclick="closeAddModal()" class="px-5 py-2.5 text-sm border border-gray-300 dark:border-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800 text-gray-700 dark:text-gray-300 transition font-medium">Cancel</button>
        <button type="submit" class="px-5 py-2.5 text-sm text-white rounded-lg font-medium transition" style="background:hsl(var(--accent))">
          <i class="fas fa-plus mr-1"></i> Create Recruiter
        </button>
      </div>
    </form>
  </div>
</div>

<script>
// ─── Search (debounced) ──────────────────────────────────
(function() {
  var input = document.getElementById('search-input');
  var timer;
  input.addEventListener('input', function() {
    clearTimeout(timer);
    timer = setTimeout(function() {
      var url = new URL(window.location.href);
      if (input.value) url.searchParams.set('search', input.value);
      else url.searchParams.delete('search');
      window.location.href = url.toString();
    }, 500);
  });
})();

// ─── Filters ─────────────────────────────────────────────
function toggleFilters() {
  var p = document.getElementById('filters-panel');
  p.style.display = p.style.display === 'none' ? 'block' : 'none';
}
function clearFilters() { window.location.href = '/admin/recruiters'; }

(function() {
  var form = document.getElementById('filter-form');
  if (!form) return;
  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var url = new URL(window.location.origin + '/admin/recruiters');
    var fd = new FormData(form);
    fd.forEach(function(val, key) { if (val) url.searchParams.set(key, val); });
    var search = document.getElementById('search-input').value;
    if (search) url.searchParams.set('search', search);
    window.location.href = url.toString();
  });
})();

// Auto-open filters if any are active
<% if (activeFilters) { %>
  document.getElementById('filters-panel').style.display = 'block';
<% } %>

// ─── View Toggle ─────────────────────────────────────────
var currentView = localStorage.getItem('admin-recruiters-view') || 'grid';
function setView(v) {
  currentView = v;
  localStorage.setItem('admin-recruiters-view', v);
  var gridEl = document.getElementById('view-grid');
  gridEl.style.display = v === 'grid' ? 'grid' : 'none';
  gridEl.style.gridTemplateColumns = 'repeat(3, 1fr)';
  document.getElementById('view-list').style.display = v === 'list' ? 'block' : 'none';
  document.getElementById('btn-grid').style.background = v === 'grid' ? 'hsl(var(--accent))' : '';
  document.getElementById('btn-grid').style.color = v === 'grid' ? 'white' : '#6b7280';
  document.getElementById('btn-list').style.background = v === 'list' ? 'hsl(var(--accent))' : '';
  document.getElementById('btn-list').style.color = v === 'list' ? 'white' : '#6b7280';
}
setView(currentView);

// ─── Modal ───────────────────────────────────────────────
function openAddModal() { document.getElementById('addModal').style.display = 'block'; }
function closeAddModal() { document.getElementById('addModal').style.display = 'none'; }

document.getElementById('addForm').addEventListener('submit', function(e) {
  e.preventDefault();
  var fd = new FormData(this);
  var body = {};
  fd.forEach(function(v, k) { if (v) body[k] = v; });

  fetch('/admin/recruiters/api/create', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(body)
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    if (data.success) {
      showToast('Recruiter created successfully', 'success');
      setTimeout(function() { location.reload(); }, 800);
    } else {
      showToast(data.error || 'Failed to create recruiter', 'error');
    }
  })
  .catch(function() { showToast('Network error', 'error'); });
});

function recalcTiers() {
  if (!confirm('Recalculate tier scores for all recruiters?')) return;
  fetch('/admin/recruiters/api/recalc-tiers', { method: 'POST' })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    if (data.success) {
      showToast('Tiers recalculated', 'success');
      setTimeout(function() { location.reload(); }, 800);
    } else {
      showToast(data.error || 'Failed', 'error');
    }
  })
  .catch(function() { showToast('Network error', 'error'); });
}

// Close modal on Escape
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') closeAddModal();
});
</script>

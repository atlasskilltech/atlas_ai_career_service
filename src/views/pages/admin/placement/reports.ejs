<div class="space-y-5">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Placement Reports</h1>
      <p class="text-sm text-gray-500 mt-1">Generate and download placement reports for NAAC/accreditation</p>
    </div>
    <a href="/admin/placement" class="inline-flex items-center gap-2 px-4 py-2 border border-gray-300 dark:border-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800 text-sm transition">
      <i class="fas fa-arrow-left"></i> Analytics
    </a>
  </div>

  <!-- Filter Selection -->
  <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-5">
    <h3 class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-4">Select Report Parameters</h3>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4" id="reportFilters">
      <div>
        <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Academic Year</label>
        <select id="rpt_year" class="w-full text-sm border border-gray-300 dark:border-gray-700 rounded-lg px-3 py-2 bg-white dark:bg-gray-800">
          <option value="">All Years</option>
          <% filterOptions.academic_years.forEach(function(y) { %>
            <option value="<%= y %>"><%= y %></option>
          <% }); %>
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Program</label>
        <select id="rpt_program" class="w-full text-sm border border-gray-300 dark:border-gray-700 rounded-lg px-3 py-2 bg-white dark:bg-gray-800">
          <option value="">All Programs</option>
          <% filterOptions.programs.forEach(function(p) { %>
            <option value="<%= p %>"><%= p %></option>
          <% }); %>
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Branch</label>
        <select id="rpt_branch" class="w-full text-sm border border-gray-300 dark:border-gray-700 rounded-lg px-3 py-2 bg-white dark:bg-gray-800">
          <option value="">All Branches</option>
          <% filterOptions.branches.forEach(function(b) { %>
            <option value="<%= b %>"><%= b %></option>
          <% }); %>
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Industry</label>
        <select id="rpt_industry" class="w-full text-sm border border-gray-300 dark:border-gray-700 rounded-lg px-3 py-2 bg-white dark:bg-gray-800">
          <option value="">All Industries</option>
          <% filterOptions.industries.forEach(function(i) { %>
            <option value="<%= i %>"><%= i %></option>
          <% }); %>
        </select>
      </div>
    </div>
  </div>

  <!-- Export Cards -->
  <div class="grid sm:grid-cols-3 gap-4">
    <!-- Excel Report -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 hover:shadow-lg transition group">
      <div class="w-14 h-14 rounded-2xl mb-4 flex items-center justify-center bg-green-50 dark:bg-green-900/20 group-hover:scale-110 transition">
        <i class="fas fa-file-excel text-2xl text-green-600"></i>
      </div>
      <h3 class="text-base font-bold text-gray-900 dark:text-white mb-1">Excel Report</h3>
      <p class="text-sm text-gray-500 mb-4 leading-relaxed">Full placement data with all breakdowns across multiple sheets — placements, summary, program-wise, branch-wise, and top companies.</p>
      <ul class="text-xs text-gray-400 mb-5 space-y-1">
        <li><i class="fas fa-check-circle text-green-500 mr-1"></i> 5 worksheets</li>
        <li><i class="fas fa-check-circle text-green-500 mr-1"></i> Formatted headers</li>
        <li><i class="fas fa-check-circle text-green-500 mr-1"></i> Up to 10,000 records</li>
      </ul>
      <button onclick="downloadReport('excel')" class="w-full py-2.5 rounded-lg text-white text-sm font-medium transition bg-green-600 hover:bg-green-700">
        <i class="fas fa-download mr-1"></i> Download Excel
      </button>
    </div>

    <!-- PDF Report -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 hover:shadow-lg transition group">
      <div class="w-14 h-14 rounded-2xl mb-4 flex items-center justify-center bg-red-50 dark:bg-red-900/20 group-hover:scale-110 transition">
        <i class="fas fa-file-pdf text-2xl text-red-600"></i>
      </div>
      <h3 class="text-base font-bold text-gray-900 dark:text-white mb-1">PDF Report</h3>
      <p class="text-sm text-gray-500 mb-4 leading-relaxed">Formatted multi-page PDF placement report suitable for NAAC/accreditation submissions with all metrics and breakdowns.</p>
      <ul class="text-xs text-gray-400 mb-5 space-y-1">
        <li><i class="fas fa-check-circle text-red-500 mr-1"></i> NAAC-ready format</li>
        <li><i class="fas fa-check-circle text-red-500 mr-1"></i> University branding</li>
        <li><i class="fas fa-check-circle text-red-500 mr-1"></i> Tables + metrics</li>
      </ul>
      <button onclick="downloadReport('pdf')" class="w-full py-2.5 rounded-lg text-white text-sm font-medium transition bg-red-600 hover:bg-red-700">
        <i class="fas fa-download mr-1"></i> Download PDF
      </button>
    </div>

    <!-- Summary Infographic -->
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6 hover:shadow-lg transition group">
      <div class="w-14 h-14 rounded-2xl mb-4 flex items-center justify-center bg-purple-50 dark:bg-purple-900/20 group-hover:scale-110 transition">
        <i class="fas fa-image text-2xl text-purple-600"></i>
      </div>
      <h3 class="text-base font-bold text-gray-900 dark:text-white mb-1">Summary Infographic</h3>
      <p class="text-sm text-gray-500 mb-4 leading-relaxed">One-page landscape PDF infographic with key placement statistics — perfect for presentations, social media, and quick sharing.</p>
      <ul class="text-xs text-gray-400 mb-5 space-y-1">
        <li><i class="fas fa-check-circle text-purple-500 mr-1"></i> Single page</li>
        <li><i class="fas fa-check-circle text-purple-500 mr-1"></i> Landscape format</li>
        <li><i class="fas fa-check-circle text-purple-500 mr-1"></i> Key stats at a glance</li>
      </ul>
      <button onclick="downloadReport('summary')" class="w-full py-2.5 rounded-lg text-white text-sm font-medium transition bg-purple-600 hover:bg-purple-700">
        <i class="fas fa-download mr-1"></i> Download Summary
      </button>
    </div>
  </div>

  <!-- Info Banner -->
  <div class="bg-blue-50 dark:bg-blue-900/10 rounded-xl border border-blue-200 dark:border-blue-800/30 p-4 flex items-start gap-3">
    <i class="fas fa-info-circle text-blue-500 mt-0.5"></i>
    <div>
      <p class="text-sm text-blue-900 dark:text-blue-200 font-medium">About Report Generation</p>
      <p class="text-xs text-blue-700 dark:text-blue-400 mt-1">PDF reports are generated using Puppeteer and may take a few seconds. Excel reports include all raw data for further analysis. All reports respect the filters selected above.</p>
    </div>
  </div>
</div>

<script>
function getFilterParams() {
  var params = new URLSearchParams();
  var year = document.getElementById('rpt_year').value;
  var program = document.getElementById('rpt_program').value;
  var branch = document.getElementById('rpt_branch').value;
  var industry = document.getElementById('rpt_industry').value;
  if (year) params.set('academic_year', year);
  if (program) params.set('program', program);
  if (branch) params.set('branch', branch);
  if (industry) params.set('industry', industry);
  return params.toString();
}

function downloadReport(type) {
  var params = getFilterParams();
  var url = '/admin/placement/export/' + type + (params ? '?' + params : '');
  var btn = event.target.closest('button');
  var originalHtml = btn.innerHTML;

  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i> Generating...';

  // Use a hidden link to trigger download
  var link = document.createElement('a');
  link.href = url;
  link.style.display = 'none';
  document.body.appendChild(link);
  link.click();
  document.body.removeChild(link);

  // Re-enable button after delay
  setTimeout(function() {
    btn.disabled = false;
    btn.innerHTML = originalHtml;
  }, 5000);
}
</script>

<div class="max-w-4xl mx-auto space-y-5">
  <!-- Back -->
  <a href="/job-board" class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-accent transition-colors"><i class="fas fa-arrow-left text-xs"></i> Back to Job Board</a>

  <!-- Job Header Card -->
  <div class="card !p-0 overflow-hidden">
    <div class="p-5 sm:p-6">
      <div class="flex flex-col sm:flex-row gap-4">
        <!-- Company Logo -->
        <div class="flex-shrink-0 w-14 h-14 bg-gray-50 dark:bg-gray-800 rounded-xl flex items-center justify-center border border-gray-100 dark:border-gray-700">
          <% if (job.company_logo) { %>
            <img src="<%= job.company_logo %>" alt="<%= job.company %>" class="w-11 h-11 rounded-lg object-cover">
          <% } else { %>
            <span class="text-xl font-bold text-gray-400"><%= job.company.charAt(0).toUpperCase() %></span>
          <% } %>
        </div>

        <!-- Job Title & Meta -->
        <div class="flex-1 min-w-0">
          <h1 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white"><%= job.title %></h1>
          <p class="text-base text-gray-500 mt-1"><%= job.company %></p>

          <!-- Key Info Pills -->
          <div class="flex flex-wrap items-center gap-3 mt-3 text-sm text-gray-600 dark:text-gray-400">
            <% if (job.location) { %>
              <span class="inline-flex items-center gap-1.5"><i class="fas fa-map-marker-alt text-red-400 text-xs"></i> <%= job.location %></span>
            <% } %>
            <% if (job.salary_min || job.salary_max) { %>
              <span class="inline-flex items-center gap-1.5"><i class="fas fa-indian-rupee-sign text-green-500 text-xs"></i>
                <% if (job.salary_min && job.salary_max) { %><%= (job.salary_min/100000).toFixed(0) %>-<%= (job.salary_max/100000).toFixed(0) %> LPA<% } else if (job.salary_max) { %>Up to <%= (job.salary_max/100000).toFixed(0) %> LPA<% } else { %><%= (job.salary_min/100000).toFixed(0) %>+ LPA<% } %>
              </span>
            <% } %>
            <% if (job.experience_min !== null) { %>
              <span class="inline-flex items-center gap-1.5"><i class="fas fa-clock text-blue-400 text-xs"></i> <%= job.experience_min || 0 %>-<%= job.experience_max || 'Any' %> years</span>
            <% } %>
          </div>

          <!-- Tags -->
          <div class="flex flex-wrap gap-2 mt-3">
            <% const typeColors = {full_time: 'blue', part_time: 'yellow', internship: 'green', contract: 'purple', freelance: 'orange'}; %>
            <% const typeColor = typeColors[job.job_type] || 'gray'; %>
            <span class="px-2.5 py-1 rounded-md text-xs font-medium bg-<%= typeColor %>-50 text-<%= typeColor %>-700 dark:bg-<%= typeColor %>-900/20 dark:text-<%= typeColor %>-300 border border-<%= typeColor %>-200 dark:border-<%= typeColor %>-800 capitalize"><%= (job.job_type || 'full_time').replace('_', ' ') %></span>
            <span class="px-2.5 py-1 rounded-md text-xs font-medium bg-gray-50 text-gray-700 dark:bg-gray-800 dark:text-gray-300 border border-gray-200 dark:border-gray-700 capitalize"><i class="fas fa-laptop-house mr-1 text-purple-400"></i><%= (job.work_mode || 'onsite').replace('_', ' ') %></span>
            <% if (job.is_verified) { %><span class="px-2.5 py-1 rounded-md text-xs font-medium bg-green-50 text-green-700 dark:bg-green-900/20 dark:text-green-300 border border-green-200 dark:border-green-800"><i class="fas fa-check-circle mr-1"></i>Verified</span><% } %>
          </div>
        </div>
      </div>
    </div>

    <!-- Action Bar -->
    <div class="px-5 sm:px-6 py-4 bg-gray-50 dark:bg-gray-800/50 border-t border-gray-100 dark:border-gray-800 flex flex-wrap gap-2.5">
      <% if (job.hasApplied) { %>
        <button disabled class="btn-primary text-sm !opacity-60"><i class="fas fa-check mr-1.5"></i> Applied</button>
      <% } else if (job.apply_url) { %>
        <a href="<%= job.apply_url %>" target="_blank" rel="noopener noreferrer" class="btn-primary text-sm"><i class="fas fa-external-link-alt mr-1.5"></i> Apply Externally</a>
      <% } %>
      <% if (!job.hasApplied) { %>
        <button onclick="openApplyModal()" class="btn-outline text-sm"><i class="fas fa-paper-plane mr-1.5"></i> Quick Apply</button>
      <% } %>
      <button onclick="toggleSave()" id="save-btn" class="btn-outline text-sm">
        <i class="<%= job.isSaved ? 'fas' : 'far' %> fa-bookmark mr-1.5"></i> <%= job.isSaved ? 'Saved' : 'Save' %>
      </button>
      <button onclick="openMatchModal()" class="btn-outline text-sm"><i class="fas fa-chart-pie mr-1.5"></i> Match Score</button>
    </div>
  </div>

  <!-- Skills Card -->
  <% let skills = []; try { skills = typeof job.skills === 'string' ? JSON.parse(job.skills) : (job.skills || []); } catch(e) { skills = []; } %>
  <% if (skills.length > 0 && !(skills.length === 1 && skills[0] === 'General')) { %>
    <div class="card !p-5">
      <h3 class="font-semibold text-sm mb-3 flex items-center gap-2"><i class="fas fa-tools text-accent text-xs"></i> Required Skills</h3>
      <div class="flex flex-wrap gap-2">
        <% skills.forEach(skill => { %>
          <span class="px-3 py-1.5 bg-accent/8 text-accent border border-accent/15 rounded-lg text-sm font-medium"><%= skill %></span>
        <% }); %>
      </div>
    </div>
  <% } %>

  <!-- Description Card -->
  <% if (job.description) { %>
    <div class="card !p-5">
      <h3 class="font-semibold text-sm mb-3 flex items-center gap-2"><i class="fas fa-file-alt text-accent text-xs"></i> Job Description</h3>
      <div class="prose dark:prose-invert max-w-none text-sm leading-relaxed whitespace-pre-wrap text-gray-700 dark:text-gray-300"><%= job.description %></div>
    </div>
  <% } %>

  <!-- Job Details Grid -->
  <div class="card !p-5">
    <h3 class="font-semibold text-sm mb-4 flex items-center gap-2"><i class="fas fa-info-circle text-accent text-xs"></i> Job Details</h3>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
      <div class="space-y-1">
        <span class="text-xs font-medium text-gray-400 uppercase tracking-wider">Category</span>
        <p class="text-sm font-medium"><%= job.category || 'N/A' %></p>
      </div>
      <div class="space-y-1">
        <span class="text-xs font-medium text-gray-400 uppercase tracking-wider">Posted</span>
        <p class="text-sm font-medium"><%= job.posted_date ? new Date(job.posted_date).toLocaleDateString('en-IN', {day: 'numeric', month: 'short', year: 'numeric'}) : 'N/A' %></p>
      </div>
      <% if (job.expires_at) { %>
        <div class="space-y-1">
          <span class="text-xs font-medium text-gray-400 uppercase tracking-wider">Expires</span>
          <p class="text-sm font-medium"><%= new Date(job.expires_at).toLocaleDateString('en-IN', {day: 'numeric', month: 'short', year: 'numeric'}) %></p>
        </div>
      <% } %>
    </div>
  </div>
</div>

<!-- Quick Apply Modal -->
<div id="apply-modal" class="modal-overlay hidden">
  <div class="modal-content p-6">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-lg font-semibold">Quick Apply</h3>
      <button onclick="closeApplyModal()" class="w-8 h-8 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 flex items-center justify-center text-gray-400"><i class="fas fa-times"></i></button>
    </div>
    <p class="text-sm text-gray-500 mb-4"><%= job.title %> at <%= job.company %></p>
    <div class="space-y-3">
      <div><label class="label-field">Cover Letter (optional)</label><textarea id="apply-cover" rows="5" class="input-field" placeholder="Write a brief cover letter explaining why you're a great fit..."></textarea></div>
      <button onclick="submitApplication()" id="apply-btn" class="btn-primary w-full">Submit Application</button>
    </div>
  </div>
</div>

<!-- Match Score Modal -->
<div id="match-modal" class="modal-overlay hidden">
  <div class="modal-content p-6">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-lg font-semibold">AI Job Match Analysis</h3>
      <button onclick="closeMatchModal()" class="w-8 h-8 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 flex items-center justify-center text-gray-400"><i class="fas fa-times"></i></button>
    </div>
    <div class="space-y-3">
      <div><label class="label-field">Your Resume Text</label><textarea id="match-resume" rows="5" class="input-field" placeholder="Paste your resume text here..."></textarea></div>
      <button onclick="analyzeMatch()" id="match-btn" class="btn-primary w-full"><i class="fas fa-robot mr-1.5"></i> Analyze Match</button>
      <div id="match-results"></div>
    </div>
  </div>
</div>

<script>
const JOB_ID = <%= job.id %>;
let isSaved = <%= job.isSaved ? 'true' : 'false' %>;

function openApplyModal() { document.getElementById('apply-modal').classList.remove('hidden'); }
function closeApplyModal() { document.getElementById('apply-modal').classList.add('hidden'); }
function openMatchModal() { document.getElementById('match-modal').classList.remove('hidden'); }
function closeMatchModal() { document.getElementById('match-modal').classList.add('hidden'); }

async function toggleSave() {
  try {
    const method = isSaved ? 'DELETE' : 'POST';
    await fetch('/job-board/api/' + JOB_ID + '/save', { method });
    isSaved = !isSaved;
    var btn = document.getElementById('save-btn');
    btn.innerHTML = '<i class="' + (isSaved ? 'fas' : 'far') + ' fa-bookmark mr-1.5"></i> ' + (isSaved ? 'Saved' : 'Save');
    showToast(isSaved ? 'Job saved!' : 'Job unsaved', 'success');
  } catch { showToast('Failed', 'error'); }
}

async function submitApplication() {
  var btn = document.getElementById('apply-btn');
  btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1.5"></i> Applying...';
  try {
    var res = await fetch('/job-board/api/' + JOB_ID + '/apply', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ coverLetter: document.getElementById('apply-cover').value }),
    });
    var data = await res.json();
    if (data.success) { showToast('Application submitted!', 'success'); closeApplyModal(); location.reload(); }
    else showToast(data.error || 'Failed', 'error');
  } catch { showToast('Failed to apply', 'error'); }
  btn.disabled = false; btn.innerHTML = 'Submit Application';
}

async function analyzeMatch() {
  var btn = document.getElementById('match-btn');
  btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1.5"></i> Analyzing...';
  try {
    var res = await fetch('/job-board/api/match', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ resumeText: document.getElementById('match-resume').value, jobDescription: '<%= (job.description || "").replace(/'/g, "\\'").replace(/\n/g, " ") %>' }),
    });
    var data = await res.json();
    if (data.success) {
      var r = data.result;
      var scoreColor = r.matchPercentage >= 70 ? 'text-green-600' : r.matchPercentage >= 40 ? 'text-yellow-600' : 'text-red-600';
      var scoreBg = r.matchPercentage >= 70 ? 'bg-green-50 dark:bg-green-900/20' : r.matchPercentage >= 40 ? 'bg-yellow-50 dark:bg-yellow-900/20' : 'bg-red-50 dark:bg-red-900/20';
      document.getElementById('match-results').innerHTML =
        '<div class="mt-4 space-y-4">' +
        '<div class="p-4 rounded-xl ' + scoreBg + ' text-center"><span class="text-4xl font-bold ' + scoreColor + '">' + r.matchPercentage + '%</span><p class="text-xs text-gray-500 mt-1">Match Score</p></div>' +
        '<div><p class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-2">Matching Skills</p><div class="flex flex-wrap gap-1.5">' + (r.matchingSkills||[]).map(function(s){return '<span class="badge-success">'+s+'</span>';}).join('') + '</div></div>' +
        '<div><p class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-2">Missing Skills</p><div class="flex flex-wrap gap-1.5">' + (r.missingSkills||[]).map(function(s){return '<span class="badge-danger">'+s+'</span>';}).join('') + '</div></div>' +
        '<div><p class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-2">Recommendations</p><ul class="space-y-1.5">' + (r.recommendations||[]).map(function(s){return '<li class="text-sm text-gray-600 dark:text-gray-400 flex gap-2"><i class="fas fa-lightbulb text-yellow-500 mt-0.5 text-xs"></i><span>'+s+'</span></li>';}).join('') + '</ul></div>' +
        '</div>';
    }
  } catch { showToast('Analysis failed', 'error'); }
  btn.disabled = false; btn.innerHTML = '<i class="fas fa-robot mr-1.5"></i> Analyze Match';
}
</script>

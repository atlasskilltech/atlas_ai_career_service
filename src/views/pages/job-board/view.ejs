<div class="max-w-5xl mx-auto space-y-5">
  <!-- Back -->
  <a href="/job-board" class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-accent transition-colors"><i class="fas fa-arrow-left text-xs"></i> Back to Job Board</a>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
    <!-- Main Content (Left 2/3) -->
    <div class="lg:col-span-2 space-y-5">

      <!-- Job Header Card -->
      <div class="card !p-0 overflow-hidden">
        <div class="p-5 sm:p-6">
          <div class="flex flex-col sm:flex-row gap-4">
            <!-- Company Logo -->
            <div class="flex-shrink-0 w-14 h-14 bg-gray-50 dark:bg-gray-800 rounded-xl flex items-center justify-center border border-gray-100 dark:border-gray-700">
              <% if (job.company_logo) { %>
                <img src="<%= job.company_logo %>" alt="<%= job.company %>" class="w-11 h-11 rounded-lg object-cover">
              <% } else { %>
                <span class="text-xl font-bold text-gray-400"><%= job.company.charAt(0).toUpperCase() %></span>
              <% } %>
            </div>

            <!-- Job Title & Meta -->
            <div class="flex-1 min-w-0">
              <h1 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white"><%= job.title %></h1>
              <p class="text-base text-gray-500 mt-1"><%= job.company %></p>

              <!-- Key Info Pills -->
              <div class="flex flex-wrap items-center gap-3 mt-3 text-sm text-gray-600 dark:text-gray-400">
                <% if (job.location) { %>
                  <span class="inline-flex items-center gap-1.5"><i class="fas fa-map-marker-alt text-red-400 text-xs"></i> <%= job.location %></span>
                <% } %>
                <% if (job.salary_min || job.salary_max) { %>
                  <span class="inline-flex items-center gap-1.5"><i class="fas fa-indian-rupee-sign text-green-500 text-xs"></i>
                    <% if (job.salary_min && job.salary_max) { %><%= (job.salary_min/100000).toFixed(0) %>-<%= (job.salary_max/100000).toFixed(0) %> LPA<% } else if (job.salary_max) { %>Up to <%= (job.salary_max/100000).toFixed(0) %> LPA<% } else { %><%= (job.salary_min/100000).toFixed(0) %>+ LPA<% } %>
                  </span>
                <% } %>
                <% if (job.experience_min !== null) { %>
                  <span class="inline-flex items-center gap-1.5"><i class="fas fa-clock text-blue-400 text-xs"></i> <%= job.experience_min || 0 %>-<%= job.experience_max || 'Any' %> years</span>
                <% } %>
              </div>

              <!-- Tags -->
              <div class="flex flex-wrap gap-2 mt-3">
                <% const typeColors = {full_time: 'blue', part_time: 'yellow', internship: 'green', contract: 'purple', freelance: 'orange'}; %>
                <% const typeColor = typeColors[job.job_type] || 'gray'; %>
                <span class="px-2.5 py-1 rounded-md text-xs font-medium bg-<%= typeColor %>-50 text-<%= typeColor %>-700 dark:bg-<%= typeColor %>-900/20 dark:text-<%= typeColor %>-300 border border-<%= typeColor %>-200 dark:border-<%= typeColor %>-800 capitalize"><%= (job.job_type || 'full_time').replace('_', ' ') %></span>
                <span class="px-2.5 py-1 rounded-md text-xs font-medium bg-gray-50 text-gray-700 dark:bg-gray-800 dark:text-gray-300 border border-gray-200 dark:border-gray-700 capitalize"><i class="fas fa-laptop-house mr-1 text-purple-400"></i><%= (job.work_mode || 'onsite').replace('_', ' ') %></span>
                <% if (job.category) { %>
                  <span class="px-2.5 py-1 rounded-md text-xs font-medium bg-accent/10 text-accent border border-accent/20"><%= job.category %></span>
                <% } %>
                <% if (job.is_verified) { %><span class="px-2.5 py-1 rounded-md text-xs font-medium bg-green-50 text-green-700 dark:bg-green-900/20 dark:text-green-300 border border-green-200 dark:border-green-800"><i class="fas fa-check-circle mr-1"></i>Verified</span><% } %>
              </div>
            </div>
          </div>
        </div>

        <!-- Action Bar -->
        <div class="px-5 sm:px-6 py-4 bg-gray-50 dark:bg-gray-800/50 border-t border-gray-100 dark:border-gray-800 flex flex-wrap gap-2.5">
          <% if (job.hasApplied) { %>
            <button disabled class="btn-primary text-sm !opacity-60"><i class="fas fa-check mr-1.5"></i> Applied</button>
          <% } else if (job.apply_url) { %>
            <a href="<%= job.apply_url %>" target="_blank" rel="noopener noreferrer" class="btn-primary text-sm"><i class="fas fa-external-link-alt mr-1.5"></i> Apply Externally</a>
          <% } %>
          <% if (!job.hasApplied) { %>
            <button onclick="openApplyModal()" class="btn-outline text-sm"><i class="fas fa-paper-plane mr-1.5"></i> Quick Apply</button>
          <% } %>
          <button onclick="toggleSave()" id="save-btn" class="btn-outline text-sm">
            <i class="<%= job.isSaved ? 'fas' : 'far' %> fa-bookmark mr-1.5"></i> <%= job.isSaved ? 'Saved' : 'Save' %>
          </button>
          <button onclick="openMatchModal()" class="btn-outline text-sm"><i class="fas fa-chart-pie mr-1.5"></i> Match Score</button>
        </div>
      </div>

      <!-- Description Card -->
      <% if (job.description) { %>
        <div class="card !p-6">
          <h3 class="font-semibold text-base mb-4 flex items-center gap-2"><i class="fas fa-file-alt text-accent text-sm"></i> Job Description</h3>
          <div class="job-description text-sm leading-relaxed text-gray-700 dark:text-gray-300" id="job-desc-content"><%- job.description.replace(/</g, '&lt;').replace(/>/g, '&gt;') %></div>
        </div>
      <% } %>

      <!-- Skills Card -->
      <% let skills = []; try { skills = typeof job.skills === 'string' ? JSON.parse(job.skills) : (job.skills || []); } catch(e) { skills = []; } %>
      <% if (skills.length > 0 && !(skills.length === 1 && skills[0] === 'General')) { %>
        <div class="card !p-6">
          <h3 class="font-semibold text-base mb-4 flex items-center gap-2"><i class="fas fa-tools text-accent text-sm"></i> Required Skills</h3>
          <div class="flex flex-wrap gap-2">
            <% skills.forEach(skill => { %>
              <span class="px-3 py-1.5 bg-accent/8 text-accent border border-accent/15 rounded-lg text-sm font-medium"><%= skill %></span>
            <% }); %>
          </div>
        </div>
      <% } %>

    </div>

    <!-- Sidebar (Right 1/3) -->
    <div class="space-y-5">

      <!-- Job Details Card -->
      <div class="card !p-5">
        <h3 class="font-semibold text-sm mb-4 flex items-center gap-2"><i class="fas fa-info-circle text-accent text-xs"></i> Job Details</h3>
        <div class="space-y-4">
          <% if (job.category) { %>
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-lg bg-accent/10 flex items-center justify-center flex-shrink-0">
                <i class="fas fa-tag text-accent text-xs"></i>
              </div>
              <div>
                <p class="text-xs text-gray-400">Category</p>
                <p class="text-sm font-medium"><%= job.category %></p>
              </div>
            </div>
          <% } %>
          <% if (job.location) { %>
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-lg bg-red-50 dark:bg-red-900/20 flex items-center justify-center flex-shrink-0">
                <i class="fas fa-map-marker-alt text-red-400 text-xs"></i>
              </div>
              <div>
                <p class="text-xs text-gray-400">Location</p>
                <p class="text-sm font-medium"><%= job.location %></p>
              </div>
            </div>
          <% } %>
          <% if (job.salary_min || job.salary_max) { %>
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-lg bg-green-50 dark:bg-green-900/20 flex items-center justify-center flex-shrink-0">
                <i class="fas fa-indian-rupee-sign text-green-500 text-xs"></i>
              </div>
              <div>
                <p class="text-xs text-gray-400">Salary</p>
                <p class="text-sm font-medium">
                  <% if (job.salary_min && job.salary_max) { %><%= (job.salary_min/100000).toFixed(0) %>-<%= (job.salary_max/100000).toFixed(0) %> LPA<% } else if (job.salary_max) { %>Up to <%= (job.salary_max/100000).toFixed(0) %> LPA<% } else { %><%= (job.salary_min/100000).toFixed(0) %>+ LPA<% } %>
                </p>
              </div>
            </div>
          <% } %>
          <% if (job.experience_min !== null) { %>
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-lg bg-blue-50 dark:bg-blue-900/20 flex items-center justify-center flex-shrink-0">
                <i class="fas fa-clock text-blue-400 text-xs"></i>
              </div>
              <div>
                <p class="text-xs text-gray-400">Experience</p>
                <p class="text-sm font-medium"><%= job.experience_min || 0 %>-<%= job.experience_max || 'Any' %> years</p>
              </div>
            </div>
          <% } %>
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-blue-50 dark:bg-blue-900/20 flex items-center justify-center flex-shrink-0">
              <i class="fas fa-briefcase text-blue-500 text-xs"></i>
            </div>
            <div>
              <p class="text-xs text-gray-400">Job Type</p>
              <p class="text-sm font-medium capitalize"><%= (job.job_type || 'full_time').replace('_', ' ') %></p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-purple-50 dark:bg-purple-900/20 flex items-center justify-center flex-shrink-0">
              <i class="fas fa-laptop-house text-purple-500 text-xs"></i>
            </div>
            <div>
              <p class="text-xs text-gray-400">Work Mode</p>
              <p class="text-sm font-medium capitalize"><%= (job.work_mode || 'onsite').replace('_', ' ') %></p>
            </div>
          </div>
          <% if (job.posted_date) { %>
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-lg bg-gray-100 dark:bg-gray-800 flex items-center justify-center flex-shrink-0">
                <i class="far fa-calendar text-gray-500 text-xs"></i>
              </div>
              <div>
                <p class="text-xs text-gray-400">Posted</p>
                <p class="text-sm font-medium"><%= new Date(job.posted_date).toLocaleDateString('en-IN', {day: 'numeric', month: 'short', year: 'numeric'}) %></p>
              </div>
            </div>
          <% } %>
          <% if (job.expires_at) { %>
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-lg bg-orange-50 dark:bg-orange-900/20 flex items-center justify-center flex-shrink-0">
                <i class="fas fa-hourglass-half text-orange-500 text-xs"></i>
              </div>
              <div>
                <p class="text-xs text-gray-400">Expires</p>
                <p class="text-sm font-medium"><%= new Date(job.expires_at).toLocaleDateString('en-IN', {day: 'numeric', month: 'short', year: 'numeric'}) %></p>
              </div>
            </div>
          <% } %>
        </div>

        <!-- Apply CTA in sidebar -->
        <div class="mt-5 pt-5 border-t border-gray-100 dark:border-gray-800">
          <% if (job.hasApplied) { %>
            <button disabled class="btn-primary w-full text-sm !opacity-60"><i class="fas fa-check mr-1.5"></i> Already Applied</button>
          <% } else if (job.apply_url) { %>
            <a href="<%= job.apply_url %>" target="_blank" rel="noopener noreferrer" class="btn-primary w-full text-sm text-center block"><i class="fas fa-external-link-alt mr-1.5"></i> Apply Now</a>
          <% } else { %>
            <button onclick="openApplyModal()" class="btn-primary w-full text-sm"><i class="fas fa-paper-plane mr-1.5"></i> Quick Apply</button>
          <% } %>
        </div>
      </div>

      <!-- Share Card -->
      <div class="card !p-5">
        <h3 class="font-semibold text-sm mb-3 flex items-center gap-2"><i class="fas fa-share-alt text-accent text-xs"></i> Share this Job</h3>
        <div class="flex gap-2">
          <button onclick="copyJobLink()" class="flex-1 btn-outline text-xs !py-2" title="Copy link"><i class="fas fa-link mr-1"></i> Copy Link</button>
          <a href="https://wa.me/?text=<%= encodeURIComponent(job.title + ' at ' + job.company + ' - ' + 'https://careerservice.atlasskilltech.app/job-board/view/' + job.id) %>" target="_blank" class="flex-1 btn-outline text-xs !py-2 text-center" title="Share on WhatsApp"><i class="fab fa-whatsapp mr-1"></i> WhatsApp</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Related Jobs Section -->
  <% if (relatedJobs && relatedJobs.length > 0) { %>
    <div class="space-y-4">
      <div class="flex items-center justify-between">
        <h2 class="text-lg font-bold flex items-center gap-2"><i class="fas fa-th-large text-accent text-sm"></i> Related Jobs</h2>
        <% if (job.category) { %>
          <a href="/job-board?category=<%= encodeURIComponent(job.category) %>" class="text-sm text-accent hover:underline">View all <i class="fas fa-arrow-right text-xs ml-0.5"></i></a>
        <% } %>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
        <% relatedJobs.forEach(rJob => { %>
          <% let rSkills = []; try { rSkills = typeof rJob.skills === 'string' ? JSON.parse(rJob.skills) : (rJob.skills || []); } catch(e) { rSkills = []; } %>
          <% const rTypeColors = {full_time: 'blue', part_time: 'yellow', internship: 'green', contract: 'purple', freelance: 'orange'}; %>
          <% const rTypeColor = rTypeColors[rJob.job_type] || 'gray'; %>
          <a href="/job-board/view/<%= rJob.id %>" class="card !p-0 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 group block">
            <div class="p-4">
              <!-- Header -->
              <div class="flex items-start gap-3 mb-3">
                <div class="w-10 h-10 bg-gray-50 dark:bg-gray-800 rounded-xl flex items-center justify-center border border-gray-100 dark:border-gray-700 flex-shrink-0">
                  <% if (rJob.company_logo) { %>
                    <img src="<%= rJob.company_logo %>" alt="<%= rJob.company %>" class="w-8 h-8 rounded-lg object-cover">
                  <% } else { %>
                    <span class="text-sm font-bold text-gray-400"><%= rJob.company.charAt(0).toUpperCase() %></span>
                  <% } %>
                </div>
                <div class="min-w-0 flex-1">
                  <h4 class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-accent transition-colors line-clamp-1"><%= rJob.title %></h4>
                  <p class="text-xs text-gray-500 mt-0.5"><%= rJob.company %></p>
                </div>
              </div>

              <!-- Tags -->
              <div class="flex flex-wrap gap-1.5 mb-2.5">
                <span class="px-2 py-0.5 rounded text-[11px] font-medium bg-<%= rTypeColor %>-50 text-<%= rTypeColor %>-700 dark:bg-<%= rTypeColor %>-900/20 dark:text-<%= rTypeColor %>-300 border border-<%= rTypeColor %>-200 dark:border-<%= rTypeColor %>-800 capitalize"><%= (rJob.job_type || 'full_time').replace('_', ' ') %></span>
                <span class="px-2 py-0.5 rounded text-[11px] font-medium bg-gray-50 text-gray-600 dark:bg-gray-800 dark:text-gray-400 border border-gray-200 dark:border-gray-700 capitalize"><%= (rJob.work_mode || 'onsite').replace('_', ' ') %></span>
              </div>

              <!-- Meta -->
              <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-gray-500">
                <% if (rJob.location) { %>
                  <span class="inline-flex items-center gap-1"><i class="fas fa-map-marker-alt text-red-400"></i> <%= rJob.location %></span>
                <% } %>
                <% if (rJob.salary_min || rJob.salary_max) { %>
                  <span class="inline-flex items-center gap-1"><i class="fas fa-indian-rupee-sign text-green-500"></i>
                    <% if (rJob.salary_min && rJob.salary_max) { %><%= (rJob.salary_min/100000).toFixed(0) %>-<%= (rJob.salary_max/100000).toFixed(0) %> LPA<% } else if (rJob.salary_max) { %>Up to <%= (rJob.salary_max/100000).toFixed(0) %> LPA<% } else { %><%= (rJob.salary_min/100000).toFixed(0) %>+ LPA<% } %>
                  </span>
                <% } %>
                <% if (rJob.experience_min !== null || rJob.experience_max !== null) { %>
                  <span class="inline-flex items-center gap-1"><i class="fas fa-clock text-blue-400"></i> <%= rJob.experience_min || 0 %>-<%= rJob.experience_max || 'Any' %> yrs</span>
                <% } %>
              </div>

              <!-- Skills -->
              <% if (rSkills.length > 0 && !(rSkills.length === 1 && rSkills[0] === 'General')) { %>
                <div class="flex flex-wrap gap-1 mt-2.5">
                  <% rSkills.slice(0, 3).forEach(skill => { %>
                    <span class="px-1.5 py-0.5 bg-accent/8 text-accent border border-accent/15 rounded text-[11px] font-medium"><%= skill %></span>
                  <% }); %>
                  <% if (rSkills.length > 3) { %><span class="px-1.5 py-0.5 text-gray-400 text-[11px]">+<%= rSkills.length - 3 %></span><% } %>
                </div>
              <% } %>
            </div>

            <!-- Footer -->
            <div class="px-4 py-2.5 bg-gray-50 dark:bg-gray-800/50 border-t border-gray-100 dark:border-gray-800 rounded-b-xl flex items-center justify-between">
              <% if (rJob.posted_date) { %>
                <span class="text-[11px] text-gray-400"><i class="far fa-calendar mr-1"></i><%= new Date(rJob.posted_date).toLocaleDateString('en-IN', {day: 'numeric', month: 'short'}) %></span>
              <% } else { %>
                <span></span>
              <% } %>
              <span class="text-xs font-medium text-accent">View Details <i class="fas fa-arrow-right text-[10px] ml-0.5"></i></span>
            </div>
          </a>
        <% }); %>
      </div>
    </div>
  <% } %>
</div>

<!-- Quick Apply Modal -->
<div id="apply-modal" class="modal-overlay hidden">
  <div class="modal-content p-6">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-lg font-semibold">Quick Apply</h3>
      <button onclick="closeApplyModal()" class="w-8 h-8 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 flex items-center justify-center text-gray-400"><i class="fas fa-times"></i></button>
    </div>
    <p class="text-sm text-gray-500 mb-4"><%= job.title %> at <%= job.company %></p>
    <div class="space-y-3">
      <div><label class="label-field">Cover Letter (optional)</label><textarea id="apply-cover" rows="5" class="input-field" placeholder="Write a brief cover letter explaining why you're a great fit..."></textarea></div>
      <button onclick="submitApplication()" id="apply-btn" class="btn-primary w-full">Submit Application</button>
    </div>
  </div>
</div>

<!-- Match Score Modal -->
<div id="match-modal" class="modal-overlay hidden">
  <div class="modal-content p-6">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-lg font-semibold">AI Job Match Analysis</h3>
      <button onclick="closeMatchModal()" class="w-8 h-8 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 flex items-center justify-center text-gray-400"><i class="fas fa-times"></i></button>
    </div>
    <div class="space-y-3">
      <div><label class="label-field">Your Resume Text</label><textarea id="match-resume" rows="5" class="input-field" placeholder="Paste your resume text here..."></textarea></div>
      <button onclick="analyzeMatch()" id="match-btn" class="btn-primary w-full"><i class="fas fa-robot mr-1.5"></i> Analyze Match</button>
      <div id="match-results"></div>
    </div>
  </div>
</div>

<style>
  .job-description { line-height: 1.75; }
  .job-description h1, .job-description h2, .job-description h3,
  .job-description h4, .job-description h5, .job-description h6 {
    font-weight: 600;
    margin-top: 1.25em;
    margin-bottom: 0.5em;
    color: var(--tw-prose-headings, #1a202c);
  }
  .dark .job-description h1, .dark .job-description h2, .dark .job-description h3,
  .dark .job-description h4, .dark .job-description h5, .dark .job-description h6 {
    color: #e2e8f0;
  }
  .job-description p { margin-bottom: 0.75em; }
  .job-description ul, .job-description ol { margin: 0.5em 0; padding-left: 0; }
  .job-description li { margin-bottom: 0.35em; }
</style>

<script>
const JOB_ID = <%= job.id %>;
let isSaved = <%= job.isSaved ? 'true' : 'false' %>;

// Format the job description text properly
(function() {
  var el = document.getElementById('job-desc-content');
  if (!el) return;
  var text = el.textContent || '';

  // Split into lines and process
  var lines = text.split('\n');
  var html = '';
  var inList = false;

  for (var i = 0; i < lines.length; i++) {
    var line = lines[i].trim();
    if (!line) {
      if (inList) { html += '</ul>'; inList = false; }
      continue;
    }

    // Detect bullet points (•, -, *, ●, ■, ◆, ►, ▪)
    var bulletMatch = line.match(/^[\u2022\u2023\u25E6\u2043\u2219\u25CF\u25CB\u25AA\u25AB\u25A0\u25A1\u25C6\u25BA\u25B8\u2013\u2014\-\*\>]\s*(.*)/);
    if (bulletMatch) {
      if (!inList) { html += '<ul class="space-y-1.5 my-3 ml-1">'; inList = true; }
      html += '<li class="flex gap-2 items-start"><span class="text-accent mt-1.5 text-[6px]"><i class="fas fa-circle"></i></span><span>' + bulletMatch[1] + '</span></li>';
    } else {
      if (inList) { html += '</ul>'; inList = false; }
      // Check if line looks like a heading (short, no period at end, possibly bold-like)
      if (line.length < 80 && !line.endsWith('.') && !line.endsWith(',') && (line.endsWith(':') || /^[A-Z][^.]*$/.test(line) && line.split(' ').length <= 8)) {
        html += '<h4 class="text-sm font-semibold text-gray-900 dark:text-white mt-4 mb-2">' + line + '</h4>';
      } else {
        html += '<p class="mb-2">' + line + '</p>';
      }
    }
  }
  if (inList) html += '</ul>';

  if (html.trim()) el.innerHTML = html;
})();

function openApplyModal() { document.getElementById('apply-modal').classList.remove('hidden'); }
function closeApplyModal() { document.getElementById('apply-modal').classList.add('hidden'); }
function openMatchModal() { document.getElementById('match-modal').classList.remove('hidden'); }
function closeMatchModal() { document.getElementById('match-modal').classList.add('hidden'); }

function copyJobLink() {
  navigator.clipboard.writeText(window.location.href).then(function() {
    showToast('Link copied to clipboard!', 'success');
  }).catch(function() {
    showToast('Failed to copy link', 'error');
  });
}

async function toggleSave() {
  try {
    const method = isSaved ? 'DELETE' : 'POST';
    await fetch('/job-board/api/' + JOB_ID + '/save', { method });
    isSaved = !isSaved;
    var btn = document.getElementById('save-btn');
    btn.innerHTML = '<i class="' + (isSaved ? 'fas' : 'far') + ' fa-bookmark mr-1.5"></i> ' + (isSaved ? 'Saved' : 'Save');
    showToast(isSaved ? 'Job saved!' : 'Job unsaved', 'success');
  } catch { showToast('Failed', 'error'); }
}

async function submitApplication() {
  var btn = document.getElementById('apply-btn');
  btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1.5"></i> Applying...';
  try {
    var res = await fetch('/job-board/api/' + JOB_ID + '/apply', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ coverLetter: document.getElementById('apply-cover').value }),
    });
    var data = await res.json();
    if (data.success) { showToast('Application submitted!', 'success'); closeApplyModal(); location.reload(); }
    else showToast(data.error || 'Failed', 'error');
  } catch { showToast('Failed to apply', 'error'); }
  btn.disabled = false; btn.innerHTML = 'Submit Application';
}

async function analyzeMatch() {
  var btn = document.getElementById('match-btn');
  btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1.5"></i> Analyzing...';
  try {
    var res = await fetch('/job-board/api/match', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ resumeText: document.getElementById('match-resume').value, jobDescription: '<%= (job.description || "").replace(/\\/g, "\\\\").replace(/'/g, "\\'").replace(/\n/g, " ").replace(/\r/g, "") %>' }),
    });
    var data = await res.json();
    if (data.success) {
      var r = data.result;
      var scoreColor = r.matchPercentage >= 70 ? 'text-green-600' : r.matchPercentage >= 40 ? 'text-yellow-600' : 'text-red-600';
      var scoreBg = r.matchPercentage >= 70 ? 'bg-green-50 dark:bg-green-900/20' : r.matchPercentage >= 40 ? 'bg-yellow-50 dark:bg-yellow-900/20' : 'bg-red-50 dark:bg-red-900/20';
      document.getElementById('match-results').innerHTML =
        '<div class="mt-4 space-y-4">' +
        '<div class="p-4 rounded-xl ' + scoreBg + ' text-center"><span class="text-4xl font-bold ' + scoreColor + '">' + r.matchPercentage + '%</span><p class="text-xs text-gray-500 mt-1">Match Score</p></div>' +
        '<div><p class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-2">Matching Skills</p><div class="flex flex-wrap gap-1.5">' + (r.matchingSkills||[]).map(function(s){return '<span class="badge-success">'+s+'</span>';}).join('') + '</div></div>' +
        '<div><p class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-2">Missing Skills</p><div class="flex flex-wrap gap-1.5">' + (r.missingSkills||[]).map(function(s){return '<span class="badge-danger">'+s+'</span>';}).join('') + '</div></div>' +
        '<div><p class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-2">Recommendations</p><ul class="space-y-1.5">' + (r.recommendations||[]).map(function(s){return '<li class="text-sm text-gray-600 dark:text-gray-400 flex gap-2"><i class="fas fa-lightbulb text-yellow-500 mt-0.5 text-xs"></i><span>'+s+'</span></li>';}).join('') + '</ul></div>' +
        '</div>';
    }
  } catch { showToast('Analysis failed', 'error'); }
  btn.disabled = false; btn.innerHTML = '<i class="fas fa-robot mr-1.5"></i> Analyze Match';
}
</script>

<% const typeColors = {full_time: 'blue', part_time: 'yellow', internship: 'green', contract: 'purple', freelance: 'orange'}; %>
<% const typeColor = typeColors[job.job_type] || 'gray'; %>
<% let skills = []; try { skills = typeof job.skills === 'string' ? JSON.parse(job.skills) : (job.skills || []); } catch(e) { skills = []; } %>
<% const logoColors = ['#4F46E5','#0891B2','#059669','#D97706','#DC2626','#7C3AED','#2563EB','#0D9488','#C026D3','#EA580C']; %>
<% const logoColor = logoColors[job.company.charCodeAt(0) % logoColors.length]; %>

<div class="max-w-5xl mx-auto space-y-5">
  <!-- Back -->
  <a href="/job-board" class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-accent transition-colors"><i class="fas fa-arrow-left text-xs"></i> Back to Job Board</a>

  <!-- Hero Header -->
  <div class="card !p-0 overflow-hidden">
    <!-- Colored Banner -->
    <div class="h-2 w-full" style="background: linear-gradient(90deg, <%= logoColor %>, <%= logoColor %>88);"></div>
    <div class="p-5 sm:p-6">
      <div class="flex flex-col sm:flex-row gap-4">
        <!-- Company Logo -->
        <% const heroLogoUrl = job.company_logo || ('https://logo.clearbit.com/' + job.company.toLowerCase().replace(/\s*(pvt|private|ltd|limited|inc|corp|llp|llc|co|technologies|tech|software|solutions|consulting|services|india|global|group)\s*/gi, '').trim().replace(/\s+/g, '') + '.com'); %>
        <div class="flex-shrink-0 w-14 h-14 rounded-2xl relative overflow-hidden" style="background: <%= logoColor %>;">
          <span class="absolute inset-0 flex items-center justify-center text-2xl font-bold text-white"><%= job.company.charAt(0).toUpperCase() %></span>
          <img src="<%= heroLogoUrl %>" alt="" class="absolute inset-0 w-full h-full object-contain bg-white p-1 rounded-2xl" onerror="this.remove();">
        </div>

        <!-- Title & Company -->
        <div class="flex-1 min-w-0">
          <h1 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white leading-tight"><%= job.title %></h1>
          <p class="text-base text-gray-500 mt-1 font-medium"><%= job.company %></p>

          <!-- Info Chips -->
          <div class="flex flex-wrap items-center gap-2 mt-3">
            <% if (job.location) { %>
              <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400"><i class="fas fa-map-marker-alt text-red-400 text-[10px]"></i> <%= job.location %></span>
            <% } %>
            <% if (job.salary_min || job.salary_max) { %>
              <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-300"><i class="fas fa-indian-rupee-sign text-[10px]"></i>
                <% if (job.salary_min && job.salary_max) { %><%= (job.salary_min/100000).toFixed(0) %>-<%= (job.salary_max/100000).toFixed(0) %> LPA<% } else if (job.salary_max) { %>Up to <%= (job.salary_max/100000).toFixed(0) %> LPA<% } else { %><%= (job.salary_min/100000).toFixed(0) %>+ LPA<% } %>
              </span>
            <% } %>
            <% if (job.experience_min !== null) { %>
              <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-blue-50 dark:bg-blue-900/20 text-blue-700 dark:text-blue-300"><i class="fas fa-clock text-[10px]"></i> <%= job.experience_min || 0 %>-<%= job.experience_max || 'Any' %> yrs</span>
            <% } %>
            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-<%= typeColor %>-50 dark:bg-<%= typeColor %>-900/20 text-<%= typeColor %>-700 dark:text-<%= typeColor %>-300 capitalize"><%= (job.job_type || 'full_time').replace('_', ' ') %></span>
            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-purple-50 dark:bg-purple-900/20 text-purple-700 dark:text-purple-300 capitalize"><i class="fas fa-laptop-house text-[10px]"></i> <%= (job.work_mode || 'onsite').replace('_', ' ') %></span>
            <% if (job.category) { %>
              <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-accent/10 text-accent"><%= job.category %></span>
            <% } %>
            <% if (job.is_verified) { %><span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-green-50 text-green-700 dark:bg-green-900/20 dark:text-green-300"><i class="fas fa-check-circle text-[10px]"></i> Verified</span><% } %>
          </div>
        </div>

        <!-- Action Buttons (right aligned on desktop) -->
        <div class="flex sm:flex-col gap-2 flex-shrink-0 sm:items-end">
          <button onclick="toggleSave()" id="save-btn" class="w-9 h-9 rounded-xl border border-gray-200 dark:border-gray-700 flex items-center justify-center text-gray-400 hover:text-accent hover:border-accent transition-colors" title="<%= job.isSaved ? 'Saved' : 'Save' %>">
            <i class="<%= job.isSaved ? 'fas text-accent' : 'far' %> fa-bookmark text-sm"></i>
          </button>
          <button onclick="openMatchModal()" class="w-9 h-9 rounded-xl border border-gray-200 dark:border-gray-700 flex items-center justify-center text-gray-400 hover:text-blue-500 hover:border-blue-500 transition-colors" title="Match Score">
            <i class="fas fa-chart-pie text-sm"></i>
          </button>
        </div>
      </div>
    </div>

    <!-- Action Bar - Clean -->
    <div class="px-5 sm:px-6 py-3.5 bg-gray-50 dark:bg-gray-800/50 border-t border-gray-100 dark:border-gray-800 flex flex-wrap items-center gap-3">
      <% if (job.hasApplied) { %>
        <button disabled class="inline-flex items-center gap-1.5 px-5 py-2 rounded-lg bg-green-600 text-white text-sm font-medium opacity-80 cursor-not-allowed"><i class="fas fa-check text-xs"></i> Applied</button>
      <% } else { %>
        <% if (job.apply_url) { %>
          <a href="<%= job.apply_url %>" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 px-5 py-2 rounded-lg text-white text-sm font-medium transition-all hover:shadow-md" style="background: <%= logoColor %>;"><i class="fas fa-external-link-alt text-xs"></i> Apply Now</a>
        <% } %>
        <button onclick="openApplyModal()" class="inline-flex items-center gap-1.5 px-5 py-2 rounded-lg border border-gray-200 dark:border-gray-700 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"><i class="fas fa-paper-plane text-xs text-gray-400"></i> Quick Apply</button>
      <% } %>
      <div class="flex items-center gap-2 ml-auto">
        <button onclick="copyJobLink()" class="inline-flex items-center gap-1.5 px-3 py-2 rounded-lg border border-gray-200 dark:border-gray-700 text-xs font-medium text-gray-500 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors" title="Copy link"><i class="fas fa-link text-[10px]"></i> Share</button>
        <a href="https://wa.me/?text=<%= encodeURIComponent(job.title + ' at ' + job.company + ' - ' + 'https://careerservice.atlasskilltech.app/job-board/view/' + job.id) %>" target="_blank" class="inline-flex items-center gap-1.5 px-3 py-2 rounded-lg border border-gray-200 dark:border-gray-700 text-xs font-medium text-green-600 hover:bg-green-50 dark:hover:bg-green-900/20 transition-colors" title="WhatsApp"><i class="fab fa-whatsapp text-sm"></i></a>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
    <!-- Main Content -->
    <div class="lg:col-span-2 space-y-5">

      <!-- Description Card -->
      <% if (job.description) { %>
        <div class="card !p-6">
          <h3 class="font-semibold text-base mb-4 flex items-center gap-2"><i class="fas fa-file-alt text-accent text-sm"></i> Job Description</h3>
          <div class="job-description text-sm text-gray-700 dark:text-gray-300" id="job-desc-content"><%- job.description.replace(/</g, '&lt;').replace(/>/g, '&gt;') %></div>
        </div>
      <% } %>

      <!-- Skills Card -->
      <% if (skills.length > 0 && !(skills.length === 1 && skills[0] === 'General')) { %>
        <div class="card !p-6">
          <h3 class="font-semibold text-base mb-4 flex items-center gap-2"><i class="fas fa-tools text-accent text-sm"></i> Required Skills</h3>
          <div class="flex flex-wrap gap-2">
            <% skills.forEach(skill => { %>
              <span class="px-3 py-1.5 bg-accent/8 text-accent border border-accent/15 rounded-lg text-sm font-medium"><%= skill %></span>
            <% }); %>
          </div>
        </div>
      <% } %>
    </div>

    <!-- Sidebar -->
    <div class="space-y-5">
      <!-- Job Overview Card -->
      <div class="card !p-5">
        <h3 class="font-semibold text-sm mb-4 flex items-center gap-2"><i class="fas fa-info-circle text-accent text-xs"></i> Job Overview</h3>
        <div class="grid grid-cols-2 gap-3">
          <% if (job.posted_date) { %>
            <div class="p-3 rounded-xl bg-gray-50 dark:bg-gray-800/50 text-center">
              <i class="far fa-calendar text-gray-400 text-sm mb-1.5 block"></i>
              <p class="text-[11px] text-gray-400 mb-0.5">Posted</p>
              <p class="text-xs font-semibold"><%= new Date(job.posted_date).toLocaleDateString('en-IN', {day: 'numeric', month: 'short', year: 'numeric'}) %></p>
            </div>
          <% } %>
          <% if (job.expires_at) { %>
            <div class="p-3 rounded-xl bg-orange-50 dark:bg-orange-900/10 text-center">
              <i class="fas fa-hourglass-half text-orange-400 text-sm mb-1.5 block"></i>
              <p class="text-[11px] text-gray-400 mb-0.5">Expires</p>
              <p class="text-xs font-semibold"><%= new Date(job.expires_at).toLocaleDateString('en-IN', {day: 'numeric', month: 'short', year: 'numeric'}) %></p>
            </div>
          <% } %>
          <div class="p-3 rounded-xl bg-gray-50 dark:bg-gray-800/50 text-center">
            <i class="fas fa-briefcase text-blue-400 text-sm mb-1.5 block"></i>
            <p class="text-[11px] text-gray-400 mb-0.5">Job Type</p>
            <p class="text-xs font-semibold capitalize"><%= (job.job_type || 'full_time').replace('_', ' ') %></p>
          </div>
          <div class="p-3 rounded-xl bg-gray-50 dark:bg-gray-800/50 text-center">
            <i class="fas fa-laptop-house text-purple-400 text-sm mb-1.5 block"></i>
            <p class="text-[11px] text-gray-400 mb-0.5">Work Mode</p>
            <p class="text-xs font-semibold capitalize"><%= (job.work_mode || 'onsite').replace('_', ' ') %></p>
          </div>
          <% if (job.experience_min !== null) { %>
            <div class="p-3 rounded-xl bg-gray-50 dark:bg-gray-800/50 text-center">
              <i class="fas fa-clock text-blue-400 text-sm mb-1.5 block"></i>
              <p class="text-[11px] text-gray-400 mb-0.5">Experience</p>
              <p class="text-xs font-semibold"><%= job.experience_min || 0 %>-<%= job.experience_max || 'Any' %> yrs</p>
            </div>
          <% } %>
          <% if (job.category) { %>
            <div class="p-3 rounded-xl bg-gray-50 dark:bg-gray-800/50 text-center">
              <i class="fas fa-tag text-accent text-sm mb-1.5 block"></i>
              <p class="text-[11px] text-gray-400 mb-0.5">Category</p>
              <p class="text-xs font-semibold"><%= job.category %></p>
            </div>
          <% } %>
          <% if (job.salary_min || job.salary_max) { %>
            <div class="col-span-2 p-3 rounded-xl bg-green-50 dark:bg-green-900/10 text-center">
              <i class="fas fa-indian-rupee-sign text-green-500 text-sm mb-1.5 block"></i>
              <p class="text-[11px] text-gray-400 mb-0.5">Salary Range</p>
              <p class="text-sm font-semibold text-green-700 dark:text-green-300">
                <% if (job.salary_min && job.salary_max) { %><%= (job.salary_min/100000).toFixed(0) %>-<%= (job.salary_max/100000).toFixed(0) %> LPA<% } else if (job.salary_max) { %>Up to <%= (job.salary_max/100000).toFixed(0) %> LPA<% } else { %><%= (job.salary_min/100000).toFixed(0) %>+ LPA<% } %>
              </p>
            </div>
          <% } %>
        </div>

        <!-- Sidebar Apply CTA -->
        <div class="mt-4">
          <% if (job.hasApplied) { %>
            <button disabled class="w-full py-2.5 rounded-xl bg-green-600 text-white text-sm font-medium opacity-80 cursor-not-allowed"><i class="fas fa-check mr-1.5"></i> Already Applied</button>
          <% } else if (job.apply_url) { %>
            <a href="<%= job.apply_url %>" target="_blank" rel="noopener noreferrer" class="w-full py-2.5 rounded-xl text-white text-sm font-medium text-center block transition-all hover:shadow-md" style="background: <%= logoColor %>;"><i class="fas fa-external-link-alt mr-1.5"></i> Apply Now</a>
          <% } else { %>
            <button onclick="openApplyModal()" class="btn-primary w-full text-sm"><i class="fas fa-paper-plane mr-1.5"></i> Quick Apply</button>
          <% } %>
        </div>
      </div>

      <!-- Company Info Card -->
      <div class="card !p-5">
        <h3 class="font-semibold text-sm mb-3 flex items-center gap-2"><i class="fas fa-building text-accent text-xs"></i> About Company</h3>
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-xl flex-shrink-0 relative overflow-hidden" style="background: <%= logoColor %>;">
            <span class="absolute inset-0 flex items-center justify-center text-sm font-bold text-white"><%= job.company.charAt(0).toUpperCase() %></span>
            <img src="<%= heroLogoUrl %>" alt="" class="absolute inset-0 w-full h-full object-contain bg-white p-0.5 rounded-xl" onerror="this.remove();">
          </div>
          <div>
            <p class="text-sm font-semibold"><%= job.company %></p>
            <% if (job.location) { %><p class="text-xs text-gray-400"><%= job.location %></p><% } %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Related Jobs Section -->
  <% if (relatedJobs && relatedJobs.length > 0) { %>
    <div class="space-y-4 pt-2">
      <div class="flex items-center justify-between">
        <h2 class="text-lg font-bold flex items-center gap-2"><i class="fas fa-th-large text-accent text-sm"></i> Related Jobs</h2>
        <% if (job.category) { %>
          <a href="/job-board?category=<%= encodeURIComponent(job.category) %>" class="text-sm text-accent hover:underline font-medium">View all <i class="fas fa-arrow-right text-xs ml-0.5"></i></a>
        <% } %>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
        <% relatedJobs.forEach(rJob => { %>
          <% let rSkills = []; try { rSkills = typeof rJob.skills === 'string' ? JSON.parse(rJob.skills) : (rJob.skills || []); } catch(e) { rSkills = []; } %>
          <% const rTypeColor = typeColors[rJob.job_type] || 'gray'; %>
          <% const rLogoColor = logoColors[rJob.company.charCodeAt(0) % logoColors.length]; %>
          <a href="/job-board/view/<%= rJob.id %>" class="card !p-0 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 group block">
            <div class="h-1 w-full rounded-t-xl" style="background: <%= rLogoColor %>;"></div>
            <div class="p-4">
              <div class="flex items-start gap-3 mb-3">
                <% const rLogoUrl = rJob.company_logo || ('https://logo.clearbit.com/' + rJob.company.toLowerCase().replace(/\s*(pvt|private|ltd|limited|inc|corp|llp|llc|co|technologies|tech|software|solutions|consulting|services|india|global|group)\s*/gi, '').trim().replace(/\s+/g, '') + '.com'); %>
                <div class="w-10 h-10 rounded-xl flex-shrink-0 relative overflow-hidden" style="background: <%= rLogoColor %>;">
                  <span class="absolute inset-0 flex items-center justify-center text-sm font-bold text-white"><%= rJob.company.charAt(0).toUpperCase() %></span>
                  <img src="<%= rLogoUrl %>" alt="" class="absolute inset-0 w-full h-full object-contain bg-white p-0.5 rounded-xl" onerror="this.remove();">
                </div>
                <div class="min-w-0 flex-1">
                  <h4 class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-accent transition-colors line-clamp-1"><%= rJob.title %></h4>
                  <p class="text-xs text-gray-500 mt-0.5"><%= rJob.company %></p>
                </div>
              </div>

              <div class="flex flex-wrap gap-1.5 mb-2.5">
                <span class="px-2 py-0.5 rounded-full text-[11px] font-medium bg-<%= rTypeColor %>-50 text-<%= rTypeColor %>-700 dark:bg-<%= rTypeColor %>-900/20 dark:text-<%= rTypeColor %>-300 capitalize"><%= (rJob.job_type || 'full_time').replace('_', ' ') %></span>
                <span class="px-2 py-0.5 rounded-full text-[11px] font-medium bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400 capitalize"><%= (rJob.work_mode || 'onsite').replace('_', ' ') %></span>
              </div>

              <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-gray-500">
                <% if (rJob.location) { %>
                  <span class="inline-flex items-center gap-1"><i class="fas fa-map-marker-alt text-red-400 text-[10px]"></i> <%= rJob.location %></span>
                <% } %>
                <% if (rJob.experience_min !== null || rJob.experience_max !== null) { %>
                  <span class="inline-flex items-center gap-1"><i class="fas fa-clock text-blue-400 text-[10px]"></i> <%= rJob.experience_min || 0 %>-<%= rJob.experience_max || 'Any' %> yrs</span>
                <% } %>
              </div>

              <% if (rSkills.length > 0 && !(rSkills.length === 1 && rSkills[0] === 'General')) { %>
                <div class="flex flex-wrap gap-1 mt-2.5">
                  <% rSkills.slice(0, 3).forEach(skill => { %>
                    <span class="px-1.5 py-0.5 bg-accent/8 text-accent border border-accent/15 rounded text-[11px] font-medium"><%= skill %></span>
                  <% }); %>
                  <% if (rSkills.length > 3) { %><span class="px-1.5 py-0.5 text-gray-400 text-[11px]">+<%= rSkills.length - 3 %></span><% } %>
                </div>
              <% } %>
            </div>

            <div class="px-4 py-2.5 bg-gray-50 dark:bg-gray-800/50 border-t border-gray-100 dark:border-gray-800 rounded-b-xl flex items-center justify-between">
              <% if (rJob.posted_date) { %>
                <span class="text-[11px] text-gray-400"><i class="far fa-calendar mr-1"></i><%= new Date(rJob.posted_date).toLocaleDateString('en-IN', {day: 'numeric', month: 'short'}) %></span>
              <% } else { %><span></span><% } %>
              <span class="text-xs font-medium text-accent">View Details <i class="fas fa-arrow-right text-[10px] ml-0.5"></i></span>
            </div>
          </a>
        <% }); %>
      </div>
    </div>
  <% } %>
</div>

<!-- Quick Apply Modal -->
<div id="apply-modal" class="modal-overlay hidden">
  <div class="modal-content p-6">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-lg font-semibold">Quick Apply</h3>
      <button onclick="closeApplyModal()" class="w-8 h-8 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 flex items-center justify-center text-gray-400"><i class="fas fa-times"></i></button>
    </div>
    <p class="text-sm text-gray-500 mb-4"><%= job.title %> at <%= job.company %></p>
    <div class="space-y-3">
      <div><label class="label-field">Cover Letter (optional)</label><textarea id="apply-cover" rows="5" class="input-field" placeholder="Write a brief cover letter explaining why you're a great fit..."></textarea></div>
      <button onclick="submitApplication()" id="apply-btn" class="btn-primary w-full">Submit Application</button>
    </div>
  </div>
</div>

<!-- Match Score Modal -->
<div id="match-modal" class="modal-overlay hidden">
  <div class="modal-content p-6">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-lg font-semibold">AI Job Match Analysis</h3>
      <button onclick="closeMatchModal()" class="w-8 h-8 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 flex items-center justify-center text-gray-400"><i class="fas fa-times"></i></button>
    </div>
    <div class="space-y-3">
      <div><label class="label-field">Your Resume Text</label><textarea id="match-resume" rows="5" class="input-field" placeholder="Paste your resume text here..."></textarea></div>
      <button onclick="analyzeMatch()" id="match-btn" class="btn-primary w-full"><i class="fas fa-robot mr-1.5"></i> Analyze Match</button>
      <div id="match-results"></div>
    </div>
  </div>
</div>

<style>
  .job-description { line-height: 1.8; }
  .job-description h4 { font-weight: 600; margin-top: 1.5em; margin-bottom: 0.5em; font-size: 0.9375rem; }
  .job-description p { margin-bottom: 0.5em; }
  .job-description ul { margin: 0.5em 0; padding-left: 0; }
  .job-description li { margin-bottom: 0.25em; }
</style>

<script>
const JOB_ID = <%= job.id %>;
let isSaved = <%= job.isSaved ? 'true' : 'false' %>;

// Format the job description text properly
(function() {
  var el = document.getElementById('job-desc-content');
  if (!el) return;
  var text = el.textContent || '';
  var lines = text.split('\n');
  var html = '';
  var inList = false;

  for (var i = 0; i < lines.length; i++) {
    var line = lines[i].trim();
    if (!line) {
      if (inList) { html += '</ul>'; inList = false; }
      continue;
    }

    var bulletMatch = line.match(/^[\u2022\u2023\u25E6\u2043\u2219\u25CF\u25CB\u25AA\u25AB\u25A0\u25A1\u25C6\u25BA\u25B8\u2013\u2014\-\*\>]\s*(.*)/);
    if (bulletMatch) {
      if (!inList) { html += '<ul class="space-y-2 my-3">'; inList = true; }
      html += '<li class="flex gap-2.5 items-start"><span class="text-accent mt-1.5 text-[5px] flex-shrink-0"><i class="fas fa-circle"></i></span><span>' + bulletMatch[1] + '</span></li>';
    } else {
      if (inList) { html += '</ul>'; inList = false; }
      if (line.length < 80 && !line.endsWith('.') && !line.endsWith(',') && (line.endsWith(':') || (/^[A-Z]/.test(line) && line.split(' ').length <= 8 && !/[.;,]$/.test(line)))) {
        html += '<h4 class="text-sm font-semibold text-gray-900 dark:text-white mt-5 mb-2">' + line + '</h4>';
      } else {
        html += '<p class="mb-2 leading-relaxed">' + line + '</p>';
      }
    }
  }
  if (inList) html += '</ul>';
  if (html.trim()) el.innerHTML = html;
})();

function openApplyModal() { document.getElementById('apply-modal').classList.remove('hidden'); }
function closeApplyModal() { document.getElementById('apply-modal').classList.add('hidden'); }
function openMatchModal() { document.getElementById('match-modal').classList.remove('hidden'); }
function closeMatchModal() { document.getElementById('match-modal').classList.add('hidden'); }

function copyJobLink() {
  navigator.clipboard.writeText(window.location.href).then(function() {
    showToast('Link copied to clipboard!', 'success');
  }).catch(function() {
    showToast('Failed to copy link', 'error');
  });
}

async function toggleSave() {
  try {
    const method = isSaved ? 'DELETE' : 'POST';
    await fetch('/job-board/api/' + JOB_ID + '/save', { method });
    isSaved = !isSaved;
    var btn = document.getElementById('save-btn');
    btn.querySelector('i').className = (isSaved ? 'fas text-accent' : 'far') + ' fa-bookmark text-sm';
    showToast(isSaved ? 'Job saved!' : 'Job unsaved', 'success');
  } catch { showToast('Failed', 'error'); }
}

async function submitApplication() {
  var btn = document.getElementById('apply-btn');
  btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1.5"></i> Applying...';
  try {
    var res = await fetch('/job-board/api/' + JOB_ID + '/apply', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ coverLetter: document.getElementById('apply-cover').value }),
    });
    var data = await res.json();
    if (data.success) { showToast('Application submitted!', 'success'); closeApplyModal(); location.reload(); }
    else showToast(data.error || 'Failed', 'error');
  } catch { showToast('Failed to apply', 'error'); }
  btn.disabled = false; btn.innerHTML = 'Submit Application';
}

async function analyzeMatch() {
  var btn = document.getElementById('match-btn');
  btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1.5"></i> Analyzing...';
  try {
    var res = await fetch('/job-board/api/match', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ resumeText: document.getElementById('match-resume').value, jobDescription: '<%= (job.description || "").replace(/\\/g, "\\\\").replace(/'/g, "\\'").replace(/\n/g, " ").replace(/\r/g, "") %>' }),
    });
    var data = await res.json();
    if (data.success) {
      var r = data.result;
      var scoreColor = r.matchPercentage >= 70 ? 'text-green-600' : r.matchPercentage >= 40 ? 'text-yellow-600' : 'text-red-600';
      var scoreBg = r.matchPercentage >= 70 ? 'bg-green-50 dark:bg-green-900/20' : r.matchPercentage >= 40 ? 'bg-yellow-50 dark:bg-yellow-900/20' : 'bg-red-50 dark:bg-red-900/20';
      document.getElementById('match-results').innerHTML =
        '<div class="mt-4 space-y-4">' +
        '<div class="p-4 rounded-xl ' + scoreBg + ' text-center"><span class="text-4xl font-bold ' + scoreColor + '">' + r.matchPercentage + '%</span><p class="text-xs text-gray-500 mt-1">Match Score</p></div>' +
        '<div><p class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-2">Matching Skills</p><div class="flex flex-wrap gap-1.5">' + (r.matchingSkills||[]).map(function(s){return '<span class="badge-success">'+s+'</span>';}).join('') + '</div></div>' +
        '<div><p class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-2">Missing Skills</p><div class="flex flex-wrap gap-1.5">' + (r.missingSkills||[]).map(function(s){return '<span class="badge-danger">'+s+'</span>';}).join('') + '</div></div>' +
        '<div><p class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-2">Recommendations</p><ul class="space-y-1.5">' + (r.recommendations||[]).map(function(s){return '<li class="text-sm text-gray-600 dark:text-gray-400 flex gap-2"><i class="fas fa-lightbulb text-yellow-500 mt-0.5 text-xs"></i><span>'+s+'</span></li>';}).join('') + '</ul></div>' +
        '</div>';
    }
  } catch { showToast('Analysis failed', 'error'); }
  btn.disabled = false; btn.innerHTML = '<i class="fas fa-robot mr-1.5"></i> Analyze Match';
}
</script>

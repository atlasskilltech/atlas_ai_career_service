<div class="space-y-6">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold">My Applications</h1>
      <p class="text-sm text-gray-500 mt-1"><%= applications.length %> application<%= applications.length !== 1 ? 's' : '' %></p>
    </div>
    <a href="/job-board" class="btn-outline text-sm"><i class="fas fa-arrow-left mr-1.5"></i> Back to Job Board</a>
  </div>

  <!-- Status Overview -->
  <div class="grid grid-cols-3 sm:grid-cols-6 gap-2">
    <%
      const statusConfig = [
        { key: 'applied', icon: 'fas fa-paper-plane', color: 'blue' },
        { key: 'reviewed', icon: 'fas fa-eye', color: 'yellow' },
        { key: 'shortlisted', icon: 'fas fa-star', color: 'purple' },
        { key: 'interview', icon: 'fas fa-video', color: 'indigo' },
        { key: 'offered', icon: 'fas fa-trophy', color: 'green' },
        { key: 'rejected', icon: 'fas fa-times-circle', color: 'red' },
      ];
    %>
    <% statusConfig.forEach(s => { %>
      <% const count = applications.filter(a => a.status === s.key).length; %>
      <div class="card !p-3 text-center">
        <div class="w-8 h-8 rounded-lg bg-<%= s.color %>-50 dark:bg-<%= s.color %>-900/20 flex items-center justify-center mx-auto mb-1.5">
          <i class="<%= s.icon %> text-<%= s.color %>-500 text-xs"></i>
        </div>
        <div class="text-lg font-bold"><%= count %></div>
        <p class="text-xs text-gray-500 capitalize"><%= s.key %></p>
      </div>
    <% }); %>
  </div>

  <% if (applications.length === 0) { %>
    <div class="card !p-12 text-center">
      <div class="w-16 h-16 rounded-full bg-gray-100 dark:bg-gray-800 flex items-center justify-center mx-auto mb-4">
        <i class="fas fa-paper-plane text-2xl text-gray-300"></i>
      </div>
      <h3 class="text-lg font-semibold text-gray-600 dark:text-gray-400">No applications yet</h3>
      <p class="text-sm text-gray-400 mt-1">Start applying to jobs from the <a href="/job-board" class="text-accent hover:underline">Job Board</a></p>
    </div>
  <% } %>

  <!-- Applications List -->
  <div class="space-y-3">
    <% applications.forEach(app => { %>
      <% const statusColors = {applied: 'blue', reviewed: 'yellow', shortlisted: 'purple', interview: 'indigo', offered: 'green', rejected: 'red'}; %>
      <% const sColor = statusColors[app.status] || 'gray'; %>
      <div class="card !p-0 hover:shadow-md transition-all duration-200">
        <div class="p-4 sm:p-5">
          <div class="flex gap-4">
            <!-- Status Indicator -->
            <div class="flex-shrink-0 hidden sm:flex">
              <div class="w-12 h-12 bg-<%= sColor %>-50 dark:bg-<%= sColor %>-900/20 rounded-xl flex items-center justify-center border border-<%= sColor %>-200 dark:border-<%= sColor %>-800">
                <% if (app.status === 'applied') { %><i class="fas fa-paper-plane text-<%= sColor %>-500"></i>
                <% } else if (app.status === 'reviewed') { %><i class="fas fa-eye text-<%= sColor %>-500"></i>
                <% } else if (app.status === 'shortlisted') { %><i class="fas fa-star text-<%= sColor %>-500"></i>
                <% } else if (app.status === 'interview') { %><i class="fas fa-video text-<%= sColor %>-500"></i>
                <% } else if (app.status === 'offered') { %><i class="fas fa-trophy text-<%= sColor %>-500"></i>
                <% } else if (app.status === 'rejected') { %><i class="fas fa-times-circle text-<%= sColor %>-500"></i>
                <% } else { %><i class="fas fa-circle text-<%= sColor %>-500"></i><% } %>
              </div>
            </div>

            <!-- Info -->
            <div class="flex-1 min-w-0">
              <div class="flex items-start justify-between gap-3">
                <div class="min-w-0">
                  <a href="/job-board/view/<%= app.job_id %>" class="text-base font-semibold text-gray-900 dark:text-white hover:text-accent transition-colors line-clamp-1"><%= app.title %></a>
                  <p class="text-sm text-gray-500 mt-0.5"><%= app.company %><% if (app.location) { %> &middot; <%= app.location %><% } %></p>
                </div>
                <div class="flex items-center gap-2 flex-shrink-0">
                  <span class="px-2.5 py-1 rounded-md text-xs font-medium bg-<%= sColor %>-50 text-<%= sColor %>-700 dark:bg-<%= sColor %>-900/20 dark:text-<%= sColor %>-300 border border-<%= sColor %>-200 dark:border-<%= sColor %>-800 capitalize"><%= app.status %></span>
                </div>
              </div>

              <div class="flex flex-wrap items-center gap-x-4 gap-y-1 mt-2.5 text-xs text-gray-500">
                <span class="inline-flex items-center gap-1"><i class="far fa-calendar text-gray-400"></i> Applied <%= new Date(app.applied_at).toLocaleDateString('en-IN', {day: 'numeric', month: 'short', year: 'numeric'}) %></span>
                <% if (app.source) { %>
                  <span class="inline-flex items-center gap-1 capitalize"><i class="fas fa-globe text-gray-400"></i> <%= app.source %></span>
                <% } %>
              </div>
            </div>
          </div>
        </div>

        <!-- Footer -->
        <div class="px-4 sm:px-5 py-2.5 bg-gray-50 dark:bg-gray-800/50 border-t border-gray-100 dark:border-gray-800 rounded-b-xl flex items-center justify-between">
          <a href="/job-board/view/<%= app.job_id %>" class="text-xs text-accent hover:underline font-medium"><i class="fas fa-eye mr-1"></i> View Job</a>
          <% if (app.apply_url) { %>
            <a href="<%= app.apply_url %>" target="_blank" rel="noopener noreferrer" class="text-xs text-gray-500 hover:text-accent font-medium"><i class="fas fa-external-link-alt mr-1"></i> Original Listing</a>
          <% } %>
        </div>
      </div>
    <% }); %>
  </div>
</div>

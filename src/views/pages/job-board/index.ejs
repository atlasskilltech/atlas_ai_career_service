<div class="space-y-6">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold">Job Board</h1>
      <p class="text-sm text-gray-500 mt-1"><%= total %> jobs from LinkedIn, Naukri & more</p>
    </div>
    <div class="flex gap-2 flex-shrink-0">
      <a href="/job-board/saved" class="btn-outline text-sm"><i class="fas fa-bookmark mr-1.5"></i> Saved</a>
      <a href="/job-board/applications" class="btn-primary text-sm"><i class="fas fa-paper-plane mr-1.5"></i> My Applications</a>
    </div>
  </div>

  <!-- Stats Row -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
    <div class="card !p-4 flex items-center gap-3">
      <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center flex-shrink-0">
        <i class="fas fa-briefcase text-accent"></i>
      </div>
      <div>
        <div class="text-xl font-bold"><%= stats.totalJobs || 0 %></div>
        <p class="text-xs text-gray-500">Total Jobs</p>
      </div>
    </div>
    <div class="card !p-4 flex items-center gap-3">
      <div class="w-10 h-10 rounded-lg bg-green-50 dark:bg-green-900/20 flex items-center justify-center flex-shrink-0">
        <i class="fas fa-bolt text-green-600"></i>
      </div>
      <div>
        <div class="text-xl font-bold text-green-600"><%= stats.newToday || 0 %></div>
        <p class="text-xs text-gray-500">New Today</p>
      </div>
    </div>
    <div class="card !p-4 flex items-center gap-3">
      <div class="w-10 h-10 rounded-lg bg-blue-50 dark:bg-blue-900/20 flex items-center justify-center flex-shrink-0">
        <i class="fas fa-paper-plane text-blue-600"></i>
      </div>
      <div>
        <div class="text-xl font-bold text-blue-600"><%= stats.totalApplications || 0 %></div>
        <p class="text-xs text-gray-500">Applications</p>
      </div>
    </div>
    <div class="card !p-4 flex items-center gap-3">
      <div class="w-10 h-10 rounded-lg bg-purple-50 dark:bg-purple-900/20 flex items-center justify-center flex-shrink-0">
        <i class="fas fa-layer-group text-purple-600"></i>
      </div>
      <div>
        <div class="text-xl font-bold text-purple-600"><%= Object.keys(stats.bySource || {}).length %></div>
        <p class="text-xs text-gray-500">Sources</p>
      </div>
    </div>
  </div>

  <!-- Search & Filters -->
  <div class="card !p-5">
    <form method="GET" action="/job-board" id="search-form">
      <!-- Search Bar -->
      <div class="relative">
        <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-gray-400"></i>
        <input type="text" name="q" value="<%= filters.query %>" class="input-field !pl-11 !py-3 !text-base" placeholder="Search by job title, company, or keyword...">
      </div>

      <!-- Filter Row -->
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3 mt-3">
        <select name="location" class="input-field !py-2 text-sm">
          <option value="">All Locations</option>
          <% locations.forEach(loc => { %>
            <option value="<%= loc %>" <%= filters.location === loc ? 'selected' : '' %>><%= loc %></option>
          <% }); %>
        </select>
        <select name="category" class="input-field !py-2 text-sm">
          <option value="">All Categories</option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat %>" <%= filters.category === cat ? 'selected' : '' %>><%= cat %></option>
          <% }); %>
        </select>
        <select name="jobType" class="input-field !py-2 text-sm">
          <option value="">All Types</option>
          <option value="full_time" <%= filters.jobType === 'full_time' ? 'selected' : '' %>>Full Time</option>
          <option value="part_time" <%= filters.jobType === 'part_time' ? 'selected' : '' %>>Part Time</option>
          <option value="internship" <%= filters.jobType === 'internship' ? 'selected' : '' %>>Internship</option>
          <option value="contract" <%= filters.jobType === 'contract' ? 'selected' : '' %>>Contract</option>
          <option value="freelance" <%= filters.jobType === 'freelance' ? 'selected' : '' %>>Freelance</option>
        </select>
        <select name="workMode" class="input-field !py-2 text-sm">
          <option value="">All Modes</option>
          <option value="onsite" <%= filters.workMode === 'onsite' ? 'selected' : '' %>>Onsite</option>
          <option value="remote" <%= filters.workMode === 'remote' ? 'selected' : '' %>>Remote</option>
          <option value="hybrid" <%= filters.workMode === 'hybrid' ? 'selected' : '' %>>Hybrid</option>
        </select>
        <select name="source" class="input-field !py-2 text-sm">
          <option value="">All Sources</option>
          <option value="linkedin" <%= filters.source === 'linkedin' ? 'selected' : '' %>>LinkedIn</option>
          <option value="naukri" <%= filters.source === 'naukri' ? 'selected' : '' %>>Naukri</option>
          <option value="company" <%= filters.source === 'company' ? 'selected' : '' %>>Company</option>
          <option value="api" <%= filters.source === 'api' ? 'selected' : '' %>>External API</option>
          <option value="manual" <%= filters.source === 'manual' ? 'selected' : '' %>>Manual</option>
        </select>
        <button type="submit" class="btn-primary text-sm !py-2"><i class="fas fa-search mr-1.5"></i> Search</button>
      </div>
    </form>
  </div>

  <!-- Source Tags -->
  <% if (stats.bySource && Object.keys(stats.bySource).length > 0) { %>
    <div class="flex flex-wrap gap-2">
      <% Object.entries(stats.bySource).forEach(([src, count]) => { %>
        <% const srcColors = {linkedin: 'blue', naukri: 'purple', company: 'green', api: 'yellow', manual: 'gray'}; %>
        <a href="/job-board?source=<%= src %>" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium border transition-colors
          <%= filters.source === src ? 'bg-' + (srcColors[src] || 'gray') + '-600 text-white border-' + (srcColors[src] || 'gray') + '-600' : 'bg-' + (srcColors[src] || 'gray') + '-50 text-' + (srcColors[src] || 'gray') + '-700 border-' + (srcColors[src] || 'gray') + '-200 hover:bg-' + (srcColors[src] || 'gray') + '-100 dark:bg-' + (srcColors[src] || 'gray') + '-900/20 dark:text-' + (srcColors[src] || 'gray') + '-300 dark:border-' + (srcColors[src] || 'gray') + '-800' %>">
          <% if (src === 'linkedin') { %><i class="fab fa-linkedin"></i><% } else if (src === 'naukri') { %><i class="fas fa-briefcase"></i><% } else { %><i class="fas fa-globe"></i><% } %>
          <%= src.charAt(0).toUpperCase() + src.slice(1) %> <span class="opacity-75">(<%= count %>)</span>
        </a>
      <% }); %>
    </div>
  <% } %>

  <!-- Job Listings -->
  <div class="space-y-3">
    <% if (jobs.length === 0) { %>
      <div class="card !p-12 text-center">
        <div class="w-16 h-16 rounded-full bg-gray-100 dark:bg-gray-800 flex items-center justify-center mx-auto mb-4">
          <i class="fas fa-search text-2xl text-gray-300"></i>
        </div>
        <h3 class="text-lg font-semibold text-gray-600 dark:text-gray-400">No jobs found</h3>
        <p class="text-sm text-gray-400 mt-1">Try adjusting your search filters or check back later</p>
        <a href="/job-board" class="btn-outline text-sm mt-4 inline-flex"><i class="fas fa-redo mr-1.5"></i> Clear Filters</a>
      </div>
    <% } %>

    <% jobs.forEach(job => { %>
      <% let skills = []; try { skills = typeof job.skills === 'string' ? JSON.parse(job.skills) : (job.skills || []); } catch(e) { skills = []; } %>
      <% const typeColors = {full_time: 'blue', part_time: 'yellow', internship: 'green', contract: 'purple', freelance: 'orange'}; %>
      <% const typeColor = typeColors[job.job_type] || 'gray'; %>
      <div class="card !p-0 hover:shadow-md transition-all duration-200 group">
        <div class="p-4 sm:p-5">
          <div class="flex gap-4">
            <!-- Company Logo -->
            <div class="flex-shrink-0 hidden sm:flex">
              <div class="w-12 h-12 bg-gray-50 dark:bg-gray-800 rounded-xl flex items-center justify-center border border-gray-100 dark:border-gray-700">
                <% if (job.company_logo) { %>
                  <img src="<%= job.company_logo %>" alt="<%= job.company %>" class="w-10 h-10 rounded-lg object-cover">
                <% } else { %>
                  <span class="text-lg font-bold text-gray-400"><%= job.company.charAt(0).toUpperCase() %></span>
                <% } %>
              </div>
            </div>

            <!-- Job Info -->
            <div class="flex-1 min-w-0">
              <!-- Title Row -->
              <div class="flex items-start justify-between gap-3">
                <div class="min-w-0">
                  <a href="/job-board/view/<%= job.id %>" class="text-base font-semibold text-gray-900 dark:text-white hover:text-accent transition-colors line-clamp-1"><%= job.title %></a>
                  <p class="text-sm text-gray-500 mt-0.5"><%= job.company %></p>
                </div>
                <div class="flex items-center gap-2 flex-shrink-0">
                  <button onclick="toggleSaveJob(<%= job.id %>, this)" class="w-8 h-8 rounded-lg border border-gray-200 dark:border-gray-700 flex items-center justify-center text-gray-400 hover:text-accent hover:border-accent transition-colors" title="Save job">
                    <i class="far fa-bookmark text-sm"></i>
                  </button>
                  <a href="/job-board/view/<%= job.id %>" class="btn-primary text-xs !px-3 !py-1.5"><i class="fas fa-eye mr-1"></i> View</a>
                </div>
              </div>

              <!-- Meta Row -->
              <div class="flex flex-wrap items-center gap-x-4 gap-y-1 mt-2.5 text-xs text-gray-500">
                <% if (job.location) { %>
                  <span class="inline-flex items-center gap-1"><i class="fas fa-map-marker-alt text-red-400"></i> <%= job.location %></span>
                <% } %>
                <% if (job.salary_min || job.salary_max) { %>
                  <span class="inline-flex items-center gap-1"><i class="fas fa-indian-rupee-sign text-green-500"></i>
                    <% if (job.salary_min && job.salary_max) { %><%= (job.salary_min/100000).toFixed(0) %>-<%= (job.salary_max/100000).toFixed(0) %> LPA<% } else if (job.salary_max) { %>Up to <%= (job.salary_max/100000).toFixed(0) %> LPA<% } else { %><%= (job.salary_min/100000).toFixed(0) %>+ LPA<% } %>
                  </span>
                <% } %>
                <% if (job.experience_min !== null || job.experience_max !== null) { %>
                  <span class="inline-flex items-center gap-1"><i class="fas fa-clock text-blue-400"></i> <%= job.experience_min || 0 %>-<%= job.experience_max || 'Any' %> yrs</span>
                <% } %>
                <span class="inline-flex items-center gap-1 capitalize"><i class="fas fa-laptop-house text-purple-400"></i> <%= (job.work_mode || 'onsite').replace('_', ' ') %></span>
                <span class="inline-flex items-center gap-1 capitalize"><i class="fas fa-tag text-gray-400"></i> <%= (job.job_type || 'full_time').replace('_', ' ') %></span>
              </div>

              <!-- Category Badge -->
              <% if (job.category) { %>
                <div class="mt-2.5">
                  <span class="inline-block px-2.5 py-0.5 rounded-md text-xs font-medium bg-<%= typeColor %>-50 text-<%= typeColor %>-700 dark:bg-<%= typeColor %>-900/20 dark:text-<%= typeColor %>-300 border border-<%= typeColor %>-200 dark:border-<%= typeColor %>-800"><%= job.category %></span>
                </div>
              <% } %>

              <!-- Description -->
              <% if (job.description) { %>
                <p class="text-sm text-gray-500 mt-2.5 line-clamp-2 leading-relaxed"><%= job.description.replace(/<[^>]*>/g, '').substring(0, 180) %><%= job.description.length > 180 ? '...' : '' %></p>
              <% } %>

              <!-- Skills -->
              <% if (skills.length > 0 && !(skills.length === 1 && skills[0] === 'General')) { %>
                <div class="flex flex-wrap gap-1.5 mt-3">
                  <% skills.slice(0, 5).forEach(skill => { %>
                    <span class="px-2 py-0.5 bg-accent/8 text-accent border border-accent/15 rounded-md text-xs font-medium"><%= skill %></span>
                  <% }); %>
                  <% if (skills.length > 5) { %><span class="px-2 py-0.5 text-gray-400 text-xs">+<%= skills.length - 5 %> more</span><% } %>
                </div>
              <% } %>
            </div>
          </div>
        </div>

        <!-- Footer Bar -->
        <div class="px-4 sm:px-5 py-2.5 bg-gray-50 dark:bg-gray-800/50 border-t border-gray-100 dark:border-gray-800 rounded-b-xl flex items-center justify-between">
          <div class="flex items-center gap-3">
            <% if (job.source === 'linkedin') { %>
              <span class="inline-flex items-center gap-1 text-xs text-blue-600"><i class="fab fa-linkedin"></i> LinkedIn</span>
            <% } else if (job.source === 'naukri') { %>
              <span class="inline-flex items-center gap-1 text-xs text-purple-600"><i class="fas fa-briefcase"></i> Naukri</span>
            <% } else if (job.source === 'company') { %>
              <span class="inline-flex items-center gap-1 text-xs text-green-600"><i class="fas fa-building"></i> Company</span>
            <% } else { %>
              <span class="inline-flex items-center gap-1 text-xs text-gray-500"><i class="fas fa-globe"></i> <%= job.source %></span>
            <% } %>
            <% if (job.is_verified) { %><span class="inline-flex items-center gap-1 text-xs text-green-600"><i class="fas fa-check-circle"></i> Verified</span><% } %>
          </div>
          <% if (job.posted_date) { %>
            <span class="text-xs text-gray-400"><i class="far fa-calendar mr-1"></i><%= new Date(job.posted_date).toLocaleDateString('en-IN', {day: 'numeric', month: 'short', year: 'numeric'}) %></span>
          <% } %>
        </div>
      </div>
    <% }); %>
  </div>

  <!-- Pagination -->
  <% if (totalPages > 1) { %>
    <div class="flex items-center justify-center gap-1.5 pt-2">
      <% if (page > 1) { %>
        <a href="?<%= new URLSearchParams({...filters, page: page - 1}).toString() %>" class="w-9 h-9 rounded-lg border border-gray-200 dark:border-gray-700 flex items-center justify-center text-gray-500 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors"><i class="fas fa-chevron-left text-xs"></i></a>
      <% } %>
      <% for (let i = Math.max(1, page - 2); i <= Math.min(totalPages, page + 2); i++) { %>
        <a href="?<%= new URLSearchParams({...filters, page: i}).toString() %>" class="w-9 h-9 rounded-lg flex items-center justify-center text-sm font-medium transition-colors <%= i === page ? 'bg-primary text-white' : 'border border-gray-200 dark:border-gray-700 text-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800' %>"><%= i %></a>
      <% } %>
      <% if (page < totalPages) { %>
        <a href="?<%= new URLSearchParams({...filters, page: page + 1}).toString() %>" class="w-9 h-9 rounded-lg border border-gray-200 dark:border-gray-700 flex items-center justify-center text-gray-500 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors"><i class="fas fa-chevron-right text-xs"></i></a>
      <% } %>
    </div>
  <% } %>
</div>

<script>
async function toggleSaveJob(jobId, btn) {
  try {
    const res = await fetch('/job-board/api/' + jobId + '/save', { method: 'POST' });
    if (res.ok) {
      btn.innerHTML = '<i class="fas fa-bookmark text-sm text-accent"></i>';
      btn.classList.add('border-accent', 'text-accent');
      showToast('Job saved!', 'success');
    }
  } catch (err) { showToast('Failed to save', 'error'); }
}
</script>

<div class="space-y-5">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Job Board</h1>
      <p class="text-sm text-gray-500 mt-1"><%= total %> opportunities available</p>
    </div>
    <div class="flex gap-2 flex-shrink-0">
      <a href="/job-board/saved" class="btn-outline px-4 py-2 text-sm rounded-lg"><i class="far fa-bookmark mr-1.5"></i>Saved</a>
      <a href="/job-board/applications" class="btn-accent px-4 py-2 text-sm rounded-lg"><i class="fas fa-paper-plane mr-1.5"></i>My Applications</a>
    </div>
  </div>

  <!-- Stats Row -->
  <div class="grid grid-cols-3 gap-4">
    <div class="card flex items-center gap-3">
      <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center flex-shrink-0">
        <i class="fas fa-briefcase text-accent"></i>
      </div>
      <div>
        <div class="text-xl font-bold text-gray-900 dark:text-white"><%= stats.totalJobs || 0 %></div>
        <p class="text-xs text-gray-500">Total Jobs</p>
      </div>
    </div>
    <div class="card flex items-center gap-3">
      <div class="w-10 h-10 rounded-lg bg-green-100 dark:bg-green-900/20 flex items-center justify-center flex-shrink-0">
        <i class="fas fa-bolt text-green-600"></i>
      </div>
      <div>
        <div class="text-xl font-bold text-green-600"><%= stats.newToday || 0 %></div>
        <p class="text-xs text-gray-500">New Today</p>
      </div>
    </div>
    <div class="card flex items-center gap-3">
      <div class="w-10 h-10 rounded-lg bg-blue-100 dark:bg-blue-900/20 flex items-center justify-center flex-shrink-0">
        <i class="fas fa-paper-plane text-blue-600"></i>
      </div>
      <div>
        <div class="text-xl font-bold text-blue-600"><%= stats.totalApplications || 0 %></div>
        <p class="text-xs text-gray-500">Applications</p>
      </div>
    </div>
  </div>

  <!-- Search & Filters -->
  <div class="card">
    <form method="GET" action="/job-board" id="search-form">
      <div class="relative mb-3">
        <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
        <input type="text" name="q" value="<%= filters.query %>" class="input-field pl-10" placeholder="Search by job title, company, or keyword..." style="padding-left: 2.5rem;">
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        <select name="location" class="input-field text-sm">
          <option value="">All Locations</option>
          <% locations.forEach(loc => { %>
            <option value="<%= loc %>" <%= filters.location === loc ? 'selected' : '' %>><%= loc %></option>
          <% }); %>
        </select>
        <select name="category" class="input-field text-sm">
          <option value="">All Categories</option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat %>" <%= filters.category === cat ? 'selected' : '' %>><%= cat %></option>
          <% }); %>
        </select>
        <select name="jobType" class="input-field text-sm">
          <option value="">All Types</option>
          <option value="full_time" <%= filters.jobType === 'full_time' ? 'selected' : '' %>>Full Time</option>
          <option value="part_time" <%= filters.jobType === 'part_time' ? 'selected' : '' %>>Part Time</option>
          <option value="internship" <%= filters.jobType === 'internship' ? 'selected' : '' %>>Internship</option>
          <option value="contract" <%= filters.jobType === 'contract' ? 'selected' : '' %>>Contract</option>
          <option value="freelance" <%= filters.jobType === 'freelance' ? 'selected' : '' %>>Freelance</option>
        </select>
        <div class="flex gap-3">
          <select name="workMode" class="input-field text-sm flex-1">
            <option value="">All Modes</option>
            <option value="onsite" <%= filters.workMode === 'onsite' ? 'selected' : '' %>>Onsite</option>
            <option value="remote" <%= filters.workMode === 'remote' ? 'selected' : '' %>>Remote</option>
            <option value="hybrid" <%= filters.workMode === 'hybrid' ? 'selected' : '' %>>Hybrid</option>
          </select>
          <button type="submit" class="btn-accent px-5 py-2 text-sm rounded-lg flex-shrink-0"><i class="fas fa-search mr-1.5"></i>Search</button>
        </div>
      </div>
    </form>
    <% if (filters.query || filters.location || filters.category || filters.jobType || filters.workMode) { %>
      <div class="flex flex-wrap items-center gap-2 mt-3 pt-3 border-t border-gray-100 dark:border-gray-800">
        <span class="text-xs text-gray-400">Active:</span>
        <% if (filters.query) { %>
          <span class="badge badge-info text-xs"><i class="fas fa-search mr-1 text-[10px]"></i>"<%= filters.query %>"</span>
        <% } %>
        <% if (filters.location) { %>
          <span class="badge badge-warning text-xs"><i class="fas fa-map-marker-alt mr-1 text-[10px]"></i><%= filters.location %></span>
        <% } %>
        <% if (filters.category) { %>
          <span class="badge text-xs" style="background: rgba(124,58,237,0.1); color: #7C3AED;"><i class="fas fa-tag mr-1 text-[10px]"></i><%= filters.category %></span>
        <% } %>
        <% if (filters.jobType) { %>
          <span class="badge badge-info text-xs capitalize"><%= filters.jobType.replace('_', ' ') %></span>
        <% } %>
        <% if (filters.workMode) { %>
          <span class="badge badge-success text-xs capitalize"><%= filters.workMode %></span>
        <% } %>
        <a href="/job-board" class="text-xs text-gray-400 hover:text-red-500 transition-colors ml-auto"><i class="fas fa-times mr-1"></i>Clear all</a>
      </div>
    <% } %>
  </div>

  <!-- Job Grid -->
  <% if (jobs.length === 0) { %>
    <div class="card text-center py-12">
      <div class="w-16 h-16 rounded-2xl bg-gray-100 dark:bg-gray-800 flex items-center justify-center mx-auto mb-4">
        <i class="fas fa-search text-2xl text-gray-300"></i>
      </div>
      <h3 class="text-lg font-semibold text-gray-600 dark:text-gray-400">No jobs found</h3>
      <p class="text-sm text-gray-400 mt-1">Try adjusting your search filters or check back later</p>
      <a href="/job-board" class="btn-outline px-4 py-2 text-sm rounded-lg mt-4 inline-block"><i class="fas fa-redo mr-1.5"></i>Clear Filters</a>
    </div>
  <% } else { %>
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
      <% jobs.forEach(job => { %>
        <% let skills = []; try { skills = typeof job.skills === 'string' ? JSON.parse(job.skills) : (job.skills || []); } catch(e) { skills = []; } %>
        <% const cardLogoColors = ['#4F46E5','#0891B2','#059669','#D97706','#DC2626','#7C3AED','#2563EB','#0D9488','#C026D3','#EA580C']; %>
        <% const cardLogoColor = cardLogoColors[job.company.charCodeAt(0) % cardLogoColors.length]; %>
        <a href="/job-board/view/<%= job.id %>" class="card group hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 flex flex-col" style="padding: 0; text-decoration: none; color: inherit;">
          <!-- Card Body -->
          <div class="p-4 flex-1 flex flex-col">
            <!-- Logo + Title + Company -->
            <div class="flex items-start gap-3 mb-3">
              <div class="w-12 h-12 rounded-xl flex-shrink-0 relative overflow-hidden shadow-sm" style="background: <%= cardLogoColor %>;">
                <span class="absolute inset-0 flex items-center justify-center text-lg font-bold text-white"><%= job.company.charAt(0).toUpperCase() %></span>
                <% const cardLogoUrl = job.company_logo || ('https://logo.clearbit.com/' + job.company.toLowerCase().replace(/\s*(pvt|private|ltd|limited|inc|corp|llp|llc|co|technologies|tech|software|solutions|consulting|services|india|global|group)\s*/gi, '').trim().replace(/\s+/g, '') + '.com'); %>
                <img src="<%= cardLogoUrl %>" alt="" class="absolute inset-0 w-full h-full object-contain bg-white p-0.5 rounded-xl" onerror="this.remove();">
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-accent transition-colors line-clamp-2 leading-snug"><%= job.title %></h3>
                <p class="text-xs text-gray-500 mt-0.5 truncate"><%= job.company %></p>
              </div>
            </div>

            <!-- Location & Salary -->
            <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-gray-500 mb-3">
              <% if (job.location) { %>
                <span class="inline-flex items-center gap-1"><i class="fas fa-map-marker-alt text-red-400 text-[10px]"></i> <%= job.location %></span>
              <% } %>
              <% if (job.salary_min || job.salary_max) { %>
                <span class="inline-flex items-center gap-1 text-green-600 font-medium"><i class="fas fa-indian-rupee-sign text-[10px]"></i>
                  <% if (job.salary_min && job.salary_max) { %><%= (job.salary_min/100000).toFixed(0) %>-<%= (job.salary_max/100000).toFixed(0) %> LPA<% } else if (job.salary_max) { %>Up to <%= (job.salary_max/100000).toFixed(0) %> LPA<% } else { %><%= (job.salary_min/100000).toFixed(0) %>+ LPA<% } %>
                </span>
              <% } %>
              <% if (job.experience_min !== null || job.experience_max !== null) { %>
                <span class="inline-flex items-center gap-1"><i class="fas fa-clock text-blue-400 text-[10px]"></i> <%= job.experience_min || 0 %>-<%= job.experience_max || 'Any' %> yrs</span>
              <% } %>
            </div>

            <!-- Tags -->
            <div class="flex flex-wrap gap-1.5 mb-3">
              <% const typeLabels = {full_time: 'Full Time', part_time: 'Part Time', internship: 'Internship', contract: 'Contract', freelance: 'Freelance'}; %>
              <% const typeStyles = {full_time: 'bg-blue-50 text-blue-700 dark:bg-blue-900/20 dark:text-blue-300', part_time: 'bg-yellow-50 text-yellow-700 dark:bg-yellow-900/20 dark:text-yellow-300', internship: 'bg-green-50 text-green-700 dark:bg-green-900/20 dark:text-green-300', contract: 'bg-purple-50 text-purple-700 dark:bg-purple-900/20 dark:text-purple-300', freelance: 'bg-orange-50 text-orange-700 dark:bg-orange-900/20 dark:text-orange-300'}; %>
              <span class="inline-flex items-center px-2 py-0.5 rounded-md text-[11px] font-medium <%= typeStyles[job.job_type] || 'bg-gray-100 text-gray-600' %>"><%= typeLabels[job.job_type] || 'Full Time' %></span>
              <span class="inline-flex items-center px-2 py-0.5 rounded-md text-[11px] font-medium bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400 capitalize"><%= (job.work_mode || 'onsite').replace('_', ' ') %></span>
              <% if (job.category) { %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-md text-[11px] font-medium bg-accent/10 text-accent"><%= job.category %></span>
              <% } %>
            </div>

            <!-- Description preview -->
            <% if (job.description) { %>
              <p class="text-xs text-gray-400 dark:text-gray-500 line-clamp-2 leading-relaxed mb-3 flex-1"><%= job.description.replace(/<[^>]*>/g, '').substring(0, 150) %></p>
            <% } %>

            <!-- Skills -->
            <% if (skills.length > 0 && !(skills.length === 1 && skills[0] === 'General')) { %>
              <div class="flex flex-wrap gap-1.5 mt-auto">
                <% skills.slice(0, 4).forEach(skill => { %>
                  <span class="px-2 py-0.5 bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-400 border border-gray-200 dark:border-gray-700 rounded-md text-[11px]"><%= skill %></span>
                <% }); %>
                <% if (skills.length > 4) { %><span class="px-1.5 py-0.5 text-gray-400 text-[11px]">+<%= skills.length - 4 %></span><% } %>
              </div>
            <% } %>
          </div>

          <!-- Footer -->
          <div class="px-4 py-2.5 border-t border-gray-100 dark:border-gray-800 flex items-center justify-between bg-gray-50/50 dark:bg-gray-800/30">
            <% if (job.posted_date) { %>
              <span class="text-[11px] text-gray-400"><i class="far fa-calendar-alt mr-1"></i><%= new Date(job.posted_date).toLocaleDateString('en-IN', {day: 'numeric', month: 'short', year: 'numeric'}) %></span>
            <% } else { %>
              <span></span>
            <% } %>
            <span class="text-xs font-medium text-accent group-hover:underline">View Details <i class="fas fa-arrow-right text-[10px] ml-0.5"></i></span>
          </div>
        </a>
      <% }); %>
    </div>
  <% } %>

  <!-- Pagination -->
  <% if (totalPages > 1) { %>
    <div class="flex items-center justify-center gap-1.5 pt-2 pb-4">
      <% if (page > 1) { %>
        <a href="?<%= new URLSearchParams({...filters, page: page - 1}).toString() %>" class="w-9 h-9 rounded-lg border border-gray-200 dark:border-gray-700 flex items-center justify-center text-gray-500 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors text-sm"><i class="fas fa-chevron-left text-xs"></i></a>
      <% } %>
      <% for (let i = Math.max(1, page - 2); i <= Math.min(totalPages, page + 2); i++) { %>
        <a href="?<%= new URLSearchParams({...filters, page: i}).toString() %>" class="w-9 h-9 rounded-lg flex items-center justify-center text-sm font-medium transition-colors <%= i === page ? 'bg-accent text-white' : 'border border-gray-200 dark:border-gray-700 text-gray-600 hover:bg-gray-100 dark:hover:bg-gray-800' %>"><%= i %></a>
      <% } %>
      <% if (page < totalPages) { %>
        <a href="?<%= new URLSearchParams({...filters, page: page + 1}).toString() %>" class="w-9 h-9 rounded-lg border border-gray-200 dark:border-gray-700 flex items-center justify-center text-gray-500 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors text-sm"><i class="fas fa-chevron-right text-xs"></i></a>
      <% } %>
    </div>
  <% } %>
</div>

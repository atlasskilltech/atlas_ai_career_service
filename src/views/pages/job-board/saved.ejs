<div class="space-y-6">
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
    <div>
      <h1 class="text-xl sm:text-2xl font-bold">Saved Jobs</h1>
      <p class="text-sm text-gray-500 mt-1"><%= jobs.length %> saved job<%= jobs.length !== 1 ? 's' : '' %></p>
    </div>
    <a href="/job-board" class="btn-outline text-sm"><i class="fas fa-arrow-left mr-1"></i> Back to Job Board</a>
  </div>

  <% if (jobs.length === 0) { %>
    <div class="card p-8 text-center">
      <i class="fas fa-bookmark text-4xl text-gray-300 mb-3"></i>
      <h3 class="text-lg font-semibold text-gray-500">No saved jobs</h3>
      <p class="text-sm text-gray-400 mt-1">Save jobs from the <a href="/job-board" class="text-accent hover:underline">Job Board</a> to view them here</p>
    </div>
  <% } %>

  <% jobs.forEach(job => { %>
    <% let skills = []; try { skills = typeof job.skills === 'string' ? JSON.parse(job.skills) : (job.skills || []); } catch(e) { skills = []; } %>
    <div class="card p-4" id="saved-<%= job.id %>">
      <div class="flex flex-col sm:flex-row sm:items-start gap-3">
        <div class="flex-shrink-0 w-10 h-10 bg-gray-100 dark:bg-gray-800 rounded-lg flex items-center justify-center">
          <span class="text-lg font-bold text-gray-400"><%= job.company.charAt(0) %></span>
        </div>
        <div class="flex-1 min-w-0">
          <a href="/job-board/view/<%= job.id %>" class="font-semibold hover:text-accent"><%= job.title %></a>
          <p class="text-sm text-gray-500"><%= job.company %></p>
          <div class="flex flex-wrap items-center gap-2 mt-2 text-xs text-gray-500">
            <% if (job.location) { %><span><i class="fas fa-map-marker-alt mr-1"></i><%= job.location %></span><% } %>
            <span class="capitalize"><i class="fas fa-tag mr-1"></i><%= (job.job_type || 'full_time').replace('_', ' ') %></span>
          </div>
          <% if (skills.length > 0) { %>
            <div class="flex flex-wrap gap-1 mt-2">
              <% skills.slice(0, 5).forEach(skill => { %>
                <span class="px-2 py-0.5 bg-accent/10 text-accent rounded text-xs"><%= skill %></span>
              <% }); %>
            </div>
          <% } %>
          <p class="text-xs text-gray-400 mt-2">Saved <%= new Date(job.saved_at).toLocaleDateString('en-IN', {day: 'numeric', month: 'short', year: 'numeric'}) %></p>
        </div>
        <div class="flex gap-2 flex-shrink-0">
          <a href="/job-board/view/<%= job.id %>" class="btn-primary text-xs px-3 py-1.5">View</a>
          <button onclick="unsaveJob(<%= job.id %>)" class="btn-outline text-xs px-3 py-1.5 text-red-500"><i class="fas fa-trash"></i></button>
        </div>
      </div>
    </div>
  <% }); %>
</div>

<script>
async function unsaveJob(jobId) {
  try {
    await fetch('/job-board/api/' + jobId + '/save', { method: 'DELETE' });
    document.getElementById('saved-' + jobId).remove();
    showToast('Job removed from saved', 'success');
  } catch { showToast('Failed', 'error'); }
}
</script>

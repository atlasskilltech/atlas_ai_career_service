<div class="space-y-6">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold">Saved Jobs</h1>
      <p class="text-sm text-gray-500 mt-1"><%= jobs.length %> saved job<%= jobs.length !== 1 ? 's' : '' %></p>
    </div>
    <a href="/job-board" class="btn-outline text-sm"><i class="fas fa-arrow-left mr-1.5"></i> Back to Job Board</a>
  </div>

  <% if (jobs.length === 0) { %>
    <div class="card !p-12 text-center">
      <div class="w-16 h-16 rounded-full bg-gray-100 dark:bg-gray-800 flex items-center justify-center mx-auto mb-4">
        <i class="fas fa-bookmark text-2xl text-gray-300"></i>
      </div>
      <h3 class="text-lg font-semibold text-gray-600 dark:text-gray-400">No saved jobs yet</h3>
      <p class="text-sm text-gray-400 mt-1">Save jobs from the <a href="/job-board" class="text-accent hover:underline">Job Board</a> to view them here</p>
    </div>
  <% } %>

  <div class="space-y-3">
    <% jobs.forEach(job => { %>
      <% let skills = []; try { skills = typeof job.skills === 'string' ? JSON.parse(job.skills) : (job.skills || []); } catch(e) { skills = []; } %>
      <div class="card !p-0 hover:shadow-md transition-all duration-200" id="saved-<%= job.id %>">
        <div class="p-4 sm:p-5">
          <div class="flex gap-4">
            <!-- Logo -->
            <div class="flex-shrink-0 hidden sm:flex">
              <div class="w-12 h-12 bg-gray-50 dark:bg-gray-800 rounded-xl flex items-center justify-center border border-gray-100 dark:border-gray-700">
                <span class="text-lg font-bold text-gray-400"><%= job.company.charAt(0).toUpperCase() %></span>
              </div>
            </div>

            <!-- Info -->
            <div class="flex-1 min-w-0">
              <div class="flex items-start justify-between gap-3">
                <div class="min-w-0">
                  <a href="/job-board/view/<%= job.id %>" class="text-base font-semibold text-gray-900 dark:text-white hover:text-accent transition-colors line-clamp-1"><%= job.title %></a>
                  <p class="text-sm text-gray-500 mt-0.5"><%= job.company %></p>
                </div>
                <div class="flex items-center gap-2 flex-shrink-0">
                  <button onclick="unsaveJob(<%= job.id %>)" class="w-8 h-8 rounded-lg border border-gray-200 dark:border-gray-700 flex items-center justify-center text-gray-400 hover:text-red-500 hover:border-red-300 transition-colors" title="Remove">
                    <i class="fas fa-trash text-xs"></i>
                  </button>
                  <a href="/job-board/view/<%= job.id %>" class="btn-primary text-xs !px-3 !py-1.5"><i class="fas fa-eye mr-1"></i> View</a>
                </div>
              </div>

              <div class="flex flex-wrap items-center gap-x-4 gap-y-1 mt-2.5 text-xs text-gray-500">
                <% if (job.location) { %><span class="inline-flex items-center gap-1"><i class="fas fa-map-marker-alt text-red-400"></i> <%= job.location %></span><% } %>
                <span class="inline-flex items-center gap-1 capitalize"><i class="fas fa-tag text-gray-400"></i> <%= (job.job_type || 'full_time').replace('_', ' ') %></span>
                <span class="inline-flex items-center gap-1 capitalize"><i class="fas fa-laptop-house text-purple-400"></i> <%= (job.work_mode || 'onsite').replace('_', ' ') %></span>
              </div>

              <% if (skills.length > 0 && !(skills.length === 1 && skills[0] === 'General')) { %>
                <div class="flex flex-wrap gap-1.5 mt-2.5">
                  <% skills.slice(0, 5).forEach(skill => { %>
                    <span class="px-2 py-0.5 bg-accent/8 text-accent border border-accent/15 rounded-md text-xs font-medium"><%= skill %></span>
                  <% }); %>
                  <% if (skills.length > 5) { %><span class="px-2 py-0.5 text-gray-400 text-xs">+<%= skills.length - 5 %></span><% } %>
                </div>
              <% } %>
            </div>
          </div>
        </div>

        <!-- Footer -->
        <div class="px-4 sm:px-5 py-2.5 bg-gray-50 dark:bg-gray-800/50 border-t border-gray-100 dark:border-gray-800 rounded-b-xl flex items-center justify-between">
          <span class="inline-flex items-center gap-1.5 text-xs text-accent"><i class="fas fa-bookmark"></i> Saved</span>
          <span class="text-xs text-gray-400"><i class="far fa-calendar mr-1"></i><%= new Date(job.saved_at).toLocaleDateString('en-IN', {day: 'numeric', month: 'short', year: 'numeric'}) %></span>
        </div>
      </div>
    <% }); %>
  </div>
</div>

<script>
async function unsaveJob(jobId) {
  try {
    await fetch('/job-board/api/' + jobId + '/save', { method: 'DELETE' });
    var el = document.getElementById('saved-' + jobId);
    el.style.opacity = '0'; el.style.transform = 'translateX(20px)'; el.style.transition = 'all 0.3s';
    setTimeout(function() { el.remove(); }, 300);
    showToast('Job removed from saved', 'success');
  } catch { showToast('Failed', 'error'); }
}
</script>

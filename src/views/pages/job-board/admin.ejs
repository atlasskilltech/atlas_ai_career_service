<div class="space-y-6">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
    <div>
      <h1 class="text-xl sm:text-2xl font-bold">Job Board Admin</h1>
      <p class="text-sm text-gray-500 mt-1">Manage aggregated jobs, scrapers & listings</p>
    </div>
    <div class="flex gap-2 flex-shrink-0">
      <button onclick="openAddJobModal()" class="btn-primary text-sm"><i class="fas fa-plus mr-1"></i> Add Job</button>
      <button onclick="openImportModal()" class="btn-outline text-sm"><i class="fas fa-file-import mr-1"></i> Import</button>
    </div>
  </div>

  <!-- Admin Stats -->
  <div class="grid grid-cols-2 sm:grid-cols-5 gap-2 sm:gap-4">
    <div class="card p-3 sm:p-4 text-center">
      <div class="text-xl sm:text-2xl font-bold text-accent"><%= stats.totalJobs || 0 %></div>
      <p class="text-xs text-gray-500">Total Jobs</p>
    </div>
    <div class="card p-3 sm:p-4 text-center">
      <div class="text-xl sm:text-2xl font-bold text-green-600"><%= stats.newToday || 0 %></div>
      <p class="text-xs text-gray-500">New Today</p>
    </div>
    <div class="card p-3 sm:p-4 text-center">
      <div class="text-xl sm:text-2xl font-bold text-blue-600"><%= stats.totalApplications || 0 %></div>
      <p class="text-xs text-gray-500">Applications</p>
    </div>
    <% Object.entries(stats.bySource || {}).slice(0, 2).forEach(([src, count]) => { %>
      <div class="card p-3 sm:p-4 text-center">
        <div class="text-xl sm:text-2xl font-bold text-purple-600"><%= count %></div>
        <p class="text-xs text-gray-500 capitalize"><%= src %></p>
      </div>
    <% }); %>
  </div>

  <!-- Auto-Fetch Scheduler Status -->
  <div class="card p-4" id="scheduler-card">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center">
          <i class="fas fa-robot text-green-600" id="sched-icon"></i>
        </div>
        <div>
          <h3 class="font-semibold text-sm">Auto-Fetch Scheduler</h3>
          <p class="text-xs text-gray-500" id="sched-status">Loading...</p>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <span class="text-xs text-gray-500" id="sched-next">Next: --</span>
        <button onclick="triggerFetch()" id="trigger-btn" class="btn-outline text-xs px-3 py-1.5"><i class="fas fa-play mr-1"></i> Fetch Now</button>
      </div>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-5 gap-3 mt-4 text-center">
      <div class="p-2 bg-gray-50 dark:bg-gray-800 rounded">
        <div class="font-bold text-sm" id="sched-runs">0</div>
        <p class="text-xs text-gray-500">Runs</p>
      </div>
      <div class="p-2 bg-gray-50 dark:bg-gray-800 rounded">
        <div class="font-bold text-sm text-green-600" id="sched-added">0</div>
        <p class="text-xs text-gray-500">Total Added</p>
      </div>
      <div class="p-2 bg-gray-50 dark:bg-gray-800 rounded">
        <div class="font-bold text-sm text-blue-600" id="sched-updated">0</div>
        <p class="text-xs text-gray-500">Total Updated</p>
      </div>
      <div class="p-2 bg-gray-50 dark:bg-gray-800 rounded">
        <div class="font-bold text-sm" id="sched-last-found">0</div>
        <p class="text-xs text-gray-500">Last Found</p>
      </div>
      <div class="p-2 bg-gray-50 dark:bg-gray-800 rounded">
        <div class="font-bold text-sm" id="sched-last-time">--</div>
        <p class="text-xs text-gray-500">Last Run</p>
      </div>
    </div>
  </div>

  <!-- Source Filter -->
  <div class="flex flex-wrap gap-2">
    <a href="/job-board/admin" class="<%= !source ? 'btn-primary' : 'btn-outline' %> text-xs px-3 py-1.5">All</a>
    <a href="/job-board/admin?source=linkedin" class="<%= source === 'linkedin' ? 'btn-primary' : 'btn-outline' %> text-xs px-3 py-1.5"><i class="fab fa-linkedin mr-1"></i> LinkedIn</a>
    <a href="/job-board/admin?source=naukri" class="<%= source === 'naukri' ? 'btn-primary' : 'btn-outline' %> text-xs px-3 py-1.5">Naukri</a>
    <a href="/job-board/admin?source=company" class="<%= source === 'company' ? 'btn-primary' : 'btn-outline' %> text-xs px-3 py-1.5">Company</a>
    <a href="/job-board/admin?source=api" class="<%= source === 'api' ? 'btn-primary' : 'btn-outline' %> text-xs px-3 py-1.5">API</a>
    <a href="/job-board/admin?source=manual" class="<%= source === 'manual' ? 'btn-primary' : 'btn-outline' %> text-xs px-3 py-1.5">Manual</a>
  </div>

  <!-- Jobs Table -->
  <div class="card overflow-x-auto">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 dark:bg-gray-800">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Job</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase hidden sm:table-cell">Location</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase hidden md:table-cell">Source</th>
          <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">Status</th>
          <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200 dark:divide-gray-800">
        <% if (jobs.length === 0) { %>
          <tr><td colspan="5" class="px-4 py-8 text-center text-gray-500">No jobs found</td></tr>
        <% } %>
        <% jobs.forEach(job => { %>
          <tr id="admin-job-<%= job.id %>">
            <td class="px-4 py-3">
              <div class="font-medium"><%= job.title %></div>
              <div class="text-xs text-gray-500"><%= job.company %></div>
            </td>
            <td class="px-4 py-3 text-xs text-gray-500 hidden sm:table-cell"><%= job.location || 'N/A' %></td>
            <td class="px-4 py-3 hidden md:table-cell">
              <span class="px-2 py-0.5 rounded text-xs font-medium bg-gray-100 dark:bg-gray-800 capitalize"><%= job.source %></span>
            </td>
            <td class="px-4 py-3 text-center">
              <div class="flex items-center justify-center gap-2">
                <span class="w-2 h-2 rounded-full <%= job.is_active ? 'bg-green-500' : 'bg-red-500' %>"></span>
                <span class="text-xs"><%= job.is_active ? 'Active' : 'Inactive' %></span>
                <% if (job.is_verified) { %><i class="fas fa-check-circle text-green-500 text-xs" title="Verified"></i><% } %>
              </div>
            </td>
            <td class="px-4 py-3 text-right">
              <div class="flex items-center justify-end gap-1">
                <button onclick="toggleJobActive(<%= job.id %>, <%= job.is_active ? 0 : 1 %>)" class="text-xs px-2 py-1 rounded hover:bg-gray-100 dark:hover:bg-gray-800" title="<%= job.is_active ? 'Deactivate' : 'Activate' %>">
                  <i class="fas fa-<%= job.is_active ? 'eye-slash' : 'eye' %>"></i>
                </button>
                <% if (!job.is_verified) { %>
                  <button onclick="verifyJob(<%= job.id %>)" class="text-xs px-2 py-1 rounded hover:bg-gray-100 dark:hover:bg-gray-800 text-green-600" title="Verify">
                    <i class="fas fa-check"></i>
                  </button>
                <% } %>
                <button onclick="deleteAdminJob(<%= job.id %>)" class="text-xs px-2 py-1 rounded hover:bg-gray-100 dark:hover:bg-gray-800 text-red-600" title="Delete">
                  <i class="fas fa-trash"></i>
                </button>
              </div>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  <% if (totalPages > 1) { %>
    <div class="flex justify-center gap-2">
      <% for (let i = 1; i <= totalPages; i++) { %>
        <a href="/job-board/admin?page=<%= i %><%= source ? '&source=' + source : '' %>" class="<%= i === page ? 'btn-primary' : 'btn-outline' %> text-sm px-3 py-1.5"><%= i %></a>
      <% } %>
    </div>
  <% } %>

  <!-- Scraper Logs -->
  <% if (scraperLogs && scraperLogs.length > 0) { %>
    <div class="card p-4">
      <h3 class="font-semibold text-sm mb-3"><i class="fas fa-robot mr-2 text-accent"></i>Recent Scraper Runs</h3>
      <div class="space-y-2">
        <% scraperLogs.slice(0, 10).forEach(log => { %>
          <div class="flex items-center justify-between text-xs p-2 bg-gray-50 dark:bg-gray-800 rounded">
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full <%= log.status === 'completed' ? 'bg-green-500' : log.status === 'running' ? 'bg-yellow-500' : 'bg-red-500' %>"></span>
              <span class="font-medium capitalize"><%= log.source %></span>
              <span class="text-gray-500"><%= log.status %></span>
            </div>
            <div class="flex items-center gap-3 text-gray-500">
              <span>Found: <%= log.jobs_found %></span>
              <span>Added: <%= log.jobs_added %></span>
              <span><%= log.started_at ? new Date(log.started_at).toLocaleString() : '' %></span>
            </div>
          </div>
        <% }); %>
      </div>
    </div>
  <% } %>
</div>

<!-- Add Job Modal -->
<div id="add-job-modal" class="modal-overlay hidden">
  <div class="modal-content p-6 max-h-[90vh] overflow-y-auto">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-lg font-semibold">Add Job Manually</h3>
      <button onclick="closeAddJobModal()" class="text-gray-400 hover:text-gray-600"><i class="fas fa-times"></i></button>
    </div>
    <div class="space-y-3">
      <div class="grid grid-cols-2 gap-3">
        <div><label class="label-field">Job Title *</label><input type="text" id="aj-title" class="input-field" placeholder="Software Engineer"></div>
        <div><label class="label-field">Company *</label><input type="text" id="aj-company" class="input-field" placeholder="TCS"></div>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div><label class="label-field">Location</label><input type="text" id="aj-location" class="input-field" placeholder="Mumbai, India"></div>
        <div><label class="label-field">Category</label><input type="text" id="aj-category" class="input-field" placeholder="Engineering"></div>
      </div>
      <div class="grid grid-cols-3 gap-3">
        <div><label class="label-field">Salary Min</label><input type="number" id="aj-salary-min" class="input-field" placeholder="500000"></div>
        <div><label class="label-field">Salary Max</label><input type="number" id="aj-salary-max" class="input-field" placeholder="1000000"></div>
        <div><label class="label-field">Currency</label><input type="text" id="aj-currency" class="input-field" value="INR"></div>
      </div>
      <div class="grid grid-cols-3 gap-3">
        <div><label class="label-field">Job Type</label>
          <select id="aj-job-type" class="input-field">
            <option value="full_time">Full Time</option><option value="part_time">Part Time</option><option value="internship">Internship</option><option value="contract">Contract</option><option value="freelance">Freelance</option>
          </select>
        </div>
        <div><label class="label-field">Work Mode</label>
          <select id="aj-work-mode" class="input-field">
            <option value="onsite">Onsite</option><option value="remote">Remote</option><option value="hybrid">Hybrid</option>
          </select>
        </div>
        <div><label class="label-field">Experience (yrs)</label>
          <div class="flex gap-1"><input type="number" id="aj-exp-min" class="input-field" placeholder="0" min="0"><input type="number" id="aj-exp-max" class="input-field" placeholder="5" min="0"></div>
        </div>
      </div>
      <div><label class="label-field">Skills (comma separated)</label><input type="text" id="aj-skills" class="input-field" placeholder="JavaScript, React, Node.js"></div>
      <div><label class="label-field">Apply URL</label><input type="url" id="aj-apply-url" class="input-field" placeholder="https://..."></div>
      <div><label class="label-field">Description</label><textarea id="aj-description" rows="4" class="input-field" placeholder="Job description..."></textarea></div>
      <button onclick="addAdminJob()" id="add-job-btn" class="btn-primary w-full">Add Job</button>
    </div>
  </div>
</div>

<!-- Import Modal -->
<div id="import-modal" class="modal-overlay hidden">
  <div class="modal-content p-6">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-lg font-semibold">Bulk Import Jobs</h3>
      <button onclick="closeImportModal()" class="text-gray-400 hover:text-gray-600"><i class="fas fa-times"></i></button>
    </div>
    <div class="space-y-3">
      <div><label class="label-field">Source</label>
        <select id="import-source" class="input-field">
          <option value="api">External API</option><option value="linkedin">LinkedIn</option><option value="naukri">Naukri</option><option value="company">Company</option>
        </select>
      </div>
      <div><label class="label-field">Jobs JSON Array</label><textarea id="import-data" rows="8" class="input-field font-mono text-xs" placeholder='[{"title":"...", "company":"...", "externalId":"...", "location":"...", "description":"...", "applyUrl":"..."}]'></textarea></div>
      <button onclick="bulkImport()" id="import-btn" class="btn-primary w-full">Import Jobs</button>
      <div id="import-results"></div>
    </div>
  </div>
</div>

<script>
function openAddJobModal() { document.getElementById('add-job-modal').classList.remove('hidden'); }
function closeAddJobModal() { document.getElementById('add-job-modal').classList.add('hidden'); }
function openImportModal() { document.getElementById('import-modal').classList.remove('hidden'); }
function closeImportModal() { document.getElementById('import-modal').classList.add('hidden'); }

async function addAdminJob() {
  const data = {
    title: document.getElementById('aj-title').value,
    company: document.getElementById('aj-company').value,
    location: document.getElementById('aj-location').value,
    category: document.getElementById('aj-category').value,
    salaryMin: document.getElementById('aj-salary-min').value || null,
    salaryMax: document.getElementById('aj-salary-max').value || null,
    salaryCurrency: document.getElementById('aj-currency').value,
    jobType: document.getElementById('aj-job-type').value,
    workMode: document.getElementById('aj-work-mode').value,
    experienceMin: document.getElementById('aj-exp-min').value || 0,
    experienceMax: document.getElementById('aj-exp-max').value || null,
    skills: document.getElementById('aj-skills').value,
    applyUrl: document.getElementById('aj-apply-url').value,
    description: document.getElementById('aj-description').value,
  };
  if (!data.title || !data.company) return showToast('Title and company required', 'error');
  try {
    const res = await fetch('/job-board/admin/jobs', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data),
    });
    if (res.ok) { showToast('Job added!', 'success'); location.reload(); }
    else { const d = await res.json(); showToast(d.error || 'Failed', 'error'); }
  } catch { showToast('Failed to add job', 'error'); }
}

async function toggleJobActive(id, isActive) {
  try {
    await fetch('/job-board/admin/jobs/' + id + '/toggle', {
      method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ isActive }),
    });
    location.reload();
  } catch { showToast('Failed', 'error'); }
}

async function verifyJob(id) {
  try {
    await fetch('/job-board/admin/jobs/' + id + '/verify', { method: 'PATCH' });
    location.reload();
  } catch { showToast('Failed', 'error'); }
}

async function deleteAdminJob(id) {
  if (!confirm('Delete this job?')) return;
  try {
    await fetch('/job-board/admin/jobs/' + id, { method: 'DELETE' });
    document.getElementById('admin-job-' + id).remove();
    showToast('Job deleted', 'success');
  } catch { showToast('Failed', 'error'); }
}

async function bulkImport() {
  const btn = document.getElementById('import-btn');
  btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i> Importing...';
  try {
    const jobs = JSON.parse(document.getElementById('import-data').value);
    const source = document.getElementById('import-source').value;
    const res = await fetch('/job-board/admin/bulk-import', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ jobs, source }),
    });
    const data = await res.json();
    if (data.success) {
      document.getElementById('import-results').innerHTML = '<div class="mt-3 p-3 bg-green-50 dark:bg-green-900/20 rounded text-sm"><strong>Import Complete!</strong><br>Total: ' + data.total + ' | Added: ' + data.added + ' | Updated: ' + data.updated + '</div>';
      showToast('Import completed!', 'success');
    } else showToast(data.error || 'Failed', 'error');
  } catch (e) { showToast('Invalid JSON or import failed: ' + e.message, 'error'); }
  btn.disabled = false; btn.innerHTML = 'Import Jobs';
}

// ─── Scheduler Live Status ────────────────────────────────────
async function loadSchedulerStatus() {
  try {
    const res = await fetch('/job-board/admin/api/scheduler');
    const data = await res.json();
    if (!data.success || !data.scheduler) return;
    const s = data.scheduler;
    var icon = document.getElementById('sched-icon');
    var statusEl = document.getElementById('sched-status');
    if (s.currentlyFetching) {
      icon.className = 'fas fa-spinner fa-spin text-yellow-600';
      statusEl.textContent = 'Fetching jobs right now...';
    } else if (s.running) {
      icon.className = 'fas fa-robot text-green-600';
      statusEl.textContent = 'Running - auto-fetches every 5 minutes';
    } else {
      icon.className = 'fas fa-robot text-gray-400';
      statusEl.textContent = 'Stopped';
    }
    document.getElementById('sched-runs').textContent = s.runCount || 0;
    document.getElementById('sched-added').textContent = s.totalImported ? s.totalImported.added : 0;
    document.getElementById('sched-updated').textContent = s.totalImported ? s.totalImported.updated : 0;
    if (s.lastResult) {
      document.getElementById('sched-last-found').textContent = s.lastResult.found || 0;
    }
    if (s.lastRun) {
      document.getElementById('sched-last-time').textContent = new Date(s.lastRun).toLocaleTimeString();
    }
    if (s.nextSources) {
      document.getElementById('sched-next').textContent = 'Next: ' + s.nextSources.join(', ');
    }
  } catch (e) { /* ignore */ }
}

async function triggerFetch() {
  var btn = document.getElementById('trigger-btn');
  btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i> Fetching...';
  try {
    await fetch('/job-board/admin/api/scheduler/trigger', { method: 'POST' });
    showToast('Fetch cycle triggered! Refresh in a minute to see results.', 'success');
  } catch { showToast('Failed to trigger', 'error'); }
  setTimeout(function() { btn.disabled = false; btn.innerHTML = '<i class="fas fa-play mr-1"></i> Fetch Now'; loadSchedulerStatus(); }, 5000);
}

// Load status on page load and refresh every 30 seconds
loadSchedulerStatus();
setInterval(loadSchedulerStatus, 30000);
</script>

// =================== UPLOAD RESUME ===================
function showUploadModal() {
  document.getElementById('upload-modal').classList.remove('hidden');
  document.getElementById('upload-modal').classList.add('flex');
  document.getElementById('upload-progress').classList.add('hidden');
  document.getElementById('upload-error').classList.add('hidden');
  document.getElementById('resume-file-input').value = '';
}

function closeUploadModal() {
  document.getElementById('upload-modal').classList.add('hidden');
  document.getElementById('upload-modal').classList.remove('flex');
}

async function handleResumeUpload(input) {
  var file = input.files[0];
  if (!file) return;

  var maxSize = 10 * 1024 * 1024;
  if (file.size > maxSize) {
    document.getElementById('upload-error').classList.remove('hidden');
    document.getElementById('upload-error').textContent = 'File too large. Maximum size is 10MB.';
    return;
  }

  var allowed = ['application/pdf', 'application/msword', 'application/vnd.openxmlformats-officedocument.wordprocessingml.document'];
  if (!allowed.includes(file.type) && !file.name.match(/\.(pdf|doc|docx)$/i)) {
    document.getElementById('upload-error').classList.remove('hidden');
    document.getElementById('upload-error').textContent = 'Invalid file type. Please upload a PDF or DOCX file.';
    return;
  }

  // Show progress
  document.getElementById('upload-error').classList.add('hidden');
  document.getElementById('upload-progress').classList.remove('hidden');
  document.getElementById('upload-filename').textContent = file.name;
  document.getElementById('upload-status-text').textContent = 'Uploading file...';
  document.getElementById('upload-bar').style.width = '20%';
  document.getElementById('upload-spinner').classList.remove('hidden');

  var formData = new FormData();
  formData.append('resume', file);

  try {
    // Step 1: Upload and parse (server tries AI inline, falls back to regex)
    document.getElementById('upload-bar').style.width = '40%';
    document.getElementById('upload-status-text').textContent = 'Extracting data from resume...';

    var res = await fetch('/resume/upload-parse', { method: 'POST', body: formData });

    var result;
    try {
      result = await res.json();
    } catch(jsonErr) {
      throw new Error('Server error (status ' + res.status + '). Please try again.');
    }

    if (!result.success || !result.data) {
      throw new Error(result.error || 'Failed to parse resume.');
    }

    document.getElementById('upload-bar').style.width = '80%';

    // If server used fallback (regex), try AI enhancement in background
    if (result.ai_fallback && result.data.profile_data) {
      document.getElementById('upload-status-text').textContent = 'Filling form... (AI enhancing in background)';
      fillFormWithParsedData(result.data);

      // Try AI parse in a separate request (non-blocking)
      fetch('/resume/ai/parse-resume', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text: '' })
      }).catch(function() {});
    } else {
      fillFormWithParsedData(result.data);
    }

    document.getElementById('upload-bar').style.width = '100%';
    document.getElementById('upload-status-text').textContent = 'Data extracted! Filling form...';
    document.getElementById('upload-spinner').classList.add('hidden');

    setTimeout(function() {
      closeUploadModal();
      showToast('Resume data imported successfully!', 'success');
      triggerAutoSave();
    }, 800);
  } catch(err) {
    document.getElementById('upload-spinner').classList.add('hidden');
    document.getElementById('upload-error').classList.remove('hidden');
    document.getElementById('upload-error').textContent = err.message || 'Upload failed. Please try again.';
    document.getElementById('upload-status-text').textContent = 'Failed';
  }
}

function fillFormWithParsedData(data) {
  // Profile
  var p = data.profile_data || {};
  if (p.name) document.getElementById('profile-name').value = p.name;
  if (p.headline) document.getElementById('profile-headline').value = p.headline;
  if (p.email) document.getElementById('profile-email').value = p.email;
  if (p.phone) document.getElementById('profile-phone').value = p.phone;
  if (p.linkedin) document.getElementById('profile-linkedin').value = p.linkedin;
  if (p.github) document.getElementById('profile-github').value = p.github;
  if (p.website) document.getElementById('profile-website').value = p.website;
  if (p.location) document.getElementById('profile-location').value = p.location;
  if (p.summary) document.getElementById('profile-summary').value = p.summary;

  // Update title with name
  if (p.name) document.getElementById('resume-title').value = p.name + ' - Resume';

  // Education
  var eduList = document.getElementById('education-list');
  if (data.education_data && data.education_data.length && eduList) {
    eduList.innerHTML = '';
    data.education_data.forEach(function(edu) {
      addEntry('education');
      var entries = eduList.querySelectorAll(':scope > div');
      var last = entries[entries.length - 1];
      if (!last) return;
      var inst = last.querySelector('.edu-institution'); if (inst) inst.value = edu.institution || '';
      var deg = last.querySelector('.edu-degree'); if (deg) deg.value = edu.degree || '';
      var field = last.querySelector('.edu-field'); if (field) field.value = edu.field || '';
      var year = last.querySelector('.edu-year'); if (year) year.value = edu.year || '';
      var gpa = last.querySelector('.edu-gpa'); if (gpa) gpa.value = edu.gpa || '';
    });
  }

  // Experience
  var expList = document.getElementById('experience-list');
  if (data.experience_data && data.experience_data.length && expList) {
    expList.innerHTML = '';
    data.experience_data.forEach(function(exp) {
      addEntry('experience');
      var entries = expList.querySelectorAll(':scope > div');
      var last = entries[entries.length - 1];
      if (!last) return;
      var title = last.querySelector('.exp-title'); if (title) title.value = exp.title || '';
      var company = last.querySelector('.exp-company'); if (company) company.value = exp.company || '';
      var loc = last.querySelector('.exp-location'); if (loc) loc.value = exp.location || '';
      var start = last.querySelector('.exp-start'); if (start) start.value = exp.startDate || '';
      var end = last.querySelector('.exp-end'); if (end) end.value = exp.endDate || '';
      var desc = last.querySelector('.exp-desc'); if (desc) desc.value = exp.description || '';
    });
  }

  // Projects
  var projList = document.getElementById('projects-list');
  if (data.projects_data && data.projects_data.length && projList) {
    projList.innerHTML = '';
    data.projects_data.forEach(function(proj) {
      addEntry('projects');
      var entries = projList.querySelectorAll(':scope > div');
      var last = entries[entries.length - 1];
      if (!last) return;
      var name = last.querySelector('.proj-name'); if (name) name.value = proj.name || '';
      var tech = last.querySelector('.proj-tech'); if (tech) tech.value = proj.technologies || '';
      var desc = last.querySelector('.proj-desc'); if (desc) desc.value = proj.description || '';
      var url = last.querySelector('.proj-url'); if (url) url.value = proj.url || '';
    });
  }

  // Skills
  var s = data.skills_data || {};
  if (s.technical) document.getElementById('skills-technical').value = s.technical;
  if (s.soft) document.getElementById('skills-soft').value = s.soft;
  if (s.tools) document.getElementById('skills-tools').value = s.tools;
  if (s.languages) document.getElementById('skills-languages').value = s.languages;

  // Achievements
  var achList = document.getElementById('achievements-list');
  if (data.achievements_data && data.achievements_data.length && achList) {
    achList.innerHTML = '';
    data.achievements_data.forEach(function(ach) {
      addEntry('achievements');
      var entries = achList.querySelectorAll('.ach-text');
      var last = entries[entries.length - 1];
      if (last) last.value = typeof ach === 'string' ? ach : ach.achievement_text || '';
    });
  }

  // Certifications
  var certList = document.getElementById('certifications-list');
  if (data.certifications_data && data.certifications_data.length && certList) {
    certList.innerHTML = '';
    data.certifications_data.forEach(function(cert) {
      addEntry('certifications');
      var entries = certList.querySelectorAll(':scope > div');
      var last = entries[entries.length - 1];
      if (!last) return;
      var name = last.querySelector('.cert-name'); if (name) name.value = cert.name || '';
      var org = last.querySelector('.cert-org'); if (org) org.value = cert.organization || '';
      var date = last.querySelector('.cert-date'); if (date) date.value = cert.date || '';
    });
  }

  // Languages
  var langList = document.getElementById('languages-list');
  if (data.languages_data && data.languages_data.length && langList) {
    langList.innerHTML = '';
    data.languages_data.forEach(function(lang) {
      addEntry('languages');
      var entries = langList.querySelectorAll(':scope > div, :scope > .flex');
      var last = entries[entries.length - 1];
      if (!last) return;
      var name = last.querySelector('.lang-name'); if (name) name.value = lang.language || '';
      var level = last.querySelector('.lang-level'); if (level) level.value = lang.proficiency || 'Intermediate';
    });
  }

  // Interests
  if (data.interests_data && data.interests_data.length) {
    var interestsText = data.interests_data.map(function(i) { return typeof i === 'string' ? i : i.name || ''; }).join(', ');
    document.getElementById('interests-text').value = interestsText;
  }

  // Update preview
  updatePreview();
}

// Drag and drop support for upload dropzone
document.addEventListener('DOMContentLoaded', function() {
  var dropzone = document.getElementById('upload-dropzone');
  if (dropzone) {
    dropzone.addEventListener('dragover', function(e) { e.preventDefault(); dropzone.classList.add('border-blue-400', 'bg-blue-50/50'); });
    dropzone.addEventListener('dragleave', function(e) { e.preventDefault(); dropzone.classList.remove('border-blue-400', 'bg-blue-50/50'); });
    dropzone.addEventListener('drop', function(e) {
      e.preventDefault();
      dropzone.classList.remove('border-blue-400', 'bg-blue-50/50');
      var files = e.dataTransfer.files;
      if (files.length > 0) {
        var input = document.getElementById('resume-file-input');
        input.files = files;
        handleResumeUpload(input);
      }
    });
  }
});

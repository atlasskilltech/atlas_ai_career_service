// =================== ATS ANALYZER ===================
function showATSModal() { document.getElementById('ats-modal').classList.remove('hidden'); document.getElementById('ats-modal').classList.add('flex'); }
function closeATSModal() { document.getElementById('ats-modal').classList.add('hidden'); document.getElementById('ats-modal').classList.remove('flex'); }

async function runATSAnalysis() {
  var jd = document.getElementById('ats-jd').value.trim();
  if (!jd) return showToast('Paste a job description', 'error');
  var resumeId = document.getElementById('resume-id').value;
  if (!resumeId) return showToast('Save resume first', 'error');
  var btn = document.getElementById('ats-run-btn');
  btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Analyzing...';
  try {
    var res = await fetch('/resume/' + resumeId + '/analyze', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({ jobDescription: jd }) });
    var result = await res.json();
    if (result.success) {
      var a = result.analysis;
      var scoreColor = a.score >= 80 ? 'text-green-500' : a.score >= 60 ? 'text-yellow-500' : 'text-red-500';
      document.getElementById('ats-results').classList.remove('hidden');
      var html = '<div class="text-center mb-4"><div class="text-4xl font-bold ' + scoreColor + '">' + a.score + '%</div><div class="text-sm text-gray-500">ATS Score</div></div>';
      if (a.matchedKeywords?.length) html += '<div class="mb-3"><span class="text-xs font-bold text-gray-500">Matched Keywords:</span><div class="flex flex-wrap gap-1 mt-1">' + a.matchedKeywords.map(function(k){return '<span class="text-[10px] bg-green-50 text-green-600 px-2 py-0.5 rounded-full">'+k+'</span>';}).join('') + '</div></div>';
      if (a.missingKeywords?.length) html += '<div class="mb-3"><span class="text-xs font-bold text-gray-500">Missing Keywords:</span><div class="flex flex-wrap gap-1 mt-1">' + a.missingKeywords.map(function(k){return '<span class="text-[10px] bg-red-50 text-red-600 px-2 py-0.5 rounded-full">'+k+'</span>';}).join('') + '</div></div>';
      if (a.suggestions?.length) html += '<div class="mb-3"><span class="text-xs font-bold text-gray-500">Suggestions:</span><ul class="list-disc pl-4 mt-1 text-xs text-gray-600 space-y-1">' + a.suggestions.map(function(s){return '<li>'+s+'</li>';}).join('') + '</ul></div>';
      document.getElementById('ats-results').innerHTML = html;
    }
  } catch(err) { showToast('Analysis failed', 'error'); }
  btn.disabled = false; btn.innerHTML = '<i class="fas fa-chart-bar mr-2"></i>Analyze Resume';
}

// =================== PDF EXPORT ===================
async function exportPDF() {
  var resumeId = document.getElementById('resume-id').value;
  if (!resumeId) return showToast('Save resume first', 'error');
  showToast('Generating PDF...', 'success');
  try {
    var res = await fetch('/resume/' + resumeId + '/export');
    if (res.ok) {
      var blob = await res.blob();
      var url = URL.createObjectURL(blob);
      var a = document.createElement('a');
      a.href = url; a.download = (document.getElementById('resume-title').value || 'resume') + '.pdf';
      a.click(); URL.revokeObjectURL(url);
    } else {
      var err = await res.json();
      showToast(err.error || 'PDF export failed', 'error');
    }
  } catch(err) { showToast('PDF export failed', 'error'); }
}


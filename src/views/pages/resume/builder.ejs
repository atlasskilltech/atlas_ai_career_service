<style>
  #builder-app{display:flex;flex-direction:column;overflow:hidden}
  /* Desktop: fill viewport minus topbar+main padding */
  @media(min-width:1024px){#builder-app{height:calc(100vh - 100px)}}
  .drag-handle{cursor:grab}.drag-handle:active{cursor:grabbing}
  .sortable-ghost{opacity:0.4;background:#e0e7ff}
  .section-btn.active{background:var(--accent-light,#e0e7ff);color:var(--accent,#3b82f6);font-weight:600}
  .section-btn{transition:all 0.15s}
  .ai-btn{font-size:11px;color:#7c3aed;cursor:pointer;transition:opacity 0.15s}.ai-btn:hover{opacity:0.7}
  #preview-frame{border:none;width:100%;height:100%;background:white}
  /* Mobile tabs for switching panels */
  .mobile-tab{padding:8px 16px;font-size:13px;font-weight:500;border-radius:8px;transition:all 0.15s;color:#6b7280}
  .mobile-tab.active{background:#3b82f6;color:#fff;box-shadow:0 2px 8px rgba(59,130,246,0.3)}
  /* Resume sections sidebar toggle on tablet */
  #sections-panel{transition:all 0.3s ease}
  /* Card styling */
  .builder-card{background:white;border:1px solid #e5e7eb;border-radius:12px;overflow:hidden}
  .dark .builder-card{background:#1f2937;border-color:#374151}
</style>

<div id="builder-app">
  <!-- Top bar -->
  <div class="flex items-center justify-between mb-3 flex-shrink-0 gap-2">
    <div class="flex items-center gap-2 flex-1 min-w-0">
      <a href="/resume" class="text-gray-400 hover:text-gray-600 flex-shrink-0 p-1"><i class="fas fa-arrow-left"></i></a>
      <input type="text" id="resume-title" value="<%= resume ? resume.title : 'Untitled Resume' %>" class="text-sm sm:text-base font-bold bg-transparent border-none outline-none focus:ring-0 flex-1 min-w-0 truncate" placeholder="Resume Title">
    </div>
    <div class="flex items-center gap-1.5 sm:gap-2 flex-shrink-0">
      <span class="text-[10px] text-gray-400 hidden sm:inline" id="save-status"><i class="fas fa-check text-green-500"></i> Saved</span>
      <span class="text-[10px] text-gray-400 sm:hidden" id="save-status-mobile"><i class="fas fa-check text-green-500"></i></span>
      <select id="template-select" onchange="changeTemplate()" class="text-xs border border-gray-200 dark:border-gray-600 rounded-lg px-2 py-1.5 bg-white dark:bg-gray-800 hidden sm:block">
        <option value="modern" <%= resume?.template === 'modern' ? 'selected' : '' %>>Modern</option>
        <option value="professional" <%= resume?.template === 'professional' ? 'selected' : '' %>>Professional</option>
        <option value="minimal" <%= resume?.template === 'minimal' ? 'selected' : '' %>>Minimal</option>
        <option value="ats" <%= resume?.template === 'ats' ? 'selected' : '' %>>ATS Friendly</option>
      </select>
      <input type="color" id="theme-color" value="<%= resume?.theme_color || '#0a1a4a' %>" onchange="changeTemplate()" class="w-7 h-7 rounded cursor-pointer border-0 hidden sm:block" title="Theme Color">
      <button onclick="showUploadModal()" class="text-xs px-2.5 py-1.5 rounded-lg border border-gray-200 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition hidden sm:flex items-center gap-1" title="Upload existing resume"><i class="fas fa-upload"></i><span class="hidden md:inline">Upload</span></button>
      <% if (resume) { %>
        <button onclick="exportPDF()" class="text-xs px-2.5 py-1.5 rounded-lg border border-gray-200 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition hidden sm:flex items-center gap-1"><i class="fas fa-file-pdf"></i><span class="hidden md:inline">PDF</span></button>
      <% } %>
      <button onclick="saveResume()" class="text-xs px-3 py-1.5 rounded-lg bg-blue-600 text-white hover:bg-blue-700 transition flex items-center gap-1"><i class="fas fa-save"></i><span class="hidden sm:inline">Save</span></button>
      <!-- Mobile more menu -->
      <div class="relative sm:hidden">
        <button onclick="document.getElementById('mobile-more-menu').classList.toggle('hidden')" class="p-1.5 rounded-lg border border-gray-200 dark:border-gray-600 hover:bg-gray-50">
          <i class="fas fa-ellipsis-v text-xs text-gray-500"></i>
        </button>
        <div id="mobile-more-menu" class="hidden absolute right-0 top-full mt-1 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl shadow-lg py-2 w-48 z-50">
          <div class="px-3 py-2 flex items-center gap-2">
            <span class="text-xs text-gray-500">Template:</span>
            <select id="template-select-mobile" onchange="document.getElementById('template-select').value=this.value;changeTemplate()" class="text-xs border border-gray-200 dark:border-gray-600 rounded px-2 py-1 bg-white dark:bg-gray-800 flex-1">
              <option value="modern" <%= resume?.template === 'modern' ? 'selected' : '' %>>Modern</option>
              <option value="professional" <%= resume?.template === 'professional' ? 'selected' : '' %>>Professional</option>
              <option value="minimal" <%= resume?.template === 'minimal' ? 'selected' : '' %>>Minimal</option>
              <option value="ats" <%= resume?.template === 'ats' ? 'selected' : '' %>>ATS Friendly</option>
            </select>
          </div>
          <div class="px-3 py-2 flex items-center gap-2">
            <span class="text-xs text-gray-500">Color:</span>
            <input type="color" id="theme-color-mobile" value="<%= resume?.theme_color || '#0a1a4a' %>" onchange="document.getElementById('theme-color').value=this.value;changeTemplate()" class="w-6 h-6 rounded cursor-pointer border-0">
          </div>
          <% if (resume) { %>
            <button onclick="exportPDF();document.getElementById('mobile-more-menu').classList.add('hidden')" class="w-full text-left px-3 py-2 text-xs hover:bg-gray-50 dark:hover:bg-gray-700 flex items-center gap-2"><i class="fas fa-file-pdf w-4 text-center text-gray-400"></i>Export PDF</button>
          <% } %>
          <button onclick="showUploadModal();document.getElementById('mobile-more-menu').classList.add('hidden')" class="w-full text-left px-3 py-2 text-xs hover:bg-gray-50 dark:hover:bg-gray-700 flex items-center gap-2"><i class="fas fa-upload w-4 text-center text-blue-400"></i>Upload Resume</button>
          <button onclick="showATSModal();document.getElementById('mobile-more-menu').classList.add('hidden')" class="w-full text-left px-3 py-2 text-xs hover:bg-gray-50 dark:hover:bg-gray-700 flex items-center gap-2"><i class="fas fa-chart-bar w-4 text-center text-purple-400"></i>ATS Analyzer</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile/Tablet tab switcher -->
  <div class="flex gap-2 mb-3 lg:hidden flex-shrink-0 bg-gray-100 dark:bg-gray-800/50 p-1 rounded-xl">
    <button onclick="switchMobileTab('sections')" class="mobile-tab flex-1" data-tab="sections"><i class="fas fa-list mr-1.5"></i>Sections</button>
    <button onclick="switchMobileTab('editor')" class="mobile-tab flex-1 active" data-tab="editor"><i class="fas fa-edit mr-1.5"></i>Editor</button>
    <button onclick="switchMobileTab('preview')" class="mobile-tab flex-1" data-tab="preview"><i class="fas fa-eye mr-1.5"></i>Preview</button>
  </div>

  <!-- Main 3-col grid -->
  <div class="flex-1 grid grid-cols-1 lg:grid-cols-12 gap-3 min-h-0 overflow-hidden">

    <!-- SIDEBAR SECTIONS (3 cols) -->
    <div id="panel-sections" class="lg:col-span-3 flex-col min-h-0 overflow-hidden hidden lg:flex">
      <div class="builder-card p-3 flex-1 overflow-y-auto">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs font-bold text-gray-500 uppercase tracking-wider">Sections</span>
          <span class="text-[9px] text-gray-400"><i class="fas fa-grip-vertical mr-1"></i>Drag to reorder</span>
        </div>
        <nav id="section-list" class="space-y-0.5">
          <%
            const defaultOrder = ['profile','education','experience','projects','skills','achievements','certifications','languages','interests'];
            const sectionOrder = resume?.section_order || defaultOrder;
            const sectionMeta = {
              profile: { icon: 'fa-user', label: 'Profile' },
              education: { icon: 'fa-graduation-cap', label: 'Education' },
              experience: { icon: 'fa-briefcase', label: 'Experience' },
              projects: { icon: 'fa-code', label: 'Projects' },
              skills: { icon: 'fa-tools', label: 'Skills' },
              achievements: { icon: 'fa-trophy', label: 'Achievements' },
              certifications: { icon: 'fa-certificate', label: 'Certifications' },
              languages: { icon: 'fa-language', label: 'Languages' },
              interests: { icon: 'fa-heart', label: 'Interests' },
            };
          %>
          <% sectionOrder.forEach((key, idx) => { const meta = sectionMeta[key]; if (!meta) return; %>
            <button onclick="showSection('<%= key %>')" class="section-btn sidebar-link w-full text-left flex items-center gap-2 text-xs <%= idx === 0 ? 'active' : '' %>" data-section="<%= key %>">
              <i class="fas fa-grip-vertical drag-handle text-gray-300 text-[10px]"></i>
              <i class="fas <%= meta.icon %> w-4 text-center text-gray-400"></i>
              <span><%= meta.label %></span>
            </button>
          <% }); %>
        </nav>

        <!-- AI Tools -->
        <div class="mt-4 pt-3 border-t border-gray-200 dark:border-gray-700">
          <span class="text-[9px] font-bold text-gray-400 uppercase tracking-wider">AI Tools</span>
          <div class="space-y-0.5 mt-1">
            <button onclick="aiGenerateSummary()" class="sidebar-link w-full text-left text-xs flex items-center gap-2"><i class="fas fa-magic w-4 text-center text-purple-400"></i>Generate Summary</button>
            <button onclick="aiSuggestSkills()" class="sidebar-link w-full text-left text-xs flex items-center gap-2"><i class="fas fa-lightbulb w-4 text-center text-purple-400"></i>Suggest Skills</button>
            <button onclick="showATSModal()" class="sidebar-link w-full text-left text-xs flex items-center gap-2"><i class="fas fa-chart-bar w-4 text-center text-purple-400"></i>ATS Analyzer</button>
          </div>
        </div>

        <% if (resume) { %>
        <!-- Version History -->
        <div class="mt-4 pt-3 border-t border-gray-200 dark:border-gray-700">
          <div class="flex items-center justify-between">
            <span class="text-[9px] font-bold text-gray-400 uppercase tracking-wider">Versions</span>
            <button onclick="saveVersion()" class="text-[9px] text-purple-500 hover:underline">Save Version</button>
          </div>
          <div id="version-list" class="mt-1 space-y-0.5 max-h-24 overflow-y-auto">
            <% if (typeof versions !== 'undefined' && versions && versions.length > 0) { %>
              <% versions.forEach(v => { %>
                <button onclick="restoreVersion(<%= v.id %>)" class="text-[10px] text-gray-500 hover:text-blue-500 block w-full text-left px-2 py-0.5 rounded hover:bg-gray-50 dark:hover:bg-gray-700">
                  v<%= v.version_number %> — <%= new Date(v.created_at).toLocaleDateString('en-IN', { day:'numeric', month:'short', hour:'2-digit', minute:'2-digit' }) %>
                </button>
              <% }); %>
            <% } else { %>
              <p class="text-[10px] text-gray-400 italic px-2">No versions saved yet</p>
            <% } %>
          </div>
        </div>
        <% } %>
      </div>
    </div>

    <!-- EDITOR (5 cols) -->
    <div id="panel-editor" class="lg:col-span-5 flex flex-col min-h-0 overflow-hidden">
      <div class="builder-card flex-1 overflow-y-auto">
        <!-- Mobile section quick-nav -->
        <div class="lg:hidden sticky top-0 z-10 bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 px-3 py-2 overflow-x-auto">
          <div class="flex gap-1.5 min-w-max">
            <% sectionOrder.forEach((key, idx) => { const meta = sectionMeta[key]; if (!meta) return; %>
              <button onclick="showSection('<%= key %>')" class="section-btn text-[11px] px-2.5 py-1 rounded-full border border-gray-200 dark:border-gray-600 whitespace-nowrap flex items-center gap-1 <%= idx === 0 ? 'active' : '' %>" data-section="<%= key %>">
                <i class="fas <%= meta.icon %> text-[9px]"></i><%= meta.label %>
              </button>
            <% }); %>
          </div>
        </div>

        <div class="p-3 sm:p-4">
          <!-- Profile Section -->
          <div id="section-profile" class="section-content">
            <h3 class="font-semibold text-sm mb-3 flex items-center gap-2"><i class="fas fa-user text-gray-400"></i>Profile</h3>
            <div class="space-y-3">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                <div><label class="label-field text-xs">Full Name</label><input type="text" id="profile-name" class="input-field text-sm" value="<%= resume?.profile_data?.name || resume?.profile_data?.full_name || '' %>" placeholder="John Doe"></div>
                <div><label class="label-field text-xs">Headline</label><input type="text" id="profile-headline" class="input-field text-sm" value="<%= resume?.profile_data?.headline || '' %>" placeholder="Software Engineer"></div>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                <div><label class="label-field text-xs">Email</label><input type="email" id="profile-email" class="input-field text-sm" value="<%= resume?.profile_data?.email || '' %>" placeholder="john@email.com"></div>
                <div><label class="label-field text-xs">Phone</label><input type="tel" id="profile-phone" class="input-field text-sm" value="<%= resume?.profile_data?.phone || '' %>" placeholder="+91 98765 43210"></div>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                <div><label class="label-field text-xs">LinkedIn</label><input type="url" id="profile-linkedin" class="input-field text-sm" value="<%= resume?.profile_data?.linkedin || '' %>" placeholder="linkedin.com/in/johndoe"></div>
                <div><label class="label-field text-xs">GitHub</label><input type="url" id="profile-github" class="input-field text-sm" value="<%= resume?.profile_data?.github || '' %>" placeholder="github.com/johndoe"></div>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                <div><label class="label-field text-xs">Portfolio</label><input type="url" id="profile-website" class="input-field text-sm" value="<%= resume?.profile_data?.website || resume?.profile_data?.portfolio || '' %>" placeholder="johndoe.com"></div>
                <div><label class="label-field text-xs">Location</label><input type="text" id="profile-location" class="input-field text-sm" value="<%= resume?.profile_data?.location || '' %>" placeholder="Mumbai, India"></div>
              </div>
              <div>
                <div class="flex items-center justify-between">
                  <label class="label-field text-xs">Professional Summary</label>
                  <button onclick="aiGenerateSummary()" class="ai-btn"><i class="fas fa-magic mr-1"></i>AI Generate</button>
                </div>
                <textarea id="profile-summary" rows="3" class="input-field text-sm" placeholder="2-3 sentence summary..."><%= resume?.profile_data?.summary || '' %></textarea>
              </div>
            </div>
          </div>

          <!-- Education Section -->
          <div id="section-education" class="section-content hidden">
            <div class="flex items-center justify-between mb-3">
              <h3 class="font-semibold text-sm flex items-center gap-2"><i class="fas fa-graduation-cap text-gray-400"></i>Education</h3>
              <button onclick="addEntry('education')" class="text-xs text-blue-500 hover:underline"><i class="fas fa-plus mr-1"></i>Add</button>
            </div>
            <div id="education-list" class="space-y-3">
              <% const eduData = resume?.education_data || []; eduData.forEach((edu, i) => { %>
                <div class="p-3 bg-gray-50 dark:bg-gray-900/50 rounded-lg relative group" data-index="<%= i %>">
                  <button onclick="removeEntry(this)" class="absolute top-2 right-2 text-red-400 hover:text-red-600 text-xs opacity-0 group-hover:opacity-100 transition"><i class="fas fa-times"></i></button>
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 mb-2">
                    <input type="text" class="input-field text-xs edu-institution" value="<%= edu.institution || '' %>" placeholder="Institution">
                    <input type="text" class="input-field text-xs edu-degree" value="<%= edu.degree || '' %>" placeholder="Degree">
                  </div>
                  <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
                    <input type="text" class="input-field text-xs edu-field" value="<%= edu.field || '' %>" placeholder="Field of Study">
                    <input type="text" class="input-field text-xs edu-year" value="<%= edu.year || (edu.start_year && edu.end_year ? edu.start_year+' - '+edu.end_year : '') %>" placeholder="Year(s)">
                    <input type="text" class="input-field text-xs edu-gpa" value="<%= edu.gpa || edu.cgpa || '' %>" placeholder="GPA/CGPA">
                  </div>
                </div>
              <% }); %>
            </div>
          </div>

          <!-- Experience Section -->
          <div id="section-experience" class="section-content hidden">
            <div class="flex items-center justify-between mb-3">
              <h3 class="font-semibold text-sm flex items-center gap-2"><i class="fas fa-briefcase text-gray-400"></i>Experience</h3>
              <button onclick="addEntry('experience')" class="text-xs text-blue-500 hover:underline"><i class="fas fa-plus mr-1"></i>Add</button>
            </div>
            <div id="experience-list" class="space-y-3">
              <% const expData = resume?.experience_data || []; expData.forEach((exp, i) => { %>
                <div class="p-3 bg-gray-50 dark:bg-gray-900/50 rounded-lg relative group" data-index="<%= i %>">
                  <button onclick="removeEntry(this)" class="absolute top-2 right-2 text-red-400 hover:text-red-600 text-xs opacity-0 group-hover:opacity-100 transition"><i class="fas fa-times"></i></button>
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 mb-2">
                    <input type="text" class="input-field text-xs exp-title" value="<%= exp.title || exp.role || '' %>" placeholder="Job Title">
                    <input type="text" class="input-field text-xs exp-company" value="<%= exp.company || '' %>" placeholder="Company">
                  </div>
                  <div class="grid grid-cols-1 sm:grid-cols-3 gap-2 mb-2">
                    <input type="text" class="input-field text-xs exp-location" value="<%= exp.location || '' %>" placeholder="Location">
                    <input type="text" class="input-field text-xs exp-start" value="<%= exp.startDate || exp.start_date || '' %>" placeholder="Start Date">
                    <input type="text" class="input-field text-xs exp-end" value="<%= exp.endDate || exp.end_date || '' %>" placeholder="End Date">
                  </div>
                  <textarea class="input-field text-xs exp-desc" rows="3" placeholder="Bullet points / description"><%= exp.description || '' %></textarea>
                  <button onclick="aiGenerateBullets(this)" class="ai-btn mt-1"><i class="fas fa-magic mr-1"></i>AI Generate Bullets</button>
                </div>
              <% }); %>
            </div>
          </div>

          <!-- Projects Section -->
          <div id="section-projects" class="section-content hidden">
            <div class="flex items-center justify-between mb-3">
              <h3 class="font-semibold text-sm flex items-center gap-2"><i class="fas fa-code text-gray-400"></i>Projects</h3>
              <button onclick="addEntry('projects')" class="text-xs text-blue-500 hover:underline"><i class="fas fa-plus mr-1"></i>Add</button>
            </div>
            <div id="projects-list" class="space-y-3">
              <% const projData = resume?.projects_data || []; projData.forEach((proj, i) => { %>
                <div class="p-3 bg-gray-50 dark:bg-gray-900/50 rounded-lg relative group" data-index="<%= i %>">
                  <button onclick="removeEntry(this)" class="absolute top-2 right-2 text-red-400 hover:text-red-600 text-xs opacity-0 group-hover:opacity-100 transition"><i class="fas fa-times"></i></button>
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 mb-2">
                    <input type="text" class="input-field text-xs proj-name" value="<%= proj.name || proj.project_name || '' %>" placeholder="Project Name">
                    <input type="text" class="input-field text-xs proj-tech" value="<%= proj.technologies || '' %>" placeholder="Technologies">
                  </div>
                  <textarea class="input-field text-xs proj-desc" rows="2" placeholder="Description"><%= proj.description || '' %></textarea>
                  <input type="url" class="input-field text-xs mt-2 proj-url" value="<%= proj.url || proj.github_link || '' %>" placeholder="GitHub / Live URL">
                  <button onclick="aiGenerateProjectDesc(this)" class="ai-btn mt-1"><i class="fas fa-magic mr-1"></i>AI Improve Description</button>
                </div>
              <% }); %>
            </div>
          </div>

          <!-- Skills Section -->
          <div id="section-skills" class="section-content hidden">
            <div class="flex items-center justify-between mb-3">
              <h3 class="font-semibold text-sm flex items-center gap-2"><i class="fas fa-tools text-gray-400"></i>Skills</h3>
              <button onclick="aiSuggestSkills()" class="ai-btn"><i class="fas fa-magic mr-1"></i>AI Suggest</button>
            </div>
            <div class="space-y-3">
              <div><label class="label-field text-xs">Technical Skills</label><textarea id="skills-technical" rows="2" class="input-field text-xs" placeholder="JavaScript, Python, React, Node.js..."><%= resume?.skills_data?.technical || '' %></textarea></div>
              <div><label class="label-field text-xs">Soft Skills</label><textarea id="skills-soft" rows="2" class="input-field text-xs" placeholder="Leadership, Communication..."><%= resume?.skills_data?.soft || '' %></textarea></div>
              <div><label class="label-field text-xs">Tools & Frameworks</label><textarea id="skills-tools" rows="2" class="input-field text-xs" placeholder="Git, Docker, AWS, Figma..."><%= resume?.skills_data?.tools || '' %></textarea></div>
              <div><label class="label-field text-xs">Languages</label><textarea id="skills-languages" rows="1" class="input-field text-xs" placeholder="English, Hindi..."><%= resume?.skills_data?.languages || '' %></textarea></div>
            </div>
          </div>

          <!-- Achievements Section -->
          <div id="section-achievements" class="section-content hidden">
            <div class="flex items-center justify-between mb-3">
              <h3 class="font-semibold text-sm flex items-center gap-2"><i class="fas fa-trophy text-gray-400"></i>Achievements</h3>
              <button onclick="addEntry('achievements')" class="text-xs text-blue-500 hover:underline"><i class="fas fa-plus mr-1"></i>Add</button>
            </div>
            <div id="achievements-list" class="space-y-2">
              <% const achData = resume?.achievements_data || []; achData.forEach((ach, i) => { %>
                <div class="flex gap-2 items-center group" data-index="<%= i %>">
                  <input type="text" class="input-field text-xs flex-1 ach-text" value="<%= typeof ach === 'string' ? ach : ach.achievement_text || '' %>" placeholder="Achievement">
                  <button onclick="aiRewriteAchievement(this)" class="ai-btn flex-shrink-0" title="AI Rewrite"><i class="fas fa-magic"></i></button>
                  <button onclick="removeEntry(this)" class="text-red-400 hover:text-red-600 text-xs flex-shrink-0 opacity-0 group-hover:opacity-100"><i class="fas fa-times"></i></button>
                </div>
              <% }); %>
            </div>
          </div>

          <!-- Certifications Section -->
          <div id="section-certifications" class="section-content hidden">
            <div class="flex items-center justify-between mb-3">
              <h3 class="font-semibold text-sm flex items-center gap-2"><i class="fas fa-certificate text-gray-400"></i>Certifications</h3>
              <button onclick="addEntry('certifications')" class="text-xs text-blue-500 hover:underline"><i class="fas fa-plus mr-1"></i>Add</button>
            </div>
            <div id="certifications-list" class="space-y-3">
              <% const certData = resume?.certifications_data || []; certData.forEach((cert, i) => { %>
                <div class="p-3 bg-gray-50 dark:bg-gray-900/50 rounded-lg relative group" data-index="<%= i %>">
                  <button onclick="removeEntry(this)" class="absolute top-2 right-2 text-red-400 hover:text-red-600 text-xs opacity-0 group-hover:opacity-100 transition"><i class="fas fa-times"></i></button>
                  <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
                    <input type="text" class="input-field text-xs cert-name" value="<%= cert.name || cert.cert_name || '' %>" placeholder="Certification Name">
                    <input type="text" class="input-field text-xs cert-org" value="<%= cert.organization || '' %>" placeholder="Organization">
                    <input type="text" class="input-field text-xs cert-date" value="<%= cert.date || cert.issue_date || '' %>" placeholder="Date">
                  </div>
                </div>
              <% }); %>
            </div>
          </div>

          <!-- Languages Section -->
          <div id="section-languages" class="section-content hidden">
            <div class="flex items-center justify-between mb-3">
              <h3 class="font-semibold text-sm flex items-center gap-2"><i class="fas fa-language text-gray-400"></i>Languages</h3>
              <button onclick="addEntry('languages')" class="text-xs text-blue-500 hover:underline"><i class="fas fa-plus mr-1"></i>Add</button>
            </div>
            <div id="languages-list" class="space-y-2">
              <% const langData = resume?.languages_data || []; langData.forEach((lang, i) => { %>
                <div class="flex gap-2 items-center group" data-index="<%= i %>">
                  <input type="text" class="input-field text-xs flex-1 lang-name" value="<%= lang.language || lang.name || '' %>" placeholder="Language">
                  <select class="input-field text-xs w-32 lang-level">
                    <option value="Native" <%= (lang.proficiency||lang.level)==='Native'?'selected':'' %>>Native</option>
                    <option value="Fluent" <%= (lang.proficiency||lang.level)==='Fluent'?'selected':'' %>>Fluent</option>
                    <option value="Advanced" <%= (lang.proficiency||lang.level)==='Advanced'?'selected':'' %>>Advanced</option>
                    <option value="Intermediate" <%= (lang.proficiency||lang.level)==='Intermediate'?'selected':'' %>>Intermediate</option>
                    <option value="Basic" <%= (lang.proficiency||lang.level)==='Basic'?'selected':'' %>>Basic</option>
                  </select>
                  <button onclick="removeEntry(this)" class="text-red-400 hover:text-red-600 text-xs flex-shrink-0 opacity-0 group-hover:opacity-100"><i class="fas fa-times"></i></button>
                </div>
              <% }); %>
            </div>
          </div>

          <!-- Interests Section -->
          <div id="section-interests" class="section-content hidden">
            <h3 class="font-semibold text-sm mb-3 flex items-center gap-2"><i class="fas fa-heart text-gray-400"></i>Interests</h3>
            <textarea id="interests-text" rows="3" class="input-field text-xs" placeholder="Open Source, Machine Learning, Photography... (comma separated)"><%= (resume?.interests_data || []).map(i => typeof i === 'string' ? i : i.name || '').join(', ') %></textarea>
          </div>

          <!-- Mobile AI Tools row -->
          <div class="lg:hidden mt-4 pt-3 border-t border-gray-200 dark:border-gray-700">
            <div class="flex flex-wrap gap-2">
              <button onclick="aiGenerateSummary()" class="text-xs px-3 py-1.5 rounded-lg bg-purple-50 dark:bg-purple-900/20 text-purple-600 flex items-center gap-1"><i class="fas fa-magic"></i>Summary</button>
              <button onclick="aiSuggestSkills()" class="text-xs px-3 py-1.5 rounded-lg bg-purple-50 dark:bg-purple-900/20 text-purple-600 flex items-center gap-1"><i class="fas fa-lightbulb"></i>Skills</button>
              <button onclick="showATSModal()" class="text-xs px-3 py-1.5 rounded-lg bg-purple-50 dark:bg-purple-900/20 text-purple-600 flex items-center gap-1"><i class="fas fa-chart-bar"></i>ATS</button>
              <% if (resume) { %>
                <button onclick="saveVersion()" class="text-xs px-3 py-1.5 rounded-lg bg-blue-50 dark:bg-blue-900/20 text-blue-600 flex items-center gap-1"><i class="fas fa-history"></i>Save Version</button>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- PREVIEW (4 cols) -->
    <div id="panel-preview" class="lg:col-span-4 flex-col min-h-0 overflow-hidden hidden lg:flex">
      <div class="builder-card flex-1 overflow-hidden flex flex-col">
        <div class="flex items-center justify-between px-3 py-2 border-b border-gray-200 dark:border-gray-700 flex-shrink-0">
          <span class="text-xs font-bold text-gray-500">Live Preview</span>
          <div class="flex items-center gap-2">
            <% if (resume) { %>
              <a href="/resume/<%= resume.id %>/preview" target="_blank" class="text-[10px] text-blue-500 hover:underline"><i class="fas fa-external-link-alt mr-1"></i>Full</a>
            <% } %>
          </div>
        </div>
        <div class="flex-1 overflow-auto bg-gray-100 dark:bg-gray-900 p-2">
          <div id="resume-preview" class="bg-white shadow-sm rounded" style="transform-origin:top left;">
            <iframe id="preview-frame" sandbox="allow-same-origin" style="width:800px;min-height:1000px;border:none;pointer-events:none;display:block"></iframe>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>


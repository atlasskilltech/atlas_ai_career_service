<input type="hidden" id="resume-id" value="<%= resume ? resume.id : '' %>">

<!-- SortableJS CDN -->
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>

<script>
// =================== STATE ===================
var autoSaveTimer = null;
var lastSaveData = '';
var currentMobileTab = 'editor';

// =================== MOBILE TAB SWITCHING ===================
function switchMobileTab(tab) {
  currentMobileTab = tab;
  var panels = ['sections','editor','preview'];
  panels.forEach(function(p) {
    var el = document.getElementById('panel-' + p);
    if (!el) return;
    if (p === tab) {
      el.classList.remove('hidden');
      el.classList.add('flex');
    } else {
      el.classList.add('hidden');
      el.classList.remove('flex');
    }
  });
  // Update tab buttons
  document.querySelectorAll('.mobile-tab').forEach(function(btn) {
    if (btn.dataset.tab === tab) btn.classList.add('active');
    else btn.classList.remove('active');
  });
  // Scale preview when switching to it
  if (tab === 'preview') {
    setTimeout(function() { updatePreview(); scalePreview(); }, 100);
  }
}

// =================== SECTION NAV ===================
function showSection(name) {
  document.querySelectorAll('.section-content').forEach(function(s) { s.classList.add('hidden'); });
  document.querySelectorAll('.section-btn').forEach(function(b) { b.classList.remove('active'); });
  var sec = document.getElementById('section-' + name);
  if (sec) sec.classList.remove('hidden');
  document.querySelectorAll('[data-section="' + name + '"]').forEach(function(btn) { btn.classList.add('active'); });
  // On mobile, switch to editor tab
  if (window.innerWidth < 1024 && currentMobileTab === 'sections') {
    switchMobileTab('editor');
  }
}

// =================== SORTABLE DRAG-DROP ===================
document.addEventListener('DOMContentLoaded', function() {
  var sectionList = document.getElementById('section-list');
  if (sectionList && typeof Sortable !== 'undefined') {
    new Sortable(sectionList, {
      animation: 150,
      handle: '.drag-handle',
      ghostClass: 'sortable-ghost',
      onEnd: function() { triggerAutoSave(); }
    });
  }
  setupAutoSave();
  updatePreview();
  // Close mobile more menu when clicking outside
  document.addEventListener('click', function(e) {
    var menu = document.getElementById('mobile-more-menu');
    if (menu && !menu.parentElement.contains(e.target)) {
      menu.classList.add('hidden');
    }
  });
});

// =================== ADD/REMOVE ENTRIES ===================
function addEntry(type) {
  var templates = {
    education: '<div class="p-3 bg-gray-50 dark:bg-gray-900/50 rounded-lg relative group"><button onclick="removeEntry(this)" class="absolute top-2 right-2 text-red-400 hover:text-red-600 text-xs opacity-0 group-hover:opacity-100 transition"><i class="fas fa-times"></i></button><div class="grid grid-cols-1 sm:grid-cols-2 gap-2 mb-2"><input type="text" class="input-field text-xs edu-institution" placeholder="Institution"><input type="text" class="input-field text-xs edu-degree" placeholder="Degree"></div><div class="grid grid-cols-1 sm:grid-cols-3 gap-2"><input type="text" class="input-field text-xs edu-field" placeholder="Field"><input type="text" class="input-field text-xs edu-year" placeholder="Year(s)"><input type="text" class="input-field text-xs edu-gpa" placeholder="GPA"></div></div>',
    experience: '<div class="p-3 bg-gray-50 dark:bg-gray-900/50 rounded-lg relative group"><button onclick="removeEntry(this)" class="absolute top-2 right-2 text-red-400 hover:text-red-600 text-xs opacity-0 group-hover:opacity-100 transition"><i class="fas fa-times"></i></button><div class="grid grid-cols-1 sm:grid-cols-2 gap-2 mb-2"><input type="text" class="input-field text-xs exp-title" placeholder="Job Title"><input type="text" class="input-field text-xs exp-company" placeholder="Company"></div><div class="grid grid-cols-1 sm:grid-cols-3 gap-2 mb-2"><input type="text" class="input-field text-xs exp-location" placeholder="Location"><input type="text" class="input-field text-xs exp-start" placeholder="Start Date"><input type="text" class="input-field text-xs exp-end" placeholder="End Date"></div><textarea class="input-field text-xs exp-desc" rows="3" placeholder="Description"></textarea><button onclick="aiGenerateBullets(this)" class="ai-btn mt-1"><i class="fas fa-magic mr-1"></i>AI Generate Bullets</button></div>',
    projects: '<div class="p-3 bg-gray-50 dark:bg-gray-900/50 rounded-lg relative group"><button onclick="removeEntry(this)" class="absolute top-2 right-2 text-red-400 hover:text-red-600 text-xs opacity-0 group-hover:opacity-100 transition"><i class="fas fa-times"></i></button><div class="grid grid-cols-1 sm:grid-cols-2 gap-2 mb-2"><input type="text" class="input-field text-xs proj-name" placeholder="Project Name"><input type="text" class="input-field text-xs proj-tech" placeholder="Technologies"></div><textarea class="input-field text-xs proj-desc" rows="2" placeholder="Description"></textarea><input type="url" class="input-field text-xs mt-2 proj-url" placeholder="URL"><button onclick="aiGenerateProjectDesc(this)" class="ai-btn mt-1"><i class="fas fa-magic mr-1"></i>AI Improve</button></div>',
    achievements: '<div class="flex gap-2 items-center group"><input type="text" class="input-field text-xs flex-1 ach-text" placeholder="Achievement"><button onclick="aiRewriteAchievement(this)" class="ai-btn flex-shrink-0"><i class="fas fa-magic"></i></button><button onclick="removeEntry(this)" class="text-red-400 hover:text-red-600 text-xs flex-shrink-0 opacity-0 group-hover:opacity-100"><i class="fas fa-times"></i></button></div>',
    certifications: '<div class="p-3 bg-gray-50 dark:bg-gray-900/50 rounded-lg relative group"><button onclick="removeEntry(this)" class="absolute top-2 right-2 text-red-400 hover:text-red-600 text-xs opacity-0 group-hover:opacity-100 transition"><i class="fas fa-times"></i></button><div class="grid grid-cols-1 sm:grid-cols-3 gap-2"><input type="text" class="input-field text-xs cert-name" placeholder="Name"><input type="text" class="input-field text-xs cert-org" placeholder="Organization"><input type="text" class="input-field text-xs cert-date" placeholder="Date"></div></div>',
    languages: '<div class="flex gap-2 items-center group"><input type="text" class="input-field text-xs flex-1 lang-name" placeholder="Language"><select class="input-field text-xs w-32 lang-level"><option>Native</option><option>Fluent</option><option>Advanced</option><option selected>Intermediate</option><option>Basic</option></select><button onclick="removeEntry(this)" class="text-red-400 hover:text-red-600 text-xs flex-shrink-0 opacity-0 group-hover:opacity-100"><i class="fas fa-times"></i></button></div>',
  };
  var list = document.getElementById(type + '-list');
  if (list && templates[type]) list.insertAdjacentHTML('beforeend', templates[type]);
  triggerAutoSave();
}

function removeEntry(btn) {
  var entry = btn.closest('[class*="bg-gray"], .flex');
  if (entry) { entry.remove(); triggerAutoSave(); }
}

// =================== DATA COLLECTION ===================
function collectResumeData() {
  var sectionOrder = Array.from(document.querySelectorAll('#section-list .section-btn')).map(function(b) { return b.dataset.section; }).filter(Boolean);
  // Fallback if section-list not visible (mobile)
  if (!sectionOrder.length) {
    sectionOrder = ['profile','education','experience','projects','skills','achievements','certifications','languages','interests'];
  }

  return {
    title: document.getElementById('resume-title').value,
    template: document.getElementById('template-select').value,
    theme_color: document.getElementById('theme-color').value,
    section_order: sectionOrder,
    profile_data: {
      name: document.getElementById('profile-name').value,
      headline: document.getElementById('profile-headline').value,
      email: document.getElementById('profile-email').value,
      phone: document.getElementById('profile-phone').value,
      linkedin: document.getElementById('profile-linkedin').value,
      github: document.getElementById('profile-github').value,
      website: document.getElementById('profile-website').value,
      location: document.getElementById('profile-location').value,
      summary: document.getElementById('profile-summary').value,
    },
    education_data: Array.from(document.querySelectorAll('#education-list > div')).map(function(el) { return {
      institution: el.querySelector('.edu-institution')?.value || '',
      degree: el.querySelector('.edu-degree')?.value || '',
      field: el.querySelector('.edu-field')?.value || '',
      year: el.querySelector('.edu-year')?.value || '',
      gpa: el.querySelector('.edu-gpa')?.value || '',
    }; }).filter(function(e) { return e.institution || e.degree; }),
    experience_data: Array.from(document.querySelectorAll('#experience-list > div')).map(function(el) { return {
      title: el.querySelector('.exp-title')?.value || '',
      company: el.querySelector('.exp-company')?.value || '',
      location: el.querySelector('.exp-location')?.value || '',
      startDate: el.querySelector('.exp-start')?.value || '',
      endDate: el.querySelector('.exp-end')?.value || '',
      description: el.querySelector('.exp-desc')?.value || '',
    }; }).filter(function(e) { return e.title || e.company; }),
    projects_data: Array.from(document.querySelectorAll('#projects-list > div')).map(function(el) { return {
      name: el.querySelector('.proj-name')?.value || '',
      technologies: el.querySelector('.proj-tech')?.value || '',
      description: el.querySelector('.proj-desc')?.value || '',
      url: el.querySelector('.proj-url')?.value || '',
    }; }).filter(function(e) { return e.name; }),
    skills_data: {
      technical: document.getElementById('skills-technical').value,
      soft: document.getElementById('skills-soft').value,
      tools: document.getElementById('skills-tools').value,
      languages: document.getElementById('skills-languages').value,
    },
    achievements_data: Array.from(document.querySelectorAll('.ach-text')).map(function(el) { return el.value; }).filter(Boolean),
    certifications_data: Array.from(document.querySelectorAll('#certifications-list > div')).map(function(el) { return {
      name: el.querySelector('.cert-name')?.value || '',
      organization: el.querySelector('.cert-org')?.value || '',
      date: el.querySelector('.cert-date')?.value || '',
    }; }).filter(function(e) { return e.name; }),
    languages_data: Array.from(document.querySelectorAll('#languages-list > div, #languages-list > .flex')).map(function(el) { return {
      language: el.querySelector('.lang-name')?.value || '',
      proficiency: el.querySelector('.lang-level')?.value || '',
    }; }).filter(function(e) { return e.language; }),
    interests_data: (document.getElementById('interests-text')?.value || '').split(',').map(function(s) { return s.trim(); }).filter(Boolean),
  };
}

// =================== SAVE ===================
async function saveResume() {
  var resumeId = document.getElementById('resume-id').value;
  var data = collectResumeData();
  var url = resumeId ? '/resume/' + resumeId : '/resume';
  var method = resumeId ? 'PUT' : 'POST';

  var statusEl = document.getElementById('save-status');
  var statusMobile = document.getElementById('save-status-mobile');
  if (statusEl) statusEl.innerHTML = '<i class="fas fa-spinner fa-spin text-blue-500"></i> Saving...';
  if (statusMobile) statusMobile.innerHTML = '<i class="fas fa-spinner fa-spin text-blue-500"></i>';

  try {
    var res = await fetch(url, { method: method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
    var result = await res.json();
    if (res.ok) {
      if (!resumeId && result.id) {
        document.getElementById('resume-id').value = result.id;
        window.history.replaceState({}, '', '/resume/' + result.id + '/edit');
      }
      if (statusEl) statusEl.innerHTML = '<i class="fas fa-check text-green-500"></i> Saved';
      if (statusMobile) statusMobile.innerHTML = '<i class="fas fa-check text-green-500"></i>';
      lastSaveData = JSON.stringify(data);
    } else {
      if (statusEl) statusEl.innerHTML = '<i class="fas fa-exclamation-triangle text-red-500"></i> Error';
      if (statusMobile) statusMobile.innerHTML = '<i class="fas fa-exclamation-triangle text-red-500"></i>';
    }
  } catch(err) {
    if (statusEl) statusEl.innerHTML = '<i class="fas fa-exclamation-triangle text-red-500"></i> Error';
    if (statusMobile) statusMobile.innerHTML = '<i class="fas fa-exclamation-triangle text-red-500"></i>';
  }
}

// =================== AUTO-SAVE (every 5s) ===================
function setupAutoSave() {
  lastSaveData = JSON.stringify(collectResumeData());
  setInterval(function() {
    var current = JSON.stringify(collectResumeData());
    if (current !== lastSaveData) {
      saveResume();
      updatePreview();
    }
  }, 5000);
}

function triggerAutoSave() {
  clearTimeout(autoSaveTimer);
  autoSaveTimer = setTimeout(function() { updatePreview(); }, 300);
}

// Listen for input changes
document.addEventListener('input', function(e) {
  if (e.target.closest('#builder-app')) triggerAutoSave();
});

// =================== LIVE PREVIEW ===================
function updatePreview() {
  var data = collectResumeData();
  var frame = document.getElementById('preview-frame');
  if (!frame) return;
  var html = buildPreviewHTML(data);
  frame.srcdoc = html;
  scalePreview();
}

function scalePreview() {
  var container = document.getElementById('resume-preview');
  if (!container) return;
  var parent = container.parentElement;
  if (!parent) return;
  var scale = Math.min((parent.clientWidth - 16) / 800, 1);
  container.style.transform = 'scale(' + scale + ')';
  container.style.width = '800px';
}

function buildPreviewHTML(data) {
  var template = data.template || 'modern';
  var color = data.theme_color || '#0a1a4a';
  var p = data.profile_data || {};
  var esc = function(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); };
  var order = data.section_order || ['profile','education','experience','projects','skills','achievements','certifications','languages','interests'];

  var renderSec = function(key) {
    switch(key) {
      case 'education': return (data.education_data||[]).length ? '<h2>EDUCATION</h2>' + (data.education_data||[]).map(function(e){return '<div class="entry"><div class="eh"><span>'+esc(e.institution)+'</span><span>'+esc(e.year)+'</span></div><div class="es">'+esc(e.degree)+(e.field?' in '+esc(e.field):'')+(e.gpa?' | GPA: '+esc(e.gpa):'')+'</div></div>';}).join('') : '';
      case 'experience': return (data.experience_data||[]).length ? '<h2>EXPERIENCE</h2>' + (data.experience_data||[]).map(function(e){return '<div class="entry"><div class="eh"><span>'+esc(e.title)+' — '+esc(e.company)+'</span><span>'+esc(e.startDate)+' - '+esc(e.endDate||'Present')+'</span></div>'+(e.location?'<div class="es">'+esc(e.location)+'</div>':'')+'<div class="ed">'+esc(e.description)+'</div></div>';}).join('') : '';
      case 'projects': return (data.projects_data||[]).length ? '<h2>PROJECTS</h2>' + (data.projects_data||[]).map(function(pr){return '<div class="entry"><div class="eh"><span>'+esc(pr.name)+'</span><span>'+esc(pr.technologies)+'</span></div><div class="ed">'+esc(pr.description)+'</div></div>';}).join('') : '';
      case 'skills': var s=data.skills_data||{}; return (s.technical||s.soft||s.tools||s.languages)?'<h2>SKILLS</h2><div class="sg">'+(s.technical?'<div><b>Technical:</b> '+esc(s.technical)+'</div>':'')+(s.tools?'<div><b>Tools:</b> '+esc(s.tools)+'</div>':'')+(s.soft?'<div><b>Soft Skills:</b> '+esc(s.soft)+'</div>':'')+(s.languages?'<div><b>Languages:</b> '+esc(s.languages)+'</div>':'')+'</div>':'';
      case 'achievements': return (data.achievements_data||[]).length?'<h2>ACHIEVEMENTS</h2><ul>'+(data.achievements_data||[]).map(function(a){return '<li>'+esc(a)+'</li>';}).join('')+'</ul>':'';
      case 'certifications': return (data.certifications_data||[]).length?'<h2>CERTIFICATIONS</h2><ul>'+(data.certifications_data||[]).map(function(c){return '<li><b>'+esc(c.name)+'</b>'+(c.organization?' — '+esc(c.organization):'')+(c.date?' ('+esc(c.date)+')':'')+'</li>';}).join('')+'</ul>':'';
      case 'languages': return (data.languages_data||[]).length?'<h2>LANGUAGES</h2><div class="sg">'+(data.languages_data||[]).map(function(l){return '<div>'+esc(l.language)+' — '+esc(l.proficiency)+'</div>';}).join('')+'</div>':'';
      case 'interests': return (data.interests_data||[]).length?'<h2>INTERESTS</h2><p>'+(data.interests_data||[]).map(function(i){return esc(typeof i==='string'?i:i.name||'');}).join(', ')+'</p>':'';
      default: return '';
    }
  };

  var fontFamily = template==='professional'?'"Georgia",serif':template==='minimal'?'"Helvetica Neue","Arial",sans-serif':'"Calibri","Segoe UI",sans-serif';
  var contact = [p.email,p.phone,p.location,p.linkedin,p.github,p.website].filter(Boolean).join(' | ');

  var html = '<!DOCTYPE html><html><head><meta charset="UTF-8"><style>';
  html += '*{margin:0;padding:0;box-sizing:border-box}body{font-family:' + fontFamily + ';color:#333;line-height:1.5;padding:28px 32px;font-size:12.5px}';
  html += 'h1{font-size:' + (template==='minimal'?'20px':'24px') + ';text-align:' + (template==='professional'?'left':'center') + ';margin-bottom:1px;color:' + (template==='minimal'?'#333':color) + ';letter-spacing:' + (template==='professional'?'2px':'0') + ';text-transform:' + (template==='professional'?'uppercase':'none') + '}';
  html += '.hl{text-align:' + (template==='professional'?'left':'center') + ';font-size:12px;color:#555;font-style:italic;margin-bottom:1px}';
  html += '.ct{text-align:' + (template==='professional'?'left':'center') + ';font-size:10.5px;color:#666;margin-bottom:10px}';
  html += '.sm{font-size:11.5px;color:#444;margin-bottom:12px;' + (template==='professional'?'border-left:3px solid '+color+';padding-left:10px;':'') + '}';
  html += 'h2{font-size:11px;text-transform:uppercase;letter-spacing:1.5px;border-bottom:' + (template==='minimal'?'1px solid #ddd':template==='ats'?'1px solid #333':'2px solid '+color) + ';padding-bottom:2px;margin:12px 0 6px;color:' + (template==='minimal'?'#555':color) + ';font-weight:700}';
  html += '.entry{margin-bottom:8px}.eh{display:flex;justify-content:space-between;font-weight:600;font-size:12px}.es{font-style:italic;font-size:10.5px;color:#555}';
  html += '.ed{font-size:11.5px;margin-top:2px;white-space:pre-line}.sg{display:grid;grid-template-columns:1fr 1fr;gap:3px 14px;font-size:11.5px}';
  html += 'ul{padding-left:16px;font-size:11.5px}li{margin-bottom:2px}p{font-size:11.5px}b{font-weight:600}';
  html += '</style></head><body>';
  html += '<h1>' + esc(p.name||'Your Name') + '</h1>';
  html += (p.headline ? '<div class="hl">' + esc(p.headline) + '</div>' : '');
  html += '<div class="ct">' + (contact || 'email@example.com | +91 98765 43210') + '</div>';
  html += (p.summary ? '<div class="sm">' + esc(p.summary) + '</div>' : '');
  html += order.filter(function(k){return k!=='profile';}).map(renderSec).filter(Boolean).join('');
  html += '</body></html>';
  return html;
}


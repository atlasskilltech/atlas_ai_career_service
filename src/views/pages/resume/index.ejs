<div class="space-y-6">
  <div class="flex items-center justify-between flex-wrap gap-4">
    <div>
      <h1 class="text-2xl font-bold">Resume Builder</h1>
      <p class="text-sm text-gray-500 mt-1">Create ATS-optimized resumes with AI assistance</p>
    </div>
    <a href="/resume/new" class="btn-primary"><i class="fas fa-plus mr-2"></i>New Resume</a>
  </div>

  <% if (!resumes || resumes.length === 0) { %>
    <div class="card text-center py-16">
      <i class="fas fa-file-alt text-6xl text-gray-300 dark:text-gray-600 mb-4"></i>
      <h3 class="text-xl font-semibold text-gray-600 dark:text-gray-300">No resumes yet</h3>
      <p class="text-gray-400 mt-2 mb-6">Create your first ATS-optimized resume with AI help</p>
      <a href="/resume/new" class="btn-accent inline-block"><i class="fas fa-magic mr-2"></i>Create Resume</a>
    </div>
  <% } else { %>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      <% resumes.forEach(resume => { %>
        <div class="card hover:shadow-md transition-shadow relative">
          <% if (resume.is_primary) { %>
            <span class="absolute top-3 right-3 text-[10px] bg-green-100 dark:bg-green-900/30 text-green-600 dark:text-green-400 px-2 py-0.5 rounded-full font-semibold"><i class="fas fa-star mr-1"></i>Primary</span>
          <% } %>
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-blue-500 to-purple-500 flex items-center justify-center text-white text-sm font-bold">
              <%= resume.title ? resume.title.charAt(0).toUpperCase() : 'R' %>
            </div>
            <div class="min-w-0 flex-1">
              <h3 class="font-semibold text-sm truncate"><%= resume.title || 'Untitled Resume' %></h3>
              <p class="text-[10px] text-gray-400">Updated <%= new Date(resume.updated_at).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></p>
            </div>
          </div>
          <div class="flex items-center gap-2 mb-3">
            <span class="text-[10px] px-2 py-0.5 rounded-full bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 capitalize"><%= resume.template || 'modern' %></span>
            <% if (resume.ats_score > 0) { %>
              <span class="text-[10px] px-2 py-0.5 rounded-full font-semibold
                <%= resume.ats_score >= 80 ? 'bg-green-50 dark:bg-green-900/30 text-green-600 dark:text-green-400' : resume.ats_score >= 60 ? 'bg-yellow-50 dark:bg-yellow-900/30 text-yellow-600 dark:text-yellow-400' : 'bg-red-50 dark:bg-red-900/30 text-red-600 dark:text-red-400' %>">
                ATS: <%= resume.ats_score %>%
              </span>
            <% } %>
          </div>
          <div class="flex gap-2">
            <a href="/resume/<%= resume.id %>/edit" class="btn-primary text-xs flex-1 text-center"><i class="fas fa-edit mr-1"></i>Edit</a>
            <a href="/resume/<%= resume.id %>/preview" target="_blank" class="btn-outline text-xs px-3" title="Preview"><i class="fas fa-eye"></i></a>
            <button onclick="duplicateResume(<%= resume.id %>)" class="btn-outline text-xs px-3" title="Duplicate"><i class="fas fa-copy"></i></button>
            <form action="/resume/<%= resume.id %>?_method=DELETE" method="POST" class="inline" onsubmit="return confirm('Delete this resume?')">
              <button type="submit" class="btn-outline text-xs px-3 text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 border-red-200 dark:border-red-700" title="Delete"><i class="fas fa-trash"></i></button>
            </form>
          </div>
        </div>
      <% }); %>
    </div>
  <% } %>
</div>

<script>
async function duplicateResume(id) {
  try {
    const res = await fetch('/resume/' + id + '/duplicate', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
    const data = await res.json();
    if (data.success) { showToast('Resume duplicated!', 'success'); setTimeout(() => location.reload(), 500); }
    else showToast(data.error || 'Failed', 'error');
  } catch { showToast('Failed to duplicate', 'error'); }
}
</script>

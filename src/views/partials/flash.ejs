<% if (typeof success !== 'undefined' && success && success.length > 0) { %>
  <div id="flash-success" class="fixed top-4 right-4 z-50 flex items-center gap-3 px-5 py-3.5 rounded-xl shadow-xl text-white text-sm font-medium animate-slide-in" style="background:linear-gradient(135deg,#16a34a,#15803d);backdrop-filter:blur(12px)">
    <div class="w-7 h-7 rounded-lg bg-white/20 flex items-center justify-center flex-shrink-0"><i class="fas fa-check text-xs"></i></div>
    <span><%= success %></span>
    <button onclick="this.parentElement.remove()" class="ml-2 p-1 rounded-lg hover:bg-white/10 transition"><i class="fas fa-times text-xs"></i></button>
  </div>
<% } %>
<% if (typeof error !== 'undefined' && error && error.length > 0) { %>
  <div id="flash-error" class="fixed top-4 right-4 z-50 flex items-center gap-3 px-5 py-3.5 rounded-xl shadow-xl text-white text-sm font-medium animate-slide-in" style="background:linear-gradient(135deg,#dc2626,#b91c1c);backdrop-filter:blur(12px)">
    <div class="w-7 h-7 rounded-lg bg-white/20 flex items-center justify-center flex-shrink-0"><i class="fas fa-exclamation text-xs"></i></div>
    <span><%= error %></span>
    <button onclick="this.parentElement.remove()" class="ml-2 p-1 rounded-lg hover:bg-white/10 transition"><i class="fas fa-times text-xs"></i></button>
  </div>
<% } %>

<!-- Overlay backdrop -->
<div id="sidebar-overlay" class="fixed inset-0 bg-black/50 z-40 hidden" onclick="toggleSidebar()"></div>

<aside id="app-sidebar" class="fixed left-0 top-0 h-full w-64 bg-white dark:bg-gray-900 border-r border-gray-200 dark:border-gray-800 z-50 flex flex-col transition-transform duration-300 -translate-x-full">
  <!-- Close button -->
  <button onclick="toggleSidebar()" class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 text-lg">
    <i class="fas fa-times"></i>
  </button>

  <div class="p-6 border-b border-gray-200 dark:border-gray-800">
    <h1 class="text-xl font-bold text-primary dark:text-white">Atlas Career</h1>
    <p class="text-xs text-gray-500 mt-1">SkillTech University</p>
  </div>

  <nav class="flex-1 p-4 space-y-1 overflow-y-auto">
    <a href="/dashboard" class="sidebar-link <%= currentPath === '/dashboard' ? 'active' : '' %>">
      <i class="fas fa-th-large w-5"></i> Dashboard
    </a>
    <a href="/resume" class="sidebar-link <%= currentPath.startsWith('/resume') ? 'active' : '' %>">
      <i class="fas fa-file-alt w-5"></i> Resume Builder
    </a>
    <a href="/resume/ats" class="sidebar-link <%= currentPath.startsWith('/resume/ats') ? 'active' : '' %>">
      <i class="fas fa-search-plus w-5"></i> ATS Analyzer
    </a>
    <a href="/cover-letter" class="sidebar-link <%= currentPath.startsWith('/cover-letter') ? 'active' : '' %>">
      <i class="fas fa-envelope-open-text w-5"></i> Cover Letters
    </a>
    <a href="/linkedin" class="sidebar-link <%= currentPath.startsWith('/linkedin') ? 'active' : '' %>">
      <i class="fab fa-linkedin w-5"></i> LinkedIn Optimizer
    </a>
    <a href="/jobs" class="sidebar-link <%= currentPath.startsWith('/jobs') ? 'active' : '' %>">
      <i class="fas fa-briefcase w-5"></i> Job Tracker
    </a>
    <a href="/networking" class="sidebar-link <%= currentPath.startsWith('/networking') ? 'active' : '' %>">
      <i class="fas fa-users w-5"></i> Networking CRM
    </a>
    <a href="/interview" class="sidebar-link <%= currentPath.startsWith('/interview') ? 'active' : '' %>">
      <i class="fas fa-microphone w-5"></i> Mock Interview
    </a>
    <a href="/skills" class="sidebar-link <%= currentPath.startsWith('/skills') ? 'active' : '' %>">
      <i class="fas fa-chart-line w-5"></i> Skill Gap Analyzer
    </a>
    <a href="/documents" class="sidebar-link <%= currentPath.startsWith('/documents') ? 'active' : '' %>">
      <i class="fas fa-folder-open w-5"></i> Document Hub
    </a>
  </nav>

  <div class="p-4 border-t border-gray-200 dark:border-gray-800">
    <a href="/auth/logout" class="sidebar-link text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 hover:text-red-600">
      <i class="fas fa-sign-out-alt w-5"></i> Logout
    </a>
  </div>
</aside>

<script>
function toggleSidebar() {
  var sidebar = document.getElementById('app-sidebar');
  var overlay = document.getElementById('sidebar-overlay');
  var isOpen = !sidebar.classList.contains('-translate-x-full');
  if (isOpen) {
    sidebar.classList.add('-translate-x-full');
    overlay.classList.add('hidden');
    document.body.classList.remove('overflow-hidden');
  } else {
    sidebar.classList.remove('-translate-x-full');
    overlay.classList.remove('hidden');
    document.body.classList.add('overflow-hidden');
  }
}
// Close sidebar on window resize
window.addEventListener('resize', function() {
  var sidebar = document.getElementById('app-sidebar');
  var overlay = document.getElementById('sidebar-overlay');
  if (sidebar && !sidebar.classList.contains('-translate-x-full')) {
    sidebar.classList.add('-translate-x-full');
    if (overlay) overlay.classList.add('hidden');
    document.body.classList.remove('overflow-hidden');
  }
});
</script>

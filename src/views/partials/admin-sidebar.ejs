<!-- Admin Sidebar — starts closed, toggle with hamburger -->
<aside id="app-sidebar" class="admin-sidebar fixed left-0 top-0 bottom-0 z-50 flex flex-col overflow-hidden"
  style="width:var(--sidebar-w);transform:translateX(-100%);transition:transform 0.3s cubic-bezier(0.4,0,0.2,1);background:hsl(228,100%,11%)">

  <!-- Brand Header -->
  <div class="flex items-center justify-between px-5 py-5" style="border-bottom:1px solid rgba(255,255,255,0.08)">
    <div class="flex items-center gap-3">
      <div class="w-9 h-9 rounded-xl flex items-center justify-center font-black text-sm" style="background:hsl(var(--accent));color:hsl(var(--primary))">A</div>
      <div>
        <h1 class="text-base font-bold text-white leading-tight">Atlas Admin</h1>
        <p class="text-[10px] font-medium tracking-wider uppercase" style="color:hsl(var(--accent))">Career Services</p>
      </div>
    </div>
    <button onclick="toggleSidebar()" class="lg:hidden p-1.5 rounded-lg hover:bg-white/10 transition" style="color:rgba(255,255,255,0.5)">
      <i class="fas fa-times text-sm"></i>
    </button>
  </div>

  <!-- Navigation -->
  <nav class="flex-1 px-3 py-4 overflow-y-auto" style="scrollbar-width:thin">
    <!-- Main Section -->
    <div class="space-y-0.5">
      <a href="/admin" class="sidebar-link <%= currentPath === '/admin' ? 'active' : '' %>">
        <div class="sidebar-icon"><i class="fas fa-tachometer-alt"></i></div>
        <span>Dashboard</span>
      </a>
      <a href="/admin/students" class="sidebar-link <%= currentPath.startsWith('/admin/students') ? 'active' : '' %>">
        <div class="sidebar-icon"><i class="fas fa-user-graduate"></i></div>
        <span>Students</span>
      </a>
      <a href="/admin/jobs" class="sidebar-link <%= currentPath.startsWith('/admin/jobs') ? 'active' : '' %>">
        <div class="sidebar-icon"><i class="fas fa-briefcase"></i></div>
        <span>Jobs</span>
      </a>
      <a href="/admin/recruiters" class="sidebar-link <%= currentPath.startsWith('/admin/recruiters') ? 'active' : '' %>">
        <div class="sidebar-icon"><i class="fas fa-building"></i></div>
        <span>Recruiters</span>
      </a>
      <a href="/admin/applications" class="sidebar-link <%= currentPath === '/admin/applications' ? 'active' : '' %>">
        <div class="sidebar-icon"><i class="fas fa-paper-plane"></i></div>
        <span>Applications</span>
      </a>
      <a href="/admin/pipeline" class="sidebar-link <%= currentPath.startsWith('/admin/pipeline') ? 'active' : '' %>">
        <div class="sidebar-icon"><i class="fas fa-columns"></i></div>
        <span>Pipeline</span>
      </a>
      <a href="/job-board/admin" class="sidebar-link <%= currentPath === '/job-board/admin' ? 'active' : '' %>">
        <div class="sidebar-icon"><i class="fas fa-search-dollar"></i></div>
        <span>Job Board</span>
      </a>
    </div>

    <!-- Analytics Section -->
    <div class="mt-6 mb-2">
      <p class="px-3 mb-2 text-[10px] font-semibold tracking-widest uppercase" style="color:hsl(var(--accent))">Analytics</p>
    </div>
    <div class="space-y-0.5">
      <a href="/admin/skill-gap" class="sidebar-link <%= currentPath.startsWith('/admin/skill-gap') ? 'active' : '' %>">
        <div class="sidebar-icon"><i class="fas fa-chart-bar"></i></div>
        <span>Skill Gap</span>
      </a>
      <a href="/admin/placement" class="sidebar-link <%= currentPath.startsWith('/admin/placement') ? 'active' : '' %>">
        <div class="sidebar-icon"><i class="fas fa-chart-pie"></i></div>
        <span>Placement</span>
      </a>
      <a href="/admin/interviews" class="sidebar-link <%= currentPath === '/admin/interviews' ? 'active' : '' %>">
        <div class="sidebar-icon"><i class="fas fa-video"></i></div>
        <span>Interviews</span>
      </a>
    </div>

    <!-- System Section -->
    <div class="mt-6 mb-2">
      <p class="px-3 mb-2 text-[10px] font-semibold tracking-widest uppercase" style="color:hsl(var(--accent))">System</p>
    </div>
    <div class="space-y-0.5">
      <a href="/admin/communication" class="sidebar-link <%= currentPath === '/admin/communication' ? 'active' : '' %>">
        <div class="sidebar-icon"><i class="fas fa-envelope"></i></div>
        <span>Communication</span>
      </a>
      <a href="/admin/settings" class="sidebar-link <%= currentPath === '/admin/settings' ? 'active' : '' %>">
        <div class="sidebar-icon"><i class="fas fa-cog"></i></div>
        <span>Settings</span>
      </a>
    </div>

    <!-- Quick Links -->
    <div class="mt-6 mb-2">
      <p class="px-3 mb-2 text-[10px] font-semibold tracking-widest uppercase" style="color:hsl(var(--accent))">Quick Links</p>
    </div>
    <a href="/dashboard" class="sidebar-link">
      <div class="sidebar-icon"><i class="fas fa-exchange-alt"></i></div>
      <span>Student View</span>
    </a>
  </nav>

  <!-- Logout -->
  <div class="px-3 py-3" style="border-top:1px solid rgba(255,255,255,0.08)">
    <a href="/auth/logout" class="sidebar-link" style="color:#fca5a5">
      <div class="sidebar-icon" style="background:rgba(239,68,68,0.1)"><i class="fas fa-sign-out-alt"></i></div>
      <span>Logout</span>
    </a>
  </div>
</aside>

<style>
  .sidebar-link {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 9px 12px;
    border-radius: 10px;
    color: rgba(191,219,254,0.8);
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    transition: all 0.15s ease;
  }
  .sidebar-link:hover {
    background: rgba(255,255,255,0.06);
    color: #fff;
  }
  .sidebar-link.active {
    background: rgba(255,255,255,0.1);
    color: #fff;
    box-shadow: inset 3px 0 0 hsl(var(--accent));
  }
  .sidebar-icon {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    flex-shrink: 0;
    background: rgba(255,255,255,0.04);
    transition: background 0.15s;
  }
  .sidebar-link:hover .sidebar-icon,
  .sidebar-link.active .sidebar-icon {
    background: rgba(255,255,255,0.1);
  }
</style>

<script>
function toggleSidebar() {
  var isOpen = document.documentElement.classList.contains('sidebar-open') || document.body.classList.contains('sidebar-open');
  if (isOpen) {
    document.documentElement.classList.remove('sidebar-open');
    document.body.classList.remove('sidebar-open');
  } else {
    document.documentElement.classList.add('sidebar-open');
    document.body.classList.add('sidebar-open');
  }
}

// Auto-close sidebar when a link is clicked
document.querySelectorAll('#app-sidebar .sidebar-link').forEach(function(link) {
  link.addEventListener('click', function() {
    document.documentElement.classList.remove('sidebar-open');
    document.body.classList.remove('sidebar-open');
  });
});
</script>

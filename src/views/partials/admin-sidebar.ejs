<!-- Mobile overlay backdrop -->
<div id="sidebar-overlay" class="fixed inset-0 bg-black/50 z-40 hidden lg:hidden" onclick="toggleSidebar()"></div>

<aside id="app-sidebar" class="fixed left-0 top-0 h-full w-64 bg-primary dark:bg-gray-900 z-50 flex flex-col transition-transform duration-300 -translate-x-full lg:translate-x-0">
  <!-- Close button for mobile -->
  <button onclick="toggleSidebar()" class="absolute top-4 right-4 lg:hidden text-blue-200 hover:text-white text-lg">
    <i class="fas fa-times"></i>
  </button>

  <div class="p-6 border-b border-blue-900">
    <h1 class="text-xl font-bold text-white">Atlas Admin</h1>
    <p class="text-xs text-blue-300 mt-1">Placement Cell Dashboard</p>
  </div>

  <nav class="flex-1 p-4 space-y-1 overflow-y-auto">
    <a href="/admin" class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-blue-200 hover:bg-blue-900 hover:text-white transition-all <%= currentPath === '/admin' ? 'bg-blue-900 text-white' : '' %>">
      <i class="fas fa-tachometer-alt w-5"></i> Dashboard
    </a>
    <a href="/admin/students" class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-blue-200 hover:bg-blue-900 hover:text-white transition-all <%= currentPath.startsWith('/admin/students') ? 'bg-blue-900 text-white' : '' %>">
      <i class="fas fa-user-graduate w-5"></i> Students
    </a>
    <a href="/admin/jobs" class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-blue-200 hover:bg-blue-900 hover:text-white transition-all <%= currentPath.startsWith('/admin/jobs') ? 'bg-blue-900 text-white' : '' %>">
      <i class="fas fa-briefcase w-5"></i> Jobs
    </a>
    <a href="/admin/recruiters" class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-blue-200 hover:bg-blue-900 hover:text-white transition-all <%= currentPath === '/admin/recruiters' ? 'bg-blue-900 text-white' : '' %>">
      <i class="fas fa-building w-5"></i> Recruiters
    </a>
    <a href="/admin/applications" class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-blue-200 hover:bg-blue-900 hover:text-white transition-all <%= currentPath === '/admin/applications' ? 'bg-blue-900 text-white' : '' %>">
      <i class="fas fa-paper-plane w-5"></i> Applications
    </a>
    <a href="/job-board/admin" class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-blue-200 hover:bg-blue-900 hover:text-white transition-all <%= currentPath === '/job-board/admin' ? 'bg-blue-900 text-white' : '' %>">
      <i class="fas fa-search-dollar w-5"></i> Job Board
    </a>

    <div class="pt-4 mt-4 border-t border-blue-900">
      <p class="text-xs text-blue-400 uppercase tracking-wide px-4 mb-2">Analytics</p>
      <a href="/admin/skill-gap" class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-blue-200 hover:bg-blue-900 hover:text-white transition-all <%= currentPath === '/admin/skill-gap' ? 'bg-blue-900 text-white' : '' %>">
        <i class="fas fa-chart-bar w-5"></i> Skill Gap
      </a>
      <a href="/admin/placement" class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-blue-200 hover:bg-blue-900 hover:text-white transition-all <%= currentPath === '/admin/placement' ? 'bg-blue-900 text-white' : '' %>">
        <i class="fas fa-chart-pie w-5"></i> Placement
      </a>
      <a href="/admin/interviews" class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-blue-200 hover:bg-blue-900 hover:text-white transition-all <%= currentPath === '/admin/interviews' ? 'bg-blue-900 text-white' : '' %>">
        <i class="fas fa-video w-5"></i> Interviews
      </a>
    </div>

    <div class="pt-4 mt-4 border-t border-blue-900">
      <p class="text-xs text-blue-400 uppercase tracking-wide px-4 mb-2">System</p>
      <a href="/admin/communication" class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-blue-200 hover:bg-blue-900 hover:text-white transition-all <%= currentPath === '/admin/communication' ? 'bg-blue-900 text-white' : '' %>">
        <i class="fas fa-envelope w-5"></i> Communication
      </a>
      <a href="/admin/settings" class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-blue-200 hover:bg-blue-900 hover:text-white transition-all <%= currentPath === '/admin/settings' ? 'bg-blue-900 text-white' : '' %>">
        <i class="fas fa-cog w-5"></i> Settings
      </a>
    </div>

    <div class="pt-4 mt-4 border-t border-blue-900">
      <p class="text-xs text-blue-400 uppercase tracking-wide px-4 mb-2">Quick Links</p>
      <a href="/dashboard" class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-blue-200 hover:bg-blue-900 hover:text-white transition-all">
        <i class="fas fa-exchange-alt w-5"></i> Student View
      </a>
    </div>
  </nav>

  <div class="p-4 border-t border-blue-900">
    <a href="/auth/logout" class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-red-300 hover:bg-red-900/30 hover:text-red-200 transition-all">
      <i class="fas fa-sign-out-alt w-5"></i> Logout
    </a>
  </div>
</aside>

<script>
function toggleSidebar() {
  var sidebar = document.getElementById('app-sidebar');
  var overlay = document.getElementById('sidebar-overlay');
  var isOpen = !sidebar.classList.contains('-translate-x-full');
  if (isOpen) {
    sidebar.classList.add('-translate-x-full');
    overlay.classList.add('hidden');
    document.body.classList.remove('overflow-hidden');
  } else {
    sidebar.classList.remove('-translate-x-full');
    overlay.classList.remove('hidden');
    document.body.classList.add('overflow-hidden');
  }
}
window.addEventListener('resize', function() {
  if (window.innerWidth >= 1024) {
    var sidebar = document.getElementById('app-sidebar');
    var overlay = document.getElementById('sidebar-overlay');
    if (sidebar) sidebar.classList.remove('-translate-x-full');
    if (overlay) overlay.classList.add('hidden');
    document.body.classList.remove('overflow-hidden');
  }
});
</script>

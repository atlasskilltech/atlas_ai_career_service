<!-- Admin Sidebar — starts closed, toggle with hamburger -->
<aside id="app-sidebar" style="position:fixed;left:0;top:0;bottom:0;width:256px;z-index:50;display:flex;flex-direction:column;transform:translateX(-100%);transition:transform 0.3s ease;background:hsl(228,100%,11%)">
  <!-- Close button -->
  <button onclick="toggleSidebar()" style="position:absolute;top:16px;right:16px;color:#93c5fd;font-size:18px;background:none;border:none;cursor:pointer">
    <i class="fas fa-times"></i>
  </button>

  <div style="padding:24px;border-bottom:1px solid #1e3a5f">
    <h1 style="font-size:20px;font-weight:700;color:#fff;margin:0">Atlas Admin</h1>
    <p style="font-size:12px;color:#93c5fd;margin-top:4px">Placement Cell Dashboard</p>
  </div>

  <nav style="flex:1;padding:16px;overflow-y:auto">
    <div style="display:flex;flex-direction:column;gap:4px">
      <a href="/admin" class="admin-nav-link <%= currentPath === '/admin' ? 'active' : '' %>">
        <i class="fas fa-tachometer-alt" style="width:20px"></i> Dashboard
      </a>
      <a href="/admin/students" class="admin-nav-link <%= currentPath.startsWith('/admin/students') ? 'active' : '' %>">
        <i class="fas fa-user-graduate" style="width:20px"></i> Students
      </a>
      <a href="/admin/jobs" class="admin-nav-link <%= currentPath.startsWith('/admin/jobs') ? 'active' : '' %>">
        <i class="fas fa-briefcase" style="width:20px"></i> Jobs
      </a>
      <a href="/admin/recruiters" class="admin-nav-link <%= currentPath.startsWith('/admin/recruiters') ? 'active' : '' %>">
        <i class="fas fa-building" style="width:20px"></i> Recruiters
      </a>
      <a href="/admin/applications" class="admin-nav-link <%= currentPath === '/admin/applications' ? 'active' : '' %>">
        <i class="fas fa-paper-plane" style="width:20px"></i> Applications
      </a>
      <a href="/admin/pipeline" class="admin-nav-link <%= currentPath.startsWith('/admin/pipeline') ? 'active' : '' %>">
        <i class="fas fa-columns" style="width:20px"></i> Pipeline
      </a>
      <a href="/job-board/admin" class="admin-nav-link <%= currentPath === '/job-board/admin' ? 'active' : '' %>">
        <i class="fas fa-search-dollar" style="width:20px"></i> Job Board
      </a>
    </div>

    <div style="padding-top:16px;margin-top:16px;border-top:1px solid #1e3a5f">
      <p style="font-size:10px;color:#60a5fa;text-transform:uppercase;letter-spacing:0.05em;padding:0 16px;margin-bottom:8px">Analytics</p>
      <div style="display:flex;flex-direction:column;gap:4px">
        <a href="/admin/skill-gap" class="admin-nav-link <%= currentPath.startsWith('/admin/skill-gap') ? 'active' : '' %>">
          <i class="fas fa-chart-bar" style="width:20px"></i> Skill Gap
        </a>
        <a href="/admin/placement" class="admin-nav-link <%= currentPath.startsWith('/admin/placement') ? 'active' : '' %>">
          <i class="fas fa-chart-pie" style="width:20px"></i> Placement
        </a>
        <a href="/admin/interviews" class="admin-nav-link <%= currentPath === '/admin/interviews' ? 'active' : '' %>">
          <i class="fas fa-video" style="width:20px"></i> Interviews
        </a>
      </div>
    </div>

    <div style="padding-top:16px;margin-top:16px;border-top:1px solid #1e3a5f">
      <p style="font-size:10px;color:#60a5fa;text-transform:uppercase;letter-spacing:0.05em;padding:0 16px;margin-bottom:8px">System</p>
      <div style="display:flex;flex-direction:column;gap:4px">
        <a href="/admin/communication" class="admin-nav-link <%= currentPath === '/admin/communication' ? 'active' : '' %>">
          <i class="fas fa-envelope" style="width:20px"></i> Communication
        </a>
        <a href="/admin/settings" class="admin-nav-link <%= currentPath === '/admin/settings' ? 'active' : '' %>">
          <i class="fas fa-cog" style="width:20px"></i> Settings
        </a>
      </div>
    </div>

    <div style="padding-top:16px;margin-top:16px;border-top:1px solid #1e3a5f">
      <p style="font-size:10px;color:#60a5fa;text-transform:uppercase;letter-spacing:0.05em;padding:0 16px;margin-bottom:8px">Quick Links</p>
      <a href="/dashboard" class="admin-nav-link">
        <i class="fas fa-exchange-alt" style="width:20px"></i> Student View
      </a>
    </div>
  </nav>

  <div style="padding:16px;border-top:1px solid #1e3a5f">
    <a href="/auth/logout" style="display:flex;align-items:center;gap:12px;padding:10px 16px;border-radius:8px;color:#fca5a5;text-decoration:none;font-size:14px;transition:background 0.2s" onmouseover="this.style.background='rgba(127,29,29,0.3)'" onmouseout="this.style.background='transparent'">
      <i class="fas fa-sign-out-alt" style="width:20px"></i> Logout
    </a>
  </div>
</aside>

<style>
  .admin-nav-link {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 16px;
    border-radius: 8px;
    color: #bfdbfe;
    text-decoration: none;
    font-size: 14px;
    transition: background 0.2s, color 0.2s;
  }
  .admin-nav-link:hover { background: #1e3a5f; color: #fff; }
  .admin-nav-link.active { background: #1e3a5f; color: #fff; }
</style>

<script>
function toggleSidebar() {
  var sidebar = document.getElementById('app-sidebar');
  var content = document.querySelector('.admin-content');
  var isOpen = sidebar.style.transform === 'translateX(0px)' || sidebar.style.transform === 'translateX(0)';
  if (isOpen) {
    sidebar.style.transform = 'translateX(-100%)';
    if (content) content.style.marginLeft = '0';
  } else {
    sidebar.style.transform = 'translateX(0)';
    if (content) content.style.marginLeft = '256px';
  }
}
</script>
